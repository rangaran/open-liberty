<server description="Server for testing empty JSP include path with fileServingEnabled=false">

    <include location="../fatTestPorts.xml"/>

    <featureManager>
        <feature>jsp-2.3</feature>
        <feature>localConnector-1.0</feature>
    </featureManager>

    <!-- Critical configuration: fileServingEnabled must be false to reproduce the NPE issue -->
    <webContainer fileServingEnabled="false"/>

    <jspEngine jdkSourceLevel="18"/>

    <logging traceSpecification="*=info=enabled:com.ibm.ws.jsp*=all" maxFileSize="32" maxFiles="24" traceFormat="BASIC"/>
    
</server>

