#CMVCPATHNAME io.openliberty.data.internal/resources/io/openliberty/data/internal/persistence/resources/CWWKDMessages.nlsprops
#ISMESSAGEFILE TRUE
#NLS_ENCODING=UNICODE
#
#COMPONENTPREFIX CWWKD
#COMPONENTNAMEFOR CWWKD Jakarta Data
#
# NLS_MESSAGEFORMAT_VAR
#
#   Strings in this file which contain replacement variables are processed by the MessageFormat 
#   class (single quote must be coded as 2 consecutive single quotes ''). Strings in this file 
#   which do NOT contain replacement variables are NOT processed by the MessageFormat class 
#   (single quote must be coded as one single quote '). 

# All messages must use the range CWWKD1000 to CWWKD1399

CWWKD1000.repo.general.err=CWWKD1000E: Bei der Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c ist ein Fehler aufgetreten. Der Fehler k\u00f6nnte darauf hindeuten, dass die Repository-Methode ung\u00fcltig ist. Fehler: {2}.
CWWKD1000.repo.general.err.explanation=Bei der angegebenen Repository-Methode ist ein Fehler aufgetreten.
CWWKD1000.repo.general.err.useraction=Suchen Sie die Schnittstelle und die Methode des Repositorys und pr\u00fcfen Sie, ob Korrekturen erforderlich sind.

CWWKD1001.no.primary.entity=CWWKD1001E: Die Repository-Methode \u201e {0} \u201c erfordert eine Entit\u00e4tsklasse, doch die Repository-Schnittstelle \u201e {1} \u201c legt keine prim\u00e4re Entit\u00e4tsklasse fest. Um diesen Fehler zu beheben, kann die Schnittstelle des Repositorys \u201e {1} \u201c einen der integrierten Repository-Supertypen, wie beispielsweise \u201e {2} \u201c, erweitern und die Entit\u00e4tsklasse als ersten Typparameter \u00fcbergeben.
CWWKD1001.no.primary.entity.explanation=Repository-Methoden, die keine eigene Entit\u00e4tsklasse haben, erfordern, dass das Repository eine prim\u00e4re Entit\u00e4tsklasse definiert.
CWWKD1001.no.primary.entity.useraction=Definieren Sie eine prim\u00e4re Entit\u00e4tsklasse f\u00fcr das Repository.

CWWKD1002.method.annos.err=CWWKD1002E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c ist mit einer Kombination von Annotationen versehen, die ung\u00fcltig ist: \u201e {2} \u201c.
CWWKD1002.method.annos.err.explanation=Diese Kombination von Annotationen ist f\u00fcr eine einzelne Repository-Methode nicht zul\u00e4ssig.
CWWKD1002.method.annos.err.useraction=Suchen Sie die Repository-Schnittstelle und -Methode und ermitteln Sie die richtige Kombination von Methodenannotationen.

CWWKD1003.rtrn.err=CWWKD1003E: Der R\u00fcckgabetyp \u201e {0} \u201c der Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c ist kein g\u00fcltiger R\u00fcckgabetyp f\u00fcr eine Repository-Methode vom Typ \u201e {3} \u201c. Zu den zul\u00e4ssigen R\u00fcckgabetypen geh\u00f6ren: ` {4} `.
CWWKD1003.rtrn.err.explanation=Der R\u00fcckgabetyp der Methode geh\u00f6rt nicht zu den unterst\u00fctzten R\u00fcckgabetypen f\u00fcr den angegebenen Typ der Repository-Methode.
CWWKD1003.rtrn.err.useraction=Informationen zu den Annotationen \u201eInsert\u201c, \u201eUpdate\u201c und \u201eSave\u201c finden Sie in der Jakarta Data Javadoc-Dokumentation; die g\u00fcltigen R\u00fcckgabetypen sind in der Dokumentation \u201eAbfrage nach Methodennamen\u201c aufgef\u00fchrt.

CWWKD1004.general.rtrn.err=CWWKD1004E: Der R\u00fcckgabetyp \u201e {0} \u201c der Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c ist kein g\u00fcltiger R\u00fcckgabetyp f\u00fcr eine Repository-Methode.
CWWKD1004.general.rtrn.err.explanation=Der R\u00fcckgabetyp der Methode geh\u00f6rt nicht zu den unterst\u00fctzten R\u00fcckgabetypen f\u00fcr den Typ der Repository-Methode.
CWWKD1004.general.rtrn.err.useraction=Eine Liste der g\u00fcltigen R\u00fcckgabetypen f\u00fcr die jeweilige Repository-Methode finden Sie in der Javadoc-Dokumentation zu Jakarta Data.

CWWKD1005.find.rtrn.err=CWWKD1005E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c ist ung\u00fcltig. Die Methode gibt einen R\u00fcckgabetyp vom Typ \u201e {2} \u201c an, der nicht aus dem Entit\u00e4tstyp \u201e {3} \u201c konvertierbar ist. Der Ergebnistyp einer Suchoperation muss der Entit\u00e4tstyp sein, ein Typ eines Entit\u00e4tsattributs, der durch die Select-Annotation ausgew\u00e4hlt wird, ein Java-Record, der sich aus Entit\u00e4tsattributen zusammensetzt, oder ein Typ, der durch die Abfrage ausgew\u00e4hlt wird, die der Query-Annotation \u00fcbergeben wird. Der R\u00fcckgabetyp der Repository-Find-Methode kann der Ergebnistyp, ein Array des Ergebnistyps oder einer der folgenden, mit dem Ergebnistyp parametrisierten Typen sein: {4}.
CWWKD1005.find.rtrn.err.explanation=Der R\u00fcckgabetyp der Methode geh\u00f6rt nicht zu den unterst\u00fctzten R\u00fcckgabetypen f\u00fcr Suchmethoden des Repositorys.
CWWKD1005.find.rtrn.err.useraction=Eine Liste der g\u00fcltigen R\u00fcckgabetypen f\u00fcr die Suchmethoden des Repositorys finden Sie in der Javadoc-Dokumentation zu Jakarta Data.

CWWKD1006.delete.rtrn.err=CWWKD1006E: Der R\u00fcckgabetyp \u201e {0} \u201c der Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c ist kein g\u00fcltiger R\u00fcckgabetyp f\u00fcr eine L\u00f6schoperation. Der R\u00fcckgabetyp muss entweder \u201evoid\u201c, \u201elong\u201c, \u201eint\u201c, \u201eboolean\u201c, \u201earray\u201c, \u201eList\u201c oder \u201eOptional\u201c sein. Ein R\u00fcckgabetyp vom Typ \u201evoid\u201c gibt keinen Wert zur\u00fcck. Ein R\u00fcckgabetyp vom Typ \u201elong\u201c oder \u201eint\u201c gibt die Anzahl der gel\u00f6schten Elemente zur\u00fcck. Der R\u00fcckgabetyp \u201eboolean\u201c gibt an, ob Entit\u00e4ten gel\u00f6scht wurden. Ein R\u00fcckgabetyp vom Typ Array, List oder Optional, der entweder mit einer Entit\u00e4tsklasse vom Typ \u201e {3} \u201c oder einer eindeutigen Identifikationsklasse vom Typ \u201e {4} \u201c parametrisiert ist, gibt die gel\u00f6schten Entit\u00e4ten oder Entit\u00e4ts-IDs zur\u00fcck.
CWWKD1006.delete.rtrn.err.explanation=Der R\u00fcckgabetyp der Methode geh\u00f6rt nicht zu den unterst\u00fctzten R\u00fcckgabetypen f\u00fcr eine L\u00f6schoperation.
CWWKD1006.delete.rtrn.err.useraction=Passen Sie die Repository-Methode so an, dass sie einen der unterst\u00fctzten R\u00fcckgabetypen verwendet.

CWWKD1007.updel.rtrn.err=CWWKD1007E: Der R\u00fcckgabetyp \u201e {0} \u201c der Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c ist kein g\u00fcltiger R\u00fcckgabetyp f\u00fcr eine Repository- {3} -Operation. Der R\u00fcckgabetyp muss entweder \u201evoid\u201c, \u201elong\u201c, \u201eint\u201c oder \u201eboolean\u201c sein. Ein R\u00fcckgabetyp vom Typ \u201evoid\u201c gibt keinen Wert zur\u00fcck. Ein R\u00fcckgabetyp vom Typ \u201elong\u201c oder \u201eint\u201c gibt die Anzahl der \u00fcbereinstimmenden Entit\u00e4ten zur\u00fcck. Ein R\u00fcckgabetyp vom Typ \u201eboolean\u201c gibt an, ob Entit\u00e4ten \u00fcbereinstimmen.
CWWKD1007.updel.rtrn.err.explanation=Der R\u00fcckgabetyp der Methode geh\u00f6rt nicht zu den unterst\u00fctzten R\u00fcckgabetypen f\u00fcr eine Aktualisierungs- oder L\u00f6schoperation.
CWWKD1007.updel.rtrn.err.useraction=Passen Sie die Repository-Methode so an, dass sie einen der unterst\u00fctzten R\u00fcckgabetypen verwendet.

CWWKD1008.ambig.rtrn.err=CWWKD1008E: Der R\u00fcckgabetyp \u201e {0} \u201c der Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c ist mehrdeutig, da er mehreren Entit\u00e4tsattributen entspricht: {3}. Die Repository-Methode muss auf die Annotation \u201eQuery\u201c umgestellt werden und eine Abfrage mit einer SELECT-Klausel verwenden, die angibt, welches Entit\u00e4tsattribut zur\u00fcckgegeben werden soll.
CWWKD1008.ambig.rtrn.err.explanation=Der R\u00fcckgabetyp der Methode geh\u00f6rt nicht zu den unterst\u00fctzten R\u00fcckgabetypen f\u00fcr eine delete-Methode.
CWWKD1008.ambig.rtrn.err.useraction=Passen Sie die Repository-Methode so an, dass das Entit\u00e4tsattribut mithilfe der Annotation \u201eQuery\u201c ausgew\u00e4hlt wird.

CWWKD1009.lifecycle.param.err=CWWKD1009E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c kann keine Parameter vom Typ \u201e {2} \u201c haben, da die Methode mit der Lebenszyklus-Annotation \u201e {3} \u201c versehen ist. Repository-Methoden, die mit einer Lebenszyklus-Annotation versehen sind, m\u00fcssen genau einen Parameter haben, bei dem es sich entweder um die Entit\u00e4t selbst oder um ein Array bzw. eine Liste dieser Entit\u00e4t handeln muss.
CWWKD1009.lifecycle.param.err.explanation=Lebenszyklusmethoden m\u00fcssen einen einzigen Entit\u00e4tsparameter haben.
CWWKD1009.lifecycle.param.err.useraction=Aktualisieren Sie die Repository-Methode so, dass sie einen einzigen Parameter akzeptiert, der entweder eine Entit\u00e4t, ein Array dieser Entit\u00e4t oder eine Liste dieser Entit\u00e4t ist.

CWWKD1010.unknown.entity.attr=CWWKD1010E: Ein Entit\u00e4tsattribut namens \u201e {0} \u201c wurde in der Entit\u00e4tsklasse \u201e {1} \u201c f\u00fcr die Methode \u201e {2} \u201c der Repository-Schnittstelle \u201e {3} \u201c nicht gefunden. G\u00fcltige Attributnamen f\u00fcr die Entit\u00e4t sind: {4}.
CWWKD1010.unknown.entity.attr.explanation=Die Repository-Methode versucht, ein Entit\u00e4tsattribut zu verwenden, das nicht existiert.
CWWKD1010.unknown.entity.attr.useraction=Passen Sie die Repository-Methode so an, dass sie einem g\u00fcltigen Attribut entspricht, das von der Entit\u00e4t definiert ist.

CWWKD1011.unknown.method.pattern=CWWKD1011E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c entspricht keinem der in Jakarta Data definierten Muster. Eine Repository-Methode muss entweder Annotationen verwenden, eine Methode zum Zugriff auf Ressourcen sein oder gem\u00e4\u00df dem Muster \u201eQuery by Method Name\u201c benannt sein. Annotationen wie \u201e {2} \u201c werden zur Definition von Operationen verwendet. Eine Methode f\u00fcr den Zugriff auf Ressourcen darf keine Parameter enthalten und muss einen der R\u00fcckgabetypen aus dem Typenverzeichnis \u201e {3} \u201c verwenden. Das Muster \u201eAbfrage nach Methodennamen\u201c muss mit einem der Schl\u00fcsselw\u00f6rter \u201e {4} \u201c beginnen, gefolgt von null oder mehr Zeichen. Methodennamen k\u00f6nnen auch das Schl\u00fcsselwort \u201eBy\u201c sowie eine oder mehrere durch Trennzeichen getrennte Bedingungen enthalten. Beispiele f\u00fcr g\u00fcltige Namen von Repository-Methoden sind: {5}.
CWWKD1011.unknown.method.pattern.explanation=Repository-Methoden m\u00fcssen den in Jakarta Data definierten Mustern entsprechen.
CWWKD1011.unknown.method.pattern.useraction=Aktualisieren Sie die Repository-Methode so, dass sie einem der Muster aus Jakarta Data entspricht.

CWWKD1012.fd.missing.param.anno=CWWKD1012E: Der Parameter \u201e {0} \u201c der Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c entspricht keinem Entit\u00e4tsattribut. Parameter, die keinem Entit\u00e4tsattribut entsprechen, m\u00fcssen mit der Annotation \u201eBy\u201c versehen sein oder einen der speziellen Parametertypen aufweisen: \u201e {3} \u201c. Um eine Bedingung f\u00fcr die Einschr\u00e4nkung der Abfrageergebnisse zu definieren, muss der Parameter mit der Annotation \u201eBy\u201c versehen werden, und der Wert der Annotation \u201eBy\u201c muss dem Namen des Entit\u00e4tsattributs zugewiesen werden. Alternativ k\u00f6nnen Sie die Kompilierungsoption \u201e-parameters\u201c aktivieren und dem Parameter denselben Namen wie dem Entit\u00e4tsattribut geben.
CWWKD1012.fd.missing.param.anno.explanation=Die Parameter der Methoden zum Suchen und L\u00f6schen im Repository m\u00fcssen Entit\u00e4tsattributen entsprechen oder spezielle, von Jakarta Data definierte Parametertypen sein.
CWWKD1012.fd.missing.param.anno.useraction=Passen Sie die Repository-Methode so an, dass alle Parameter Entit\u00e4tsattributen entsprechen oder einen der speziellen Parametertypen von Jakarta Data aufweisen.

CWWKD1013.cde.missing.param.anno=CWWKD1013E: Der Parameter \u201e {0} \u201c der Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c entspricht keinem Entit\u00e4tsattribut. Parameter, die keinem Entit\u00e4tsattribut entsprechen, m\u00fcssen mit der Annotation \u201eBy\u201c versehen werden, und der Wert der Annotation \u201eBy\u201c muss dem Namen des Entit\u00e4tsattributs entsprechen. Alternativ k\u00f6nnen Sie die Kompilierungsoption \u201e-parameters\u201c aktivieren und dem Parameter denselben Namen wie dem Entit\u00e4tsattribut geben.
CWWKD1013.cde.missing.param.anno.explanation=Die Parameter der Repository-Methoden \u201ecount\u201c, \u201edelete\u201c und \u201eexists\u201c m\u00fcssen den Attributen der Entit\u00e4t entsprechen.
CWWKD1013.cde.missing.param.anno.useraction=Aktualisieren Sie die Repository-Methode so, dass alle Parameter den Entit\u00e4tsattributen entsprechen.

CWWKD1014.upd.missing.param.anno=CWWKD1014E: Die Methode \u201e {0} \u201c des Repositorys \u201e {1} \u201c ist keine g\u00fcltige Update-Methode des Lebenszyklus, da die Methode Parameter vom Typ \u201e {2} \u201c enth\u00e4lt. Repository-Methoden, die mit einer Lebenszyklus-Annotation versehen sind, m\u00fcssen genau einen Parameter haben, bei dem es sich um die Entit\u00e4t, ein Array der Entit\u00e4t oder eine Liste der Entit\u00e4t handeln muss. Die Methode \u201e {0} \u201c ist ebenfalls keine g\u00fcltige parameterbasierte Aktualisierungsoperation, da der Methodenparameter \u201e {3} \u201c keine Annotation ( {4} ) aufweist, die den Namen des Entit\u00e4tsattributs angibt. Alternativ k\u00f6nnen Sie die Kompilierungsoption \u201e-parameters\u201c aktivieren und dem Parameter denselben Namen wie dem Entit\u00e4tsattribut geben.
CWWKD1014.upd.missing.param.anno.explanation=Die Parameter der Methoden zur Aktualisierung des Repositorys m\u00fcssen mit den Attributen der Entit\u00e4t \u00fcbereinstimmen. Alternativ m\u00fcssen Lebenszyklusmethoden einen einzigen Entit\u00e4tsparameter haben.
CWWKD1014.upd.missing.param.anno.useraction=Aktualisieren Sie die Repository-Methode so, dass alle Parameter den Entit\u00e4tsattributen entsprechen. Alternativ kannst du die Repository-Methode so anpassen, dass sie einen einzigen Parameter akzeptiert, der entweder eine Entit\u00e4t, ein Array dieser Entit\u00e4t oder eine Liste dieser Entit\u00e4ten ist.

CWWKD1015.null.entity.param=CWWKD1015E: Die Methode ` {0} ` der Repository-Schnittstelle ` {1} ` akzeptiert keine Null-Entit\u00e4t.
CWWKD1015.null.entity.param.explanation=Lebenszyklusmethoden erfordern eine Entit\u00e4tsinstanz, die nicht null ist.
CWWKD1015.null.entity.param.useraction=Passen Sie den Anwendungscode an, um zu vermeiden, dass der Repository-Methode ein Nullwert \u00fcbergeben wird.

CWWKD1016.incompat.entity.param=CWWKD1016E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c erfordert eine Entit\u00e4t vom Typ \u201e {2} \u201c, es wurde jedoch ein Wert vom Typ \u201e {3} \u201c \u00fcbergeben.
CWWKD1016.incompat.entity.param.explanation=Die Lifecycle-Methode akzeptiert nur Entit\u00e4tswerte des deklarierten Typs.
CWWKD1016.incompat.entity.param.useraction=Passen Sie den Anwendungscode so an, dass ein Entit\u00e4tswert desselben Entit\u00e4tstyps \u00fcbergeben wird, wie er von der Repository-Methode deklariert wird.

CWWKD1017.dup.special.param=CWWKD1017E: Die Methode \u201e {0} \u201c des Repositorys \u201e {1} \u201c darf nicht mehrere \u201e {2} \u201c-Parameter enthalten.
CWWKD1017.dup.special.param.explanation=Einige der speziellen Parameter von Jakarta Data, darunter \u201eLimit\u201c und \u201e PageRequest, \u201c, d\u00fcrfen innerhalb der Signatur einer Repository-Methode nicht mehrfach vorkommen.
CWWKD1017.dup.special.param.useraction=Aktualisieren Sie die Signatur der Repository-Methode so, dass der spezielle Parametertyp \u201eJakarta Data\u201c h\u00f6chstens einmal vorkommt.

CWWKD1018.confl.special.param=CWWKD1018E: Die Methode \u201e {0} \u201c des Repositorys \u201e {1} \u201c darf nicht gleichzeitig die Parameter \u201e {2} \u201c und \u201e {3} \u201c enthalten.
CWWKD1018.confl.special.param.explanation=Einige der speziellen Parameter von Jakarta Data, wie beispielsweise \u201eLimit\u201c und \u201e PageRequest, \u201c, k\u00f6nnen nicht in einer einzigen Repository-Methodensignatur kombiniert werden.
CWWKD1018.confl.special.param.useraction=Aktualisieren Sie das Repository so, dass nicht beide speziellen Parametertypen von Jakarta Data in derselben Methodensignatur verwendet werden.

CWWKD1019.mixed.positional.named=CWWKD1019E: Die Methode ` {0} ` der Repository-Schnittstelle ` {1} ` darf keine Abfrage enthalten, die Positions- und benannte Parameter vermischt. Die Schnittstelle definiert eine Mischung aus Positionsparametern {2} und benannten Parametern {3} {4} f\u00fcr den Wert der Annotation \u201eQuery\u201c: {5}. Eine Abfrage mit Positionsparametern muss jeden Parameter anhand seines Ordnungswerts referenzieren, beginnend mit?1, und die Methodenparameter d\u00fcrfen nicht mit der Annotation \u201eParam\u201c versehen sein. In einer Abfrage mit benannten Parametern muss jeder Parameter \u00fcber seinen Namen referenziert werden, z. B. ` {6} `, und die Methodenparameter m\u00fcssen die Annotation `Param` tragen, z. B. ` {7} `. Alternativ k\u00f6nnen durch Aktivieren der Kompilierungsoption \u201e-parameters\u201c Methodenparameter den benannten Parameter durch \u00dcbereinstimmung seines Namens angeben, zum Beispiel \u201e {8} \u201c.
CWWKD1019.mixed.positional.named.explanation=Abfragen mit Parametern m\u00fcssen entweder ausschlie\u00dflich benannte Parameter oder ausschlie\u00dflich Positionsparameter verwenden, jedoch keine Kombination aus beiden.
CWWKD1019.mixed.positional.named.useraction=Passen Sie die Repository-Methode so an, dass sie nur benannte Parameter oder nur Positionsparameter verwendet.

CWWKD1020.invalid.param.type=CWWKD1020E: Die Parameter der Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c d\u00fcrfen nicht vom Typ \u201e {2} \u201c sein, da es sich bei der Repository-Methode um eine \u201e {3} \u201c-Operation handelt.
CWWKD1020.invalid.param.type.explanation=Der Parametertyp ist bei dieser Art von Methode nicht zul\u00e4ssig.
CWWKD1020.invalid.param.type.useraction=Aktualisieren Sie die Repository-Methode, um f\u00fcr jeden Wert, der f\u00fcr einen Vergleich ben\u00f6tigt wird, einen Methodenparameter zu definieren.

CWWKD1021.insufficient.params=CWWKD1021E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c verf\u00fcgt \u00fcber die Parameter \u201e {2} \u201c, doch die von der Methode definierten Abfragebedingungen erfordern die Parameter \u201e {3} \u201c. Die Abfrage f\u00fcr die Methode lautet: {4}.
CWWKD1021.insufficient.params.explanation=Abfragebedingungen, die Wertvergleiche definieren, erfordern eine entsprechende Anzahl von Repository-Methodenparametern, um die Werte zu \u00fcbergeben.
CWWKD1021.insufficient.params.useraction=Aktualisieren Sie die Repository-Methode, um f\u00fcr jeden Wert, der f\u00fcr einen Vergleich ben\u00f6tigt wird, einen Methodenparameter zu definieren.

CWWKD1022.too.many.params=CWWKD1022E: Die Abfragebedingungen der Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c erfordern die Parameter \u201e {2} \u201c, w\u00e4hrend die Signatur der Repository-Methode die Parameter \u201e {3} \u201c aufweist. Die Abfrage f\u00fcr die Methode lautet: {4}.
CWWKD1022.too.many.params.explanation=Abfragebedingungen, die Wertvergleiche definieren, erfordern eine entsprechende Anzahl von Repository-Methodenparametern, um die Werte zu \u00fcbergeben. Zus\u00e4tzliche Parameter sind nicht zul\u00e4ssig.
CWWKD1022.too.many.params.useraction=Aktualisieren Sie die Signatur der Repository-Methode, um \u00fcberfl\u00fcssige Parameter zu entfernen, die nicht den deklarierten Bedingungen entsprechen.

CWWKD1023.extra.param=CWWKD1023E: Die Abfragebedingungen der Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c erfordern die Parameter \u201e {2} \u201c, doch die Repository-Methode verf\u00fcgt zus\u00e4tzlich \u00fcber den Parameter \u201e {3} \u201c. Die Abfrage f\u00fcr die Methode lautet: {4}.
CWWKD1023.extra.param.explanation=Abfragebedingungen, die Wertvergleiche definieren, erfordern eine entsprechende Anzahl von Repository-Methodenparametern, um die Werte zu \u00fcbergeben. Zus\u00e4tzliche Parameter sind nicht zul\u00e4ssig.
CWWKD1023.extra.param.useraction=Aktualisieren Sie die Signatur der Repository-Methode, um \u00fcberfl\u00fcssige Parameter zu entfernen, die nicht den deklarierten Bedingungen entsprechen.

CWWKD1024.missing.entity.attr=CWWKD1024E: In der Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c fehlt ein Entit\u00e4tsattributname oder es wurde ein Parameter \u00fcbergeben, dem ein Entit\u00e4tsattributname fehlt. G\u00fcltige Attributnamen f\u00fcr die Entit\u00e4tsklasse \u201e {2} \u201c sind: \u201e {3} \u201c.
CWWKD1024.missing.entity.attr.explanation=Die Abfragebedingungen und Sortierkriterien f\u00fcr eine Repository-Methode m\u00fcssen einen Entit\u00e4tsattributnamen enthalten.
CWWKD1024.missing.entity.attr.useraction=\u00dcberpr\u00fcfen Sie die Deklaration und Verwendung der Repository-Methode, um sicherzustellen, dass f\u00fcr jede Abfragebedingung und jedes Sortierkriterium ein Entit\u00e4tsattributname angegeben wird.

CWWKD1025.missing.id.attr=CWWKD1025E: Die Entit\u00e4tsklasse \u201e {0} \u201c, die von der Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c verwendet wird, verf\u00fcgt nicht \u00fcber ein ID-Attribut.
CWWKD1025.missing.id.attr.explanation=Repository-Methoden, die eine Entit\u00e4t l\u00f6schen und zur\u00fcckgeben, m\u00fcssen \u00fcber ein ID-Attribut verf\u00fcgen.
CWWKD1025.missing.id.attr.useraction=Falls die Entit\u00e4t kein einziges Attribut f\u00fcr die ID besitzt, definieren Sie separate Repository-Methoden, die die Entit\u00e4t abfragen und l\u00f6schen.

CWWKD1026.ignore.case.not.text=CWWKD1026E: Das Attribut \u201e {0} \u201c der Entit\u00e4t \u201e {1} \u201c ist kein Zeichen und keine Zeichenfolge; daher darf das Sortierkriterium \u201e {2} \u201c nicht festlegen, dass die Gro\u00df-/Kleinschreibung ignoriert wird. Der Typ des Attributs lautet \u201e {3} \u201c, und es wurde an die Methode \u201e {4} \u201c der Repository-Schnittstelle \u201e {5} \u201c \u00fcbergeben.
CWWKD1026.ignore.case.not.text.explanation=Das Sortieren ohne Ber\u00fccksichtigung der Gro\u00df-/Kleinschreibung ist nur bei Entit\u00e4tsattributen m\u00f6glich, die Text darstellen.
CWWKD1026.ignore.case.not.text.useraction=Stellen Sie sicher, dass die Sortierkriterien auf das richtige Entit\u00e4tsattribut angewendet werden, und entfernen Sie die Anweisung zur Gro\u00df-/Kleinschreibung, wenn das Entit\u00e4tsattribut keinen Text darstellt.

CWWKD1027.datastore.lacks.java.comp=CWWKD1027E: Eine oder mehrere Repository-Schnittstellen ( {0} ) aus dem Anwendungsartefakt \u201e {1} \u201c geben einen Wert f\u00fcr \u201e {2} \u201c ( dataStore ) an, der nicht mit einer Datenquellen-Ressourcenreferenz oder einer Persistenz-Einheitsreferenz \u00fcbereinstimmt, da ihm das Namespace-Pr\u00e4fix \u201ejava:comp/env/\u201c fehlt. Erw\u00e4gen Sie, die Repository-Annotation so zu \u00e4ndern, dass \u201e {3} \u201c angegeben wird.
CWWKD1027.datastore.lacks.java.comp.explanation=JNDI-Namen von Verweisen auf Datenquellenressourcen und Persistenz-Einheiten m\u00fcssen das Namensraumpr\u00e4fix \u201ejava:\u201c enthalten.
CWWKD1027.datastore.lacks.java.comp.useraction=Stellen Sie sicher, dass der Wert des Datenspeichers der Repository-Annotation ein \u201ejava:\u201c als Namespace-Pr\u00e4fix enth\u00e4lt, wenn der Wert den JNDI-Namen einer Datenquellen-Ressourcenreferenz oder einer Persistenz-Unit-Referenz angibt.

CWWKD1028.first.exceeds.max=CWWKD1028E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c fordert die ersten Ergebnisse von \u201e {2} \u201c an, was die maximal zul\u00e4ssige Anzahl von Ergebnissen \u00fcberschreitet: {3}.
CWWKD1028.first.exceeds.max.explanation=Die maximale Anzahl der Suchergebnisse wird durch systemseitige Beschr\u00e4nkungen und den angegebenen Wert begrenzt.
CWWKD1028.first.exceeds.max.useraction=Reduzieren Sie die angeforderte maximale Anzahl von Abfrageergebnissen auf einen niedrigeren Wert.

CWWKD1029.first.neg.or.zero=CWWKD1029E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c fordert die ersten Ergebnisse von \u201e {2} \u201c ab. Die angegebene maximale Anzahl der zur\u00fcckzugebenden Ergebnisse muss eine positive Zahl sein.
CWWKD1029.first.neg.or.zero.explanation=Die maximale Anzahl der Suchergebnisse muss eine positive Zahl sein.
CWWKD1029.first.neg.or.zero.useraction=Aktualisieren Sie die Repository-Methode, um eine positive maximale Anzahl von Ergebnissen anzugeben.

CWWKD1030.ql.lacks.entity=CWWKD1030E: In der Abfrage \u201e {0} \u201c, die f\u00fcr die Methode \u201e {1} \u201c des Repositorys \u201e {2} \u201c angegeben ist, fehlt der Entit\u00e4tsname. F\u00fcr Anfragen an \u201e {3} \u201c nutzen Sie bitte das Formular unter: {4}.
CWWKD1030.ql.lacks.entity.explanation=Die Abfrage enth\u00e4lt eine Klausel, die den Entit\u00e4tsnamen erfordert.
CWWKD1030.ql.lacks.entity.useraction=Aktualisieren Sie die Abfrage f\u00fcr die Repository-Methode, sodass sie den Entit\u00e4tsnamen enth\u00e4lt.

CWWKD1031.ql.similar.entity=CWWKD1031E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c definiert eine Abfrage, die einen Entit\u00e4tsnamen vom Typ \u201e {2} \u201c erfordert, der zwar nicht gefunden wird, aber eine enge \u00dcbereinstimmung mit dem Entit\u00e4tsnamen vom Typ \u201e {3} \u201c aufweist. Die Abfrage lautet: {4}.
CWWKD1031.ql.similar.entity.explanation=Die Abfrage enth\u00e4lt m\u00f6glicherweise einen Tippfehler in der Angabe des Entit\u00e4tsnamens.
CWWKD1031.ql.similar.entity.useraction=\u00dcberpr\u00fcfen Sie die Abfrage, um sicherzustellen, dass der richtige Entit\u00e4tsname verwendet wird.

CWWKD1032.ql.unknown.entity=CWWKD1032E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c gibt eine Abfrage an, f\u00fcr die ein Entit\u00e4tsname \u201e {2} \u201c erforderlich ist, der nicht gefunden wurde. Stellen Sie sicher, dass \u201e {2} \u201c der Name einer g\u00fcltigen Entit\u00e4t ist. Damit die Entit\u00e4t gefunden werden kann, m\u00fcssen Sie dem Repository eine Lebenszyklusmethode zuweisen, die mit einer der Annotationen \u201e {3} \u201c versehen ist, und die Entit\u00e4t als Parameter \u00fcbergeben. Alternativ kann das Repository die Schnittstelle \u201e DataRepository \u201c oder eine andere integrierte Repository-Schnittstelle erweitern, wobei die Entit\u00e4tsklasse als erste Typvariable dient. Die Abfrage lautet: {4}.
CWWKD1032.ql.unknown.entity.explanation=M\u00f6glicherweise enth\u00e4lt die Abfrage einen Tippfehler in der Angabe des Entit\u00e4tsnamens, oder das Repository gibt seine prim\u00e4re Entit\u00e4tsklasse nicht an.
CWWKD1032.ql.unknown.entity.useraction=\u00dcberpr\u00fcfen Sie die Abfrage, um sicherzustellen, dass der richtige Entit\u00e4tsname verwendet wird. \u00dcberpr\u00fcfen Sie die Repository-Definition, um sicherzustellen, dass die richtige prim\u00e4re Entit\u00e4tsklasse angegeben ist.

CWWKD1033.ql.orderby.disallowed=CWWKD1033E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c kann keine Abfrage angeben, die eine ORDER BY-Klausel enth\u00e4lt, da die Methode \u201e {2} \u201c zur\u00fcckgibt. Entfernen Sie die ORDER BY-Klausel und verwenden Sie stattdessen die Annotation \u201e {3} \u201c, um statische Sortierkriterien festzulegen. Die Abfrage lautet: {4}.
CWWKD1033.ql.orderby.disallowed.explanation=Die ORDER BY-Klausel ist mit der Cursor-basierten Paginierung nicht kompatibel.
CWWKD1033.ql.orderby.disallowed.useraction=Ersetzen Sie die ORDER BY-Klausel durch Anmerkungen, die die Sortierkriterien festlegen.

CWWKD1034.ql.req.end.in.where=CWWKD1034E: Die Abfrage, die durch die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c angegeben wird, muss mit einer WHERE-Klausel enden, da die Methode \u201e {2} \u201c zur\u00fcckgibt. Die WHERE-Klausel endet an Position {3}, die L\u00e4nge der Abfrage betr\u00e4gt jedoch {4}. Die Abfrage lautet: {5}.
CWWKD1034.ql.req.end.in.where.explanation=Bei der Verwendung der Cursor-basierten Paginierung ist eine WHERE-Klausel erforderlich.
CWWKD1034.ql.req.end.in.where.useraction=F\u00fcge der Abfrage eine WHERE-Klausel hinzu.

CWWKD1035.incompat.page.mode=CWWKD1035E: Eine Seitenanforderung mit dem Paginierungsmodus \u201e {0} \u201c darf nicht an die Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c \u00fcbergeben werden, da die Methode \u201e {3} \u201c anstelle von \u201e {4} \u201c zur\u00fcckgibt.
CWWKD1035.incompat.page.mode.explanation=Der angeforderte Paginierungsmodus ist nicht mit dem R\u00fcckgabetyp der Repository-Methode kompatibel.
CWWKD1035.incompat.page.mode.useraction=Verwenden Sie f\u00fcr den Paginierungsmodus \u201eOFFSET\u201c den R\u00fcckgabetyp \u201ePage\u201c und f\u00fcr die Paginierungsmodi \u201eCURSOR_NEXT\u201c und \u201eCURSOR_PREVIOUS\u201c den R\u00fcckgabetyp \u201e CursoredPage \u201c.

CWWKD1036.cursor.size.mismatch=CWWKD1036E: Ein Cursor mit Elementen vom Typ \u201e {0} \u201c, der an die Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c \u00fcbergeben wird, kann nicht mit Sortierkriterien vom Typ \u201esize\u201c {3} verwendet werden, da die Anzahl und Reihenfolge der Cursor-Elemente mit den Sortierkriterien \u00fcbereinstimmen m\u00fcssen. Der Cursor besteht aus: {4}. Das Sortierkriterium lautet: {5}.
CWWKD1036.cursor.size.mismatch.explanation=Die Anzahl der Cursor-Elemente muss mit der Gr\u00f6\u00dfe der kombinierten Sortierkriterien der Repository-Methode \u00fcbereinstimmen.
CWWKD1036.cursor.size.mismatch.useraction=Passen Sie die Cursorelemente oder die Sortierkriterien so an, dass beide dieselbe Gr\u00f6\u00dfe haben.

CWWKD1037.cursor.rtrn.mismatch=CWWKD1037E: Es ist nicht m\u00f6glich, einen Cursor aus dem Ergebnis \u201e {0} \u201c der Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c abzurufen. Abfragen, die eine cursorbasierte Paginierung verwenden, m\u00fcssen Ergebnisse desselben Typs wie der Entit\u00e4tstyp zur\u00fcckgeben, n\u00e4mlich \u201e {3} \u201c. Der R\u00fcckgabetyp der Repository-Methode ist \u201e {4} \u201c.
CWWKD1037.cursor.rtrn.mismatch.explanation=Eine Cursor-basierte Paginierung ist nur m\u00f6glich, wenn die Repository-Methode den Entit\u00e4tstyp zur\u00fcckgibt.
CWWKD1037.cursor.rtrn.mismatch.useraction=Aktualisieren Sie die Repository-Methode so, dass sie den Entit\u00e4tstyp zur\u00fcckgibt.

CWWKD1038.no.prev.offset.page=CWWKD1038E: F\u00fcr die Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c kann keine Seitenzahl vor \u201e {0} \u201c angefordert werden, da die Methode \u201e Page.hasPrevious \u201c den Wert \u201efalse\u201c zur\u00fcckgibt, was bedeutet, dass es keine vorherige Seite gibt.
CWWKD1038.no.prev.offset.page.explanation=Bei der versetzten Paginierung sind Seitenzahlen unter 1 nicht zul\u00e4ssig.
CWWKD1038.no.prev.offset.page.useraction=Stellen Sie sicher, dass die angeforderte Seitenzahl eine positive Zahl ist, und verwenden Sie die Methode \u201e Page.hasPrevious \u201c, um sicherzustellen, dass die Anforderung der vorherigen Seite zul\u00e4ssig ist.

CWWKD1039.no.prev.cursor.page=CWWKD1039E: F\u00fcr die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c kann keine vorherige Seite angefordert werden, da die Methode \u201e Page.hasPrevious \u201c den Wert \u201efalse\u201c zur\u00fcckgibt, was darauf hinweist, dass keine vorherige Seite vorhanden ist.
CWWKD1039.no.prev.cursor.page.explanation=Bei der cursorbasierten Paginierung ist es nicht m\u00f6glich, die vorherige Seite anzufordern, wenn bekannt ist, dass die aktuelle Seite die Ergebnisse am Anfang des Datensatzes enth\u00e4lt.
CWWKD1039.no.prev.cursor.page.useraction=Verwenden Sie die Methode \u201e Page.hasPrevious \u201c, um sicherzustellen, dass der Aufruf der vorherigen Seite zul\u00e4ssig ist.

CWWKD1040.no.next.page=CWWKD1040E: F\u00fcr die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c kann keine n\u00e4chste Seite angefordert werden, da \u201e {2} \u201c den Wert \u201efalse\u201c zur\u00fcckgibt, was darauf hinweist, dass keine n\u00e4chste Seite vorhanden ist.
CWWKD1040.no.next.page.explanation=Eine n\u00e4chste Seite kann nicht angefordert werden, wenn bekannt ist, dass die aktuelle Seite das Ende des Datensatzes enth\u00e4lt.
CWWKD1040.no.next.page.useraction=Verwenden Sie die Methode \u201e hasNext \u201c, um sicherzustellen, dass die Anforderung der n\u00e4chsten Seite zul\u00e4ssig ist.

CWWKD1041.rtrn.mismatch.pagereq=CWWKD1041E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c hat den R\u00fcckgabetyp \u201e {2} \u201c, es fehlt jedoch ein Parameter vom Typ \u201e PageRequest \u201c im Anschluss an die Parameter f\u00fcr die Abfragebedingungen.
CWWKD1041.rtrn.mismatch.pagereq.explanation=Repository-Methoden mit den R\u00fcckgabetypen \u201ePage\u201c und \u201e CursoredPage \u201c m\u00fcssen einen Parameter vom Typ \u201e PageRequest \u201c enthalten.
CWWKD1041.rtrn.mismatch.pagereq.useraction=F\u00fcge der Signatur der Repository-Methode den Parameter \u201e PageRequest \u201c hinzu.

CWWKD1042.no.totals=CWWKD1042E: Seiten, die \u00fcber die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c abgerufen werden, enthalten keine Gesamtanzahl von Elementen und Seiten, da bei der Seitenanforderung \u201e {2} \u201c f\u00fcr \u201e requestTotal \u201c der Wert \u201efalse\u201c angegeben wird. Um eine Seite mit der Gesamtanzahl abzurufen, verwenden Sie die Methode \u201e PageRequest.withTotal \u201c anstelle der Methode \u201e PageRequest.withoutTotal \u201c.
CWWKD1042.no.totals.explanation=Die Methode \u201e PageRequest.withoutTotal \u201c legt fest, dass angeforderte Seiten keine Gesamtanzahl von Elementen und Seiten enthalten.
CWWKD1042.no.totals.useraction=Verwenden Sie die Methode \u201e PageRequest.withTotal \u201c, um die Gesamtanzahl der Elemente und Seiten abzufragen.

CWWKD1043.offset.exceeds.max=CWWKD1043E: Der Offset \u201e {0} \u201c, der f\u00fcr die Seitenanforderung \u201e {1} \u201c ben\u00f6tigt wird und an die Methode \u201e {2} \u201c der Repository-Schnittstelle \u201e {3} \u201c \u00fcbergeben wird, \u00fcberschreitet den maximal zul\u00e4ssigen Wert von \u201e {4} \u201c.
CWWKD1043.offset.exceeds.max.explanation=Die Kombination aus Seitenzahl und maximaler Seitengr\u00f6\u00dfe ist zu gro\u00df.
CWWKD1043.offset.exceeds.max.useraction=F\u00fcgen Sie der Abfrage Einschr\u00e4nkungen hinzu, um die Anzahl der Treffer zu verringern.

CWWKD1044.invalid.resource.type=CWWKD1044E: Die Ressourcen-Accessor-Methode \u201e {0} \u201c des Repositorys \u201e {1} \u201c kann keine \u201e {2} \u201c-Ressource zur\u00fcckgeben. Die unterst\u00fctzten R\u00fcckgabetypen f\u00fcr Ressourcen-Zugriffsmethoden sind: ` {3} `.
CWWKD1044.invalid.resource.type.explanation=Der R\u00fcckgabetyp der Zugriffsmethode f\u00fcr die Ressource geh\u00f6rt nicht zu den von Jakarta Data unterst\u00fctzten Typen.
CWWKD1044.invalid.resource.type.useraction=Entfernen Sie die Methode oder passen Sie sie so an, dass sie einen der unterst\u00fctzten Typen zur\u00fcckgibt.

CWWKD1045.unknown.entity.anno=CWWKD1045E: Der integrierte Jakarta-Datenanbieter kann keine Implementierung der Repository-Schnittstelle \u201e {0} \u201c bereitstellen, da die vom Repository verwendete Entit\u00e4tsklasse \u201e {1} \u201c eine nicht erkannte Entit\u00e4tsannotation enth\u00e4lt. Die folgenden Entit\u00e4tsanmerkungen sind in der Entit\u00e4tsklasse \u201e {2} \u201c zu finden. Unterst\u00fctzte Entit\u00e4tsannotationen sind: {3}.
CWWKD1045.unknown.entity.anno.explanation=Der integrierte Jakarta-Datenanbieter unterst\u00fctzt eine der Entit\u00e4tsanmerkungen nicht.
CWWKD1045.unknown.entity.anno.useraction=Entfernen Sie die Annotation f\u00fcr die nicht erkannte Entit\u00e4t oder verwenden Sie das Attribut \u201eprovider\u201c der Repository-Annotation, um einen Jakarta-Data-Anbieter auszuw\u00e4hlen, der die Entit\u00e4tsannotation erkennt.

CWWKD1046.result.convert.err=CWWKD1046E: Das Ergebnis \u201e {0} \u201c der Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c kann nicht in den R\u00fcckgabetyp \u201e {3} \u201c der Repository-Methode konvertiert werden.
CWWKD1046.result.convert.err.explanation=Der Ergebniswert ist nicht mit dem R\u00fcckgabetyp der Repository-Methode kompatibel.
CWWKD1046.result.convert.err.useraction=Stellen Sie sicher, dass der R\u00fcckgabetyp der Repository-Methode mit dem Typ des von der Abfrage zur\u00fcckgegebenen Ergebnisses \u00fcbereinstimmt.

CWWKD1047.result.out.of.range=CWWKD1047E: Das Ergebnis \u201e {0} \u201c der Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c kann nicht in den R\u00fcckgabetyp \u201e {3} \u201c der Repository-Methode konvertiert werden, da das Ergebnis nicht im Bereich von \u201e {4} \u201c bis \u201e {5} \u201c liegt.
CWWKD1047.result.out.of.range.explanation=Der Ergebniswert ist nicht mit dem R\u00fcckgabetyp der Repository-Methode kompatibel, da er au\u00dferhalb des Bereichs der Werte liegt, die konvertiert werden k\u00f6nnen.
CWWKD1047.result.out.of.range.useraction=Passen Sie den R\u00fcckgabetyp der Repository-Methode so an, dass der Wert zur\u00fcckgegeben werden kann.

CWWKD1048.result.exceeds.max=CWWKD1048E: Das Ergebnis vom Typ \u201e {0} \u201c der Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c kann nicht in den R\u00fcckgabetyp \u201e {3} \u201c der Repository-Methode konvertiert werden, da der Ergebniswert den Maximalwert von \u201e {4} \u201c \u00fcberschreitet.
CWWKD1048.result.exceeds.max.explanation=Der Ergebniswert ist nicht mit dem R\u00fcckgabetyp der Repository-Methode kompatibel, da er den Maximalwert \u00fcberschreitet, der in diesen Typ konvertiert werden kann.
CWWKD1048.result.exceeds.max.useraction=Passen Sie den R\u00fcckgabetyp der Repository-Methode so an, dass der Wert zur\u00fcckgegeben werden kann.

CWWKD1049.count.convert.err=CWWKD1049E: Der Z\u00e4hlwert \u201e {0} \u201c aus der Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c kann nicht in den R\u00fcckgabetyp \u201e {3} \u201c der Repository-Methode konvertiert werden.
CWWKD1049.count.convert.err.explanation=Der Z\u00e4hlwert ist nicht mit dem R\u00fcckgabetyp der Repository-Methode kompatibel.
CWWKD1049.count.convert.err.useraction=Passen Sie den R\u00fcckgabetyp der Repository-Methode so an, dass der Wert zur\u00fcckgegeben werden kann.

CWWKD1050.opt.lock.exc=CWWKD1050E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c hat keine Entit\u00e4t vom Typ \u201e {2} \u201c gefunden, die den Entit\u00e4tsattributen \u201e {3} \u201c entspricht. Stellen Sie sicher, dass die Entit\u00e4tsinstanz, die an die Methode ` {0} ` \u00fcbergeben wird, auf der aktuellsten Version der Entit\u00e4t basiert. Die aktuellste Version der Entit\u00e4t kann \u00fcber eine `find`-Methode oder \u00fcber den R\u00fcckgabewert einer der folgenden Lebenszyklusmethoden abgerufen werden: ` {4} `.
CWWKD1050.opt.lock.exc.explanation=Es wurde kein entsprechender Eintrag gefunden.
CWWKD1050.opt.lock.exc.useraction=Falls zu erwarten ist, dass die Entit\u00e4t in der Datenbank nicht gefunden wird, sind keine Ma\u00dfnahmen erforderlich. Andernfalls stellen Sie sicher, dass die aktuellste Version der Entit\u00e4t verwendet wird.

CWWKD1051.single.opt.lock.exc=CWWKD1051E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c hat in der Datenbank keine passende Entit\u00e4t vom Typ \u201e {2} \u201c gefunden. Stellen Sie sicher, dass die Entit\u00e4tsinstanz, die an die Methode ` {0} ` \u00fcbergeben wird, auf der aktuellsten Version der Entit\u00e4t basiert. Die aktuellste Version der Entit\u00e4t kann \u00fcber eine `find`-Methode oder \u00fcber den R\u00fcckgabewert einer der folgenden Lebenszyklusmethoden abgerufen werden: ` {3} `.
CWWKD1051.single.opt.lock.exc.explanation=Es wurde kein entsprechender Eintrag gefunden.
CWWKD1051.single.opt.lock.exc.useraction=Falls zu erwarten ist, dass die Entit\u00e4t in der Datenbank nicht gefunden wird, sind keine Ma\u00dfnahmen erforderlich. Andernfalls stellen Sie sicher, dass die aktuellste Version der Entit\u00e4t verwendet wird.

CWWKD1052.multi.opt.lock.exc=CWWKD1052E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c hat die Entit\u00e4ten \u201e {2} \u201c der Entit\u00e4ten \u201e {3} \u201c und \u201e {4} \u201c in der Datenbank nicht gefunden. Stellen Sie sicher, dass die Entit\u00e4tsinstanzen, die an die Methode ` {0} ` \u00fcbergeben werden, auf der jeweils neuesten Version der Entit\u00e4t basieren. Die aktuellste Version einer Entit\u00e4t kann \u00fcber eine Suchmethode oder \u00fcber den R\u00fcckgabewert einer der folgenden Lebenszyklusmethoden abgerufen werden: {5}.
CWWKD1052.multi.opt.lock.exc.explanation=Eine oder mehrere der Entit\u00e4ten wurden in der Datenbank nicht gefunden.
CWWKD1052.multi.opt.lock.exc.useraction=Falls davon ausgegangen wird, dass eine Entit\u00e4t m\u00f6glicherweise nicht in der Datenbank gefunden wird, sind keine Ma\u00dfnahmen erforderlich. Andernfalls stellen Sie sicher, dass jeweils die aktuellste Version der einzelnen Entit\u00e4ten verwendet wird.

CWWKD1053.empty.result=CWWKD1053E: Der R\u00fcckgabetyp \u201e {0} \u201c der Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c kann kein leeres Ergebnis zur\u00fcckgeben. Wenn ein leeres Ergebnis erwartet wird, muss die Repository-Methode ein Array oder einen der folgenden R\u00fcckgabetypen zur\u00fcckgeben: {3}.
CWWKD1053.empty.result.explanation=Der R\u00fcckgabetyp der Repository-Methode l\u00e4sst es nicht zu, dass sie ein leeres Ergebnis zur\u00fcckgibt.
CWWKD1053.empty.result.useraction=Passen Sie die Repository-Methode so an, dass sie einen der R\u00fcckgabetypen verwendet, der ein leeres Ergebnis darstellen kann.

CWWKD1054.non.unique.result=CWWKD1054E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c hat den R\u00fcckgabetyp \u201e {2} \u201c, der keine Ergebnisse vom Typ \u201e {3} \u201c zur\u00fcckgeben kann. Um die Ausgabe auf ein einziges Ergebnis zu beschr\u00e4nken, verwenden Sie eines der folgenden Jakarta-Data-Muster: {4}.
CWWKD1054.non.unique.result.explanation=Der R\u00fcckgabetyp der Repository-Methode erlaubt keine R\u00fcckgabe mehrerer Ergebnisse.
CWWKD1054.non.unique.result.useraction=Passen Sie die Repository-Methode so an, dass sie entweder einen R\u00fcckgabetyp verwendet, der mehrere Ergebnisse unterst\u00fctzt, oder dass sie h\u00f6chstens ein einziges Ergebnis zur\u00fcckgibt.

CWWKD1055.unsupported.entity.attr=CWWKD1055E: Das Attribut \u201e {0} \u201c der Entit\u00e4t \u201e {1} \u201c hat einen nicht unterst\u00fctzten Typ: \u201e {2} \u201c. Jakarta Data unterst\u00fctzt Java-Enumerationstypen, die zeitbezogenen Typen der \u201e {3} \u201c sowie die folgenden Grundtypen: {4}. Der integrierte Jakarta-Datenanbieter unterst\u00fctzt auch einige Jakarta-Persistence-Typen, wie beispielsweise Embeddables. Alternativ k\u00f6nnen Sie, wenn Sie eine Jakarta-Persistence-Entit\u00e4t verwenden, die Annotation \u201e {5} \u201c zum Attribut \u201e {0} \u201c hinzuf\u00fcgen, um eine \u201e AttributeConverter \u201c-Implementierung bereitzustellen, die einen nicht unterst\u00fctzten Typ in einen unterst\u00fctzten Typ konvertiert.
CWWKD1055.unsupported.entity.attr.explanation=Jakarta Data unterst\u00fctzt den vom Entity-Attribut verwendeten Typ nicht.
CWWKD1055.unsupported.entity.attr.useraction=Passen Sie das Entit\u00e4tsattribut so an, dass einer der unterst\u00fctzten Typen verwendet wird.

CWWKD1056.unsupported.keyword=CWWKD1056E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c enth\u00e4lt in ihrem Namen das Schl\u00fcsselwort \u201e {2} \u201c, das kein unterst\u00fctztes Schl\u00fcsselwort des Musters \u201eJakarta Data Query by Method Name\u201c ist.
CWWKD1056.unsupported.keyword.explanation=Der Methodenname enth\u00e4lt ein Schl\u00fcsselwort, das nicht als Teil des unterst\u00fctzten Musters \u201eJakarta Data Query by Method Name\u201c erkannt wird.
CWWKD1056.unsupported.keyword.useraction=Benenne die Repository-Methode um, um das nicht unterst\u00fctzte Schl\u00fcsselwort zu entfernen.

CWWKD1057.no.args.constr.inacc=CWWKD1057E: Der R\u00fcckgabetyp \u201e {0} \u201c der Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c ist f\u00fcr eine Repository-Methode ung\u00fcltig, da die Klasse \u201e {3} \u201c keinen \u00f6ffentlichen Konstruktor ohne Parameter besitzt.
CWWKD1057.no.args.constr.inacc.explanation=Es wird ein \u00f6ffentlicher Konstruktor ohne Parameter ben\u00f6tigt, um das Ergebnis in die angegebene Klasse zu konvertieren.
CWWKD1057.no.args.constr.inacc.useraction=Passen Sie die Repository-Methode so an, dass sie einen von Jakarta Data unterst\u00fctzten R\u00fcckgabetyp aufweist oder eine Unterklasse von `Iterable` mit einem \u00f6ffentlichen Konstruktor ohne Parameter ist.

CWWKD1058.no.args.constr.err=CWWKD1058E: Der R\u00fcckgabetyp \u201e {0} \u201c der Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c ist f\u00fcr eine Repository-Methode ung\u00fcltig, da der Konstruktor der Klasse \u201e {3} \u201c einen Fehler ausgel\u00f6st hat: \u201e {4} \u201c.
CWWKD1058.no.args.constr.err.explanation=Der \u00f6ffentliche Konstruktor ohne Parameter ist aufgrund eines Fehlers fehlgeschlagen.
CWWKD1058.no.args.constr.err.useraction=Behebe den Fehler im Konstruktor oder passe die Repository-Methode so an, dass ein anderer R\u00fcckgabetyp verwendet wird.

CWWKD1059.attr.cast.err=CWWKD1059E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c kann nicht auf das Attribut \u201e {2} \u201c der Entit\u00e4t \u201e {3} \u201c zugreifen, da das Feld oder die Methode \u201e {4} \u201c der Klasse \u201e {5} \u201c nicht mit einem Wert vom Typ \u201e {6} \u201c kompatibel ist.
CWWKD1059.attr.cast.err.explanation=Ein Entit\u00e4tsattribut oder ein zugeh\u00f6riges Attribut aus seiner Hierarchie entspricht nicht dem erwarteten Typ.
CWWKD1059.attr.cast.err.useraction=\u00dcberpr\u00fcfen Sie das Entit\u00e4tsmodell und stellen Sie sicher, dass f\u00fcr jedes Attribut die richtigen Typen verwendet werden.

CWWKD1060.name.out.of.scope=CWWKD1060E: Die Repository-Schnittstelle \u201e {0} \u201c in der Anwendung \u201e {1} \u201c konfiguriert einen Wert f\u00fcr \u201e {2} \u201c f\u00fcr das Attribut \u201e {3} \u201c, doch die Namen unter \u201e {3} \u201c sind f\u00fcr das Artefakt, das die Repository-Schnittstelle bereitstellt, nicht zug\u00e4nglich. Verwenden Sie stattdessen einen \u201e {4} \u201c-Namen.
CWWKD1060.name.out.of.scope.explanation=Auf den angegebenen Namensraum kann von dem Artefakt aus, in dem die Repository-Schnittstelle definiert ist, nicht zugegriffen werden.
CWWKD1060.name.out.of.scope.useraction=Aktualisieren Sie die Repository-Annotation, um einen Datenspeichernamen anzugeben, der f\u00fcr das Modul oder die Bibliothek sichtbar ist, das bzw. die die Repository-Schnittstelle bereitstellt.

CWWKD1061.comp.name.in.ejb=CWWKD1061E: Eine oder mehrere Repository-Schnittstellen ( {0} ), die im Enterprise-Bean-Modul \u201e {1} \u201c der Anwendung \u201e {2} \u201c definiert sind, konfigurieren den Wert \u201e {3} \u201c f\u00fcr das Attribut \u201e {4} \u201c. {5} -Namen sind f\u00fcr Enterprise-Bean-Module jedoch nicht zug\u00e4nglich. Verwende einen Namen aus einem der folgenden Namensr\u00e4ume: {6}.
CWWKD1061.comp.name.in.ejb.explanation=Auf den angegebenen Namensraum kann von dem Enterprise-Bean-Modul, in dem die Repository-Schnittstelle definiert ist, nicht zugegriffen werden.
CWWKD1061.comp.name.in.ejb.useraction=Aktualisieren Sie die Repository-Annotation, um einen Datenspeichernamen anzugeben, der f\u00fcr das Enterprise-Bean-Modul sichtbar ist, das die Repository-Schnittstelle bereitstellt.

CWWKD1062.resource.not.found=CWWKD1062E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c kann die Ressource \u201e {2} \u201c mit dem Filter \u201e {3} \u201c nicht finden.
CWWKD1062.resource.not.found.explanation=Die Ressource wurde nicht gefunden.
CWWKD1062.resource.not.found.useraction=Stellen Sie sicher, dass die angegebene Ressource und alle anderen Ressourcen, von denen sie abh\u00e4ngt, vorhanden und korrekt konfiguriert sind.

CWWKD1063.unsupported.resource=CWWKD1063E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c kann keine \u201e {2} \u201c-Ressource abrufen, da der Jakarta-Persistence-Anbieter die \u201eunwrap\u201c-Operation, die eine \u201e {3} \u201c-Instanz zur\u00fcckgibt, nicht unterst\u00fctzt.
CWWKD1063.unsupported.resource.explanation=Der Jakarta-Persistence-Anbieter unterst\u00fctzt die \u201eunwrap\u201c-Operation nicht, bei der der angegebene Ressourcentyp zur\u00fcckgegeben wird.
CWWKD1063.unsupported.resource.useraction=Entferne die nicht unterst\u00fctzte Methode f\u00fcr den Zugriff auf Ressourcen aus der Repository-Schnittstelle.

CWWKD1064.datastore.error=CWWKD1064E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c kann den Datenspeicher \u201e {2} \u201c f\u00fcr das Repository aufgrund des folgenden Fehlers nicht abrufen: {3}.
CWWKD1064.datastore.error.explanation=Beim Abrufen des Datenspeichers ist ein Fehler aufgetreten.
CWWKD1064.datastore.error.useraction=Stellen Sie sicher, dass der angegebene Datenspeicher und alle anderen Ressourcen, von denen er abh\u00e4ngt, vorhanden und korrekt konfiguriert sind.

CWWKD1065.ddlgen.timeout=CWWKD1065E: Die DDL-Generierung f\u00fcr eine oder mehrere Repository-Schnittstellen ( {0} ) ist fehlgeschlagen, da der Datenspeicher \u201e {1} \u201c die DDL-Generierung f\u00fcr die folgenden Entit\u00e4ten nicht innerhalb von {2} Sekunden abgeschlossen hat: {3}.
CWWKD1065.ddlgen.timeout.explanation=Der Versuch, die DDL zu generieren, ist abgelaufen und wurde nicht abgeschlossen.
CWWKD1065.ddlgen.timeout.useraction=Versuchen Sie die DDL-Generierung erneut, wenn das System und die Datenbank nicht ausgelastet sind.

CWWKD1066.ddlgen.failed=CWWKD1066E: Bei der DDL-Generierung f\u00fcr eine oder mehrere Repository-Schnittstellen ( {0} ), die den Datenspeicher \u201e {1} \u201c verwenden, ist bei der DDL-Generierung f\u00fcr die folgenden Entit\u00e4ten ein Fehler aufgetreten: {2}. Die Fehlermeldung lautet: \u201e {3} \u201c.
CWWKD1066.ddlgen.failed.explanation=Der Versuch, die DDL zu generieren, ist fehlgeschlagen und wurde nicht abgeschlossen.
CWWKD1066.ddlgen.failed.useraction=Untersuchen Sie den Fehler und nehmen Sie Korrekturen an der Repository-Schnittstelle, den Entit\u00e4ten, der Konfiguration des Datenspeichers oder der Datenbank vor.

CWWKD1067.ddlgen.emf.timeout=CWWKD1067E: Die DDL-Generierung f\u00fcr eine oder mehrere Repository-Schnittstellen ( {0} ) ist fehlgeschlagen, da der Datenspeicher {1} nicht verf\u00fcgbar war oder die folgenden Entit\u00e4ten nicht innerhalb von {2} Sekunden bereitstellen konnte: {3}.
CWWKD1067.ddlgen.emf.timeout.explanation=Die Bereitstellung der f\u00fcr die DDL-Generierung erforderlichen Ressourcen ist abgelaufen und wurde nicht abgeschlossen.
CWWKD1067.ddlgen.emf.timeout.useraction=Versuchen Sie die DDL-Generierung erneut, wenn das System und die Datenbank nicht ausgelastet sind.

CWWKD1068.entity.name.conflict=CWWKD1068E: Die Repository-Schnittstelle von \u201e {0} \u201c enth\u00e4lt mehrere Entit\u00e4ten mit dem Namen \u201e {1} \u201c, die von verschiedenen Klassen bereitgestellt werden: \u201e {2} \u201c. Verwenden Sie die folgenden Jakarta-Persistence-Entit\u00e4tsannotationen, um jeder Entit\u00e4tsklasse einen eindeutigen Entit\u00e4tsnamen und Tabellennamen zuzuweisen: {3}.
CWWKD1068.entity.name.conflict.explanation=Entit\u00e4ts- und Tabellennamen werden aus dem unqualifizierten Klassennamen abgeleitet oder durch Jakarta-Persistence-Annotationen zugewiesen.
CWWKD1068.entity.name.conflict.useraction=Benennen Sie die Entit\u00e4ten um oder f\u00fcgen Sie Jakarta-Persistence-Annotationen hinzu, um den Namenskonflikt explizit zu beheben.

CWWKD1069.record.entity.name.conflict=CWWKD1069E: Die Repository-Schnittstelle von \u201e {0} \u201c enth\u00e4lt mehrere Entit\u00e4ten mit dem Namen \u201e {1} \u201c, die von verschiedenen Klassen bereitgestellt werden: \u201e {2} \u201c. Wenn Java-Datens\u00e4tze als Entit\u00e4ten verwendet werden, muss es auch m\u00f6glich sein, dem Entit\u00e4tsnamen das Suffix \u201eEntity\u201c anzuh\u00e4ngen, ohne dass es zu einem Namenskonflikt kommt. Zum Beispiel: {2}.
CWWKD1069.record.entity.name.conflict.explanation=Entit\u00e4ts- und Tabellennamen werden aus dem unqualifizierten Klassennamen abgeleitet oder durch Jakarta-Persistence-Annotationen zugewiesen.
CWWKD1069.record.entity.name.conflict.useraction=Benennen Sie die Entit\u00e4ten um oder wechseln Sie zu Jakarta-Persistence-Entit\u00e4ten, um den Namenskonflikt zu beheben.

CWWKD1070.record.convert.err=CWWKD1070E: Das \u201e {0} \u201c-Objekt, das an die Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c \u00fcbergeben wird, kann aufgrund des folgenden Fehlers nicht als Entit\u00e4t verwendet werden: {3}.
CWWKD1070.record.convert.err.explanation=Es ist nicht m\u00f6glich, den Java-Datensatz als Entit\u00e4t zu verwenden.
CWWKD1070.record.convert.err.useraction=Definieren Sie die Entit\u00e4t als Jakarta-Persistence-Entit\u00e4t, anstatt eine Java-Record-Entit\u00e4t zu verwenden.

CWWKD1071.record.with.type.var=CWWKD1071E: Der Datensatz \u201e {0} \u201c wird von einer oder mehreren der Repository-Schnittstellen ( {1} ) im Anwendungsartefakt \u201e {2} \u201c als Entit\u00e4t verwendet, kann jedoch keine Entit\u00e4t sein, da er eine oder mehrere Typvariablen enth\u00e4lt: {3}.
CWWKD1071.record.with.type.var.explanation=Entit\u00e4tsklassen d\u00fcrfen keine generischen Typvariablen enthalten.
CWWKD1071.record.with.type.var.useraction=Entferne die Typvariablen aus dem Datensatz.

CWWKD1072.record.comp.conflict=CWWKD1072E: Der Datensatz \u201e {0} \u201c wird von einer oder mehreren der Repository-Schnittstellen ( {1} ) im Anwendungsartefakt \u201e {2} \u201c als Entit\u00e4t verwendet, kann jedoch keine Entit\u00e4t sein, da sowohl die Komponente \u201e {3} \u201c als auch die Komponente \u201e {4} \u201c auf denselben Entit\u00e4tsattributnamen verweisen.
CWWKD1072.record.comp.conflict.explanation=Die Namen von Entit\u00e4tsattributen m\u00fcssen unabh\u00e4ngig von der Gro\u00df-/Kleinschreibung eindeutig sein.
CWWKD1072.record.comp.conflict.useraction=Benennen Sie eine der Datensatzkomponenten um, um den Konflikt zu vermeiden.

CWWKD1073.offset.exceeds.max=CWWKD1073E: Der Startwert von \u201e {0} \u201c f\u00fcr das Limit \u201e {1} \u201c, der an die Methode \u201e {2} \u201c der Repository-Schnittstelle \u201e {3} \u201c \u00fcbergeben wird, \u00fcberschreitet den maximal zul\u00e4ssigen Wert von \u201e {4} \u201c.
CWWKD1073.offset.exceeds.max.explanation=Der Startwert f\u00fcr den Grenzwert ist zu gro\u00df.
CWWKD1073.offset.exceeds.max.useraction=F\u00fcgen Sie der Abfrage Einschr\u00e4nkungen hinzu, um die Anzahl der Treffer zu verringern.

CWWKD1074.qbmn.incompat.keywords=CWWKD1074E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c darf das Schl\u00fcsselwort \u201e {2} \u201c nicht mit dem Schl\u00fcsselwort \u201e {3} \u201c in derselben Bedingung \u201eQuery by Method Name\u201c kombinieren.
CWWKD1074.qbmn.incompat.keywords.explanation=Die angegebenen Schl\u00fcsselw\u00f6rter f\u00fcr die Abfrage nach Methodennamen sind untereinander nicht kompatibel.
CWWKD1074.qbmn.incompat.keywords.useraction=Benenne die Methode um, damit die Schl\u00fcsselw\u00f6rter nicht in derselben Bedingung kombiniert werden.

CWWKD1075.entity.attr.conflict=CWWKD1075E: Die Entit\u00e4t \u201e {0} \u201c darf kein Attribut namens \u201e {1} \u201c und kein Attribut namens \u201e {2} \u201c haben, da die Jakarta-Data-Spezifikation diese Namen als Aliase f\u00fcr dasselbe Entit\u00e4tsattribut betrachtet.
CWWKD1075.entity.attr.conflict.explanation=Aufgrund des Unterstrichs kommt es zu einer Namens\u00fcberschneidung zwischen zwei Entit\u00e4tsattributen.
CWWKD1075.entity.attr.conflict.useraction=Verwenden Sie in den Namen von Entit\u00e4tsattributen keine Unterstriche.

CWWKD1076.repo.disposed=CWWKD1076E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c kann nicht aufgerufen werden, da die Anwendung, die das Repository definiert, beendet wurde. Die Repository-Instanz lautet {2}.
CWWKD1076.repo.disposed.explanation=Repository-Methoden d\u00fcrfen nicht au\u00dferhalb des Lebenszyklus der Anwendung verwendet werden, die das Repository definiert.
CWWKD1076.repo.disposed.useraction=Stellen Sie sicher, dass die Repository-Methode nicht au\u00dferhalb des Geltungsbereichs der Anwendung verwendet wird, die das Repository definiert.

CWWKD1077.defaultds.not.found=CWWKD1077E: Das Anwendungsartefakt \u201e {0} \u201c verf\u00fcgt \u00fcber eine oder mehrere Repository-Schnittstellen ( {1} ), die den Datenspeicher \u201e {2} \u201c verwenden oder standardm\u00e4\u00dfig darauf zur\u00fcckgreifen. Dieser Datenspeicher muss in der Serverkonfiguration konfiguriert werden, indem ein Element vom Typ \u201e dataSource \u201c mit der Kennung \u201e DefaultDataSource \u201c definiert wird. Beispiel: {3} Alternativ k\u00f6nnen Sie den Wert \u201e dataStore \u201c der Annotation \u201eRepository\u201c auf den Bezeichner eines Elements vom Typ \u201e databaseStore \u201c oder auf den JNDI-Namen einer Datenquellen-Ressourcenreferenz oder einer Persistenz-Unit-Referenz setzen, auf die das Anwendungsartefakt zugreifen kann. Ein \u201e databaseStore \u201c-Element kann in der Serverkonfiguration definiert werden. Beispiel: {4} Eine Anwendungskomponente kann die Annotation \u201eResource\u201c verwenden, um eine Referenz auf eine Datenquellenre\
    ssource zu definieren. Beispielsweise {5}, das eine Serverkonfiguration erfordert, die ein Konfigurationselement \u201e dataSource \u201c mit dem Attribut \u201e {6} \u201c enth\u00e4lt. Eine Anwendungskomponente kann die Annotation \u201e PersistenceUnit \u201c verwenden, um eine Persistenz-Einheitsreferenz zu definieren. Beispielsweise {7}, wonach die Datei \u201e persistence.xml \u201c ein \u201epersistence-unit\u201c-Element mit einem entsprechenden \u201ename\u201c-Attribut enthalten muss. Zum Beispiel: {8}
CWWKD1077.defaultds.not.found.explanation=Datenrepositorien in Jakarta verwenden standardm\u00e4\u00dfig die Standarddatenquelle von Jakarta EE, die in der Serverkonfiguration eingerichtet werden muss.
CWWKD1077.defaultds.not.found.useraction=Konfigurieren Sie die Standarddatenquelle von Jakarta EE oder geben Sie einen anderen Datenspeicher f\u00fcr das Repository an.

CWWKD1078.datastore.not.found=CWWKD1078E: Eine oder mehrere Repository-Schnittstellen ( {0} ) des Anwendungsartefakts \u201e {1} \u201c geben einen Datenspeicher \u201e {2} \u201c an, der nicht mit der ID eines Elements \u201e dataSource \u201c oder eines Elements \u201e databaseStore \u201c in der Serverkonfiguration \u00fcbereinstimmt, oder er stimmt nicht mit dem JNDI-Namen einer Datenquelle, einer Datenquellen-Ressourcenreferenz oder einer Persistenz-Unit-Referenz \u00fcberein, auf die das Anwendungsartefakt zugreifen kann, oder eine der zugeh\u00f6rigen Ressourcen ist nicht korrekt konfiguriert. Ein \u201e dataSource \u201c-Element kann in der Serverkonfiguration definiert werden. Beispielsweise kann {3} ein databaseStore Element in der Serverkonfiguration definiert werden. Beispiel: {4} Eine Anwendungskomponente kann die Annotation \u201eResource\u201c verwenden, um eine Referenz auf eine Datenquellenressource zu definieren. Beispielsweise {5}, das eine Serverkonfiguration erfordert, die ei\
    n Konfigurationselement \u201e dataSource \u201c mit dem Attribut \u201e {6} \u201c enth\u00e4lt. Eine Anwendungskomponente kann die Annotation \u201e PersistenceUnit \u201c verwenden, um eine Persistenz-Einheitsreferenz zu definieren. Beispielsweise {7}, wonach die Datei \u201e persistence.xml \u201c ein \u201epersistence-unit\u201c-Element mit einem entsprechenden \u201ename\u201c-Attribut enthalten muss. Zum Beispiel: {8}
CWWKD1078.datastore.not.found.explanation=Der Datenspeicher eines Jakarta-Datenrepositorys kann die ID eines Elements vom Typ \u201e dataSource \u201c oder \u201e databaseStore \u201c in der Serverkonfiguration sein oder ein JNDI-Name einer Datenquelle, einer Datenquellen-Ressourcenreferenz oder einer Persistenz-Einheitsreferenz.
CWWKD1078.datastore.not.found.useraction=Stellen Sie sicher, dass die Ressource korrekt konfiguriert ist. Wenn Sie einen JNDI-Namen verwenden, stellen Sie sicher, dass der Geltungsbereich des JNDI-Namens den Zugriff auf die Ressource f\u00fcr das Anwendungsartefakt erm\u00f6glicht, das das Repository bereitstellt.

CWWKD1079.jndi.not.found=CWWKD1079E: Eine oder mehrere Repository-Schnittstellen ( {0} ) des Anwendungsartefakts \u201e {1} \u201c geben einen Datenspeicher mit dem JNDI-Namen \u201e {2} \u201c an, doch ist eine Datenquelle, eine Datenquellen-Ressourcenreferenz oder eine Persistenz-Unit-Referenz mit diesem JNDI-Namen f\u00fcr das Anwendungsartefakt nicht zug\u00e4nglich, oder eine der zugeh\u00f6rigen Ressourcen ist nicht korrekt konfiguriert. Eine Anwendungskomponente kann die Annotation \u201eResource\u201c verwenden, um eine Referenz auf eine Datenquellenressource zu definieren. Beispielsweise {3}, das auf ein Serverkonfigurationselement dataSource mit dem Attribut {4} verweist. Eine Anwendungskomponente kann die Annotation \u201e PersistenceUnit \u201c verwenden, um eine Persistenz-Einheitsreferenz zu definieren. Beispielsweise {5}, wonach die Datei \u201e persistence.xml \u201c ein \u201epersistence-unit\u201c-Element mit einem entsprechenden \u201ename\u201c-Attribut enthalten muss. Beispie\
    l: {6} Eine Anwendungskomponente kann die Annotation \u201e DataSourceDefinition \u201c verwenden, um eine Datenquelle zu definieren. Alternativ kann ein ` dataSource `-Element eine Datenquelle in der Serverkonfiguration definieren. Zum Beispiel: {7}
CWWKD1079.jndi.not.found.explanation=Wenn der Datenspeicher eines Jakarta-Daten-Repositorys auf einen JNDI-Namen einer Datenquelle, eine Datenquellen-Ressourcenreferenz oder eine Persistenz-Unit-Referenz gesetzt ist, muss der JNDI-Name f\u00fcr das Anwendungsartefakt, das das Repository bereitstellt, zug\u00e4nglich sein, und die Datenquelle oder die Persistenz-Unit muss korrekt konfiguriert sein.
CWWKD1079.jndi.not.found.useraction=Stellen Sie sicher, dass die Ressource korrekt konfiguriert ist, und stellen Sie sicher, dass der Geltungsbereich des JNDI-Namens die Ressource f\u00fcr das Anwendungsartefakt zug\u00e4nglich macht, das das Repository bereitstellt.

CWWKD1080.datastore.general.err=CWWKD1080E: Eine oder mehrere Repository-Schnittstellen ( {0} ) aus dem Anwendungsartefakt \u201e {1} \u201c sind aufgrund eines Fehlers nicht verf\u00fcgbar. Der Fehler k\u00f6nnte auf ein Konfigurationsproblem zur\u00fcckzuf\u00fchren sein, oder der Datenspeicher \u201e {2} \u201c f\u00fcr das Repository ist m\u00f6glicherweise nicht verf\u00fcgbar. Die Fehlermeldung lautet: \u201e {3} \u201c.
CWWKD1080.datastore.general.err.explanation=Ein Fehler verhindert, dass die angegebenen Repositorys verwendet werden k\u00f6nnen.
CWWKD1080.datastore.general.err.useraction=Suchen Sie die Repository-Schnittstellen und die Konfiguration des Datenspeichers und nehmen Sie gegebenenfalls Korrekturen vor.

CWWKD1081.entity.general.err=CWWKD1081E: Aufgrund eines Fehlers steht die Entit\u00e4t \u201e {0} \u201c einer oder mehreren Repository-Schnittstellen ( {1} ) nicht zur Verf\u00fcgung, die den Datenspeicher \u201e {2} \u201c verwenden. Der Fehler ist {3}.
CWWKD1081.entity.general.err.explanation=Ein Fehler verhindert, dass die angegebene Entit\u00e4t verwendet werden kann.
CWWKD1081.entity.general.err.useraction=Suchen Sie die Entit\u00e4t und nehmen Sie gegebenenfalls Korrekturen vor.

CWWKD1082.entity.classes.missing=CWWKD1082E: Die Persistenz-Einheit f\u00fcr den Datenspeicher \u201e {0} \u201c definiert keine Entit\u00e4tsklassen ( {1} ), die von einer oder mehreren Repository-Schnittstellen ( {2} ), die diesen Datenspeicher nutzen, ben\u00f6tigt werden.
CWWKD1082.entity.classes.missing.explanation=Repositorys verwenden Entit\u00e4tsklassen, die in der Persistenz-Einheit definiert werden m\u00fcssen.
CWWKD1082.entity.classes.missing.useraction=F\u00fcge alle Entit\u00e4tsklassen in die Persistenz-Einheit ein.

CWWKD1083.dup.method.param=CWWKD1083E: Mehrere Parameter in der Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c entsprechen dem benannten Parameter: \u201e {2} \u201c. Sie k\u00f6nnen einen Methodenparameter mit \u201e {3} \u201c kennzeichnen, um den benannten Parameter der Abfragesprache anzugeben. Alternativ k\u00f6nnen Sie die Kompilierungsoption \u201e-parameters\u201c aktivieren und einen Methodenparameter in der Form \u201e {4} \u201c definieren, wof\u00fcr die Annotation \u201eParam\u201c nicht erforderlich ist.
CWWKD1083.dup.method.param.explanation=Jeder Methodenparameter muss genau einem Abfrageparameter entsprechen.
CWWKD1083.dup.method.param.useraction=\u00dcberpr\u00fcfen Sie, ob jeder der Methodenparameter den richtigen benannten Parameter angibt. Entferne doppelte Methodenparameter. 
CWWKD1084.missing.named.params=CWWKD1084E: Die Parameter der Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c definieren nicht die benannten Parameter ( {2} ), die vom Wert der Annotation \u201eQuery\u201c verlangt werden: {3}. Sie k\u00f6nnen einen benannten Parameter f\u00fcr die Abfrage definieren, indem Sie die Annotation \u201eParam\u201c auf einen entsprechenden Methodenparameter anwenden. Zum Beispiel: {4}. Alternativ k\u00f6nnen Sie, wenn Sie die Kompilierungsoption \u201e-parameters\u201c aktivieren, die Annotation \u201eParam\u201c weglassen, sofern Sie den Methodenparameter so benennen, dass er denselben Namen wie der benannte Parameter tr\u00e4gt. Wenn beispielsweise \u201eString\u201c der Typ des benannten Parameters ist, kann der Methodenparameter \u201e {5} \u201c lauten, wof\u00fcr die Annotation \u201eParam\u201c nicht erforderlich ist.
CWWKD1084.missing.named.params.explanation=Der Wert der Annotation \u201eQuery\u201c erfordert einen oder mehrere benannte Parameter, die nicht von der Repository-Methode bereitgestellt werden.
CWWKD1084.missing.named.params.useraction=F\u00fcgen Sie der Repository-Methode Parameter hinzu, um die fehlenden benannten Parameter anzugeben.

CWWKD1085.extra.method.params=CWWKD1085E: Die Parameter der Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c definieren Abfrageparameter ( {2} ), die mit keinem der benannten Parameter ( {3} ) \u00fcbereinstimmen, die vom Wert der Annotation \u201eQuery\u201c verwendet werden: {4}.
CWWKD1085.extra.method.params.explanation=Alle Methodenparameter m\u00fcssen von der Abfrage verwendet werden oder als Parametertypen in Jakarta Data definiert sein.
CWWKD1085.extra.method.params.useraction=Entferne die \u00fcberfl\u00fcssigen Methodenparameter.

CWWKD1086.named.params.unused=CWWKD1086E: Die Parameter der Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c definieren benannte Parameter ( {2} ), die im Wert der Annotation \u201eQuery\u201c nicht verwendet werden: {3}. Sie k\u00f6nnen in einer Abfrage auf benannte Parameter verweisen, indem Sie das Zeichen \u201e:\u201c gefolgt vom Parameternamen verwenden. Zum Beispiel: {4}. Auf Positionsparameter in einer Abfrage kann mithilfe des Zeichens? verwiesen werden Zeichen, gefolgt von einem Ordnungswert, beginnend mit?1. Vermeiden Sie es, Methodenparameter mit der Annotation \u201eParam\u201c zu versehen, wenn die Abfrage Positionsparameter verwendet oder keine Parameter hat.
CWWKD1086.named.params.unused.explanation=Die Param-Annotation kann nur verwendet werden, wenn die Abfrage benannte Parameter enth\u00e4lt.
CWWKD1086.named.params.unused.useraction=Entfernen Sie die \u201eParam\u201c-Annotation oder stellen Sie die Abfrage so um, dass benannte Parameter verwendet werden.

CWWKD1087.null.param=CWWKD1087E: Der Parameter \u201e {0} \u201c der Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c ist ein Nullwert. Geben Sie einen Wert ein, der nicht null ist.
CWWKD1087.null.param.explanation=Der Parameterwert darf nicht null sein.
CWWKD1087.null.param.useraction=Geben Sie f\u00fcr den Parameter einen Wert ungleich Null an.

CWWKD1088.empty.sorts=CWWKD1088E: Die Sortierkriterien, die durch den Parameter \u201e {0} \u201c der Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c festgelegt werden, sind leer.
CWWKD1088.empty.sorts.explanation=Die Sortierkriterien d\u00fcrfen nicht leer sein.
CWWKD1088.empty.sorts.useraction=Geben Sie einen Wert f\u00fcr das Sortierkriterium an.

CWWKD1089.unordered.pagination=CWWKD1089E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c muss die Sortierkriterien angeben, da die Methode einen Wert vom Typ \u201e {2} \u201c zur\u00fcckgibt. Ungeordnete Daten k\u00f6nnen nicht in Seiten aufgeteilt werden.
CWWKD1089.unordered.pagination.explanation=F\u00fcr die Paginierung sind geordnete Daten erforderlich.
CWWKD1089.unordered.pagination.useraction=Verwenden Sie die Annotation \u201e OrderBy \u201c, um die Sortierkriterien f\u00fcr die Repository-Methode festzulegen.

CWWKD1090.orderby.conflict=CWWKD1090E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c kann die Annotation \u201e OrderBy \u201c und das Schl\u00fcsselwort \u201e OrderBy \u201c nicht kombinieren.
CWWKD1090.orderby.conflict.explanation=Die Annotation \u201e OrderBy \u201c ist nicht mit dem Schl\u00fcsselwort \u201e OrderBy \u201c kompatibel.
CWWKD1090.orderby.conflict.useraction=Verwenden Sie ausschlie\u00dflich die Annotation \u201e OrderBy \u201c oder das Schl\u00fcsselwort \u201e OrderBy \u201c.

CWWKD1091.method.name.parse.err=CWWKD1091E: Ein Entit\u00e4tsattribut namens \u201e {0} \u201c wurde in der Entit\u00e4tsklasse \u201e {1} \u201c f\u00fcr die Methode \u201e {2} \u201c der Repository-Schnittstelle \u201e {3} \u201c nicht gefunden. Stellen Sie sicher, dass die Repository-Methode entweder einen Namen hat, der dem Muster \u201eAbfrage nach Methodennamen\u201c entspricht, oder mit einer der folgenden Annotationen versehen ist: ` {4} `. G\u00fcltige Attributnamen f\u00fcr die Entit\u00e4t sind: {5}.
CWWKD1091.method.name.parse.err.explanation=Der Name der Repository-Methode wurde gem\u00e4\u00df dem Muster \u201eAbfrage nach Methodennamen\u201c analysiert, da die Repository-Methode keine Jakarta-Data-Annotation enth\u00e4lt, die den Typ der Operation angibt.
CWWKD1091.method.name.parse.err.useraction=Korrigieren Sie den Namen der Repository-Methode oder versehen Sie die Repository-Methode mit einer Anmerkung, um eine Jakarta-Data-Operation wie \u201eQuery\u201c, \u201eFind\u201c oder \u201eSave\u201c anzugeben.

CWWKD1092.lifecycle.arg.empty=CWWKD1092E: Die Methode \u201e {0} \u201c des Repositorys \u201e {1} \u201c akzeptiert keinen leeren Parameter \u201e {2} \u201c. Der Parameterwert muss mindestens eine Entit\u00e4t enthalten.
CWWKD1092.lifecycle.arg.empty.explanation=Methoden zum Einf\u00fcgen, Aktualisieren, Speichern und L\u00f6schen
 require mindestens eine Einheit.
CWWKD1092.lifecycle.arg.empty.useraction=Stellen Sie sicher, dass das Array, die Liste oder der Stream, der an die Methode \u00fcbergeben wird, mindestens ein Element enth\u00e4lt.

CWWKD1093.fn.not.applicable=CWWKD1093E: Die Funktion \u201e {0} \u201c kann f\u00fcr die Entit\u00e4t \u201e {1} \u201c nicht ausgewertet werden, die von der Methode \u201e {2} \u201c der Repository-Schnittstelle \u201e {3} \u201c verwendet wird. Die Entit\u00e4t verf\u00fcgt \u00fcber kein Attribut, das mit \u201e {4} \u201c gekennzeichnet ist oder aus dem \u201e {0} \u201c abgeleitet werden kann.
CWWKD1093.fn.not.applicable.explanation=Die Funktion kann f\u00fcr die Entit\u00e4t nicht verwendet werden, da ihr ein ID- oder Versionsattribut fehlt.
CWWKD1093.fn.not.applicable.useraction=Verwenden Sie diese Funktion nicht in der Abfragesprache oder in den Parametern der Repository-Methode.

CWWKD1094.return.mismatch=CWWKD1094E: Die Methode ` {0} ` der Repository-Schnittstelle ` {1} ` hat den R\u00fcckgabetyp ` {2} `, der nicht in der Lage ist, die Anzahl der Entit\u00e4ten ` {3} ` zur\u00fcckzugeben, die die Repository-Methode als Parameter akzeptiert. Zu den zul\u00e4ssigen R\u00fcckgabetypen f\u00fcr eine ` {4} `-Methode, die mehrere Entit\u00e4ten akzeptiert, geh\u00f6ren: ` {5} `.
CWWKD1094.return.mismatch.explanation=Eine Repository-Lebenszyklusmethode, die Entit\u00e4ten zur\u00fcckgibt, muss in der Lage sein, dieselbe Anzahl von Entit\u00e4ten zur\u00fcckzugeben, wie von der Methode angenommen wird.
CWWKD1094.return.mismatch.useraction=Passen Sie die Repository-Methode so an, dass sie entweder einen R\u00fcckgabetyp verwendet, der mehrere Entit\u00e4ten zur\u00fcckgeben kann, oder dass sie nur eine einzige Entit\u00e4t akzeptiert.

CWWKD1095.repo.err=CWWKD1095E: Aufgrund eines Fehlers kann keine Implementierung der Repository-Schnittstelle \u201e {0} \u201c bereitgestellt werden. Die Repository-Annotation lautet \u201e {1} \u201c. Die prim\u00e4re Entit\u00e4tsklasse ist \u201e {2} \u201c. Der Fehler lautet: {3}
CWWKD1095.repo.err.explanation=Der integrierte Jakarta-Datenanbieter kann aufgrund eines Fehlers keine Instanz des Repositorys bereitstellen.
CWWKD1095.repo.err.useraction=Untersuchen Sie den Fehler und korrigieren Sie die Repository-Schnittstelle, die Entit\u00e4ten, die Konfiguration des Datenspeichers oder die Datenbank.

CWWKD1096.orderby.incompat=CWWKD1096E: Die Methode \u201e {0} \u201c des Repositorys \u201e {1} \u201c verf\u00fcgt \u00fcber die Annotation \u201e OrderBy \u201c, doch die Methode \u201e {0} \u201c ist weder eine Such- noch eine L\u00f6schoperation, die Entit\u00e4ten zur\u00fcckgibt.
CWWKD1096.orderby.incompat.explanation=Die Annotation \u201e OrderBy \u201c ist mit der Art der Repository-Operation nicht kompatibel.
CWWKD1096.orderby.incompat.useraction=Entfernen Sie die Anmerkung \u201e OrderBy \u201c.

CWWKD1097.param.incompat=CWWKD1097E: Die Methode \u201e {0} \u201c des Repositorys \u201e {1} \u201c verf\u00fcgt \u00fcber den Parameter \u201e {2} \u201c, doch die Methode \u201e {0} \u201c ist weder eine Such- noch eine L\u00f6schoperation, die Entit\u00e4ten zur\u00fcckgibt.
CWWKD1097.param.incompat.explanation=Die Parameter \u201eOrder\u201c, \u201eSort\u201c und \u201eLimit\u201c sind mit dieser Art von Repository-Operation nicht kompatibel.
CWWKD1097.param.incompat.useraction=Entfernen Sie den Parameter \u201eOrder\u201c, \u201eSort\u201c oder \u201eLimit\u201c.

CWWKD1098.spec.param.position.err=CWWKD1098E: Die Methode \u201e {0} \u201c des Repositorys \u201e {1} \u201c verf\u00fcgt \u00fcber einen Parameter \u201e {2} \u201c, der vor den Abfrageparametern steht. Parametertypen, die in Jakarta Data ( {3} ) eine besondere Bedeutung haben, m\u00fcssen in der Signatur der Repository-Methode hinter den anderen Parametern stehen.
CWWKD1098.spec.param.position.err.explanation=Wenn spezielle, in Jakarta Data definierte Parametertypen in der Signatur einer Repository-Methode enthalten sind, m\u00fcssen sie hinter allen Abfrageparametern stehen.
CWWKD1098.spec.param.position.err.useraction=Verschieben Sie die speziell definierten Jakarta-Datentypen an das Ende der Methodensignatur im Repository.

CWWKD1099.first.keyword.incompat=CWWKD1099E: Die Methode \u201e {0} \u201c im Repository \u201e {1} \u201c enth\u00e4lt im Namen das Schl\u00fcsselwort \u201eFirst\u201c, was mit dem Parameter \u201e {2} \u201c dieser Methode unvereinbar ist.
CWWKD1099.first.keyword.incompat.explanation=Bei einer Abfrage nach Methodennamen, die einen \u201eLimit\u201c- oder \u201e PageRequest \u201c-Parameter enth\u00e4lt, kann das Schl\u00fcsselwort \u201eFirst\u201c nicht verwendet werden.
CWWKD1099.first.keyword.incompat.useraction=Entferne das Wort \u201eFirst\u201c aus dem Methodennamen.

CWWKD1100.cursor.requires.sort=CWWKD1100E: Die Methode \u201e {0} \u201c des Repositorys \u201e {1} \u201c gibt \u201e {2} \u201c zur\u00fcck, verf\u00fcgt jedoch weder \u00fcber die Annotation \u201e OrderBy \u201c noch \u00fcber einen der folgenden Parameter zur Festlegung von Sortierkriterien: \u201e {3} \u201c. Sortierkriterien sind f\u00fcr die cursorbasierte Paginierung erforderlich und k\u00f6nnen nicht innerhalb einer ORDER BY-Klausel eines Query-Annotationswerts angegeben werden.
CWWKD1100.cursor.requires.sort.explanation=F\u00fcr die Cursor-basierte Paginierung sind Sortierkriterien erforderlich.
CWWKD1100.cursor.requires.sort.useraction=Entferne die ORDER BY-Klausel aus dem Wert der Query-Annotation, falls dort eine vorhanden ist. F\u00fcgen Sie eine Annotation vom Typ \u201e OrderBy \u201c oder einen Parameter f\u00fcr eine Repository-Methode hinzu, um die Sortierkriterien festzulegen.

CWWKD1101.attr.subset.mismatch=CWWKD1101E: Der R\u00fcckgabetyp \u201e {0} \u201c der Methode \u201e {1} \u201c des Repositorys \u201e {2} \u201c verwendet den Java-Record-Typ \u201e {3} \u201c, um die Ergebnisse als Teilmenge von Entit\u00e4tsattributen zu definieren: {4}. Allerdings ist mindestens einer der angeforderten Attributnamen in der Entit\u00e4t \u201e {5} \u201c nicht vorhanden. Um eine Teilmenge von Entit\u00e4tsattributen als Java-Datensatz zur\u00fcckzugeben, stellen Sie sicher, dass die Namen der Datensatzkomponenten zu den folgenden g\u00fcltigen Attributnamen f\u00fcr die Entit\u00e4t \u201e {5} \u201c geh\u00f6ren: {6}. Alternativ k\u00f6nnen Sie die Anmerkung \u201eAusw\u00e4hlen\u201c verwenden, um g\u00fcltige Entit\u00e4tsattributnamen zuzuweisen. Um ein einzelnes Entit\u00e4tsattribut zur\u00fcckzugeben, das einen Java-Datensatztyp hat, versehen Sie die Methode \u201e {1} \u201c mit der Annotation \u201eSelect\u201c und weisen Sie deren Member-Wert dem Namen des Entit\u00e4\
    tsattributs zu.
CWWKD1101.attr.subset.mismatch.explanation=Wenn Java-Datens\u00e4tze verwendet werden, um eine Teilmenge von Entit\u00e4tsattributen abzurufen, m\u00fcssen alle Komponenten des Datensatzes g\u00fcltigen Entit\u00e4tsattributen entsprechen.
CWWKD1101.attr.subset.mismatch.useraction=Benennen Sie die Datensatzkomponenten so um, dass sie g\u00fcltigen Entit\u00e4tsattributnamen entsprechen, oder verwenden Sie die Annotation \u201eSelect\u201c, um Entit\u00e4tsattribute explizit anhand ihres Namens abzufragen.

CWWKD1102.incompat.query.result=CWWKD1102E: Die Methode \u201e {0} \u201c des Repositorys \u201e {1} \u201c hat den R\u00fcckgabetyp \u201e {2} \u201c, doch der Jakarta-Persistence-Anbieter hat eine Abfrage mit Ergebnissen vom Typ \u201e {3} \u201c durchgef\u00fchrt. Pr\u00fcfen Sie, ob der Jakarta-Persistenz-Anbieter Abfragen f\u00fcr die Typen der Entit\u00e4tsattribute zul\u00e4sst, die von der Methode ` {0} ` ausgew\u00e4hlt werden. Pr\u00fcfen Sie, ob andere Ursachen f\u00fcr die Inkompatibilit\u00e4t vorliegen, falls der Jakarta-Anbieter die Abfrage der Typen der Entit\u00e4tsattribute zul\u00e4sst, die von der Methode ` {0} ` ausgew\u00e4hlt werden.
CWWKD1102.incompat.query.result.explanation=In Jakarta Persistence lassen die Provider nicht zu, dass alle Arten von Entit\u00e4tsattributen zur\u00fcckgegeben werden. Wenn der Jakarta-Anbieter nicht den Typ der Entit\u00e4tsattribute zur\u00fcckgibt, den die Methode ausgew\u00e4hlt hat, liegt eine weitere Ursache f\u00fcr die Inkompatibilit\u00e4t vor. Beispielsweise k\u00f6nnte der Jakarta-Persistence-Anbieter einen Fehler enthalten oder die Signatur der Repository-Methode k\u00f6nnte fehlerhaft sein.
CWWKD1102.incompat.query.result.useraction=Falls der Typ der Entit\u00e4tsattribute, die die Methode ausw\u00e4hlt, nicht zul\u00e4ssig ist, passen Sie die Abfrage so an, dass entweder die gesamte Entit\u00e4t oder eine andere Menge von Entit\u00e4tsattributen abgerufen wird, die vom Jakarta-Persistenz-Anbieter zugelassen ist. Wenn der Typ der Entit\u00e4tsattribute, die die Methode ausw\u00e4hlt, zul\u00e4ssig ist, pr\u00fcfen Sie, ob andere Ursachen f\u00fcr die Inkompatibilit\u00e4t vorliegen.

CWWKD1103.incompat.query.result=CWWKD1103E: Die Methode \u201e {0} \u201c des Repositorys \u201e {1} \u201c hat den R\u00fcckgabetyp \u201e {2} \u201c, doch der Jakarta-Persistence-Anbieter f\u00fchrte eine Abfrage vom Typ \u201e {3} \u201c durch, deren Ergebnisse vom Typ \u201e {4} \u201c waren. Pr\u00fcfen Sie, ob der Jakarta-Persistenz-Anbieter Abfragen f\u00fcr die Typen der Entit\u00e4tsattribute zul\u00e4sst, die von der Methode ` {0} ` ausgew\u00e4hlt werden. Pr\u00fcfen Sie, ob andere Ursachen f\u00fcr die Inkompatibilit\u00e4t vorliegen, falls der Jakarta-Anbieter die Abfrage der Typen der Entit\u00e4tsattribute zul\u00e4sst, die von der Methode ` {0} ` ausgew\u00e4hlt werden.
CWWKD1103.incompat.query.result.explanation=In Jakarta Persistence lassen die Provider nicht zu, dass alle Arten von Entit\u00e4tsattributen zur\u00fcckgegeben werden. Wenn der Jakarta-Anbieter nicht den Typ der Entit\u00e4tsattribute zur\u00fcckgibt, den die Methode ausgew\u00e4hlt hat, liegt eine weitere Ursache f\u00fcr die Inkompatibilit\u00e4t vor. Beispielsweise k\u00f6nnte der Jakarta-Persistence-Anbieter einen Fehler enthalten oder die Signatur der Repository-Methode k\u00f6nnte fehlerhaft sein.
CWWKD1103.incompat.query.result.useraction=Falls der Typ der Entit\u00e4tsattribute, die die Methode ausw\u00e4hlt, nicht zul\u00e4ssig ist, passen Sie die Abfrage so an, dass entweder die gesamte Entit\u00e4t oder eine andere Menge von Entit\u00e4tsattributen abgerufen wird, die vom Jakarta-Persistenz-Anbieter zugelassen ist. Wenn der Typ der Entit\u00e4tsattribute, die die Methode ausw\u00e4hlt, zul\u00e4ssig ist, pr\u00fcfen Sie, ob andere Ursachen f\u00fcr die Inkompatibilit\u00e4t vorliegen.

CWWKD1104.empty.anno.value=CWWKD1104E: Der Leerwert f\u00fcr die Klasse \u201eString\u201c ist kein g\u00fcltiger Wert f\u00fcr die Annotation \u201e {0} \u201c, die bei der Methode \u201e {1} \u201c des Repositorys \u201e {2} \u201c verwendet wird.
CWWKD1104.empty.anno.value.explanation=Der Leerwert f\u00fcr die Klasse \u201eString\u201c wird nicht unterst\u00fctzt. Welcher Wert unterst\u00fctzt wird, h\u00e4ngt von der Art der Anmerkung ab. Wenn es sich bei der Annotation beispielsweise um eine \u201eParam\u201c-Annotation handelt, sind g\u00fcltige Werte die Namen der benannten Parameter, die im Wert der \u201eQuery\u201c-Annotation verwendet werden.
CWWKD1104.empty.anno.value.useraction=Falls die Anmerkung nicht ben\u00f6tigt wird, entfernen Sie sie aus der Repository-Methode. Andernfalls geben Sie einen g\u00fcltigen Wert f\u00fcr die Anmerkung an.

CWWKD1105.keyword.in.orderby=CWWKD1105E: Die Klausel \u201e OrderBy \u201c der Methode \u201e {0} \u201c des Repositorys \u201e {1} \u201c kann nicht analysiert werden, da das Entit\u00e4tsattribut \u201e {2} \u201c der Entit\u00e4t \u201e {3} \u201c das Schl\u00fcsselwort \u201e {4} \u201c des Musters \u201eJakarta Data Query by Method Name\u201c enth\u00e4lt. Entfernen Sie die Klausel \u201e OrderBy \u201c aus dem Namen der Methode \u201e {0} \u201c und verwenden Sie stattdessen die Annotation \u201e OrderBy \u201c.
CWWKD1105.keyword.in.orderby.explanation=Entit\u00e4tsattributnamen, die Schl\u00fcsselw\u00f6rter von Jakarta Data enthalten, d\u00fcrfen nicht in den Namen von Repository-Methoden verwendet werden, die dem Muster \u201eJakarta Data Query by Method Name\u201c folgen.
CWWKD1105.keyword.in.orderby.useraction=Benennen Sie das Entit\u00e4tsattribut um oder verwenden Sie stattdessen die Annotation \u201e OrderBy \u201c, um die Reihenfolge festzulegen.

CWWKD1106.init.timed.out=CWWKD1106E: Das Repository \u201e {0} \u201c, das den Datenspeicher \u201e {1} \u201c ben\u00f6tigt und vom Anwendungsartefakt \u201e {2} \u201c bereitgestellt oder verwendet wird, war innerhalb von {3} Sekunden nicht verf\u00fcgbar. Stellen Sie sicher, dass das Anwendungsartefakt \u201e {2} \u201c gestartet wird und dass die Datenspeicherressource \u201e {1} \u201c, die als Wert f\u00fcr \u201e dataStore \u201c der Annotation \u201eRepository\u201c angegeben ist, korrekt konfiguriert ist und dem Anwendungsartefakt zum Zeitpunkt des ersten Zugriffs auf das Repository \u201e {0} \u201c zur Verf\u00fcgung steht.
CWWKD1106.init.timed.out.explanation=Ein Repository wurde nicht innerhalb der vorgegebenen Zeit verf\u00fcgbar.
CWWKD1106.init.timed.out.useraction=\u00dcberpr\u00fcfen Sie die Konfiguration des Repositorys \u201e dataStore \u201c und stellen Sie sicher, dass es f\u00fcr Anwendungsartefakte, die das Repository definieren und nutzen, zug\u00e4nglich ist. Vergewissern Sie sich au\u00dferdem, dass die Anwendung und alle ihre Module erfolgreich starten.

CWWKD1107.init.timed.out.checkpoint=CWWKD1107E: Das Anwendungsartefakt \u201e {0} \u201c hat auf das Repository \u201e {1} \u201c zugegriffen, bevor ein Checkpoint der Anwendung abgeschlossen war. Aktualisieren Sie die Anwendung \u201e {0} \u201c, um zu vermeiden, dass das Repository vor einem Checkpoint verwendet wird.
CWWKD1107.init.timed.out.checkpoint.explanation=Anwendungen k\u00f6nnen Repositorys erst nach Abschluss eines Checkpoints nutzen.
CWWKD1107.init.timed.out.checkpoint.useraction=Verwenden Sie das Repository erst wieder, nachdem der Checkpoint abgeschlossen ist.

CWWKD1108.missing.entity.anno=CWWKD1108E: Die Entit\u00e4tsklasse \u201e {0} \u201c ben\u00f6tigt die Annotation \u201e {1} \u201c, da die Annotation \u201e {2} \u201c auf das Element \u201e {3} \u201c der Entit\u00e4tsklasse angewendet wird.
CWWKD1108.missing.entity.anno.explanation=Entit\u00e4tsklassen, die Annotationen verwenden
 from Das Paket \u201e jakarta.persistence \u201c muss ebenfalls mit der Entit\u00e4t versehen werden
 annotation aus der Jakarta-Persistence-Spezifikation.
CWWKD1108.missing.entity.anno.useraction=Wende die Entity-Annotation auf das
 entity die Jakarta-Persistence-Annotationen aus der Klasse entfernen oder aus ihren Elementen l\u00f6schen.

CWWKD1109.jpa.anno.on.record=CWWKD1109E: Die Annotation \u201e {0} \u201c ist f\u00fcr die Methode \u201e {1} \u201c der Entit\u00e4tsklasse \u201e {2} \u201c nicht zul\u00e4ssig, da die Entit\u00e4tsklasse \u201e {2} \u201c ein Java-Record ist.
CWWKD1109.jpa.anno.on.record.explanation=Jakarta Persistence-Annotationen sind bei Java-Records nicht zul\u00e4ssig.
CWWKD1109.jpa.anno.on.record.useraction=Wechseln Sie zu einer Jakarta-Persistence-Entit\u00e4tsklasse oder entfernen Sie die Jakarta-Persistence-Annotation aus dem Java-Datensatz.

CWWKD1110.incompat.with.collection=CWWKD1110E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c enth\u00e4lt in ihrem Namen das Schl\u00fcsselwort \u201e {2} \u201c, was mit dem Attribut \u201e {3} \u201c der Entit\u00e4t \u201e {4} \u201c nicht kompatibel ist, da dieses Attribut einen Sammlungstyp aufweist. Die folgenden Schl\u00fcsselw\u00f6rter f\u00fcr die Abfrage nach Methodennamen k\u00f6nnen bei Entit\u00e4tsattributen verwendet werden, die einen Sammlungstyp haben: {5}.
CWWKD1110.incompat.with.collection.explanation=Einige der Schl\u00fcsselw\u00f6rter f\u00fcr die Abfrage nach Methodennamen sind nicht mit Entit\u00e4tsattributen kompatibel, die einen Sammlungstyp haben.
CWWKD1110.incompat.with.collection.useraction=Aktualisieren Sie die Repository-Methode, um die Verwendung des Schl\u00fcsselworts zu vermeiden, das mit dem Sammlungstyp nicht kompatibel ist.

CWWKD1111.unsupported.convert=CWWKD1111E: Die Implementierung von \u201e {0} \u201c unter AttributeConverter konvertiert Werte vom Typ \u201e {1} \u201c in den Typ \u201e {2} \u201c, der von der Jakarta-Data-Spezifikation nicht unterst\u00fctzt wird. Die Jakarta-Data-Spezifikation unterst\u00fctzt Java-Enumerationstypen, die zeitbezogenen Typen der \u201e {3} \u201c sowie die folgenden Grundtypen: {4}. Der integrierte Jakarta-Datenanbieter unterst\u00fctzt auch einige Jakarta-Persistence-Typen.
CWWKD1111.unsupported.convert.explanation=Die Implementierung von \u201e AttributeConverter \u201c kann nicht mit dem integrierten Jakarta-Datenanbieter verwendet werden, da sie Werte in einen nicht unterst\u00fctzten Typ konvertiert.
CWWKD1111.unsupported.convert.useraction=Aktualisieren Sie die Implementierung von ` AttributeConverter `, um Werte in einen der unterst\u00fctzten Typen zu konvertieren.

CWWKD1112.record.entity.verify.err=CWWKD1112W: Es ist eine Entit\u00e4tsklasse f\u00fcr den Datensatz \u201e {0} \u201c definiert, die jedoch m\u00f6glicherweise nicht funktioniert. Die \u00dcberpr\u00fcfung der Bytes der Jakarta-Persistence-Entit\u00e4tsklasse, die f\u00fcr die Entit\u00e4tsklasse generiert wurde, ist fehlgeschlagen. Die definierte Entit\u00e4tsklasse wird von einer oder mehreren Repository-Schnittstellen ( {1} ) im Anwendungsartefakt \u201e {2} \u201c verwendet. Die Fehlermeldung lautet: \u201e {3} \u201c.
CWWKD1112.record.entity.verify.err.explanation=Wenn ein Repository eine Datensatzentit\u00e4t verwendet, wird eine Jakarta-Persistence-Entit\u00e4t generiert, um diese Datensatzentit\u00e4t darzustellen. Die \u00dcberpr\u00fcfung der Bytes der generierten Jakarta-Persistence-Entit\u00e4tsklasse ist fehlgeschlagen.
CWWKD1112.record.entity.verify.err.useraction=Stellen Sie sicher, dass die Implementierung der Datensatzentit\u00e4t den Anforderungen und Konventionen f\u00fcr eine Datensatzentit\u00e4t entspricht.

CWWKD1113.server.stopping=CWWKD1113I: Ein oder mehrere Repositorys ( {0} ) konnten nicht initialisiert werden, da der Server heruntergefahren wird.
CWWKD1113.server.stopping.explanation=Der Server wird heruntergefahren und wird nicht versuchen, die Repositorys zu initialisieren.
CWWKD1113.server.stopping.useraction=Es ist keine Aktion erforderlich.

CWWKD1114.app.stopping=CWWKD1114I: Ein oder mehrere Repositorys ( {0} ) konnten nicht initialisiert werden, da sich die Anwendung \u201e {1} \u201c im Status \u201e {2} \u201c befindet.
CWWKD1114.app.stopping.explanation=Die Anwendung wird angehalten oder wurde bereits angehalten und versucht nicht, die Repositorys zu initialisieren.
CWWKD1114.app.stopping.useraction=Starten Sie die Anwendung, um die Repositorys verf\u00fcgbar zu machen.

CWWKD1115.app.unavailable=CWWKD1115E: Ein oder mehrere Repositorys ( {0} ) konnten nicht initialisiert werden, da die Anwendung \u201e {1} \u201c nicht verf\u00fcgbar ist.
CWWKD1115.app.unavailable.explanation=Die Anwendung, die die Repositorys definiert, ist nicht verf\u00fcgbar. Die Repositorys k\u00f6nnen nicht initialisiert werden.
CWWKD1115.app.unavailable.useraction=Starten Sie die Anwendung, um die Repositorys verf\u00fcgbar zu machen.

CWWKD1116.resource.unavailable=CWWKD1116E: Ein oder mehrere Repositorys ( {0} ) konnten nicht initialisiert werden, da die Ressource {1} nicht innerhalb von {2} Sekunden verf\u00fcgbar war.
CWWKD1116.resource.unavailable.explanation=Eine von den Repositorys ben\u00f6tigte Ressource wurde nicht bereitgestellt.
CWWKD1116.resource.unavailable.useraction=\u00dcberpr\u00fcfen Sie die Konfiguration der Ressourcen, die von den Repositorys verwendet werden.

CWWKD1117.anno.constraint.conflict=CWWKD1117E: Der Parameter \u201e {0} \u201c der Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c darf nicht mit den Annotationen \u201e {3} \u201c versehen werden. Eine oder mehrere der Annotationen sind nicht mit dem Typ \u201e {4} \u201c des Repository-Methodenparameters kompatibel.
CWWKD1117.anno.constraint.conflict.explanation=Constraint und seine Untertypen k\u00f6nnen nicht mit anderen Parameter-Annotationen als der Annotation \u201eBy\u201c kombiniert werden.
CWWKD1117.anno.constraint.conflict.useraction=Entfernen Sie die widerspr\u00fcchliche Anmerkung oder geben Sie den Attributtyp der Entit\u00e4t anstelle eines Constraint-Typs an.

CWWKD1118.param.anno.conflict=CWWKD1118E: Der Parameter \u201e {0} \u201c der Methode \u201e {1} \u201c der Repository-Schnittstelle \u201e {2} \u201c darf nicht mit den Annotationen \u201e {3} \u201c versehen werden. Zwei oder mehr Anmerkungen stehen im Widerspruch zueinander.
CWWKD1118.param.anno.conflict.explanation=Die Kombination der Parameter-Annotationen ist ung\u00fcltig.
CWWKD1118.param.anno.conflict.useraction=Entfernen Sie eine oder mehrere der in Konflikt stehenden Annotationen aus dem Parameter der Repository-Methode.

CWWKD1119.keyword.prevents.count=CWWKD1119E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c ruft Seiten ab, die keine Gesamtanzahl von Elementen und Seiten enthalten, da die Abfrage das Schl\u00fcsselwort \u201e {2} \u201c enth\u00e4lt. Die vollst\u00e4ndige Abfrage lautet: {3}.
CWWKD1119.keyword.prevents.count.explanation=Das Schl\u00fcsselwort ist nicht mit der M\u00f6glichkeit vereinbar, die Gesamtanzahl der Elemente und Seiten zu ermitteln.
CWWKD1119.keyword.prevents.count.useraction=Ersetzen Sie die Abfrage durch eine, die das Schl\u00fcsselwort nicht verwendet, oder vermeiden Sie es, die Gesamtanzahl der Elemente und Seiten abzufragen.

CWWKD1120.cursor.keyword.mismatch=CWWKD1120E: Die Methode \u201e {0} \u201c der Repository-Schnittstelle \u201e {1} \u201c definiert eine Abfrage, die das Schl\u00fcsselwort \u201e {2} \u201c enth\u00e4lt, das mit der cursorbasierten Paginierung nicht kompatibel ist. Abfragen f\u00fcr die Cursor-basierte Paginierung m\u00fcssen mit einer WHERE-Klausel enden und d\u00fcrfen keine Unterabfragen enthalten. Die Abfrage lautet: {3}.
CWWKD1120.cursor.keyword.mismatch.explanation=Schl\u00fcsselw\u00f6rter wie GROUP BY, HAVING, ORDER BY, EXCEPT, INTERSECT und UNION sind nicht mit der cursorbasierten Paginierung kompatibel.
CWWKD1120.cursor.keyword.mismatch.useraction=Formuliere die Abfrage so um, dass sie nur die Klauseln SELECT, FROM und WHERE enth\u00e4lt.

CWWKD1121.record.lacks.id=CWWKD1121E: Der Datensatz \u201e {0} \u201c kann nicht als Entit\u00e4t verwendet werden, da ihm eine eindeutige Kennung fehlt. Eine der Datensatzkomponenten ( {1} ) muss den Namen \u201eid\u201c tragen, einen Namen haben, der auf \u201e_id\u201c, \u201eId\u201c oder \u201eID\u201c endet, oder vom Typ \u201e java.util.UUID \u201c sein.
CWWKD1121.record.lacks.id.explanation=Entit\u00e4ten m\u00fcssen \u00fcber ein Attribut f\u00fcr eine eindeutige Kennung verf\u00fcgen.
CWWKD1121.record.lacks.id.useraction=F\u00fcgen Sie eine Datensatzkomponente hinzu oder benennen Sie sie um, damit sie einer der angegebenen Konventionen zur Vergabe einer eindeutigen Kennung entspricht.

CWWKD1122.entity.lacks.id=CWWKD1122E: Die Klasse \u201e {0} \u201c kann nicht als Entit\u00e4t verwendet werden, da ihr eine eindeutige Kennung fehlt. Um eine eindeutige Kennung zuzuweisen, stellen Sie sicher, dass die Funktion \u201e {1} \u201c aktiviert ist, f\u00fcgen Sie die Annotation @ jakarta.persistence.Entity zur Entit\u00e4tsklasse hinzu und f\u00fcgen Sie die Annotation @ jakarta.persistence.Id zu h\u00f6chstens einem Feld oder einer Getter-Methode der Entit\u00e4tsklasse hinzu. Alternativ k\u00f6nnen Sie die Entit\u00e4t und ihre eindeutige Kennung in einer \u201e META-INF/orm.xml \u201c-Datei definieren.
CWWKD1122.entity.lacks.id.explanation=Entit\u00e4ten m\u00fcssen \u00fcber ein Attribut f\u00fcr eine eindeutige Kennung verf\u00fcgen.
CWWKD1122.entity.lacks.id.useraction=Aktivieren Sie die Jakarta-Persistence-Funktion und halten Sie sich an das Jakarta-Persistence-Entit\u00e4tsmodell, um eine eindeutige Kennung zuzuweisen.

CWWKD1123.sort.incompat.with.cursor=CWWKD1123E: F\u00fcr eine angeforderte Ergebnisseite kann kein Cursor abgeleitet werden, da eines der Sortierkriterien, die an die Methode \u201e {0} \u201c des Repositorys \u201e {1} \u201c \u00fcbergeben wurden, kein Entit\u00e4tsattribut ist: {2}. Verwenden Sie die Methode ` {3} `, um einen Cursor zu erstellen, der den Sortierkriterien entspricht, und \u00fcbergeben Sie diesen Cursor an die Methode ` afterCursor ` oder ` beforeCursor ` einer ` PageRequest `-Klasse. Alternativ k\u00f6nnen Sie die Sortierkriterien so \u00e4ndern, dass nur die Namen der Entit\u00e4tsattribute ber\u00fccksichtigt werden. G\u00fcltige Attributnamen f\u00fcr die Entit\u00e4tsklasse \u201e {4} \u201c sind \u201e {5} \u201c.
CWWKD1123.sort.incompat.with.cursor.explanation=Um automatisch einen Cursor auf der Grundlage der Sortierkriterien zu erstellen, muss jedes Sortierkriterium nach dem Namen eines einzelnen Entit\u00e4tsattributs sortieren.
CWWKD1123.sort.incompat.with.cursor.useraction=Geben Sie einen Cursor an, der mit den Sortierkriterien \u00fcbereinstimmt. Alternativ k\u00f6nnen Sie auf eine offsetbasierte Paginierung umstellen oder die Sortierkriterien so anpassen, dass nur nach Entit\u00e4tsattributen sortiert wird.
