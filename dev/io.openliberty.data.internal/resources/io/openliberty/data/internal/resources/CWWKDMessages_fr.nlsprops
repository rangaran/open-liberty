#CMVCPATHNAME io.openliberty.data.internal/resources/io/openliberty/data/internal/persistence/resources/CWWKDMessages.nlsprops
#ISMESSAGEFILE TRUE
#NLS_ENCODING=UNICODE
#
#COMPONENTPREFIX CWWKD
#COMPONENTNAMEFOR CWWKD Jakarta Data
#
# NLS_MESSAGEFORMAT_VAR
#
#   Strings in this file which contain replacement variables are processed by the MessageFormat 
#   class (single quote must be coded as 2 consecutive single quotes ''). Strings in this file 
#   which do NOT contain replacement variables are NOT processed by the MessageFormat class 
#   (single quote must be coded as one single quote '). 

# All messages must use the range CWWKD1000 to CWWKD1399

CWWKD1000.repo.general.err=CWWKD1000E: Une erreur s''est produite lors de l''ex\u00e9cution de la m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} `. Cette erreur peut indiquer que la m\u00e9thode du r\u00e9f\u00e9rentiel n''est pas valide. Erreur : {2}.
CWWKD1000.repo.general.err.explanation=Une erreur s'est produite avec la m\u00e9thode de r\u00e9f\u00e9rentiel indiqu\u00e9e.
CWWKD1000.repo.general.err.useraction=Identifiez l'interface et la m\u00e9thode du r\u00e9f\u00e9rentiel, puis d\u00e9terminez si des corrections sont n\u00e9cessaires.

CWWKD1001.no.primary.entity=CWWKD1001E: La m\u00e9thode du r\u00e9f\u00e9rentiel \u00ab {0} \u00bb n\u00e9cessite une classe d''entit\u00e9, mais l''interface du r\u00e9f\u00e9rentiel \u00ab {1} \u00bb ne sp\u00e9cifie pas de classe d''entit\u00e9 principale. Pour corriger cette erreur, l''interface du r\u00e9f\u00e9rentiel \u00ab {1} \u00bb peut \u00e9tendre l''un des supertypes de r\u00e9f\u00e9rentiel int\u00e9gr\u00e9s, tels que \u00ab {2} \u00bb, et fournir la classe d''entit\u00e9 comme premier param\u00e8tre de type.
CWWKD1001.no.primary.entity.explanation=Les m\u00e9thodes de r\u00e9f\u00e9rentiel qui ne disposent pas de leur propre classe d'entit\u00e9 n\u00e9cessitent que le r\u00e9f\u00e9rentiel d\u00e9finisse une classe d'entit\u00e9 principale.
CWWKD1001.no.primary.entity.useraction=D\u00e9finissez une classe d'entit\u00e9 principale pour le r\u00e9f\u00e9rentiel.

CWWKD1002.method.annos.err=CWWKD1002E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` est annot\u00e9e avec une combinaison d''annotations non valide : ` {2} `.
CWWKD1002.method.annos.err.explanation=Cette combinaison d'annotations n'est pas valide pour une m\u00e9thode de r\u00e9f\u00e9rentiel unique.
CWWKD1002.method.annos.err.useraction=Identifiez l'interface et la m\u00e9thode du r\u00e9f\u00e9rentiel, puis d\u00e9terminez la combinaison appropri\u00e9e d'annotations de m\u00e9thode.

CWWKD1003.rtrn.err=CWWKD1003E: Le type de retour \u00ab {0} \u00bb de la m\u00e9thode \u00ab {1} \u00bb de l''interface de r\u00e9f\u00e9rentiel \u00ab {2} \u00bb n''est pas un type de retour valide pour une m\u00e9thode d'' {3} du r\u00e9f\u00e9rentiel. Les types de retour valides sont les suivants : {4}
CWWKD1003.rtrn.err.explanation=Le type de retour de la m\u00e9thode ne fait pas partie des types de retour pris en charge pour le type de m\u00e9thode de r\u00e9f\u00e9rentiel indiqu\u00e9.
CWWKD1003.rtrn.err.useraction=Consultez la documentation Javadoc de Jakarta Data pour les annotations Insert, Update et Save, ainsi que la documentation \u00ab Query by Method name \u00bb pour conna\u00eetre les types de retour valides.

CWWKD1004.general.rtrn.err=CWWKD1004E: Le type de retour \u00ab {0} \u00bb de la m\u00e9thode \u00ab {1} \u00bb de l''interface de r\u00e9f\u00e9rentiel \u00ab {2} \u00bb n''est pas un type de retour valide pour une m\u00e9thode de r\u00e9f\u00e9rentiel.
CWWKD1004.general.rtrn.err.explanation=Le type de retour de la m\u00e9thode ne fait pas partie des types de retour pris en charge pour ce type de m\u00e9thode de r\u00e9f\u00e9rentiel.
CWWKD1004.general.rtrn.err.useraction=Consultez la documentation Javadoc de Jakarta Data pour obtenir la liste des types de retour valides pour le type de m\u00e9thode de r\u00e9f\u00e9rentiel.

CWWKD1005.find.rtrn.err=CWWKD1005E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` n''est pas valide. La m\u00e9thode sp\u00e9cifie un type de retour \u00ab {2} \u00bb qui n''est pas convertible \u00e0 partir du type d''entit\u00e9 \u00ab {3} \u00bb. Le type de r\u00e9sultat d''une op\u00e9ration de recherche doit \u00eatre le type de l''entit\u00e9, le type d''un attribut de l''entit\u00e9 s\u00e9lectionn\u00e9 par l''annotation `Select`, un enregistrement Java compos\u00e9 d''attributs de l''entit\u00e9, ou un type s\u00e9lectionn\u00e9 par la requ\u00eate fournie \u00e0 l''annotation `Query`. Le type de retour de la m\u00e9thode `find` du r\u00e9f\u00e9rentiel peut \u00eatre le type du r\u00e9sultat, un tableau de ce type, ou l''un des types suivants param\u00e9tr\u00e9 avec le type du r\u00e9sultat : ` {4} `.
CWWKD1005.find.rtrn.err.explanation=Le type de retour de la m\u00e9thode ne fait pas partie des types de retour pris en charge pour les m\u00e9thodes de recherche du r\u00e9f\u00e9rentiel.
CWWKD1005.find.rtrn.err.useraction=Consultez la documentation Javadoc de Jakarta Data pour obtenir la liste des types de retour valides pour les m\u00e9thodes de recherche du r\u00e9f\u00e9rentiel.

CWWKD1006.delete.rtrn.err=CWWKD1006E: Le type de retour \u00ab {0} \u00bb de la m\u00e9thode \u00ab {1} \u00bb de l''interface de r\u00e9f\u00e9rentiel \u00ab {2} \u00bb n''est pas un type de retour valide pour une op\u00e9ration de suppression. Le type de retour doit \u00eatre soit void, long, int, boolean, array, List ou Optional. Un type de retour de type `void` ne renvoie aucune valeur. Un type de retour de type long ou int renvoie un compteur de suppressions. Le type de retour bool\u00e9en indique si des entit\u00e9s ont \u00e9t\u00e9 supprim\u00e9es. Un type de retour de type tableau, liste ou Optional, param\u00e9tr\u00e9 soit avec une classe d''entit\u00e9 de type \u00ab {3} \u00bb, soit avec une classe d''identificateur unique de type \u00ab {4} \u00bb, renvoie les entit\u00e9s supprim\u00e9es ou leurs identifiants.
CWWKD1006.delete.rtrn.err.explanation=Le type de retour de la m\u00e9thode ne fait pas partie des types de retour pris en charge pour une op\u00e9ration de suppression.
CWWKD1006.delete.rtrn.err.useraction=Modifiez la m\u00e9thode du r\u00e9f\u00e9rentiel afin qu'elle utilise l'un des types de retour pris en charge.

CWWKD1007.updel.rtrn.err=CWWKD1007E: Le type de retour \u00ab {0} \u00bb de la m\u00e9thode \u00ab {1} \u00bb de l''interface de r\u00e9f\u00e9rentiel \u00ab {2} \u00bb n''est pas un type de retour valide pour une op\u00e9ration d'' {3} ation de r\u00e9f\u00e9rentiel. Le type de retour doit \u00eatre soit void, soit long, soit int, soit boolean. Un type de retour de type `void` ne renvoie aucune valeur. Un type de retour de type long ou int renvoie le nombre d''entit\u00e9s correspondantes. Le type de retour bool\u00e9en indique si des entit\u00e9s correspondent.
CWWKD1007.updel.rtrn.err.explanation=Le type de retour de la m\u00e9thode ne fait pas partie des types de retour pris en charge pour une op\u00e9ration de mise \u00e0 jour ou de suppression.
CWWKD1007.updel.rtrn.err.useraction=Modifiez la m\u00e9thode du r\u00e9f\u00e9rentiel afin qu'elle utilise l'un des types de retour pris en charge.

CWWKD1008.ambig.rtrn.err=CWWKD1008E: Le type de retour \u00ab {0} \u00bb de la m\u00e9thode \u00ab {1} \u00bb de l''interface de r\u00e9f\u00e9rentiel \u00ab {2} \u00bb est ambigu, car il correspond \u00e0 plusieurs attributs d''entit\u00e9 : {3}. La m\u00e9thode du r\u00e9f\u00e9rentiel doit passer \u00e0 l''annotation Query et utiliser une requ\u00eate comportant une clause SELECT qui pr\u00e9cise quel attribut d''entit\u00e9 renvoyer.
CWWKD1008.ambig.rtrn.err.explanation=Le type de retour de la m\u00e9thode ne fait pas partie des types de retour pris en charge pour une m\u00e9thode de suppression.
CWWKD1008.ambig.rtrn.err.useraction=Modifiez la m\u00e9thode du r\u00e9f\u00e9rentiel afin d'utiliser l'annotation `Query` pour s\u00e9lectionner l'attribut de l'entit\u00e9.

CWWKD1009.lifecycle.param.err=CWWKD1009E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` ne peut pas accepter de param\u00e8tres de type ` {2} `, car cette m\u00e9thode est annot\u00e9e avec l''annotation de cycle de vie ` {3} `. Les m\u00e9thodes de r\u00e9f\u00e9rentiel annot\u00e9es avec une annotation de cycle de vie doivent avoir exactement un param\u00e8tre, qui doit \u00eatre l''entit\u00e9 elle-m\u00eame ou un tableau ou une liste de cette entit\u00e9.
CWWKD1009.lifecycle.param.err.explanation=Les m\u00e9thodes de cycle de vie doivent avoir un seul param\u00e8tre d'entit\u00e9.
CWWKD1009.lifecycle.param.err.useraction=Modifiez la m\u00e9thode du r\u00e9f\u00e9rentiel afin qu'elle accepte un seul param\u00e8tre, qui peut \u00eatre une entit\u00e9, un tableau de cette entit\u00e9 ou une liste de cette entit\u00e9.

CWWKD1010.unknown.entity.attr=CWWKD1010E: L''attribut d''entit\u00e9 nomm\u00e9 \u00ab {0} \u00bb est introuvable dans la classe d''entit\u00e9 \u00ab {1} \u00bb pour la m\u00e9thode \u00ab {2} \u00bb de l''interface de r\u00e9f\u00e9rentiel \u00ab {3} \u00bb. Les noms d''attributs valides pour cette entit\u00e9 sont : {4}.
CWWKD1010.unknown.entity.attr.explanation=La m\u00e9thode du r\u00e9f\u00e9rentiel tente d'utiliser un attribut d'entit\u00e9 qui n'existe pas.
CWWKD1010.unknown.entity.attr.useraction=Mettez \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel afin qu'elle corresponde \u00e0 un attribut valide d\u00e9fini par l'entit\u00e9.

CWWKD1011.unknown.method.pattern=CWWKD1011E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` ne correspond \u00e0 aucun des mod\u00e8les d\u00e9finis par Jakarta Data. Une m\u00e9thode de r\u00e9f\u00e9rentiel doit soit utiliser des annotations, soit \u00eatre une m\u00e9thode d''acc\u00e8s aux ressources, soit \u00eatre nomm\u00e9e conform\u00e9ment au mod\u00e8le \u00ab Query by Method Name \u00bb. Des annotations telles que ` {2} ` sont utilis\u00e9es pour d\u00e9finir des op\u00e9rations. Une m\u00e9thode d''acc\u00e8s \u00e0 une ressource ne doit comporter aucun param\u00e8tre et doit renvoyer l''un des types de retour suivants : {3}. Le mod\u00e8le \u00ab Requ\u00eate par nom de m\u00e9thode \u00bb doit commencer par l''un des mots-cl\u00e9s {4}, suivi de z\u00e9ro ou plusieurs caract\u00e8res. Les noms de m\u00e9thodes peuvent \u00e9galement inclure le mot-cl\u00e9 \u00ab By \u00bb et une ou plusieurs conditions d\u00e9limit\u00e9es. Voici quelques exemples de noms\
    \ de m\u00e9thodes de r\u00e9f\u00e9rentiel valides : {5}.
CWWKD1011.unknown.method.pattern.explanation=Les m\u00e9thodes du r\u00e9f\u00e9rentiel doivent respecter les mod\u00e8les d\u00e9finis par Jakarta Data.
CWWKD1011.unknown.method.pattern.useraction=Mettez \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel afin qu'elle respecte l'un des mod\u00e8les de Jakarta Data.

CWWKD1012.fd.missing.param.anno=CWWKD1012E: Le param\u00e8tre \u00ab {0} \u00bb de la m\u00e9thode \u00ab {1} \u00bb de l''interface du r\u00e9f\u00e9rentiel \u00ab {2} \u00bb ne correspond \u00e0 aucun attribut d''entit\u00e9. Les param\u00e8tres qui ne correspondent pas \u00e0 un attribut d''entit\u00e9 doivent \u00eatre annot\u00e9s avec l''annotation \u00ab By \u00bb ou avoir l''un des types de param\u00e8tres sp\u00e9ciaux suivants : {3}. Pour d\u00e9finir une condition de filtrage des r\u00e9sultats de la requ\u00eate, le param\u00e8tre doit \u00eatre annot\u00e9 avec l''annotation \u00ab By \u00bb, et la valeur de cette annotation doit correspondre au nom de l''attribut de l''entit\u00e9. Vous pouvez \u00e9galement activer l''option de compilation -parameters et attribuer au param\u00e8tre le m\u00eame nom que l''attribut de l''entit\u00e9.
CWWKD1012.fd.missing.param.anno.explanation=Les param\u00e8tres des m\u00e9thodes de recherche et de suppression du r\u00e9f\u00e9rentiel doivent correspondre \u00e0 des attributs d'entit\u00e9 ou \u00eatre des types de param\u00e8tres sp\u00e9ciaux d\u00e9finis par Jakarta Data.
CWWKD1012.fd.missing.param.anno.useraction=Mettez \u00e0 jour la m\u00e9thode de gestion du r\u00e9f\u00e9rentiel de mani\u00e8re \u00e0 ce que tous les param\u00e8tres correspondent \u00e0 des attributs d'entit\u00e9 ou adoptent l'un des types de param\u00e8tres sp\u00e9ciaux de Jakarta Data.

CWWKD1013.cde.missing.param.anno=CWWKD1013E: Le param\u00e8tre \u00ab {0} \u00bb de la m\u00e9thode \u00ab {1} \u00bb de l''interface du r\u00e9f\u00e9rentiel \u00ab {2} \u00bb ne correspond \u00e0 aucun attribut d''entit\u00e9. Les param\u00e8tres qui ne correspondent pas \u00e0 un attribut d''entit\u00e9 doivent \u00eatre annot\u00e9s avec l''annotation \u00ab By \u00bb, et la valeur de cette annotation doit correspondre au nom de l''attribut d''entit\u00e9. Vous pouvez \u00e9galement activer l''option de compilation -parameters et attribuer au param\u00e8tre le m\u00eame nom que l''attribut de l''entit\u00e9.
CWWKD1013.cde.missing.param.anno.explanation=Les param\u00e8tres des m\u00e9thodes count, delete et exists du r\u00e9f\u00e9rentiel doivent correspondre aux attributs de l'entit\u00e9.
CWWKD1013.cde.missing.param.anno.useraction=Modifiez la m\u00e9thode de gestion du r\u00e9f\u00e9rentiel de mani\u00e8re \u00e0 ce que tous les param\u00e8tres correspondent aux attributs de l'entit\u00e9.

CWWKD1014.upd.missing.param.anno=CWWKD1014E: La m\u00e9thode \u00ab {0} \u00bb du r\u00e9f\u00e9rentiel \u00ab {1} \u00bb n''est pas une m\u00e9thode \u00ab Update \u00bb de cycle de vie valide, car elle comporte des param\u00e8tres de type \u00ab {2} \u00bb. Les m\u00e9thodes de r\u00e9f\u00e9rentiel annot\u00e9es d''une annotation de cycle de vie doivent avoir exactement un param\u00e8tre, qui doit \u00eatre l''entit\u00e9 elle-m\u00eame, un tableau de cette entit\u00e9 ou une liste de cette entit\u00e9. La m\u00e9thode ` {0} ` ne constitue pas non plus une op\u00e9ration de mise \u00e0 jour valide bas\u00e9e sur des param\u00e8tres, car le param\u00e8tre de m\u00e9thode ` {3} ` ne comporte pas d''annotation (de type {4} ) indiquant le nom de l''attribut de l''entit\u00e9. Vous pouvez \u00e9galement activer l''option de compilation -parameters et attribuer au param\u00e8tre le m\u00eame nom que l''attribut de l''entit\u00e9.
CWWKD1014.upd.missing.param.anno.explanation=Les param\u00e8tres des m\u00e9thodes de mise \u00e0 jour du r\u00e9f\u00e9rentiel doivent correspondre aux attributs de l'entit\u00e9. Sinon, les m\u00e9thodes de cycle de vie doivent avoir un seul param\u00e8tre d'entit\u00e9.
CWWKD1014.upd.missing.param.anno.useraction=Modifiez la m\u00e9thode de gestion du r\u00e9f\u00e9rentiel de mani\u00e8re \u00e0 ce que tous les param\u00e8tres correspondent aux attributs de l'entit\u00e9. Vous pouvez \u00e9galement modifier la m\u00e9thode du r\u00e9f\u00e9rentiel pour qu'elle accepte un seul param\u00e8tre, qui peut \u00eatre une entit\u00e9, un tableau de cette entit\u00e9 ou une liste de cette entit\u00e9.

CWWKD1015.null.entity.param=CWWKD1015E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` ne peut pas accepter d''entit\u00e9 nulle.
CWWKD1015.null.entity.param.explanation=Les m\u00e9thodes du cycle de vie n\u00e9cessitent une instance d'entit\u00e9 non nulle.
CWWKD1015.null.entity.param.useraction=Mettez \u00e0 jour le code de l'application afin d'\u00e9viter de transmettre une valeur d'entit\u00e9 nulle \u00e0 la m\u00e9thode du r\u00e9f\u00e9rentiel.

CWWKD1016.incompat.entity.param=CWWKD1016E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` n\u00e9cessite une entit\u00e9 de type ` {2} `, mais une valeur de type ` {3} ` a \u00e9t\u00e9 fournie.
CWWKD1016.incompat.entity.param.explanation=La m\u00e9thode \u00ab lifecycle \u00bb n'accepte que les valeurs d'entit\u00e9 du type d\u00e9clar\u00e9.
CWWKD1016.incompat.entity.param.useraction=Mettez \u00e0 jour le code de l'application afin de fournir une valeur d'entit\u00e9 du m\u00eame type que celui d\u00e9clar\u00e9 par la m\u00e9thode du r\u00e9f\u00e9rentiel.

CWWKD1017.dup.special.param=CWWKD1017E: La m\u00e9thode ` {0} ` du r\u00e9f\u00e9rentiel ` {1} ` ne peut pas accepter plusieurs param\u00e8tres ` {2} `.
CWWKD1017.dup.special.param.explanation=Certains param\u00e8tres sp\u00e9ciaux de Jakarta Data, notamment \u00ab Limit \u00bb et \u00ab PageRequest, \u00bb, ne peuvent pas appara\u00eetre plusieurs fois dans la signature d'une m\u00e9thode de r\u00e9f\u00e9rentiel.
CWWKD1017.dup.special.param.useraction=Mettez \u00e0 jour la signature de la m\u00e9thode du r\u00e9f\u00e9rentiel afin qu'elle ne contienne qu'une seule occurrence du type de param\u00e8tre sp\u00e9cial Jakarta Data.

CWWKD1018.confl.special.param=CWWKD1018E: La m\u00e9thode ` {0} ` du r\u00e9f\u00e9rentiel ` {1} ` ne peut pas avoir \u00e0 la fois un param\u00e8tre ` {2} ` et un param\u00e8tre ` {3} `.
CWWKD1018.confl.special.param.explanation=Certains param\u00e8tres sp\u00e9ciaux de Jakarta Data, tels que \u00ab Limit \u00bb et \u00ab PageRequest, \u00bb, ne peuvent pas \u00eatre combin\u00e9s au sein d'une m\u00eame signature de m\u00e9thode de r\u00e9f\u00e9rentiel.
CWWKD1018.confl.special.param.useraction=Mettez \u00e0 jour le r\u00e9f\u00e9rentiel afin de ne plus utiliser les deux types de param\u00e8tres sp\u00e9ciaux de Jakarta Data dans la m\u00eame signature de m\u00e9thode.

CWWKD1019.mixed.positional.named=CWWKD1019E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` ne peut pas contenir de requ\u00eate m\u00e9langeant des param\u00e8tres positionnels et des param\u00e8tres nomm\u00e9s. L''interface d\u00e9finit un m\u00e9lange de param\u00e8tres de position {2} et de param\u00e8tres nomm\u00e9s {3} {4} pour la valeur de l''annotation Query : {5}. Une requ\u00eate comportant des param\u00e8tres de position doit r\u00e9f\u00e9rencer chaque param\u00e8tre par sa valeur ordinale, en commen\u00e7ant par?1, et les param\u00e8tres de la m\u00e9thode ne doivent pas porter l''annotation Param. Dans une requ\u00eate avec des param\u00e8tres nomm\u00e9s, chaque param\u00e8tre doit \u00eatre r\u00e9f\u00e9renc\u00e9 par son nom, par exemple {6}, et les param\u00e8tres de la m\u00e9thode doivent porter l''annotation Param, par exemple {7}. Sinon, l''activation de l''option de compilation -parameters permet aux param\u00e8tres de m\u00e9thode d''identifier\
    \ le param\u00e8tre nomm\u00e9 en faisant correspondre son nom, par exemple : {8}.
CWWKD1019.mixed.positional.named.explanation=Les requ\u00eates avec param\u00e8tres doivent utiliser soit tous les param\u00e8tres nomm\u00e9s, soit tous les param\u00e8tres positionnels, mais pas une combinaison des deux.
CWWKD1019.mixed.positional.named.useraction=Modifiez la m\u00e9thode du r\u00e9f\u00e9rentiel afin qu'elle utilise uniquement des param\u00e8tres nomm\u00e9s ou uniquement des param\u00e8tres de position.

CWWKD1020.invalid.param.type=CWWKD1020E: Les param\u00e8tres de la m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` ne doivent pas \u00eatre de type ` {2} `, car cette m\u00e9thode du r\u00e9f\u00e9rentiel est une op\u00e9ration de type ` {3} `.
CWWKD1020.invalid.param.type.explanation=Ce type de param\u00e8tre n'est pas autoris\u00e9 pour ce type de m\u00e9thode.
CWWKD1020.invalid.param.type.useraction=Mettez \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel afin de d\u00e9finir un param\u00e8tre de m\u00e9thode pour chaque valeur requise par une comparaison.

CWWKD1021.insufficient.params=CWWKD1021E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` dispose de param\u00e8tres de type ` {2} `, mais les conditions de requ\u00eate d\u00e9finies par cette m\u00e9thode n\u00e9cessitent des param\u00e8tres de type ` {3} `. La requ\u00eate pour cette m\u00e9thode est la suivante : {4}.
CWWKD1021.insufficient.params.explanation=Les conditions de requ\u00eate qui d\u00e9finissent des comparaisons de valeurs n\u00e9cessitent un nombre correspondant de param\u00e8tres de m\u00e9thode du r\u00e9f\u00e9rentiel pour fournir ces valeurs.
CWWKD1021.insufficient.params.useraction=Mettez \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel afin de d\u00e9finir un param\u00e8tre de m\u00e9thode pour chaque valeur requise par une comparaison.

CWWKD1022.too.many.params=CWWKD1022E: Les conditions de requ\u00eate de la m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` n\u00e9cessitent des param\u00e8tres de type ` {2} `, mais la signature de la m\u00e9thode du r\u00e9f\u00e9rentiel comporte des param\u00e8tres de type ` {3} `. La requ\u00eate pour cette m\u00e9thode est la suivante : {4}.
CWWKD1022.too.many.params.explanation=Les conditions de requ\u00eate qui d\u00e9finissent des comparaisons de valeurs n\u00e9cessitent un nombre correspondant de param\u00e8tres de m\u00e9thode du r\u00e9f\u00e9rentiel pour fournir ces valeurs. Les param\u00e8tres suppl\u00e9mentaires ne sont pas autoris\u00e9s.
CWWKD1022.too.many.params.useraction=Mettez \u00e0 jour la signature de la m\u00e9thode du r\u00e9f\u00e9rentiel afin de supprimer les param\u00e8tres superflus qui ne correspondent pas aux conditions d\u00e9clar\u00e9es.

CWWKD1023.extra.param=CWWKD1023E: Les conditions de requ\u00eate de la m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` n\u00e9cessitent des param\u00e8tres de type ` {2} `, mais cette m\u00e9thode dispose d''un param\u00e8tre suppl\u00e9mentaire de type ` {3} `. La requ\u00eate pour cette m\u00e9thode est la suivante : {4}.
CWWKD1023.extra.param.explanation=Les conditions de requ\u00eate qui d\u00e9finissent des comparaisons de valeurs n\u00e9cessitent un nombre correspondant de param\u00e8tres de m\u00e9thode du r\u00e9f\u00e9rentiel pour fournir ces valeurs. Les param\u00e8tres suppl\u00e9mentaires ne sont pas autoris\u00e9s.
CWWKD1023.extra.param.useraction=Mettez \u00e0 jour la signature de la m\u00e9thode du r\u00e9f\u00e9rentiel afin de supprimer les param\u00e8tres superflus qui ne correspondent pas aux conditions d\u00e9clar\u00e9es.

CWWKD1024.missing.entity.attr=CWWKD1024E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` ne contient pas de nom d''attribut d''entit\u00e9 ou a re\u00e7u un param\u00e8tre d\u00e9pourvu de nom d''attribut d''entit\u00e9. Les noms d''attributs valides pour la classe d''entit\u00e9 \u00ab {2} \u00bb sont les suivants : {3}.
CWWKD1024.missing.entity.attr.explanation=Les conditions de requ\u00eate et les crit\u00e8res de tri d'une m\u00e9thode de r\u00e9f\u00e9rentiel doivent inclure le nom d'un attribut d'entit\u00e9.
CWWKD1024.missing.entity.attr.useraction=V\u00e9rifiez la d\u00e9claration et l'utilisation de la m\u00e9thode du r\u00e9f\u00e9rentiel afin de vous assurer qu'un nom d'attribut d'entit\u00e9 est fourni pour chaque condition de requ\u00eate et chaque crit\u00e8re de tri.

CWWKD1025.missing.id.attr=CWWKD1025E: La classe d''entit\u00e9 \u00ab {0} \u00bb, utilis\u00e9e par la m\u00e9thode \u00ab {1} \u00bb de l''interface de r\u00e9f\u00e9rentiel \u00ab {2} \u00bb, ne comporte pas d''attribut \u00ab ID \u00bb.
CWWKD1025.missing.id.attr.explanation=Les m\u00e9thodes du r\u00e9f\u00e9rentiel qui suppriment et renvoient une entit\u00e9 doivent comporter un attribut ID.
CWWKD1025.missing.id.attr.useraction=Si l'entit\u00e9 ne dispose pas d'un attribut unique pour l'identifiant, d\u00e9finissez des m\u00e9thodes de r\u00e9f\u00e9rentiel distinctes pour r\u00e9cup\u00e9rer l'entit\u00e9 et la supprimer.

CWWKD1026.ignore.case.not.text=CWWKD1026E: L''attribut \u00ab {0} \u00bb de l''entit\u00e9 \u00ab {1} \u00bb n''est ni un caract\u00e8re ni une s\u00e9quence de caract\u00e8res; par cons\u00e9quent, le crit\u00e8re de tri \u00ab {2} \u00bb ne doit pas sp\u00e9cifier l''ignorance de la casse. Le type de l''attribut est \u00ab {3} \u00bb, et il a \u00e9t\u00e9 transmis \u00e0 la m\u00e9thode \u00ab {4} \u00bb de l''interface de r\u00e9f\u00e9rentiel \u00ab {5} \u00bb.
CWWKD1026.ignore.case.not.text.explanation=Le tri sans distinction de casse n'est possible qu'avec les attributs d'entit\u00e9 qui contiennent du texte.
CWWKD1026.ignore.case.not.text.useraction=Assurez-vous que les crit\u00e8res de tri s'appliquent bien \u00e0 l'attribut d'entit\u00e9 concern\u00e9 et supprimez l'instruction demandant de ne pas tenir compte de la casse si l'attribut d'entit\u00e9 ne contient pas de texte.

CWWKD1027.datastore.lacks.java.comp=CWWKD1027E: Une ou plusieurs interfaces de r\u00e9f\u00e9rentiel ( {0} ) de l''artefact d''application {1} sp\u00e9cifient une valeur {2} dataStore qui ne correspond \u00e0 aucune r\u00e9f\u00e9rence de ressource de source de donn\u00e9es ni \u00e0 aucune r\u00e9f\u00e9rence d''unit\u00e9 de persistance, car elle ne comporte pas le pr\u00e9fixe d''espace de noms java:comp/env/. Envisagez de modifier l''annotation \u00ab Repository \u00bb pour indiquer \u00ab {3} \u00bb.
CWWKD1027.datastore.lacks.java.comp.explanation=Les noms JNDI des r\u00e9f\u00e9rences aux ressources de source de donn\u00e9es et aux unit\u00e9s de persistance doivent inclure le pr\u00e9fixe d'espace de noms \u00ab java: \u00bb.
CWWKD1027.datastore.lacks.java.comp.useraction=Assurez-vous que la valeur de stockage de donn\u00e9es de l'annotation Repository inclut le pr\u00e9fixe d'espace de noms java: lorsque cette valeur d\u00e9signe le nom JNDI d'une r\u00e9f\u00e9rence de ressource de source de donn\u00e9es ou d'une r\u00e9f\u00e9rence d'unit\u00e9 de persistance.

CWWKD1028.first.exceeds.max=CWWKD1028E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` demande les premiers r\u00e9sultats de ` {2} `, ce qui d\u00e9passe le nombre maximal de r\u00e9sultats autoris\u00e9 : {3}.
CWWKD1028.first.exceeds.max.explanation=Le nombre maximal de r\u00e9sultats de la requ\u00eate est limit\u00e9 par les contraintes du syst\u00e8me et par la valeur indiqu\u00e9e.
CWWKD1028.first.exceeds.max.useraction=R\u00e9duisez le nombre maximal de r\u00e9sultats de requ\u00eate demand\u00e9 \u00e0 une valeur inf\u00e9rieure.

CWWKD1029.first.neg.or.zero=CWWKD1029E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` r\u00e9cup\u00e8re les premiers r\u00e9sultats de ` {2} `. Le nombre maximal de r\u00e9sultats \u00e0 renvoyer doit \u00eatre un nombre positif.
CWWKD1029.first.neg.or.zero.explanation=Le nombre maximal de r\u00e9sultats de la requ\u00eate doit \u00eatre un nombre positif.
CWWKD1029.first.neg.or.zero.useraction=Modifiez la m\u00e9thode du r\u00e9f\u00e9rentiel afin de d\u00e9finir un nombre maximal de r\u00e9sultats.

CWWKD1030.ql.lacks.entity=CWWKD1030E: Le nom de l''entit\u00e9 est absent de la requ\u00eate \u00ab {0} \u00bb sp\u00e9cifi\u00e9e pour la m\u00e9thode \u00ab {1} \u00bb du r\u00e9f\u00e9rentiel \u00ab {2} \u00bb. Pour toute question relative \u00e0 l'' {3}, veuillez utiliser le formulaire suivant : {4}.
CWWKD1030.ql.lacks.entity.explanation=La requ\u00eate contient une clause qui exige le nom de l'entit\u00e9.
CWWKD1030.ql.lacks.entity.useraction=Modifiez la requ\u00eate de la m\u00e9thode de r\u00e9f\u00e9rentiel afin d'y inclure le nom de l'entit\u00e9.

CWWKD1031.ql.similar.entity=CWWKD1031E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` sp\u00e9cifie une requ\u00eate qui n\u00e9cessite un nom d''entit\u00e9 ` {2} ` introuvable, mais qui correspond \u00e9troitement au nom d''entit\u00e9 ` {3} `. La requ\u00eate est la suivante : {4}.
CWWKD1031.ql.similar.entity.explanation=La requ\u00eate contient peut-\u00eatre une faute de frappe dans la r\u00e9f\u00e9rence au nom de l'entit\u00e9.
CWWKD1031.ql.similar.entity.useraction=V\u00e9rifiez la requ\u00eate pour vous assurer que le nom de l'entit\u00e9 utilis\u00e9 est correct.

CWWKD1032.ql.unknown.entity=CWWKD1032E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` sp\u00e9cifie une requ\u00eate qui n\u00e9cessite un nom d''entit\u00e9 ` {2} ` introuvable. Assurez-vous que \u00ab {2} \u00bb est le nom d''une entit\u00e9 valide. Pour permettre la recherche de l''entit\u00e9, attribuez au r\u00e9f\u00e9rentiel une m\u00e9thode de cycle de vie annot\u00e9e avec l''une des annotations {3} et passez l''entit\u00e9 en param\u00e8tre. Vous pouvez \u00e9galement faire en sorte que le r\u00e9f\u00e9rentiel \u00e9tende l''interface ` DataRepository ` ou une autre interface de r\u00e9f\u00e9rentiel int\u00e9gr\u00e9e, en d\u00e9finissant la classe d''entit\u00e9 comme premi\u00e8re variable de type. La requ\u00eate est la suivante : {4}.
CWWKD1032.ql.unknown.entity.explanation=Il se peut que la requ\u00eate contienne une faute de frappe dans la r\u00e9f\u00e9rence au nom de l'entit\u00e9, ou que le r\u00e9f\u00e9rentiel ne pr\u00e9cise pas sa classe d'entit\u00e9 principale.
CWWKD1032.ql.unknown.entity.useraction=V\u00e9rifiez la requ\u00eate pour vous assurer que le nom de l'entit\u00e9 utilis\u00e9 est correct. V\u00e9rifiez la d\u00e9finition du r\u00e9f\u00e9rentiel pour vous assurer que la classe d'entit\u00e9 principale correcte est bien sp\u00e9cifi\u00e9e.

CWWKD1033.ql.orderby.disallowed=CWWKD1033E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` ne peut pas sp\u00e9cifier une requ\u00eate comprenant une clause `ORDER BY`, car cette m\u00e9thode renvoie des objets de type ` {2} `. Supprimez la clause ORDER BY et utilisez plut\u00f4t l''annotation ` {3} ` pour d\u00e9finir des crit\u00e8res de tri statiques. La requ\u00eate est la suivante : {4}.
CWWKD1033.ql.orderby.disallowed.explanation=La clause ORDER BY n'est pas compatible avec la pagination bas\u00e9e sur un curseur.
CWWKD1033.ql.orderby.disallowed.useraction=Remplacez la clause ORDER BY par des annotations qui pr\u00e9cisent les crit\u00e8res de tri.

CWWKD1034.ql.req.end.in.where=CWWKD1034E: La requ\u00eate sp\u00e9cifi\u00e9e par la m\u00e9thode ` {0} ` de l''interface de r\u00e9f\u00e9rentiel ` {1} ` doit se terminer par une clause `WHERE`, car cette m\u00e9thode renvoie des objets de type ` {2} `. La clause WHERE se termine \u00e0 la position {3}, mais la longueur de la requ\u00eate est de {4}. La requ\u00eate est la suivante : {5}.
CWWKD1034.ql.req.end.in.where.explanation=Une clause WHERE est obligatoire lors de l'utilisation de la pagination par curseur.
CWWKD1034.ql.req.end.in.where.useraction=Ajoutez une clause WHERE \u00e0 la requ\u00eate.

CWWKD1035.incompat.page.mode=CWWKD1035E: Une requ\u00eate de page utilisant le mode de pagination {0} ne doit pas \u00eatre transmise \u00e0 la m\u00e9thode {1} de l''interface de r\u00e9f\u00e9rentiel {2}, car cette m\u00e9thode renvoie {3} au lieu de {4}.
CWWKD1035.incompat.page.mode.explanation=Le mode de pagination demand\u00e9 n'est pas compatible avec le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel.
CWWKD1035.incompat.page.mode.useraction=Utilisez le type de retour \u00ab Page \u00bb pour le mode de pagination OFFSET et le type de retour \u00ab CursoredPage \u00bb pour les modes de pagination CURSOR_NEXT et CURSOR_PREVIOUS.

CWWKD1036.cursor.size.mismatch=CWWKD1036E: Un curseur comportant des \u00e9l\u00e9ments de type \u00ab {0} \u00bb transmis \u00e0 la m\u00e9thode \u00ab {1} \u00bb de l''interface de r\u00e9f\u00e9rentiel \u00ab {2} \u00bb ne peut pas \u00eatre utilis\u00e9 avec des crit\u00e8res de tri de type \u00ab size \u00bb {3}, car le nombre et l''ordre des \u00e9l\u00e9ments du curseur doivent correspondre aux crit\u00e8res de tri. Le curseur se compose de : {4}. Le crit\u00e8re de tri est : {5}.
CWWKD1036.cursor.size.mismatch.explanation=Le nombre d'\u00e9l\u00e9ments du curseur doit correspondre \u00e0 la taille des crit\u00e8res de tri combin\u00e9s de la m\u00e9thode du r\u00e9f\u00e9rentiel.
CWWKD1036.cursor.size.mismatch.useraction=Modifiez les \u00e9l\u00e9ments du curseur ou les crit\u00e8res de tri de mani\u00e8re \u00e0 ce qu'ils aient tous deux la m\u00eame taille.

CWWKD1037.cursor.rtrn.mismatch=CWWKD1037E: Impossible d''obtenir un curseur \u00e0 partir du r\u00e9sultat {0} de la m\u00e9thode {1} de l''interface de d\u00e9p\u00f4t {2}. Les requ\u00eates utilisant une pagination par curseur doivent renvoyer des r\u00e9sultats du m\u00eame type que celui de l''entit\u00e9, \u00e0 savoir \u00ab {3} \u00bb. Le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel est ` {4} `.
CWWKD1037.cursor.rtrn.mismatch.explanation=La pagination par curseur n'est possible que lorsque la m\u00e9thode du r\u00e9f\u00e9rentiel renvoie le type d'entit\u00e9.
CWWKD1037.cursor.rtrn.mismatch.useraction=Modifiez la m\u00e9thode du r\u00e9f\u00e9rentiel afin qu'elle renvoie le type d'entit\u00e9.

CWWKD1038.no.prev.offset.page=CWWKD1038E: Il n''est pas possible de demander un num\u00e9ro de page ant\u00e9rieur \u00e0 {0} pour la m\u00e9thode {1} de l''interface du r\u00e9f\u00e9rentiel {2}, car la m\u00e9thode Page.hasPrevious renvoie la valeur \u00ab false \u00bb, indiquant qu''il n''y a pas de page pr\u00e9c\u00e9dente.
CWWKD1038.no.prev.offset.page.explanation=La pagination d\u00e9cal\u00e9e ne permet pas d'utiliser des num\u00e9ros de page inf\u00e9rieurs \u00e0 1.
CWWKD1038.no.prev.offset.page.useraction=Assurez-vous que le num\u00e9ro de page demand\u00e9 est un nombre positif et utilisez la m\u00e9thode ` Page.hasPrevious ` pour v\u00e9rifier qu'il est valide afin de demander la page pr\u00e9c\u00e9dente.

CWWKD1039.no.prev.cursor.page=CWWKD1039E: Il n''est pas possible de demander la page pr\u00e9c\u00e9dente via la m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} `, car la m\u00e9thode ` Page.hasPrevious ` renvoie la valeur `false`, ce qui indique qu''il n''y a pas de page pr\u00e9c\u00e9dente.
CWWKD1039.no.prev.cursor.page.explanation=La pagination par curseur ne permet pas de demander la page pr\u00e9c\u00e9dente lorsqu'on sait que la page actuelle contient les r\u00e9sultats situ\u00e9s au d\u00e9but de l'ensemble de donn\u00e9es.
CWWKD1039.no.prev.cursor.page.useraction=Utilisez la m\u00e9thode ` Page.hasPrevious ` pour v\u00e9rifier qu'il est possible de demander la page pr\u00e9c\u00e9dente.

CWWKD1040.no.next.page=CWWKD1040E: Il n''est pas possible de demander la page suivante pour la m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} `, car ` {2} ` renvoie la valeur `false`, ce qui indique qu''il n''y a pas de page suivante.
CWWKD1040.no.next.page.explanation=Il n'est pas possible de demander la page suivante lorsqu'on sait que la page actuelle contient la fin de l'ensemble de donn\u00e9es.
CWWKD1040.no.next.page.useraction=Utilisez la m\u00e9thode ` hasNext ` pour v\u00e9rifier s'il est possible de demander la page suivante.

CWWKD1041.rtrn.mismatch.pagereq=CWWKD1041E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` a un type de retour ` {2} `, mais il lui manque un param\u00e8tre de type ` PageRequest ` apr\u00e8s les param\u00e8tres d\u00e9finissant les conditions de requ\u00eate.
CWWKD1041.rtrn.mismatch.pagereq.explanation=Les m\u00e9thodes de r\u00e9f\u00e9rentiel dont le type de retour est \u00ab Page \u00bb ou \u00ab CursoredPage \u00bb doivent comporter un param\u00e8tre \u00ab PageRequest \u00bb.
CWWKD1041.rtrn.mismatch.pagereq.useraction=Ajoutez un param\u00e8tre \u00ab PageRequest \u00bb \u00e0 la signature de la m\u00e9thode du r\u00e9f\u00e9rentiel.

CWWKD1042.no.totals=CWWKD1042E: Les pages r\u00e9cup\u00e9r\u00e9es via la m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` ne contiennent pas le nombre total d''\u00e9l\u00e9ments et de pages, car la requ\u00eate de la page ` {2} ` attribue la valeur `false` au param\u00e8tre ` requestTotal `. Pour demander une page incluant le nombre total d''\u00e9l\u00e9ments, utilisez la m\u00e9thode ` PageRequest.withTotal ` \u00e0 la place de la m\u00e9thode ` PageRequest.withoutTotal `.
CWWKD1042.no.totals.explanation=La m\u00e9thode \u00ab PageRequest.withoutTotal \u00bb pr\u00e9cise que les pages demand\u00e9es ne contiennent pas le nombre total d'\u00e9l\u00e9ments et de pages.
CWWKD1042.no.totals.useraction=Utilisez la m\u00e9thode ` PageRequest.withTotal ` pour obtenir le nombre total d'\u00e9l\u00e9ments et de pages.

CWWKD1043.offset.exceeds.max=CWWKD1043E: Le d\u00e9calage de l'' {0}, n\u00e9cessaire pour la requ\u00eate de la page {1} transmise \u00e0 la m\u00e9thode {2} de l''interface de r\u00e9f\u00e9rentiel {3}, d\u00e9passe la valeur maximale autoris\u00e9e de {4}.
CWWKD1043.offset.exceeds.max.explanation=La combinaison du nombre de pages et de la taille maximale des pages est trop importante.
CWWKD1043.offset.exceeds.max.useraction=Ajoutez des crit\u00e8res de filtrage \u00e0 la requ\u00eate afin de r\u00e9duire le nombre de r\u00e9sultats correspondants.

CWWKD1044.invalid.resource.type=CWWKD1044E: La m\u00e9thode d''acc\u00e8s aux ressources ` {0} ` du r\u00e9f\u00e9rentiel ` {1} ` ne peut pas renvoyer une ressource de type ` {2} `. Les types de retour pris en charge pour les m\u00e9thodes d''acc\u00e8s aux ressources sont les suivants : {3}.
CWWKD1044.invalid.resource.type.explanation=Le type de retour de la m\u00e9thode d'acc\u00e8s \u00e0 la ressource ne fait pas partie des types pris en charge par Jakarta Data.
CWWKD1044.invalid.resource.type.useraction=Supprimez la m\u00e9thode ou modifiez-la pour qu'elle renvoie l'un des types pris en charge.

CWWKD1045.unknown.entity.anno=CWWKD1045E: Le fournisseur de donn\u00e9es Jakarta int\u00e9gr\u00e9 ne peut pas fournir d''impl\u00e9mentation de l''interface de r\u00e9f\u00e9rentiel {0}, car la classe d''entit\u00e9 {1} utilis\u00e9e par le r\u00e9f\u00e9rentiel contient une annotation d''entit\u00e9 non reconnue. Les annotations d''entit\u00e9 suivantes se trouvent dans la classe d''entit\u00e9 : {2}. Les annotations d''entit\u00e9s prises en charge sont les suivantes : {3}.
CWWKD1045.unknown.entity.anno.explanation=Le fournisseur de donn\u00e9es Jakarta int\u00e9gr\u00e9 ne prend pas en charge l'une des annotations d'entit\u00e9.
CWWKD1045.unknown.entity.anno.useraction=Supprimez l'annotation d'entit\u00e9 non reconnue ou utilisez l'attribut \u00ab provider \u00bb de l'annotation \u00ab Repository \u00bb pour s\u00e9lectionner un fournisseur de donn\u00e9es Jakarta qui reconna\u00eet cette annotation d'entit\u00e9.

CWWKD1046.result.convert.err=CWWKD1046E: Le r\u00e9sultat de type \u00ab {0} \u00bb de la m\u00e9thode \u00ab {1} \u00bb de l''interface du r\u00e9f\u00e9rentiel \u00ab {2} \u00bb ne peut pas \u00eatre converti en type de retour \u00ab {3} \u00bb de la m\u00e9thode du r\u00e9f\u00e9rentiel.
CWWKD1046.result.convert.err.explanation=La valeur du r\u00e9sultat n'est pas compatible avec le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel.
CWWKD1046.result.convert.err.useraction=Assurez-vous que le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel correspond au type du r\u00e9sultat renvoy\u00e9 par la requ\u00eate.

CWWKD1047.result.out.of.range=CWWKD1047E: Le r\u00e9sultat de type \u00ab {0} \u00bb de la m\u00e9thode \u00ab {1} \u00bb de l''interface du r\u00e9f\u00e9rentiel \u00ab {2} \u00bb ne peut pas \u00eatre converti en type de retour \u00ab {3} \u00bb de la m\u00e9thode du r\u00e9f\u00e9rentiel, car ce r\u00e9sultat ne se situe pas dans l''intervalle compris entre \u00ab {4} \u00bb et \u00ab {5} \u00bb.
CWWKD1047.result.out.of.range.explanation=La valeur du r\u00e9sultat n'est pas compatible avec le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel, car elle se situe en dehors de la plage des valeurs pouvant \u00eatre converties.
CWWKD1047.result.out.of.range.useraction=Modifiez le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel afin de permettre le renvoi de la valeur.

CWWKD1048.result.exceeds.max=CWWKD1048E: Le r\u00e9sultat de type \u00ab {0} \u00bb de la m\u00e9thode \u00ab {1} \u00bb de l''interface du r\u00e9f\u00e9rentiel \u00ab {2} \u00bb ne peut pas \u00eatre converti en type de retour \u00ab {3} \u00bb de la m\u00e9thode du r\u00e9f\u00e9rentiel, car la valeur du r\u00e9sultat d\u00e9passe la valeur maximale de \u00ab {4} \u00bb.
CWWKD1048.result.exceeds.max.explanation=La valeur du r\u00e9sultat n'est pas compatible avec le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel, car elle d\u00e9passe la valeur maximale pouvant \u00eatre convertie en ce type.
CWWKD1048.result.exceeds.max.useraction=Modifiez le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel afin de permettre le renvoi de la valeur.

CWWKD1049.count.convert.err=CWWKD1049E: La valeur du compteur, de type \u00ab {0} \u00bb, issue de la m\u00e9thode \u00ab {1} \u00bb de l''interface de r\u00e9f\u00e9rentiel \u00ab {2} \u00bb, ne peut pas \u00eatre convertie en type de retour \u00ab {3} \u00bb de la m\u00e9thode du r\u00e9f\u00e9rentiel.
CWWKD1049.count.convert.err.explanation=La valeur du compteur n'est pas compatible avec le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel.
CWWKD1049.count.convert.err.useraction=Modifiez le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel afin de permettre le renvoi de la valeur.

CWWKD1050.opt.lock.exc=CWWKD1050E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` n''a pas trouv\u00e9 d''entit\u00e9 ` {2} ` correspondant aux attributs de l''entit\u00e9 : ` {3} `. V\u00e9rifiez que l''instance d''entit\u00e9 transmise \u00e0 la m\u00e9thode ` {0} ` repose sur la version la plus r\u00e9cente de l''entit\u00e9. La version la plus r\u00e9cente de l''entit\u00e9 peut \u00eatre obtenue via une m\u00e9thode `find` ou \u00e0 partir de la valeur de retour de l''une des m\u00e9thodes de cycle de vie suivantes : ` {4} `.
CWWKD1050.opt.lock.exc.explanation=Aucun r\u00e9sultat correspondant n'a \u00e9t\u00e9 trouv\u00e9.
CWWKD1050.opt.lock.exc.useraction=Si l'on s'attend \u00e0 ce que l'entit\u00e9 ne figure pas dans la base de donn\u00e9es, aucune action n'est requise. Sinon, assurez-vous d'utiliser la version la plus r\u00e9cente de l'entit\u00e9.

CWWKD1051.single.opt.lock.exc=CWWKD1051E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` n''a pas trouv\u00e9 d''entit\u00e9 ` {2} ` correspondante dans la base de donn\u00e9es. V\u00e9rifiez que l''instance d''entit\u00e9 transmise \u00e0 la m\u00e9thode ` {0} ` repose sur la version la plus r\u00e9cente de l''entit\u00e9. La version la plus r\u00e9cente de l''entit\u00e9 peut \u00eatre obtenue via une m\u00e9thode `find` ou \u00e0 partir de la valeur de retour de l''une des m\u00e9thodes de cycle de vie suivantes : ` {3} `.
CWWKD1051.single.opt.lock.exc.explanation=Aucun r\u00e9sultat correspondant n'a \u00e9t\u00e9 trouv\u00e9.
CWWKD1051.single.opt.lock.exc.useraction=Si l'on s'attend \u00e0 ce que l'entit\u00e9 ne figure pas dans la base de donn\u00e9es, aucune action n'est requise. Sinon, assurez-vous d'utiliser la version la plus r\u00e9cente de l'entit\u00e9.

CWWKD1052.multi.opt.lock.exc=CWWKD1052E: La m\u00e9thode {0} de l''interface de d\u00e9p\u00f4t {1} n''a pas trouv\u00e9 {2} des entit\u00e9s {3} {4} dans la base de donn\u00e9es. V\u00e9rifiez que les instances d''entit\u00e9 transmises \u00e0 la m\u00e9thode ` {0} ` sont bas\u00e9es sur la version la plus r\u00e9cente de chaque entit\u00e9. La version la plus r\u00e9cente d''une entit\u00e9 peut \u00eatre obtenue via une m\u00e9thode de recherche ou \u00e0 partir de la valeur de r\u00e9sultat de l''une des m\u00e9thodes de cycle de vie suivantes : {5}.
CWWKD1052.multi.opt.lock.exc.explanation=Une ou plusieurs entit\u00e9s n'ont pas \u00e9t\u00e9 trouv\u00e9es dans la base de donn\u00e9es.
CWWKD1052.multi.opt.lock.exc.useraction=Si l'on s'attend \u00e0 ce qu'une entit\u00e9 ne figure pas dans la base de donn\u00e9es, aucune action n'est requise. Sinon, assurez-vous d'utiliser la version la plus r\u00e9cente de chaque entit\u00e9.

CWWKD1053.empty.result=CWWKD1053E: Le type de retour \u00ab {0} \u00bb de la m\u00e9thode \u00ab {1} \u00bb de l''interface de r\u00e9f\u00e9rentiel \u00ab {2} \u00bb ne permet pas de renvoyer un r\u00e9sultat vide. Si l''on s''attend \u00e0 un r\u00e9sultat vide, la m\u00e9thode du r\u00e9f\u00e9rentiel doit renvoyer un tableau ou l''un des types de retour suivants : {3}.
CWWKD1053.empty.result.explanation=Le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel ne lui permet pas de renvoyer un r\u00e9sultat vide.
CWWKD1053.empty.result.useraction=Modifiez la m\u00e9thode du r\u00e9f\u00e9rentiel afin qu'elle utilise l'un des types de retour pouvant repr\u00e9senter un r\u00e9sultat vide.

CWWKD1054.non.unique.result=CWWKD1054E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` a pour type de retour ` {2} `, qui ne permet pas de renvoyer des r\u00e9sultats de type ` {3} `. Pour limiter la recherche \u00e0 un seul r\u00e9sultat, utilisez l''un des mod\u00e8les de donn\u00e9es Jakarta suivants : {4}.
CWWKD1054.non.unique.result.explanation=Le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel ne permet pas de renvoyer plusieurs r\u00e9sultats.
CWWKD1054.non.unique.result.useraction=Modifiez la m\u00e9thode du r\u00e9f\u00e9rentiel de mani\u00e8re \u00e0 ce qu'elle utilise un type de retour prenant en charge plusieurs r\u00e9sultats, ou modifiez-la de mani\u00e8re \u00e0 ce qu'elle ne renvoie qu'un seul r\u00e9sultat.

CWWKD1055.unsupported.entity.attr=CWWKD1055E: L''attribut \u00ab {0} \u00bb de l''entit\u00e9 \u00ab {1} \u00bb a un type non pris en charge : \u00ab {2} \u00bb. Jakarta Data prend en charge les types d''\u00e9num\u00e9ration Java, les types temporels de l'' {3}, ainsi que les types de base suivants : {4}. Le fournisseur de donn\u00e9es Jakarta int\u00e9gr\u00e9 prend \u00e9galement en charge certains types de Jakarta Persistence, tels que les objets int\u00e9grables. Sinon, si vous utilisez une entit\u00e9 Jakarta Persistence, vous pouvez ajouter l''annotation ` {5} ` \u00e0 l''attribut ` {0} ` afin de fournir une impl\u00e9mentation de ` AttributeConverter ` qui convertit un type non pris en charge en un type pris en charge.
CWWKD1055.unsupported.entity.attr.explanation=Jakarta Data ne prend pas en charge le type utilis\u00e9 par l'attribut \u00ab entity \u00bb.
CWWKD1055.unsupported.entity.attr.useraction=Mettez \u00e0 jour l'attribut de l'entit\u00e9 afin d'utiliser l'un des types pris en charge.

CWWKD1056.unsupported.keyword=CWWKD1056E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` porte un nom qui contient le mot-cl\u00e9 ` {2} `, lequel n''est pas un mot-cl\u00e9 pris en charge par le mod\u00e8le \u00ab Jakarta Data Query by Method Name \u00bb.
CWWKD1056.unsupported.keyword.explanation=Le nom de la m\u00e9thode contient un mot-cl\u00e9 qui n'est pas reconnu comme faisant partie du mod\u00e8le \u00ab Jakarta Data Query by Method Name \u00bb pris en charge.
CWWKD1056.unsupported.keyword.useraction=Renommez la m\u00e9thode \u00ab repository \u00bb afin de supprimer le mot-cl\u00e9 non pris en charge.

CWWKD1057.no.args.constr.inacc=CWWKD1057E: Le type de retour \u00ab {0} \u00bb de la m\u00e9thode \u00ab {1} \u00bb de l''interface de r\u00e9f\u00e9rentiel \u00ab {2} \u00bb n''est pas valide pour une m\u00e9thode de r\u00e9f\u00e9rentiel, car la classe \u00ab {3} \u00bb ne dispose pas d''un constructeur public sans param\u00e8tres.
CWWKD1057.no.args.constr.inacc.explanation=Un constructeur public sans param\u00e8tres est n\u00e9cessaire pour convertir le r\u00e9sultat en la classe sp\u00e9cifi\u00e9e.
CWWKD1057.no.args.constr.inacc.useraction=Modifiez la m\u00e9thode du r\u00e9f\u00e9rentiel afin qu'elle ait un type de retour pris en charge par Jakarta Data ou qu'elle soit une sous-classe de `Iterable` dot\u00e9e d'un constructeur public sans param\u00e8tres.

CWWKD1058.no.args.constr.err=CWWKD1058E: Le type de retour \u00ab {0} \u00bb de la m\u00e9thode \u00ab {1} \u00bb de l''interface de r\u00e9f\u00e9rentiel \u00ab {2} \u00bb n''est pas valide pour une m\u00e9thode de r\u00e9f\u00e9rentiel, car le constructeur de la classe \u00ab {3} \u00bb a g\u00e9n\u00e9r\u00e9 une erreur : \u00ab {4} \u00bb.
CWWKD1058.no.args.constr.err.explanation=Le constructeur public sans param\u00e8tres a \u00e9chou\u00e9 en raison d'une erreur.
CWWKD1058.no.args.constr.err.useraction=Corrigez l'erreur dans le constructeur ou modifiez la m\u00e9thode du r\u00e9f\u00e9rentiel pour qu'elle utilise un autre type de retour.

CWWKD1059.attr.cast.err=CWWKD1059E: La m\u00e9thode ` {0} ` de l''interface de r\u00e9f\u00e9rentiel ` {1} ` ne peut pas acc\u00e9der \u00e0 l''attribut ` {2} ` de l''entit\u00e9 ` {3} `, car le champ ou la m\u00e9thode ` {4} ` de la classe ` {5} ` n''est pas compatible avec une valeur de type ` {6} `.
CWWKD1059.attr.cast.err.explanation=Un attribut d'entit\u00e9 ou un attribut associ\u00e9 issu de sa hi\u00e9rarchie n'est pas compatible avec le type attendu.
CWWKD1059.attr.cast.err.useraction=Passez en revue le mod\u00e8le d'entit\u00e9 et v\u00e9rifiez que les types appropri\u00e9s sont utilis\u00e9s pour chaque attribut.

CWWKD1060.name.out.of.scope=CWWKD1060E: L''interface de r\u00e9f\u00e9rentiel \u00ab {0} \u00bb de l''application \u00ab {1} \u00bb configure une valeur \u00ab {2} \u00bb pour l''attribut \u00ab {3} \u00bb, mais les noms de \u00ab {3} \u00bb ne sont pas accessibles \u00e0 l''artefact qui fournit l''interface de r\u00e9f\u00e9rentiel. Utilisez plut\u00f4t un nom de type \u00ab {4} \u00bb.
CWWKD1060.name.out.of.scope.explanation=L'espace de noms indiqu\u00e9 n'est pas accessible depuis l'artefact dans lequel l'interface du r\u00e9f\u00e9rentiel est d\u00e9finie.
CWWKD1060.name.out.of.scope.useraction=Mettez \u00e0 jour l'annotation \u00ab Repository \u00bb afin de sp\u00e9cifier un nom de magasin de donn\u00e9es visible par le module ou la biblioth\u00e8que fournissant l'interface du r\u00e9f\u00e9rentiel.

CWWKD1061.comp.name.in.ejb=CWWKD1061E: Une ou plusieurs interfaces de r\u00e9f\u00e9rentiel ( {0} ) d\u00e9finies dans le module d''entreprise \u00ab {1} \u00bb de l''application \u00ab {2} \u00bb configurent une valeur \u00ab {3} \u00bb pour l''attribut \u00ab {4} \u00bb. Cependant, les noms de type \u00ab {5} \u00bb ne sont pas accessibles aux modules de beans d''entreprise. Utilisez un nom issu de l''un des espaces de noms suivants : {6}.
CWWKD1061.comp.name.in.ejb.explanation=L'espace de noms sp\u00e9cifi\u00e9 n'est pas accessible au module de beans d'entreprise dans lequel l'interface du r\u00e9f\u00e9rentiel est d\u00e9finie.
CWWKD1061.comp.name.in.ejb.useraction=Mettez \u00e0 jour l'annotation Repository afin de sp\u00e9cifier un nom de magasin de donn\u00e9es visible par le module Enterprise Bean qui fournit l'interface du r\u00e9f\u00e9rentiel.

CWWKD1062.resource.not.found=CWWKD1062E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` ne parvient pas \u00e0 localiser la ressource ` {2} ` avec le filtre ` {3} `.
CWWKD1062.resource.not.found.explanation=La ressource est introuvable.
CWWKD1062.resource.not.found.useraction=Assurez-vous que la ressource sp\u00e9cifi\u00e9e et toutes les autres ressources dont elle d\u00e9pend existent et sont correctement configur\u00e9es.

CWWKD1063.unsupported.resource=CWWKD1063E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` ne peut pas r\u00e9cup\u00e9rer une ressource de type ` {2} `, car le fournisseur Jakarta Persistence ne prend pas en charge l''op\u00e9ration de d\u00e9ballage renvoyant une instance de type ` {3} `.
CWWKD1063.unsupported.resource.explanation=Le fournisseur Jakarta Persistence ne prend pas en charge l'op\u00e9ration \u00ab unwrap \u00bb renvoyant le type de ressource sp\u00e9cifi\u00e9.
CWWKD1063.unsupported.resource.useraction=Supprimez la m\u00e9thode d'acc\u00e8s aux ressources non prise en charge de l'interface du r\u00e9f\u00e9rentiel.

CWWKD1064.datastore.error=CWWKD1064E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` ne parvient pas \u00e0 acc\u00e9der au magasin de donn\u00e9es ` {2} ` du r\u00e9f\u00e9rentiel en raison de l''erreur suivante : ` {3} `.
CWWKD1064.datastore.error.explanation=Une erreur s'est produite lors de la tentative d'acc\u00e8s au magasin de donn\u00e9es.
CWWKD1064.datastore.error.useraction=Assurez-vous que le magasin de donn\u00e9es sp\u00e9cifi\u00e9 et toutes les autres ressources dont il d\u00e9pend existent et sont correctement configur\u00e9s.

CWWKD1065.ddlgen.timeout=CWWKD1065E: La g\u00e9n\u00e9ration de DDL pour une ou plusieurs interfaces de r\u00e9f\u00e9rentiel ( {0} ) a \u00e9chou\u00e9 car le magasin de donn\u00e9es {1} n''a pas termin\u00e9 la g\u00e9n\u00e9ration de DDL dans un d\u00e9lai de {2} secondes pour les entit\u00e9s suivantes : {3}.
CWWKD1065.ddlgen.timeout.explanation=La tentative de g\u00e9n\u00e9ration de la DDL a expir\u00e9 et n'a pas abouti.
CWWKD1065.ddlgen.timeout.useraction=R\u00e9essayez de g\u00e9n\u00e9rer les instructions DDL lorsque le syst\u00e8me et la base de donn\u00e9es ne sont pas sous charge.

CWWKD1066.ddlgen.failed=CWWKD1066E: La g\u00e9n\u00e9ration de DDL pour une ou plusieurs interfaces de r\u00e9f\u00e9rentiel ( {0} ) utilisant le magasin de donn\u00e9es {1} a rencontr\u00e9 une erreur lors de la g\u00e9n\u00e9ration de DDL pour les entit\u00e9s suivantes : {2}. L''erreur est la suivante : {3}.
CWWKD1066.ddlgen.failed.explanation=La tentative de g\u00e9n\u00e9ration de DDL a \u00e9chou\u00e9 et n'a pas abouti.
CWWKD1066.ddlgen.failed.useraction=Examinez l'erreur et apportez les corrections n\u00e9cessaires \u00e0 l'interface du r\u00e9f\u00e9rentiel, aux entit\u00e9s, \u00e0 la configuration du magasin de donn\u00e9es ou \u00e0 la base de donn\u00e9es.

CWWKD1067.ddlgen.emf.timeout=CWWKD1067E: La g\u00e9n\u00e9ration de DDL pour une ou plusieurs interfaces de r\u00e9f\u00e9rentiel ( {0} ) a \u00e9chou\u00e9 car le magasin de donn\u00e9es {1} n''\u00e9tait pas disponible ou n''a pas pu rendre les entit\u00e9s suivantes disponibles dans un d\u00e9lai de {2} secondes : {3}.
CWWKD1067.ddlgen.emf.timeout.explanation=L'acquisition des ressources n\u00e9cessaires \u00e0 la g\u00e9n\u00e9ration du DDL a expir\u00e9 et n'a pas abouti.
CWWKD1067.ddlgen.emf.timeout.useraction=R\u00e9essayez de g\u00e9n\u00e9rer les instructions DDL lorsque le syst\u00e8me et la base de donn\u00e9es ne sont pas sous charge.

CWWKD1068.entity.name.conflict=CWWKD1068E: L''interface du r\u00e9f\u00e9rentiel \u00ab {0} \u00bb comporte plusieurs entit\u00e9s nomm\u00e9es \u00ab {1} \u00bb, qui sont fournies par diff\u00e9rentes classes : \u00ab {2} \u00bb. Utilisez les annotations d''entit\u00e9 Jakarta Persistence suivantes pour attribuer un nom d''entit\u00e9 et un nom de table uniques \u00e0 chaque classe d''entit\u00e9 : {3}.
CWWKD1068.entity.name.conflict.explanation=Les noms d'entit\u00e9s et de tables sont d\u00e9duits du nom de classe non qualifi\u00e9 ou attribu\u00e9s par les annotations Jakarta Persistence.
CWWKD1068.entity.name.conflict.useraction=Renommez les entit\u00e9s ou ajoutez des annotations Jakarta Persistence pour r\u00e9soudre explicitement le conflit de noms.

CWWKD1069.record.entity.name.conflict=CWWKD1069E: L''interface du r\u00e9f\u00e9rentiel \u00ab {0} \u00bb comporte plusieurs entit\u00e9s nomm\u00e9es \u00ab {1} \u00bb, qui sont fournies par diff\u00e9rentes classes : \u00ab {2} \u00bb. Lorsque des enregistrements Java sont utilis\u00e9s comme entit\u00e9s, il doit \u00e9galement \u00eatre possible d''ajouter le suffixe \u00ab Entity \u00bb au nom de l''entit\u00e9 sans que cela n''entra\u00eene de conflit de noms. Par exemple : {2}.
CWWKD1069.record.entity.name.conflict.explanation=Les noms d'entit\u00e9s et de tables sont d\u00e9duits du nom de classe non qualifi\u00e9 ou attribu\u00e9s par les annotations Jakarta Persistence.
CWWKD1069.record.entity.name.conflict.useraction=Renommez les entit\u00e9s ou passez aux entit\u00e9s Jakarta Persistence pour r\u00e9soudre le conflit de noms.

CWWKD1070.record.convert.err=CWWKD1070E: L''enregistrement \u00ab {0} \u00bb transmis \u00e0 la m\u00e9thode \u00ab {1} \u00bb de l''interface du r\u00e9f\u00e9rentiel \u00ab {2} \u00bb ne peut pas \u00eatre utilis\u00e9 en tant qu''entit\u00e9 en raison de l''erreur suivante : \u00ab {3} \u00bb.
CWWKD1070.record.convert.err.explanation=Il n'est pas possible d'utiliser l'enregistrement Java comme entit\u00e9.
CWWKD1070.record.convert.err.useraction=D\u00e9finissez l'entit\u00e9 en tant qu'entit\u00e9 Jakarta Persistence plut\u00f4t que d'utiliser une entit\u00e9 de type enregistrement Java.

CWWKD1071.record.with.type.var=CWWKD1071E: L''enregistrement \u00ab {0} \u00bb est utilis\u00e9 comme entit\u00e9 par une ou plusieurs interfaces de r\u00e9f\u00e9rentiel ( {1} ) dans l''artefact d''application {2}, mais cet enregistrement ne peut pas \u00eatre une entit\u00e9 car il comporte une ou plusieurs variables de type : {3}.
CWWKD1071.record.with.type.var.explanation=Les classes d'entit\u00e9s ne peuvent pas comporter de variables de type g\u00e9n\u00e9rique.
CWWKD1071.record.with.type.var.useraction=Supprimez les variables de type de l'enregistrement.

CWWKD1072.record.comp.conflict=CWWKD1072E: L''enregistrement \u00ab {0} \u00bb est utilis\u00e9 comme entit\u00e9 par une ou plusieurs interfaces du r\u00e9f\u00e9rentiel ( {1} ) dans l''artefact d''application {2}, mais cet enregistrement ne peut pas \u00eatre consid\u00e9r\u00e9 comme une entit\u00e9, car ses composants \u00ab {3} \u00bb et \u00ab {4} \u00bb renvoient tous deux au m\u00eame nom d''attribut d''entit\u00e9.
CWWKD1072.record.comp.conflict.explanation=Les noms d'attributs des entit\u00e9s doivent \u00eatre uniques, sans tenir compte de la casse.
CWWKD1072.record.comp.conflict.useraction=Renommez l'un des composants de l'enregistrement pour \u00e9viter le conflit.

CWWKD1073.offset.exceeds.max=CWWKD1073E: Le point de d\u00e9part de l'' {0}, \u00e0 savoir la limite {1} fournie \u00e0 la m\u00e9thode {2} de l''interface du r\u00e9f\u00e9rentiel {3}, d\u00e9passe la valeur maximale autoris\u00e9e de {4}.
CWWKD1073.offset.exceeds.max.explanation=La valeur initiale de la limite est trop \u00e9lev\u00e9e.
CWWKD1073.offset.exceeds.max.useraction=Ajoutez des crit\u00e8res de filtrage \u00e0 la requ\u00eate afin de r\u00e9duire le nombre de r\u00e9sultats correspondants.

CWWKD1074.qbmn.incompat.keywords=CWWKD1074E: La m\u00e9thode \u00ab {0} \u00bb de l''interface du r\u00e9f\u00e9rentiel \u00ab {1} \u00bb ne doit pas associer le mot-cl\u00e9 \u00ab {2} \u00bb au mot-cl\u00e9 \u00ab {3} \u00bb dans une m\u00eame condition \u00ab Query by Method Name \u00bb.
CWWKD1074.qbmn.incompat.keywords.explanation=Les mots-cl\u00e9s \u00ab Query by Method Name \u00bb indiqu\u00e9s ne sont pas compatibles entre eux.
CWWKD1074.qbmn.incompat.keywords.useraction=Renommez la m\u00e9thode afin de ne pas regrouper les mots-cl\u00e9s dans une m\u00eame condition.

CWWKD1075.entity.attr.conflict=CWWKD1075E: L''entit\u00e9 \u00ab {0} \u00bb ne peut pas comporter \u00e0 la fois un attribut nomm\u00e9 \u00ab {1} \u00bb et un attribut nomm\u00e9 \u00ab {2} \u00bb, car la sp\u00e9cification Jakarta Data consid\u00e8re ces noms comme des alias d''un m\u00eame attribut d''entit\u00e9.
CWWKD1075.entity.attr.conflict.explanation=Il y a un conflit entre les noms de deux attributs d'entit\u00e9 en raison du caract\u00e8re \u00ab _ \u00bb.
CWWKD1075.entity.attr.conflict.useraction=N'utilisez pas le caract\u00e8re de soulignement dans les noms d'attributs d'entit\u00e9.

CWWKD1076.repo.disposed=CWWKD1076E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` ne peut pas \u00eatre appel\u00e9e car l''application qui d\u00e9finit le r\u00e9f\u00e9rentiel s''est arr\u00eat\u00e9e. L''instance du r\u00e9f\u00e9rentiel est {2}.
CWWKD1076.repo.disposed.explanation=Les m\u00e9thodes du r\u00e9f\u00e9rentiel ne doivent pas \u00eatre utilis\u00e9es en dehors du cycle de vie de l'application qui d\u00e9finit ce r\u00e9f\u00e9rentiel.
CWWKD1076.repo.disposed.useraction=Assurez-vous que la m\u00e9thode du r\u00e9f\u00e9rentiel n'est pas utilis\u00e9e en dehors du p\u00e9rim\u00e8tre de l'application qui d\u00e9finit ce r\u00e9f\u00e9rentiel.

CWWKD1077.defaultds.not.found=CWWKD1077E: L''artefact d''application \u00ab {0} \u00bb comporte une ou plusieurs interfaces de r\u00e9f\u00e9rentiel ( {1} ) qui utilisent le magasin de donn\u00e9es \u00ab {2} \u00bb ou s''y raccordent par d\u00e9faut. Ce magasin de donn\u00e9es doit \u00eatre configur\u00e9 dans la configuration du serveur en d\u00e9finissant un \u00e9l\u00e9ment \u00ab dataSource \u00bb dont l''identifiant est \u00ab DefaultDataSource \u00bb. Par exemple, {3}. Vous pouvez \u00e9galement attribuer \u00e0 la valeur \u00ab dataStore \u00bb de l''annotation \u00ab Repository \u00bb l''identifiant d''un \u00e9l\u00e9ment \u00ab databaseStore \u00bb, ou le nom JNDI d''une r\u00e9f\u00e9rence de ressource de source de donn\u00e9es ou d''une r\u00e9f\u00e9rence d''unit\u00e9 de persistance accessible \u00e0 l''artefact d''application. Un \u00e9l\u00e9ment \u00ab databaseStore \u00bb peut \u00eatre d\u00e9fini dans la configuration du serveur. Par exemple, {4} Un composant d''application\
    \ peut utiliser l''annotation Resource pour d\u00e9finir une r\u00e9f\u00e9rence \u00e0 une ressource de source de donn\u00e9es. Par exemple, {5}, qui n\u00e9cessite que la configuration du serveur comporte un \u00e9l\u00e9ment de configuration dataSource dot\u00e9 d''un attribut {6}. Un composant d''application peut utiliser l''annotation ` PersistenceUnit ` pour d\u00e9finir une r\u00e9f\u00e9rence \u00e0 une unit\u00e9 de persistance. Par exemple, {7}, qui exige que le fichier persistence.xml contienne un \u00e9l\u00e9ment \u00ab persistence-unit \u00bb dont l''attribut \u00ab name \u00bb corresponde. Par exemple, {8}
CWWKD1077.defaultds.not.found.explanation=Les r\u00e9f\u00e9rentiels de donn\u00e9es Jakarta utilisent par d\u00e9faut la source de donn\u00e9es par d\u00e9faut de Jakarta EE, qui doit \u00eatre configur\u00e9e dans les param\u00e8tres du serveur.
CWWKD1077.defaultds.not.found.useraction=Configurez la source de donn\u00e9es par d\u00e9faut de Jakarta EE ou indiquez un autre magasin de donn\u00e9es pour le r\u00e9f\u00e9rentiel.

CWWKD1078.datastore.not.found=CWWKD1078E: Une ou plusieurs interfaces de r\u00e9f\u00e9rentiel ( {0} ) de l''artefact d''application {1} sp\u00e9cifient un magasin de donn\u00e9es {2} qui ne correspond pas \u00e0 l''ID d''un \u00e9l\u00e9ment dataSource ou d''un \u00e9l\u00e9ment databaseStore dans la configuration du serveur, ou qui ne correspond pas au nom JNDI d''une source de donn\u00e9es, d''une r\u00e9f\u00e9rence de ressource de source de donn\u00e9es ou d''une r\u00e9f\u00e9rence d''unit\u00e9 de persistance accessible \u00e0 l''artefact d''application, ou encore l''une des ressources associ\u00e9es n''est pas configur\u00e9e correctement. Un \u00e9l\u00e9ment \u00ab dataSource \u00bb peut \u00eatre d\u00e9fini dans la configuration du serveur. Par exemple, {3} Un \u00e9l\u00e9ment \u00ab databaseStore \u00bb peut \u00eatre d\u00e9fini dans la configuration du serveur. Par exemple, {4} Un composant d''application peut utiliser l''annotation Resource pour d\u00e9finir une r\u00e9f\u00e9ren\
    ce \u00e0 une ressource de source de donn\u00e9es. Par exemple, {5}, qui n\u00e9cessite que la configuration du serveur comporte un \u00e9l\u00e9ment de configuration dataSource dot\u00e9 d''un attribut {6}. Un composant d''application peut utiliser l''annotation ` PersistenceUnit ` pour d\u00e9finir une r\u00e9f\u00e9rence \u00e0 une unit\u00e9 de persistance. Par exemple, {7}, qui exige que le fichier persistence.xml contienne un \u00e9l\u00e9ment \u00ab persistence-unit \u00bb dont l''attribut \u00ab name \u00bb corresponde. Par exemple, {8}
CWWKD1078.datastore.not.found.explanation=Le magasin de donn\u00e9es d'un r\u00e9f\u00e9rentiel Jakarta Data peut correspondre \u00e0 l'identifiant d'un \u00e9l\u00e9ment \u00ab dataSource \u00bb ou \u00ab databaseStore \u00bb dans la configuration du serveur, ou encore \u00e0 un nom JNDI d'une source de donn\u00e9es, d'une r\u00e9f\u00e9rence de ressource de source de donn\u00e9es ou d'une r\u00e9f\u00e9rence d'unit\u00e9 de persistance.
CWWKD1078.datastore.not.found.useraction=Assurez-vous que la ressource est correctement configur\u00e9e. Si vous utilisez un nom JNDI, assurez-vous que la port\u00e9e de ce nom permet \u00e0 l'artefact d'application fournissant le r\u00e9f\u00e9rentiel d'acc\u00e9der \u00e0 la ressource.

CWWKD1079.jndi.not.found=CWWKD1079E: Une ou plusieurs interfaces de r\u00e9f\u00e9rentiel ( {0} ) de l''artefact d''application {1} sp\u00e9cifient un magasin de donn\u00e9es portant le nom JNDI {2}, mais l''artefact d''application ne peut pas acc\u00e9der \u00e0 la source de donn\u00e9es, \u00e0 la r\u00e9f\u00e9rence de ressource de source de donn\u00e9es ou \u00e0 la r\u00e9f\u00e9rence d''unit\u00e9 de persistance associ\u00e9e \u00e0 ce nom JNDI, ou bien l''une des ressources concern\u00e9es n''est pas configur\u00e9e correctement. Un composant d''application peut utiliser l''annotation Resource pour d\u00e9finir une r\u00e9f\u00e9rence \u00e0 une ressource de source de donn\u00e9es. Par exemple, {3}, qui renvoie \u00e0 un \u00e9l\u00e9ment de configuration du serveur dataSource dot\u00e9 d''un attribut {4}. Un composant d''application peut utiliser l''annotation ` PersistenceUnit ` pour d\u00e9finir une r\u00e9f\u00e9rence \u00e0 une unit\u00e9 de persistance. Par exemple, {5}, qui exige qu\
    e le fichier persistence.xml contienne un \u00e9l\u00e9ment \u00ab persistence-unit \u00bb dont l''attribut \u00ab name \u00bb corresponde. Par exemple, {6} Un composant d''application peut utiliser l''annotation DataSourceDefinition pour d\u00e9finir une source de donn\u00e9es. Il est \u00e9galement possible de d\u00e9finir une source de donn\u00e9es dans la configuration du serveur \u00e0 l''aide d''un \u00e9l\u00e9ment ` dataSource `. Par exemple, {7}
CWWKD1079.jndi.not.found.explanation=Lorsque le magasin de donn\u00e9es d'un r\u00e9f\u00e9rentiel Jakarta Data est d\u00e9fini sur un nom JNDI correspondant \u00e0 une source de donn\u00e9es, \u00e0 une r\u00e9f\u00e9rence de ressource de source de donn\u00e9es ou \u00e0 une r\u00e9f\u00e9rence d'unit\u00e9 de persistance, ce nom JNDI doit \u00eatre accessible \u00e0 l'artefact d'application qui fournit le r\u00e9f\u00e9rentiel, et la source de donn\u00e9es ou l'unit\u00e9 de persistance doit \u00eatre correctement configur\u00e9e.
CWWKD1079.jndi.not.found.useraction=Assurez-vous que la ressource est correctement configur\u00e9e et que la port\u00e9e du nom JNDI permet \u00e0 l'artefact d'application fournissant le r\u00e9f\u00e9rentiel d'y acc\u00e9der.

CWWKD1080.datastore.general.err=CWWKD1080E: Une ou plusieurs interfaces de r\u00e9f\u00e9rentiel ( {0} ) de l''artefact d''application {1} ne sont pas disponibles en raison d''une erreur. Cette erreur peut \u00eatre due \u00e0 un probl\u00e8me de configuration, ou bien le magasin de donn\u00e9es d'' {2} s du r\u00e9f\u00e9rentiel n''est peut-\u00eatre pas disponible. L''erreur est la suivante : {3}.
CWWKD1080.datastore.general.err.explanation=Une erreur emp\u00eache l'utilisation des r\u00e9f\u00e9rentiels indiqu\u00e9s.
CWWKD1080.datastore.general.err.useraction=Rep\u00e9rez les interfaces du r\u00e9f\u00e9rentiel et la configuration du magasin de donn\u00e9es, puis apportez les corrections n\u00e9cessaires.

CWWKD1081.entity.general.err=CWWKD1081E: En raison d''une erreur, l''entit\u00e9 {0} n''est pas disponible pour une ou plusieurs interfaces de r\u00e9f\u00e9rentiel ( {1} ) qui utilisent le magasin de donn\u00e9es {2}. Erreur : {3}.
CWWKD1081.entity.general.err.explanation=Une erreur emp\u00eache l'utilisation de l'entit\u00e9 sp\u00e9cifi\u00e9e.
CWWKD1081.entity.general.err.useraction=Rep\u00e9rez l'entit\u00e9 et apportez les corrections n\u00e9cessaires.

CWWKD1082.entity.classes.missing=CWWKD1082E: L''unit\u00e9 de persistance du magasin de donn\u00e9es {0} ne d\u00e9finit pas une ou plusieurs classes d''entit\u00e9s ( {1} ) requises par une ou plusieurs interfaces de r\u00e9f\u00e9rentiel ( {2} ) qui utilisent ce magasin de donn\u00e9es.
CWWKD1082.entity.classes.missing.explanation=Les r\u00e9f\u00e9rentiels utilisent des classes d'entit\u00e9s qui doivent \u00eatre d\u00e9finies dans l'unit\u00e9 de persistance.
CWWKD1082.entity.classes.missing.useraction=Inclure toutes les classes d'entit\u00e9 dans l'unit\u00e9 de persistance.

CWWKD1083.dup.method.param=CWWKD1083E: Plusieurs param\u00e8tres de la m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` correspondent au param\u00e8tre nomm\u00e9 : ` {2} `. Vous pouvez annoter un param\u00e8tre de m\u00e9thode avec l''annotation ` {3} ` pour sp\u00e9cifier le param\u00e8tre nomm\u00e9 du langage de requ\u00eate. Vous pouvez \u00e9galement activer l''option de compilation -parameters et d\u00e9finir un param\u00e8tre de m\u00e9thode sous la forme \u00ab {4} \u00bb, ce qui ne n\u00e9cessite pas l''annotation Param.
CWWKD1083.dup.method.param.explanation=Chaque param\u00e8tre de m\u00e9thode doit correspondre \u00e0 un seul et unique param\u00e8tre de requ\u00eate.
CWWKD1083.dup.method.param.useraction=V\u00e9rifiez que chacun des param\u00e8tres de la m\u00e9thode correspond bien au param\u00e8tre nomm\u00e9 correspondant. Supprimer les param\u00e8tres de m\u00e9thode en double. 
CWWKD1084.missing.named.params=CWWKD1084E: Les param\u00e8tres de la m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` ne d\u00e9finissent pas les param\u00e8tres nomm\u00e9s ( {2} ) requis par la valeur de l''annotation `Query` : {3}. Vous pouvez d\u00e9finir un param\u00e8tre nomm\u00e9 pour la requ\u00eate en pla\u00e7ant l''annotation `Param` sur le param\u00e8tre correspondant de la m\u00e9thode. Par exemple, {4}. Sinon, si vous activez l''option de compilation -parameters, vous pouvez omettre l''annotation Param si vous nommez le param\u00e8tre de la m\u00e9thode de la m\u00eame mani\u00e8re que le param\u00e8tre nomm\u00e9. Par exemple, si String est le type du param\u00e8tre nomm\u00e9, le param\u00e8tre de la m\u00e9thode peut \u00eatre d\u00e9fini comme suit : ` {5} `, ce qui ne n\u00e9cessite pas l''annotation `Param`.
CWWKD1084.missing.named.params.explanation=La valeur de l'annotation Query n\u00e9cessite un ou plusieurs param\u00e8tres nomm\u00e9s qui ne sont pas fournis par la m\u00e9thode du r\u00e9f\u00e9rentiel.
CWWKD1084.missing.named.params.useraction=Ajoutez des param\u00e8tres \u00e0 la m\u00e9thode du r\u00e9f\u00e9rentiel pour sp\u00e9cifier les param\u00e8tres nomm\u00e9s manquants.

CWWKD1085.extra.method.params=CWWKD1085E: Les param\u00e8tres de la m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` d\u00e9finissent des param\u00e8tres de requ\u00eate ( {2} ), qui ne correspondent \u00e0 aucun des param\u00e8tres nomm\u00e9s ( {3} ) utilis\u00e9s par la valeur de l''annotation `Query` : {4}.
CWWKD1085.extra.method.params.explanation=Tous les param\u00e8tres de la m\u00e9thode doivent \u00eatre utilis\u00e9s par la requ\u00eate ou correspondre \u00e0 des types de param\u00e8tres d\u00e9finis par Jakarta Data.
CWWKD1085.extra.method.params.useraction=Supprimez les param\u00e8tres de m\u00e9thode superflus.

CWWKD1086.named.params.unused=CWWKD1086E: Les param\u00e8tres de la m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` d\u00e9finissent des param\u00e8tres nomm\u00e9s ( {2} ), qui ne sont pas utilis\u00e9s dans la valeur de l''annotation `Query` : {3}. Vous pouvez faire r\u00e9f\u00e9rence \u00e0 des param\u00e8tres nomm\u00e9s dans une requ\u00eate en utilisant le caract\u00e8re \u00ab : \u00bb suivi du nom du param\u00e8tre. Par exemple, {4}. Les param\u00e8tres de position dans une requ\u00eate peuvent \u00eatre r\u00e9f\u00e9renc\u00e9s \u00e0 l''aide du caract\u00e8re \u00ab? \u00bb caract\u00e8re suivi d''une valeur ordinale, commen\u00e7ant par?1. \u00c9vitez d''annoter les param\u00e8tres de m\u00e9thode avec l''annotation `Param` lorsque la requ\u00eate utilise des param\u00e8tres positionnels ou ne comporte aucun param\u00e8tre.
CWWKD1086.named.params.unused.explanation=L'annotation \u00ab Param \u00bb ne peut \u00eatre utilis\u00e9e que lorsque la requ\u00eate comporte des param\u00e8tres nomm\u00e9s.
CWWKD1086.named.params.unused.useraction=Supprimez l'annotation \u00ab Param \u00bb ou modifiez la requ\u00eate pour utiliser des param\u00e8tres nomm\u00e9s.

CWWKD1087.null.param=CWWKD1087E: Le param\u00e8tre \u00ab {0} \u00bb de la m\u00e9thode \u00ab {1} \u00bb de l''interface du r\u00e9f\u00e9rentiel \u00ab {2} \u00bb a une valeur nulle. Indiquez une valeur non nulle.
CWWKD1087.null.param.explanation=La valeur du param\u00e8tre ne doit pas \u00eatre nulle.
CWWKD1087.null.param.useraction=Indiquez une valeur non nulle pour ce param\u00e8tre.

CWWKD1088.empty.sorts=CWWKD1088E: Les crit\u00e8res de tri sp\u00e9cifi\u00e9s par le param\u00e8tre \u00ab {0} \u00bb de la m\u00e9thode \u00ab {1} \u00bb de l''interface du r\u00e9f\u00e9rentiel \u00ab {2} \u00bb sont vides.
CWWKD1088.empty.sorts.explanation=Les crit\u00e8res de tri ne doivent pas \u00eatre vides.
CWWKD1088.empty.sorts.useraction=Indiquez une valeur pour le crit\u00e8re de tri.

CWWKD1089.unordered.pagination=CWWKD1089E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` doit sp\u00e9cifier les crit\u00e8res de tri, car cette m\u00e9thode renvoie une valeur de type ` {2} `. Les donn\u00e9es non ordonn\u00e9es ne peuvent pas \u00eatre r\u00e9parties en pages.
CWWKD1089.unordered.pagination.explanation=La pagination n\u00e9cessite des donn\u00e9es ordonn\u00e9es.
CWWKD1089.unordered.pagination.useraction=Utilisez l'annotation ` OrderBy ` pour d\u00e9finir les crit\u00e8res de tri de la m\u00e9thode du r\u00e9f\u00e9rentiel.

CWWKD1090.orderby.conflict=CWWKD1090E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` ne peut pas combiner l''annotation ` OrderBy ` et le mot-cl\u00e9 ` OrderBy `.
CWWKD1090.orderby.conflict.explanation=L'annotation \u00ab OrderBy \u00bb n'est pas compatible avec le mot-cl\u00e9 \u00ab OrderBy \u00bb.
CWWKD1090.orderby.conflict.useraction=Utilisez uniquement l'annotation \u00ab OrderBy \u00bb ou le mot-cl\u00e9 \u00ab OrderBy \u00bb.

CWWKD1091.method.name.parse.err=CWWKD1091E: L''attribut d''entit\u00e9 nomm\u00e9 \u00ab {0} \u00bb est introuvable dans la classe d''entit\u00e9 \u00ab {1} \u00bb pour la m\u00e9thode \u00ab {2} \u00bb de l''interface de r\u00e9f\u00e9rentiel \u00ab {3} \u00bb. V\u00e9rifiez que la m\u00e9thode du r\u00e9f\u00e9rentiel porte un nom conforme au mod\u00e8le \u00ab Query by Method Name \u00bb ou qu''elle est annot\u00e9e avec l''une des annotations suivantes : {4}. Les noms d''attributs valides pour cette entit\u00e9 sont : {5}.
CWWKD1091.method.name.parse.err.explanation=Le nom de la m\u00e9thode du r\u00e9f\u00e9rentiel a \u00e9t\u00e9 analys\u00e9 selon le mod\u00e8le \u00ab Query by Method Name \u00bb, car cette m\u00e9thode ne comporte pas d'annotation Jakarta Data indiquant le type d'op\u00e9ration.
CWWKD1091.method.name.parse.err.useraction=Corrigez le nom de la m\u00e9thode du r\u00e9f\u00e9rentiel ou ajoutez une annotation \u00e0 cette m\u00e9thode pour indiquer qu'il s'agit d'une op\u00e9ration Jakarta Data, telle que Query, Find ou Save.

CWWKD1092.lifecycle.arg.empty=CWWKD1092E: La m\u00e9thode ` {0} ` du r\u00e9f\u00e9rentiel ` {1} ` n''accepte pas un param\u00e8tre ` {2} ` vide. La valeur du param\u00e8tre doit contenir au moins une entit\u00e9.
CWWKD1092.lifecycle.arg.empty.explanation=M\u00e9thodes Insert, Update, Save et Delete
 require au moins une entit\u00e9.
CWWKD1092.lifecycle.arg.empty.useraction=Assurez-vous que le tableau, la liste ou le flux transmis \u00e0 la m\u00e9thode contient au moins une entit\u00e9.

CWWKD1093.fn.not.applicable=CWWKD1093E: La fonction \u00ab {0} \u00bb ne peut pas \u00eatre \u00e9valu\u00e9e pour l''entit\u00e9 \u00ab {1} \u00bb utilis\u00e9e par la m\u00e9thode \u00ab {2} \u00bb de l''interface de r\u00e9f\u00e9rentiel \u00ab {3} \u00bb. L''entit\u00e9 ne poss\u00e8de pas d''attribut annot\u00e9 avec \u00ab {4} \u00bb ni \u00e0 partir duquel on puisse d\u00e9duire \u00ab {0} \u00bb.
CWWKD1093.fn.not.applicable.explanation=Cette fonction ne peut pas \u00eatre utilis\u00e9e sur l'entit\u00e9, car celle-ci ne dispose pas d'un attribut ID ou version.
CWWKD1093.fn.not.applicable.useraction=N'utilisez pas cette fonction dans le langage de requ\u00eate ni dans les param\u00e8tres de la m\u00e9thode de r\u00e9f\u00e9rentiel.

CWWKD1094.return.mismatch=CWWKD1094E: La m\u00e9thode ` {0} ` de l''interface ` {1} ` a pour type de retour ` {2} `, qui ne permet pas de renvoyer le nombre d''entit\u00e9s, ` {3} `, que la m\u00e9thode du r\u00e9f\u00e9rentiel accepte en param\u00e8tre. Les types de retour valides pour une m\u00e9thode de type \u00ab {4} \u00bb qui accepte plusieurs entit\u00e9s sont les suivants : {5}.
CWWKD1094.return.mismatch.explanation=Une m\u00e9thode de cycle de vie du r\u00e9f\u00e9rentiel qui renvoie des entit\u00e9s doit \u00eatre capable de renvoyer le m\u00eame nombre d'entit\u00e9s que celui accept\u00e9 par la m\u00e9thode.
CWWKD1094.return.mismatch.useraction=Modifiez la m\u00e9thode du r\u00e9f\u00e9rentiel de mani\u00e8re \u00e0 ce qu'elle utilise un type de retour capable de renvoyer plusieurs entit\u00e9s, ou modifiez-la pour qu'elle n'accepte qu'une seule entit\u00e9.

CWWKD1095.repo.err=CWWKD1095E: Il est impossible de fournir une impl\u00e9mentation de l''interface de r\u00e9f\u00e9rentiel \u00ab {0} \u00bb en raison d''une erreur. L''annotation du r\u00e9f\u00e9rentiel est {1}. La classe d''entit\u00e9 principale est \u00ab {2} \u00bb. L''erreur est la suivante : {3}
CWWKD1095.repo.err.explanation=Le fournisseur de donn\u00e9es Jakarta int\u00e9gr\u00e9 ne parvient pas \u00e0 fournir une instance du r\u00e9f\u00e9rentiel en raison d'une erreur.
CWWKD1095.repo.err.useraction=V\u00e9rifiez l'origine de l'erreur et corrigez l'interface du r\u00e9f\u00e9rentiel, les entit\u00e9s, la configuration du magasin de donn\u00e9es ou la base de donn\u00e9es.

CWWKD1096.orderby.incompat=CWWKD1096E: La m\u00e9thode ` {0} ` du r\u00e9f\u00e9rentiel ` {1} ` comporte une annotation ` OrderBy `, mais la m\u00e9thode ` {0} ` n''est ni une op\u00e9ration de recherche ni une op\u00e9ration de suppression qui renvoie des entit\u00e9s.
CWWKD1096.orderby.incompat.explanation=L'annotation \u00ab OrderBy \u00bb n'est pas compatible avec le type d'op\u00e9ration du r\u00e9f\u00e9rentiel.
CWWKD1096.orderby.incompat.useraction=Supprimez l'annotation \u00ab OrderBy \u00bb.

CWWKD1097.param.incompat=CWWKD1097E: La m\u00e9thode ` {0} ` du r\u00e9f\u00e9rentiel ` {1} ` dispose d''un param\u00e8tre ` {2} `, mais la m\u00e9thode ` {0} ` n''est ni une op\u00e9ration de recherche ni une op\u00e9ration de suppression qui renvoie des entit\u00e9s.
CWWKD1097.param.incompat.explanation=Les param\u00e8tres \u00ab Order \u00bb, \u00ab Sort \u00bb et \u00ab Limit \u00bb ne sont pas compatibles avec ce type d'op\u00e9ration sur le r\u00e9f\u00e9rentiel.
CWWKD1097.param.incompat.useraction=Supprimez le param\u00e8tre \u00ab Order \u00bb, \u00ab Sort \u00bb ou \u00ab Limit \u00bb.

CWWKD1098.spec.param.position.err=CWWKD1098E: La m\u00e9thode ` {0} ` du r\u00e9f\u00e9rentiel ` {1} ` comporte un param\u00e8tre ` {2} ` qui est plac\u00e9 avant les param\u00e8tres de requ\u00eate. Les types de param\u00e8tres qui ont une signification particuli\u00e8re dans Jakarta Data ( {3} ) doivent \u00eatre plac\u00e9s apr\u00e8s les autres param\u00e8tres dans la signature de la m\u00e9thode du r\u00e9f\u00e9rentiel.
CWWKD1098.spec.param.position.err.explanation=Lorsque des types de param\u00e8tres d\u00e9finis par Jakarta Data sont inclus dans la signature d'une m\u00e9thode de r\u00e9f\u00e9rentiel, ils doivent \u00eatre plac\u00e9s apr\u00e8s tous les param\u00e8tres de requ\u00eate.
CWWKD1098.spec.param.position.err.useraction=D\u00e9placez les types de param\u00e8tres sp\u00e9ciaux d\u00e9finis par Jakarta Data \u00e0 la fin de la signature de la m\u00e9thode du r\u00e9f\u00e9rentiel.

CWWKD1099.first.keyword.incompat=CWWKD1099E: La m\u00e9thode \u00ab {0} \u00bb du r\u00e9f\u00e9rentiel \u00ab {1} \u00bb porte un nom qui contient le mot-cl\u00e9 \u00ab First \u00bb, ce qui est incompatible avec le param\u00e8tre \u00ab {2} \u00bb de cette m\u00e9thode.
CWWKD1099.first.keyword.incompat.explanation=Une requ\u00eate de type \u00ab Query by Method Name \u00bb qui inclut un param\u00e8tre \u00ab Limit \u00bb ou \u00ab PageRequest \u00bb ne peut pas utiliser le mot-cl\u00e9 \u00ab First \u00bb.
CWWKD1099.first.keyword.incompat.useraction=Supprimez le mot-cl\u00e9 \u00ab First \u00bb du nom de la m\u00e9thode.

CWWKD1100.cursor.requires.sort=CWWKD1100E: La m\u00e9thode ` {0} ` du r\u00e9f\u00e9rentiel ` {1} ` renvoie ` {2} `, mais ne comporte pas d''annotation ` OrderBy ` ni aucun des param\u00e8tres suivants permettant de d\u00e9finir des crit\u00e8res de tri : ` {3} `. Les crit\u00e8res de tri sont obligatoires pour la pagination bas\u00e9e sur le curseur et ne peuvent pas \u00eatre sp\u00e9cifi\u00e9s dans la clause ORDER BY d''une annotation de requ\u00eate.
CWWKD1100.cursor.requires.sort.explanation=La pagination par curseur n\u00e9cessite des crit\u00e8res de tri.
CWWKD1100.cursor.requires.sort.useraction=Supprimez la clause ORDER BY de la valeur de l'annotation Query si elle y figure. Ajoutez une annotation ` OrderBy ` ou un param\u00e8tre de m\u00e9thode de r\u00e9f\u00e9rentiel pour d\u00e9finir les crit\u00e8res de tri.

CWWKD1101.attr.subset.mismatch=CWWKD1101E: Le type de retour \u00ab {0} \u00bb de la m\u00e9thode \u00ab {1} \u00bb du r\u00e9f\u00e9rentiel \u00ab {2} \u00bb utilise le type d''enregistrement Java \u00ab {3} \u00bb pour d\u00e9finir les r\u00e9sultats comme un sous-ensemble d''attributs d''entit\u00e9 : {4}. Cependant, au moins un des noms d''attribut demand\u00e9s n''appara\u00eet pas dans l''entit\u00e9 {5}. Pour renvoyer un sous-ensemble d''attributs d''entit\u00e9 sous la forme d''un enregistrement Java, assurez-vous que les noms des composants de l''enregistrement figurent dans la liste suivante des noms d''attributs valides pour l''entit\u00e9 \u00ab {5} \u00bb : {6}. Vous pouvez \u00e9galement utiliser l''annotation \u00ab Select \u00bb pour attribuer des noms d''attributs d''entit\u00e9 valides. Pour renvoyer un attribut d''entit\u00e9 unique de type enregistrement Java, ajoutez l''annotation Select \u00e0 la m\u00e9thode ` {1} ` et attribuez la valeur de son membre au nom de l''attribut\
    \ d''entit\u00e9.
CWWKD1101.attr.subset.mismatch.explanation=Lorsque des enregistrements Java sont utilis\u00e9s pour extraire un sous-ensemble d'attributs d'entit\u00e9, tous les composants de l'enregistrement doivent correspondre \u00e0 des attributs d'entit\u00e9 valides.
CWWKD1101.attr.subset.mismatch.useraction=Renommez les composants de l'enregistrement afin qu'ils correspondent \u00e0 des noms d'attributs d'entit\u00e9 valides, ou utilisez l'annotation `Select` pour demander explicitement les attributs d'entit\u00e9 par leur nom.

CWWKD1102.incompat.query.result=CWWKD1102E: La m\u00e9thode ` {0} ` du r\u00e9f\u00e9rentiel ` {1} ` a pour type de retour ` {2} `, mais le fournisseur Jakarta Persistence a ex\u00e9cut\u00e9 une requ\u00eate dont les r\u00e9sultats sont de type ` {3} `. V\u00e9rifiez si le fournisseur de persistance Jakarta permet d''interroger les types d''attributs d''entit\u00e9 s\u00e9lectionn\u00e9s par la m\u00e9thode ` {0} `. V\u00e9rifiez s''il existe d''autres causes d''incompatibilit\u00e9 si le fournisseur Jakarta permet d''interroger les types des attributs d''entit\u00e9 s\u00e9lectionn\u00e9s par la m\u00e9thode ` {0} `.
CWWKD1102.incompat.query.result.explanation=Les fournisseurs de persistance de Jakarta ne permettent pas de renvoyer tous les types d'attributs d'entit\u00e9. Si le fournisseur Jakarta renvoie le type d'attributs d'entit\u00e9 s\u00e9lectionn\u00e9 par la m\u00e9thode, il existe une autre cause d'incompatibilit\u00e9. Par exemple, le fournisseur de persistance Jakarta pourrait comporter un bug ou la signature de la m\u00e9thode du r\u00e9f\u00e9rentiel pourrait pr\u00e9senter une erreur.
CWWKD1102.incompat.query.result.useraction=Si le type d'attributs d'entit\u00e9 s\u00e9lectionn\u00e9 par la m\u00e9thode n'est pas autoris\u00e9, modifiez la requ\u00eate afin de r\u00e9cup\u00e9rer l'entit\u00e9 dans son int\u00e9gralit\u00e9 ou un ensemble diff\u00e9rent d'attributs d'entit\u00e9 autoris\u00e9 par le fournisseur Jakarta Persistence. Si le type d'attributs d'entit\u00e9 s\u00e9lectionn\u00e9 par la m\u00e9thode est autoris\u00e9, v\u00e9rifiez s'il existe d'autres causes d'incompatibilit\u00e9.

CWWKD1103.incompat.query.result=CWWKD1103E: La m\u00e9thode ` {0} ` du r\u00e9f\u00e9rentiel ` {1} ` a pour type de retour ` {2} `, mais le fournisseur Jakarta Persistence a ex\u00e9cut\u00e9 une requ\u00eate de type ` {3} ` dont les r\u00e9sultats sont de type ` {4} `. V\u00e9rifiez si le fournisseur de persistance Jakarta permet d''interroger les types d''attributs d''entit\u00e9 s\u00e9lectionn\u00e9s par la m\u00e9thode ` {0} `. V\u00e9rifiez s''il existe d''autres causes d''incompatibilit\u00e9 si le fournisseur Jakarta permet d''interroger les types des attributs d''entit\u00e9 s\u00e9lectionn\u00e9s par la m\u00e9thode ` {0} `.
CWWKD1103.incompat.query.result.explanation=Les fournisseurs de persistance de Jakarta ne permettent pas de renvoyer tous les types d'attributs d'entit\u00e9. Si le fournisseur Jakarta renvoie le type d'attributs d'entit\u00e9 s\u00e9lectionn\u00e9 par la m\u00e9thode, il existe une autre cause d'incompatibilit\u00e9. Par exemple, le fournisseur de persistance Jakarta pourrait comporter un bug ou la signature de la m\u00e9thode du r\u00e9f\u00e9rentiel pourrait pr\u00e9senter une erreur.
CWWKD1103.incompat.query.result.useraction=Si le type d'attributs d'entit\u00e9 s\u00e9lectionn\u00e9 par la m\u00e9thode n'est pas autoris\u00e9, modifiez la requ\u00eate afin de r\u00e9cup\u00e9rer l'entit\u00e9 dans son int\u00e9gralit\u00e9 ou un ensemble diff\u00e9rent d'attributs d'entit\u00e9 autoris\u00e9 par le fournisseur Jakarta Persistence. Si le type d'attributs d'entit\u00e9 s\u00e9lectionn\u00e9 par la m\u00e9thode est autoris\u00e9, v\u00e9rifiez s'il existe d'autres causes d'incompatibilit\u00e9.

CWWKD1104.empty.anno.value=CWWKD1104E: La valeur vide de la classe String n''est pas une valeur valide pour l''annotation ` {0} ` utilis\u00e9e sur la m\u00e9thode ` {1} ` du r\u00e9f\u00e9rentiel ` {2} `.
CWWKD1104.empty.anno.value.explanation=La valeur vide pour la classe String n'est pas une valeur prise en charge. La valeur prise en charge d\u00e9pend du type d'annotation. Par exemple, si l'annotation est une annotation \u00ab Param \u00bb, les valeurs valides correspondent aux noms des param\u00e8tres nomm\u00e9s utilis\u00e9s dans la valeur de l'annotation \u00ab Query \u00bb.
CWWKD1104.empty.anno.value.useraction=Si l'annotation n'est pas n\u00e9cessaire, supprimez-la de la m\u00e9thode du r\u00e9f\u00e9rentiel. Sinon, indiquez une valeur valide pour l'annotation.

CWWKD1105.keyword.in.orderby=CWWKD1105E: La clause \u00ab OrderBy \u00bb de la m\u00e9thode \u00ab {0} \u00bb du r\u00e9f\u00e9rentiel \u00ab {1} \u00bb ne peut pas \u00eatre analys\u00e9e, car l''attribut \u00ab {2} \u00bb de l''entit\u00e9 \u00ab {3} \u00bb contient le mot-cl\u00e9 \u00ab {4} \u00bb du mod\u00e8le \u00ab Jakarta Data Query by Method Name \u00bb. Supprimez la clause \u00ab OrderBy \u00bb du nom de la m\u00e9thode \u00ab {0} \u00bb et utilisez \u00e0 la place l''annotation \u00ab OrderBy \u00bb.
CWWKD1105.keyword.in.orderby.explanation=Les noms d'attributs d'entit\u00e9 contenant des mots-cl\u00e9s Jakarta Data ne peuvent pas \u00eatre utilis\u00e9s dans les noms des m\u00e9thodes de r\u00e9f\u00e9rentiel qui suivent le mod\u00e8le \u00ab Jakarta Data Query by Method Name \u00bb.
CWWKD1105.keyword.in.orderby.useraction=Renommez l'attribut de l'entit\u00e9 ou utilisez l'annotation ` OrderBy ` pour d\u00e9finir l'ordre.

CWWKD1106.init.timed.out=CWWKD1106E: Le r\u00e9f\u00e9rentiel {0}, qui n\u00e9cessite le magasin de donn\u00e9es {1} et qui est fourni ou utilis\u00e9 par l''artefact d''application {2}, n''\u00e9tait pas disponible dans les {3} secondes. V\u00e9rifiez que l''artefact d''application {2} d\u00e9marre et que la ressource de stockage de donn\u00e9es {1}, sp\u00e9cifi\u00e9e comme valeur dataStore de l''annotation Repository, est correctement configur\u00e9e et accessible \u00e0 l''artefact d''application lors du premier acc\u00e8s au r\u00e9f\u00e9rentiel {0}.
CWWKD1106.init.timed.out.explanation=Un r\u00e9f\u00e9rentiel n'a pas \u00e9t\u00e9 mis \u00e0 disposition dans le d\u00e9lai imparti.
CWWKD1106.init.timed.out.useraction=V\u00e9rifiez la configuration de l' dataStore e et assurez-vous qu'il est accessible aux artefacts d'application qui d\u00e9finissent et utilisent ce r\u00e9f\u00e9rentiel. V\u00e9rifiez \u00e9galement que l'application et tous ses modules d\u00e9marrent correctement.

CWWKD1107.init.timed.out.checkpoint=CWWKD1107E: L''artefact de l''application \u00ab {0} \u00bb a acc\u00e9d\u00e9 au r\u00e9f\u00e9rentiel \u00ab {1} \u00bb avant qu''un point de contr\u00f4le de l''application ne soit atteint. Mettez \u00e0 jour l''application \u00ab {0} \u00bb afin d''\u00e9viter d''utiliser le r\u00e9f\u00e9rentiel avant un point de contr\u00f4le.
CWWKD1107.init.timed.out.checkpoint.explanation=Les applications ne peuvent pas utiliser les r\u00e9f\u00e9rentiels avant la fin d'un point de contr\u00f4le.
CWWKD1107.init.timed.out.checkpoint.useraction=\u00c9vitez d'utiliser le r\u00e9f\u00e9rentiel tant que le point de contr\u00f4le n'est pas termin\u00e9.

CWWKD1108.missing.entity.anno=CWWKD1108E: La classe d''entit\u00e9 ` {0} ` n\u00e9cessite l''annotation ` {1} `, car l''annotation ` {2} ` est appliqu\u00e9e au membre ` {3} ` de cette classe d''entit\u00e9.
CWWKD1108.missing.entity.anno.explanation=Classes d'entit\u00e9s utilisant des annotations
 from le paquet \u00ab jakarta.persistence \u00bb doit \u00e9galement \u00eatre annot\u00e9 avec l'entit\u00e9
 annotation tir\u00e9 de la sp\u00e9cification Jakarta Persistence.
CWWKD1108.missing.entity.anno.useraction=Appliquez l'annotation Entity \u00e0 l'
 entity ou supprimer les annotations Jakarta Persistence de ses membres.

CWWKD1109.jpa.anno.on.record=CWWKD1109E: L''annotation ` {0} ` n''est pas autoris\u00e9e sur la m\u00e9thode ` {1} ` de la classe d''entit\u00e9 ` {2} `, car la classe d''entit\u00e9 ` {2} ` est un enregistrement Java.
CWWKD1109.jpa.anno.on.record.explanation=Les annotations de persistance Jakarta ne sont pas autoris\u00e9es sur les enregistrements Java.
CWWKD1109.jpa.anno.on.record.useraction=Passez \u00e0 une classe d'entit\u00e9 Jakarta Persistence ou supprimez l'annotation Jakarta Persistence de l'enregistrement Java.

CWWKD1110.incompat.with.collection=CWWKD1110E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` porte un nom qui contient le mot-cl\u00e9 ` {2} `, ce qui est incompatible avec l''attribut ` {3} ` de l''entit\u00e9 ` {4} `, car cet attribut est de type collection. Les mots-cl\u00e9s de requ\u00eate par nom de m\u00e9thode suivants peuvent \u00eatre utilis\u00e9s avec les attributs d''entit\u00e9 de type collection : {5}.
CWWKD1110.incompat.with.collection.explanation=Certains mots-cl\u00e9s de la requ\u00eate par nom de m\u00e9thode ne sont pas compatibles avec les attributs d'entit\u00e9 de type collection.
CWWKD1110.incompat.with.collection.useraction=Mettez \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel afin d'\u00e9viter d'utiliser le mot-cl\u00e9 qui n'est pas compatible avec le type de collection.

CWWKD1111.unsupported.convert=CWWKD1111E: L''impl\u00e9mentation de l'' {0} AttributeConverter convertit les valeurs de type {1} en type {2}, ce qui n''est pas pris en charge par la sp\u00e9cification Jakarta Data. La sp\u00e9cification Jakarta Data prend en charge les types d''\u00e9num\u00e9ration Java, les types temporels de l'' {3}, ainsi que les types de base suivants : {4}. Le fournisseur de donn\u00e9es Jakarta int\u00e9gr\u00e9 prend \u00e9galement en charge certains types de Jakarta Persistence.
CWWKD1111.unsupported.convert.explanation=L'impl\u00e9mentation de l'interface ` AttributeConverter ` ne peut pas \u00eatre utilis\u00e9e avec le fournisseur de donn\u00e9es Jakarta int\u00e9gr\u00e9, car celui-ci convertit les valeurs en un type non pris en charge.
CWWKD1111.unsupported.convert.useraction=Mettez \u00e0 jour l'impl\u00e9mentation de ` AttributeConverter ` afin de convertir les valeurs en l'un des types pris en charge.

CWWKD1112.record.entity.verify.err=CWWKD1112W: Une classe d''entit\u00e9 pour l''enregistrement \u00ab {0} \u00bb a \u00e9t\u00e9 d\u00e9finie, mais elle pourrait ne pas fonctionner. La v\u00e9rification des octets de la classe d''entit\u00e9 Jakarta Persistence, qui a \u00e9t\u00e9 g\u00e9n\u00e9r\u00e9e pour cette classe d''entit\u00e9, a \u00e9chou\u00e9. La classe d''entit\u00e9 d\u00e9finie est utilis\u00e9e par une ou plusieurs interfaces de r\u00e9f\u00e9rentiel ( {1} ) dans l''artefact d''application {2}. L''erreur est la suivante : {3}.
CWWKD1112.record.entity.verify.err.explanation=Lorsqu'un r\u00e9f\u00e9rentiel utilise une entit\u00e9 d'enregistrement, une entit\u00e9 Jakarta Persistence est g\u00e9n\u00e9r\u00e9e pour repr\u00e9senter cette entit\u00e9 d'enregistrement. La v\u00e9rification des octets de la classe d'entit\u00e9 Jakarta Persistence g\u00e9n\u00e9r\u00e9e a \u00e9chou\u00e9.
CWWKD1112.record.entity.verify.err.useraction=V\u00e9rifiez que l'impl\u00e9mentation de l'entit\u00e9 d'enregistrement respecte les exigences et les conventions applicables \u00e0 ce type d'entit\u00e9.

CWWKD1113.server.stopping=CWWKD1113I: Un ou plusieurs r\u00e9f\u00e9rentiels ( {0} ) n''ont pas pu \u00eatre initialis\u00e9s car le serveur est en cours d''arr\u00eat.
CWWKD1113.server.stopping.explanation=Le serveur est en train de s'arr\u00eater et ne tentera pas d'initialiser les r\u00e9f\u00e9rentiels.
CWWKD1113.server.stopping.useraction=Aucune action n'est requise.

CWWKD1114.app.stopping=CWWKD1114I: Un ou plusieurs r\u00e9f\u00e9rentiels ( {0} ) n''ont pas pu \u00eatre initialis\u00e9s car l''application {1} se trouve dans l''\u00e9tat \u00ab {2} \u00bb.
CWWKD1114.app.stopping.explanation=L'application s'arr\u00eate ou s'est arr\u00eat\u00e9e et ne tentera pas d'initialiser les r\u00e9f\u00e9rentiels.
CWWKD1114.app.stopping.useraction=Lancez l'application pour rendre les r\u00e9f\u00e9rentiels accessibles.

CWWKD1115.app.unavailable=CWWKD1115E: Un ou plusieurs r\u00e9f\u00e9rentiels ( {0} ) n''ont pas pu \u00eatre initialis\u00e9s car l''application {1} n''est pas disponible.
CWWKD1115.app.unavailable.explanation=L'application qui d\u00e9finit les r\u00e9f\u00e9rentiels n'est pas disponible. Les r\u00e9f\u00e9rentiels ne peuvent pas s'initialiser.
CWWKD1115.app.unavailable.useraction=Lancez l'application pour rendre les r\u00e9f\u00e9rentiels accessibles.

CWWKD1116.resource.unavailable=CWWKD1116E: Un ou plusieurs r\u00e9f\u00e9rentiels ( {0} ) n''ont pas pu \u00eatre initialis\u00e9s car la ressource {1} n''\u00e9tait pas disponible dans les {2} secondes.
CWWKD1116.resource.unavailable.explanation=Une ressource requise par les r\u00e9f\u00e9rentiels n'est pas devenue disponible.
CWWKD1116.resource.unavailable.useraction=V\u00e9rifiez la configuration des ressources utilis\u00e9es par les r\u00e9f\u00e9rentiels.

CWWKD1117.anno.constraint.conflict=CWWKD1117E: Le param\u00e8tre {0} de la m\u00e9thode {1} de l''interface de r\u00e9f\u00e9rentiel {2} ne peut pas \u00eatre annot\u00e9 avec les annotations suivantes : {3}. Une ou plusieurs annotations sont incompatibles avec le type \u00ab {4} \u00bb du param\u00e8tre de la m\u00e9thode du r\u00e9f\u00e9rentiel.
CWWKD1117.anno.constraint.conflict.explanation=La contrainte et ses sous-types ne peuvent pas \u00eatre combin\u00e9s avec d'autres annotations de param\u00e8tres que l'annotation \u00ab By \u00bb.
CWWKD1117.anno.constraint.conflict.useraction=Supprimez l'annotation en conflit ou indiquez le type d'attribut de l'entit\u00e9 \u00e0 la place d'un type de contrainte.

CWWKD1118.param.anno.conflict=CWWKD1118E: Le param\u00e8tre {0} de la m\u00e9thode {1} de l''interface de r\u00e9f\u00e9rentiel {2} ne peut pas \u00eatre annot\u00e9 avec les annotations suivantes : {3}. Deux annotations ou plus sont en conflit les unes avec les autres.
CWWKD1118.param.anno.conflict.explanation=La combinaison des annotations de param\u00e8tres n'est pas valide.
CWWKD1118.param.anno.conflict.useraction=Supprimez une ou plusieurs annotations en conflit du param\u00e8tre de la m\u00e9thode du r\u00e9f\u00e9rentiel.

CWWKD1119.keyword.prevents.count=CWWKD1119E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` r\u00e9cup\u00e8re les pages qui ne contiennent pas de nombre total d''\u00e9l\u00e9ments ni de pages, car la requ\u00eate contient le mot-cl\u00e9 ` {2} `. La requ\u00eate compl\u00e8te est la suivante : {3}.
CWWKD1119.keyword.prevents.count.explanation=Ce mot-cl\u00e9 est incompatible avec la possibilit\u00e9 d'obtenir le nombre total d'\u00e9l\u00e9ments et de pages.
CWWKD1119.keyword.prevents.count.useraction=Remplacez la requ\u00eate par une autre qui n'utilise pas ce mot-cl\u00e9 ou \u00e9vitez de demander le nombre total d'\u00e9l\u00e9ments et de pages.

CWWKD1120.cursor.keyword.mismatch=CWWKD1120E: La m\u00e9thode ` {0} ` de l''interface du r\u00e9f\u00e9rentiel ` {1} ` sp\u00e9cifie une requ\u00eate qui inclut le mot-cl\u00e9 ` {2} `, lequel est incompatible avec la pagination bas\u00e9e sur un curseur. Les requ\u00eates utilisant la pagination par curseur doivent se terminer par une clause WHERE et ne doivent pas contenir de sous-requ\u00eates. La requ\u00eate est la suivante : {3}.
CWWKD1120.cursor.keyword.mismatch.explanation=Les mots-cl\u00e9s tels que GROUP BY, HAVING, ORDER BY, EXCEPT, INTERSECT et UNION ne sont pas compatibles avec la pagination bas\u00e9e sur les curseurs.
CWWKD1120.cursor.keyword.mismatch.useraction=R\u00e9\u00e9crivez la requ\u00eate en n'incluant que les clauses SELECT, FROM et WHERE.

CWWKD1121.record.lacks.id=CWWKD1121E: L''enregistrement \u00ab {0} \u00bb ne peut pas \u00eatre utilis\u00e9 comme entit\u00e9, car il ne dispose pas d''un identifiant unique. L''un des composants de l''enregistrement ( {1} ) doit \u00eatre nomm\u00e9 \u00ab id \u00bb, avoir un nom se terminant par \u00ab _id \u00bb, \u00ab Id \u00bb ou \u00ab ID \u00bb, ou \u00eatre de type \u00ab java.util.UUID \u00bb.
CWWKD1121.record.lacks.id.explanation=Les entit\u00e9s doivent disposer d'un attribut d'identifiant unique.
CWWKD1121.record.lacks.id.useraction=Ajoutez ou renommez un composant d'enregistrement afin de respecter l'une des conventions indiqu\u00e9es pour l'attribution d'un identifiant unique.

CWWKD1122.entity.lacks.id=CWWKD1122E: La classe \u00ab {0} \u00bb ne peut pas \u00eatre utilis\u00e9e comme entit\u00e9, car elle ne dispose pas d''un identifiant unique. Pour attribuer un identifiant unique, assurez-vous que la fonctionnalit\u00e9 \u00ab {1} \u00bb est activ\u00e9e, ajoutez l''annotation @ jakarta.persistence.Entity \u00e0 la classe d''entit\u00e9 et ajoutez l''annotation @ jakarta.persistence.Id \u00e0 un seul champ ou \u00e0 une seule m\u00e9thode getter de la classe d''entit\u00e9. Vous pouvez \u00e9galement utiliser un fichier \u00ab META-INF/orm.xml \u00bb pour d\u00e9finir l''entit\u00e9 et son identifiant unique.
CWWKD1122.entity.lacks.id.explanation=Les entit\u00e9s doivent disposer d'un attribut d'identifiant unique.
CWWKD1122.entity.lacks.id.useraction=Activez la fonctionnalit\u00e9 Jakarta Persistence et suivez le mod\u00e8le d'entit\u00e9s de Jakarta Persistence pour attribuer un identifiant unique.

CWWKD1123.sort.incompat.with.cursor=CWWKD1123E: Il est impossible de d\u00e9terminer un curseur pour la page de r\u00e9sultats demand\u00e9e, car l''un des crit\u00e8res de tri fournis \u00e0 la m\u00e9thode ` {0} ` du r\u00e9f\u00e9rentiel ` {1} ` n''est pas un attribut d''entit\u00e9 : {2}. Utilisez la m\u00e9thode ` {3} ` pour cr\u00e9er un curseur r\u00e9pondant aux crit\u00e8res de tri, puis transmettez ce curseur \u00e0 la m\u00e9thode ` afterCursor ` ou ` beforeCursor ` d''une classe de type ` PageRequest `. Vous pouvez \u00e9galement modifier les crit\u00e8res de tri pour n''inclure que les noms des attributs d''entit\u00e9. Les noms d''attributs valides pour la classe d''entit\u00e9 \u00ab {4} \u00bb sont : {5}.
CWWKD1123.sort.incompat.with.cursor.explanation=Pour cr\u00e9er automatiquement un curseur en fonction des crit\u00e8res de tri, chacun de ces crit\u00e8res doit \u00eatre bas\u00e9 sur le nom d'un seul attribut d'entit\u00e9.
CWWKD1123.sort.incompat.with.cursor.useraction=Indiquez un curseur qui corresponde aux crit\u00e8res de tri. Vous pouvez \u00e9galement passer \u00e0 une pagination par d\u00e9calage ou modifier les crit\u00e8res de tri pour ne trier qu'en fonction des attributs de l'entit\u00e9.
