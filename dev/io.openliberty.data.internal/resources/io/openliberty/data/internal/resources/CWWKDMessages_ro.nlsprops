#CMVCPATHNAME io.openliberty.data.internal/resources/io/openliberty/data/internal/persistence/resources/CWWKDMessages.nlsprops
#ISMESSAGEFILE TRUE
#NLS_ENCODING=UNICODE
#
#COMPONENTPREFIX CWWKD
#COMPONENTNAMEFOR CWWKD Jakarta Data
#
# NLS_MESSAGEFORMAT_VAR
#
#   Strings in this file which contain replacement variables are processed by the MessageFormat 
#   class (single quote must be coded as 2 consecutive single quotes ''). Strings in this file 
#   which do NOT contain replacement variables are NOT processed by the MessageFormat class 
#   (single quote must be coded as one single quote '). 

# All messages must use the range CWWKD1000 to CWWKD1399

CWWKD1000.repo.general.err=CWWKD1000E: Metoda \u201e {0} \u201d a interfe\u021bei depozitului \u201e {1} \u201d a \u00eent\u00e2mpinat o eroare. Eroarea ar putea indica faptul c\u0103 metoda de stocare nu este valid\u0103. Eroarea este: {2}.
CWWKD1000.repo.general.err.explanation=S-a detectat o eroare la metoda de depozit specificat\u0103.
CWWKD1000.repo.general.err.useraction=Identifica\u021bi interfa\u021ba \u0219i metoda depozitului \u0219i stabili\u021bi dac\u0103 sunt necesare corecturi.

CWWKD1001.no.primary.entity=CWWKD1001E: Metoda de tip \u201erepository\u201d de tip \u201e {0} \u201d necesit\u0103 o clas\u0103 de entitate, \u00eens\u0103 interfa\u021ba de tip \u201erepository\u201d de tip \u201e {1} \u201d nu specific\u0103 o clas\u0103 de entitate principal\u0103. Pentru a remedia aceast\u0103 eroare, interfa\u021ba depozitului \u201e {1} \u201d poate extinde unul dintre supertipurile de depozit \u00eencorporate, cum ar fi \u201e {2} \u201d, \u0219i poate furniza clasa entit\u0103\u021bii ca primul parametru de tip.
CWWKD1001.no.primary.entity.explanation=Metodele de tip \u201erepository\u201d care nu au o clas\u0103 de entitate proprie necesit\u0103 ca \u201erepository\u201d-ul s\u0103 defineasc\u0103 o clas\u0103 de entitate principal\u0103.
CWWKD1001.no.primary.entity.useraction=Defini\u021bi o clas\u0103 de entitate principal\u0103 pentru depozit.

CWWKD1002.method.annos.err=CWWKD1002E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` este adnotat\u0103 cu o combina\u021bie de adnot\u0103ri care nu este valid\u0103: {2}.
CWWKD1002.method.annos.err.explanation=Aceast\u0103 combina\u021bie de adnot\u0103ri nu este valabil\u0103 pentru o singur\u0103 metod\u0103 de depozit.
CWWKD1002.method.annos.err.useraction=Identifica\u021bi interfa\u021ba \u0219i metoda depozitului \u0219i stabili\u021bi combina\u021bia corect\u0103 de adnot\u0103ri ale metodei.

CWWKD1003.rtrn.err=CWWKD1003E: Tipul de returnare \u201e {0} \u201d al metodei \u201e {1} \u201d din interfa\u021ba de depozit \u201e {2} \u201d nu este un tip de returnare valid pentru o metod\u0103 de tip \u201e {3} \u201d a unui depozit. Tipurile de returnare valabile includ: {4}
CWWKD1003.rtrn.err.explanation=Tipul de returnare al metodei nu se num\u0103r\u0103 printre tipurile de returnare acceptate pentru tipul specificat al metodei de depozit.
CWWKD1003.rtrn.err.useraction=Consulta\u021bi documenta\u021bia Javadoc pentru Jakarta Data referitoare la adnot\u0103rile Insert, Update \u0219i Save, precum \u0219i documenta\u021bia privind interogarea dup\u0103 numele metodei pentru a afla tipurile de date valabile returnate.

CWWKD1004.general.rtrn.err=CWWKD1004E: Tipul de returnare \u201e {0} \u201d al metodei \u201e {1} \u201d din interfa\u021ba de depozit \u201e {2} \u201d nu este un tip de returnare valid pentru o metod\u0103 de depozit.
CWWKD1004.general.rtrn.err.explanation=Tipul de returnare al metodei nu se num\u0103r\u0103 printre tipurile de returnare acceptate pentru tipul metodei de depozit.
CWWKD1004.general.rtrn.err.useraction=Consulta\u021bi documenta\u021bia Javadoc Jakarta Data pentru o list\u0103 a tipurilor de returnare valide pentru metoda de tip \u201erepository\u201d.

CWWKD1005.find.rtrn.err=CWWKD1005E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` nu este valid\u0103. Metoda specific\u0103 un tip de returnare de tip \u201e {2} \u201d care nu poate fi convertit din tipul de entitate \u201e {3} \u201d. Tipul rezultatului unei opera\u021biuni de c\u0103utare trebuie s\u0103 fie tipul entit\u0103\u021bii, un tip de atribut al entit\u0103\u021bii ales prin adnotarea Select, un \u00eenregistrare Java compus\u0103 din atribute ale entit\u0103\u021bii sau un tip selectat de interogarea furnizat\u0103 adnot\u0103rii Query. Tipul de returnare al metodei `find` a depozitului poate fi tipul rezultatului, un tablou de tipul rezultatului sau oricare dintre urm\u0103toarele tipuri parametrizate cu tipul rezultatului: ` {4} `.
CWWKD1005.find.rtrn.err.explanation=Tipul de returnare al metodei nu se num\u0103r\u0103 printre tipurile de returnare acceptate pentru metodele de c\u0103utare ale depozitului.
CWWKD1005.find.rtrn.err.useraction=Consulta\u021bi documenta\u021bia Javadoc Jakarta Data pentru o list\u0103 a tipurilor de returnare valide pentru metodele de c\u0103utare ale depozitului.

CWWKD1006.delete.rtrn.err=CWWKD1006E: Tipul de returnare \u201e {0} \u201d al metodei \u201e {1} \u201d din interfa\u021ba de depozit \u201e {2} \u201d nu este un tip de returnare valid pentru o opera\u021biune de \u0219tergere. Tipul de returnare trebuie s\u0103 fie void, long, int, boolean, array, List sau Optional. Un tip de return de tip void nu returneaz\u0103 nicio valoare. Un tip de return de tip long sau int returneaz\u0103 num\u0103rul de \u0219tergeri. Un tip de returnare de tip boolean indic\u0103 dac\u0103 au fost \u0219terse entit\u0103\u021bi. Un tip de returnare de tip matrice, List\u0103 sau Optional, parametrizat fie cu o clas\u0103 de entit\u0103\u021bi de tip \u201e {3} \u201d, fie cu o clas\u0103 de identificatori unici de tip \u201e {4} \u201d, returneaz\u0103 entit\u0103\u021bile \u0219terse sau ID-urile entit\u0103\u021bilor.
CWWKD1006.delete.rtrn.err.explanation=Tipul de returnare al metodei nu se num\u0103r\u0103 printre tipurile de returnare acceptate pentru o opera\u021biune de \u0219tergere.
CWWKD1006.delete.rtrn.err.useraction=Actualiza\u021bi metoda de stocare pentru a utiliza unul dintre tipurile de returnare acceptate.

CWWKD1007.updel.rtrn.err=CWWKD1007E: Tipul de returnare \u201e {0} \u201d al metodei \u201e {1} \u201d din interfa\u021ba de depozit \u201e {2} \u201d nu este un tip de returnare valid pentru o opera\u021biune de tip \u201e {3} \u201d a unui depozit. Tipul de returnare trebuie s\u0103 fie fie void, long, int sau boolean. Un tip de return de tip void nu returneaz\u0103 nicio valoare. Un tip de return de tip long sau int returneaz\u0103 num\u0103rul de entit\u0103\u021bi corespunz\u0103toare. Un tip de returnare de tip boolean indic\u0103 dac\u0103 exist\u0103 entit\u0103\u021bi care corespund.
CWWKD1007.updel.rtrn.err.explanation=Tipul de returnare al metodei nu se num\u0103r\u0103 printre tipurile de returnare acceptate pentru o opera\u021biune de actualizare sau \u0219tergere.
CWWKD1007.updel.rtrn.err.useraction=Actualiza\u021bi metoda de stocare pentru a utiliza unul dintre tipurile de returnare acceptate.

CWWKD1008.ambig.rtrn.err=CWWKD1008E: Tipul de returnare \u201e {0} \u201d al metodei \u201e {1} \u201d din interfa\u021ba de tip \u201e {2} \u201d este ambiguu, deoarece corespunde mai multor atribute ale entit\u0103\u021bii: {3}. Metoda de stocare trebuie s\u0103 treac\u0103 la adnotarea Query \u0219i s\u0103 utilizeze o interogare cu o clauz\u0103 SELECT care s\u0103 specifice ce atribut al entit\u0103\u021bii trebuie returnat.
CWWKD1008.ambig.rtrn.err.explanation=Tipul de returnare al metodei nu se num\u0103r\u0103 printre tipurile de returnare acceptate pentru o metod\u0103 de \u0219tergere.
CWWKD1008.ambig.rtrn.err.useraction=Actualiza\u021bi metoda de stocare pentru a utiliza adnotarea Query \u00een vederea select\u0103rii atributului entit\u0103\u021bii.

CWWKD1009.lifecycle.param.err=CWWKD1009E: Metoda ` {0} ` a interfe\u021bei ` {1} ` nu poate avea parametri de tip ` {2} `, deoarece metoda este adnotat\u0103 cu adnotarea de ciclu de via\u021b\u0103 ` {3} `. Metodele din depozit care sunt anotate cu o adnotare de ciclu de via\u021b\u0103 trebuie s\u0103 aib\u0103 exact un parametru, care trebuie s\u0103 fie entitatea sau un tablou sau o list\u0103 de entit\u0103\u021bi.
CWWKD1009.lifecycle.param.err.explanation=Metodele de ciclu de via\u021b\u0103 trebuie s\u0103 aib\u0103 un singur parametru de tip entitate.
CWWKD1009.lifecycle.param.err.useraction=Actualiza\u021bi metoda de stocare astfel \u00eenc\u00e2t s\u0103 accepte un singur parametru, care poate fi o entitate, un tablou de entit\u0103\u021bi sau o list\u0103 de entit\u0103\u021bi.

CWWKD1010.unknown.entity.attr=CWWKD1010E: Nu s-a g\u0103sit un atribut al entit\u0103\u021bii numit \u201e {0} \u201d \u00een clasa de entitate \u201e {1} \u201d pentru metoda \u201e {2} \u201d a interfe\u021bei de depozit \u201e {3} \u201d. Numele de atribute valide pentru entitate sunt: {4}.
CWWKD1010.unknown.entity.attr.explanation=Metoda \u201erepository\u201d \u00eencearc\u0103 s\u0103 utilizeze un atribut al entit\u0103\u021bii care nu exist\u0103.
CWWKD1010.unknown.entity.attr.useraction=Actualiza\u021bi metoda de stocare pentru a corespunde unui atribut valid definit de entitate.

CWWKD1011.unknown.method.pattern=CWWKD1011E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` nu corespunde niciunui model definit de Jakarta Data. O metod\u0103 de tip \u201erepository\u201d trebuie fie s\u0103 utilizeze adnot\u0103ri, fie s\u0103 fie o metod\u0103 de accesare a resurselor, fie s\u0103 fie denumit\u0103 conform modelului \u201eQuery by Method Name\u201d. Adnot\u0103rile de tipul \u201e {2} \u201d sunt utilizate pentru a defini opera\u021biuni. O metod\u0103 de accesare a resurselor nu trebuie s\u0103 con\u021bin\u0103 parametri \u0219i trebuie s\u0103 aib\u0103 unul dintre tipurile de returnare de tipul \u201e {3} \u201d. Modelul \u201eInterogare dup\u0103 numele metodei\u201d trebuie s\u0103 \u00eenceap\u0103 cu unul dintre cuvintele-cheie \u201e {4} \u201d, urmat de zero sau mai multe caractere. Numele metodelor pot include, de asemenea, cuv\u00e2ntul-cheie \u201eBy\u201d \u0219i una sau mai multe condi\u021bii delimitate. Exemple de nume valide pentru metodele de depozita\
    re sunt: {5}.
CWWKD1011.unknown.method.pattern.explanation=Metodele de tip \u201erepository\u201d trebuie s\u0103 respecte modelele definite de Jakarta Data.
CWWKD1011.unknown.method.pattern.useraction=Actualiza\u021bi metoda de gestionare a depozitului pentru a respecta unul dintre modelele din Jakarta Data.

CWWKD1012.fd.missing.param.anno=CWWKD1012E: Parametrul \u201e {0} \u201d al metodei \u201e {1} \u201d din interfa\u021ba depozitului \u201e {2} \u201d nu corespunde cu niciun atribut al entit\u0103\u021bii. Parametrii care nu corespund unui atribut al entit\u0103\u021bii trebuie s\u0103 fie marca\u021bi cu adnotarea \u201eBy\u201d sau s\u0103 aib\u0103 unul dintre tipurile speciale de parametri: {3}. Pentru a defini o condi\u021bie de filtrare a rezultatelor interog\u0103rii, parametrul trebuie s\u0103 fie marcat cu adnotarea \u201eBy\u201d, iar valoarea adnot\u0103rii \u201eBy\u201d trebuie s\u0103 fie numele atributului entit\u0103\u021bii. Alternativ, activa\u021bi op\u021biunea de compilare -parameters \u0219i atribui\u021bi parametrului acela\u0219i nume ca \u0219i atributul entit\u0103\u021bii.
CWWKD1012.fd.missing.param.anno.explanation=Parametrii metodelor de c\u0103utare \u0219i \u0219tergere din depozitul de date trebuie s\u0103 corespund\u0103 atributelor entit\u0103\u021bii sau s\u0103 fie tipuri speciale de parametri defini\u021bi de Jakarta Data.
CWWKD1012.fd.missing.param.anno.useraction=Actualiza\u021bi metoda de stocare astfel \u00eenc\u00e2t to\u021bi parametrii s\u0103 corespund\u0103 atributelor entit\u0103\u021bii sau s\u0103 aib\u0103 unul dintre tipurile speciale de parametri Jakarta Data.

CWWKD1013.cde.missing.param.anno=CWWKD1013E: Parametrul \u201e {0} \u201d al metodei \u201e {1} \u201d din interfa\u021ba depozitului \u201e {2} \u201d nu corespunde cu niciun atribut al entit\u0103\u021bii. Parametrii care nu corespund unui atribut al entit\u0103\u021bii trebuie s\u0103 fie marca\u021bi cu adnotarea \u201eBy\u201d, iar valoarea adnot\u0103rii \u201eBy\u201d trebuie s\u0103 fie setat\u0103 ca numele atributului entit\u0103\u021bii. Alternativ, activa\u021bi op\u021biunea de compilare -parameters \u0219i atribui\u021bi parametrului acela\u0219i nume ca \u0219i atributul entit\u0103\u021bii.
CWWKD1013.cde.missing.param.anno.explanation=Parametrii metodelor de num\u0103rare, \u0219tergere \u0219i verificare a existen\u021bei din depozit trebuie s\u0103 corespund\u0103 atributelor entit\u0103\u021bii.
CWWKD1013.cde.missing.param.anno.useraction=Actualiza\u021bi metoda de stocare astfel \u00eenc\u00e2t to\u021bi parametrii s\u0103 corespund\u0103 atributelor entit\u0103\u021bii.

CWWKD1014.upd.missing.param.anno=CWWKD1014E: Metoda \u201e {0} \u201d din depozitul \u201e {1} \u201d nu este o metod\u0103 valid\u0103 de actualizare a ciclului de via\u021b\u0103, deoarece aceast\u0103 metod\u0103 are parametri de tip \u201e {2} \u201d. Metodele din depozit care sunt anotate cu o adnotare de ciclu de via\u021b\u0103 trebuie s\u0103 aib\u0103 exact un parametru, care trebuie s\u0103 fie entitatea, un tablou de entit\u0103\u021bi sau o list\u0103 de entit\u0103\u021bi. Nici metoda \u201e {0} \u201d nu este o opera\u021biune valid\u0103 de actualizare bazat\u0103 pe parametri, deoarece parametrul metodei \u201e {3} \u201d nu are o adnotare ( {4} ) care s\u0103 indice numele atributului entit\u0103\u021bii. Alternativ, activa\u021bi op\u021biunea de compilare -parameters \u0219i atribui\u021bi parametrului acela\u0219i nume ca \u0219i atributul entit\u0103\u021bii.
CWWKD1014.upd.missing.param.anno.explanation=Parametrii metodelor de actualizare a depozitului trebuie s\u0103 corespund\u0103 atributelor entit\u0103\u021bii. Alternativ, metodele legate de ciclul de via\u021b\u0103 trebuie s\u0103 aib\u0103 un singur parametru de tip entitate.
CWWKD1014.upd.missing.param.anno.useraction=Actualiza\u021bi metoda de stocare astfel \u00eenc\u00e2t to\u021bi parametrii s\u0103 corespund\u0103 atributelor entit\u0103\u021bii. Alternativ, actualiza\u021bi metoda de tip \u201erepository\u201d astfel \u00eenc\u00e2t s\u0103 accepte un singur parametru, care poate fi o entitate, un tablou de entit\u0103\u021bi sau o list\u0103 de entit\u0103\u021bi.

CWWKD1015.null.entity.param=CWWKD1015E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` nu accept\u0103 o entitate nul\u0103.
CWWKD1015.null.entity.param.explanation=Metodele legate de ciclul de via\u021b\u0103 necesit\u0103 o instan\u021b\u0103 de entitate care nu este nul\u0103.
CWWKD1015.null.entity.param.useraction=Actualiza\u021bi codul aplica\u021biei pentru a evita transmiterea unei valori nule a entit\u0103\u021bii c\u0103tre metoda din depozit.

CWWKD1016.incompat.entity.param=CWWKD1016E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` necesit\u0103 o entitate de tip ` {2} `, dar a fost furnizat\u0103 o valoare de tip ` {3} `.
CWWKD1016.incompat.entity.param.explanation=Metoda \u201ecycle de via\u021b\u0103\u201d accept\u0103 numai valori de tip entitate ale tipului declarat.
CWWKD1016.incompat.entity.param.useraction=Actualiza\u021bi codul aplica\u021biei pentru a furniza o valoare de entitate de acela\u0219i tip cu cel declarat de metoda din depozit.

CWWKD1017.dup.special.param=CWWKD1017E: Metoda \u201e {0} \u201d din depozitul \u201e {1} \u201d nu poate avea mai mul\u021bi parametri de tip \u201e {2} \u201d.
CWWKD1017.dup.special.param.explanation=Unii dintre parametrii speciali ai Jakarta Data, inclusiv \u201eLimit\u201d \u0219i \u201e PageRequest, \u201d, nu pot ap\u0103rea de mai multe ori \u00een semn\u0103tura unei metode din depozit.
CWWKD1017.dup.special.param.useraction=Actualiza\u021bi semn\u0103tura metodei \u201erepository\u201d astfel \u00eenc\u00e2t s\u0103 con\u021bin\u0103 cel mult o singur\u0103 apari\u021bie a tipului de parametru special \u201eJakarta Data\u201d.

CWWKD1018.confl.special.param=CWWKD1018E: Metoda \u201e {0} \u201d din depozitul \u201e {1} \u201d nu poate avea at\u00e2t parametrul \u201e {2} \u201d, c\u00e2t \u0219i parametrul \u201e {3} \u201d.
CWWKD1018.confl.special.param.explanation=Unii dintre parametrii speciali ai Jakarta Data, precum \u201eLimit\u201d \u0219i \u201e PageRequest, \u201d, nu pot fi combina\u021bi \u00eentr-o singur\u0103 semn\u0103tur\u0103 a metodei de depozitare.
CWWKD1018.confl.special.param.useraction=Actualiza\u021bi depozitul astfel \u00eenc\u00e2t s\u0103 nu se utilizeze ambele tipuri de parametri speciali Jakarta Data \u00een aceea\u0219i semn\u0103tur\u0103 de metod\u0103.

CWWKD1019.mixed.positional.named=CWWKD1019E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` nu poate accepta o interogare care combin\u0103 parametri pozi\u021bionali \u0219i parametri denumi\u021bi. Interfa\u021ba define\u0219te o combina\u021bie de parametri de pozi\u021bie {2} \u0219i parametri denumi\u021bi {3} {4} pentru valoarea adnot\u0103rii Query: {5}. O interogare cu parametri pozi\u021bionali trebuie s\u0103 fac\u0103 referire la fiecare parametru prin valoarea sa ordinal\u0103, \u00eencep\u00e2nd cu?1, iar parametrii metodei nu trebuie s\u0103 aib\u0103 adnotarea Param. \u00centr-o interogare cu parametri denumi\u021bi, fiecare parametru trebuie men\u021bionat prin numele s\u0103u, de exemplu {6}, iar parametrii metodei trebuie s\u0103 aib\u0103 adnotarea Param, de exemplu {7}. Alternativ, activarea op\u021biunii de compilare -parameters permite ca parametrii metodei s\u0103 indice parametrul numit prin potrivirea numelui acestuia, de exemplu, {8}.
CWWKD1019.mixed.positional.named.explanation=Interog\u0103rile cu parametri trebuie s\u0103 utilizeze fie to\u021bi parametrii numi\u021bi, fie to\u021bi parametrii pozi\u021bionali, nu o combina\u021bie a celor doi.
CWWKD1019.mixed.positional.named.useraction=Actualiza\u021bi metoda de stocare pentru a utiliza numai parametri numi\u021bi sau numai parametri pozi\u021bionali.

CWWKD1020.invalid.param.type=CWWKD1020E: Parametrii metodei \u201e {0} \u201d a interfe\u021bei depozitului \u201e {1} \u201d nu trebuie s\u0103 fie de tipul \u201e {2} \u201d, deoarece metoda depozitului este o opera\u021biune de tip \u201e {3} \u201d.
CWWKD1020.invalid.param.type.explanation=Acest tip de parametru nu este permis pentru acest tip de metod\u0103.
CWWKD1020.invalid.param.type.useraction=Actualiza\u021bi metoda de stocare pentru a defini un parametru de metod\u0103 pentru fiecare valoare necesar\u0103 unei compara\u021bii.

CWWKD1021.insufficient.params=CWWKD1021E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` are ` {2} ` parametri, dar condi\u021biile de interogare definite de aceast\u0103 metod\u0103 necesit\u0103 ` {3} ` parametri. Interogarea pentru aceast\u0103 metod\u0103 este: {4}.
CWWKD1021.insufficient.params.explanation=Condi\u021biile de interogare care definesc compara\u021bii \u00eentre valori necesit\u0103 un num\u0103r corespunz\u0103tor de parametri ai metodei din depozit pentru a furniza valorile respective.
CWWKD1021.insufficient.params.useraction=Actualiza\u021bi metoda de stocare pentru a defini un parametru de metod\u0103 pentru fiecare valoare necesar\u0103 unei compara\u021bii.

CWWKD1022.too.many.params=CWWKD1022E: Condi\u021biile de interogare ale metodei ` {0} ` din interfa\u021ba depozitului ` {1} ` necesit\u0103 {2} parametri, dar semn\u0103tura metodei depozitului are {3} parametri. Interogarea pentru aceast\u0103 metod\u0103 este: {4}.
CWWKD1022.too.many.params.explanation=Condi\u021biile de interogare care definesc compara\u021bii \u00eentre valori necesit\u0103 un num\u0103r corespunz\u0103tor de parametri ai metodei din depozit pentru a furniza valorile respective. Nu sunt permise parametri suplimentari.
CWWKD1022.too.many.params.useraction=Actualiza\u021bi semn\u0103tura metodei din depozitul de cod pentru a elimina parametrii suplimentari care nu corespund condi\u021biilor declarate.

CWWKD1023.extra.param=CWWKD1023E: Condi\u021biile de interogare ale metodei \u201e {0} \u201d din interfa\u021ba depozitului \u201e {1} \u201d necesit\u0103 parametrii \u201e {2} \u201d, \u00eens\u0103 metoda depozitului are un parametru suplimentar, \u201e {3} \u201d. Interogarea pentru aceast\u0103 metod\u0103 este: {4}.
CWWKD1023.extra.param.explanation=Condi\u021biile de interogare care definesc compara\u021bii \u00eentre valori necesit\u0103 un num\u0103r corespunz\u0103tor de parametri ai metodei din depozit pentru a furniza valorile respective. Nu sunt permise parametri suplimentari.
CWWKD1023.extra.param.useraction=Actualiza\u021bi semn\u0103tura metodei din depozitul de cod pentru a elimina parametrii suplimentari care nu corespund condi\u021biilor declarate.

CWWKD1024.missing.entity.attr=CWWKD1024E: Metodei ` {0} ` din interfa\u021ba depozitului ` {1} ` \u00eei lipse\u0219te un nume de atribut al entit\u0103\u021bii sau i s-a furnizat un parametru care nu con\u021bine un nume de atribut al entit\u0103\u021bii. Numele de atribute valide pentru clasa de entit\u0103\u021bi \u201e {2} \u201d sunt: {3}.
CWWKD1024.missing.entity.attr.explanation=Condi\u021biile de interogare \u0219i criteriile de sortare pentru o metod\u0103 de depozit trebuie s\u0103 includ\u0103 numele unui atribut al entit\u0103\u021bii.
CWWKD1024.missing.entity.attr.useraction=Verifica\u021bi declara\u021bia \u0219i utilizarea metodei de tip \u201erepository\u201d pentru a v\u0103 asigura c\u0103 pentru fiecare condi\u021bie de interogare \u0219i criteriu de sortare este specificat un nume de atribut al entit\u0103\u021bii.

CWWKD1025.missing.id.attr=CWWKD1025E: Clasa de entitate \u201e {0} \u201d, utilizat\u0103 de metoda \u201e {1} \u201d a interfe\u021bei de depozit \u201e {2} \u201d, nu are un atribut ID.
CWWKD1025.missing.id.attr.explanation=Metodele din baza de date care \u0219terg \u0219i returneaz\u0103 o entitate trebuie s\u0103 aib\u0103 un atribut ID.
CWWKD1025.missing.id.attr.useraction=Dac\u0103 entitatea nu dispune de un singur atribut pentru ID, defini\u021bi metode separate \u00een depozit care s\u0103 interogheze entitatea \u0219i s\u0103 o \u0219tearg\u0103.

CWWKD1026.ignore.case.not.text=CWWKD1026E: Atributul \u201e {0} \u201d al entit\u0103\u021bii \u201e {1} \u201d nu este un caracter sau o secven\u021b\u0103 de caractere; prin urmare, criteriile de sortare \u201e {2} \u201d nu trebuie s\u0103 specifice ignorarea majusculelor \u0219i minusculelor. Tipul atributului este \u201e {3} \u201d, iar acesta a fost transmis metodei \u201e {4} \u201d a interfe\u021bei de depozit \u201e {5} \u201d.
CWWKD1026.ignore.case.not.text.explanation=Sortarea f\u0103r\u0103 a \u021bine cont de majuscule \u0219i minuscule este posibil\u0103 doar \u00een cazul atributelor entit\u0103\u021bilor care con\u021bin text.
CWWKD1026.ignore.case.not.text.useraction=Asigura\u021bi-v\u0103 c\u0103 criteriile de sortare sunt aplicate atributului corect al entit\u0103\u021bii \u0219i elimina\u021bi instruc\u021biunea de ignorare a majusculelor \u0219i minusculelor dac\u0103 atributul entit\u0103\u021bii nu reprezint\u0103 text.

CWWKD1027.datastore.lacks.java.comp=CWWKD1027E: Una sau mai multe interfe\u021be de depozit ( {0} ) din artefactul aplica\u021biei {1} specific\u0103 o valoare {2} dataStore care nu corespunde unei referin\u021be la o surs\u0103 de date sau la o unitate de persisten\u021b\u0103, deoarece \u00eei lipse\u0219te prefixul spa\u021biului de nume java:comp/env/. Lua\u021bi \u00een considerare modificarea adnot\u0103rii \u201eRepository\u201d pentru a specifica \u201e {3} \u201d.
CWWKD1027.datastore.lacks.java.comp.explanation=Numele JNDI ale referin\u021belor la resursele surselor de date \u0219i ale referin\u021belor la unit\u0103\u021bile de persisten\u021b\u0103 trebuie s\u0103 includ\u0103 prefixul de spa\u021biu de nume \u201ejava:\u201d.
CWWKD1027.datastore.lacks.java.comp.useraction=Asigura\u021bi-v\u0103 c\u0103 valoarea stoc\u0103rii de date a adnot\u0103rii Repository include prefixul de spa\u021biu de nume \u201ejava:\u201d atunci c\u00e2nd valoarea indic\u0103 numele JNDI al unei referin\u021be la o surs\u0103 de date sau al unei referin\u021be la o unitate de persisten\u021b\u0103.

CWWKD1028.first.exceeds.max=CWWKD1028E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` solicit\u0103 primele rezultate de la ` {2} `, ceea ce dep\u0103\u0219e\u0219te num\u0103rul maxim permis de rezultate: {3}.
CWWKD1028.first.exceeds.max.explanation=Num\u0103rul maxim de rezultate ale interog\u0103rii este limitat de restric\u021biile sistemului \u0219i de valoarea specificat\u0103.
CWWKD1028.first.exceeds.max.useraction=Reduce\u021bi num\u0103rul maxim solicitat de rezultate ale interog\u0103rii la o valoare mai mic\u0103.

CWWKD1029.first.neg.or.zero=CWWKD1029E: Metoda \u201e {0} \u201d a interfe\u021bei depozitului \u201e {1} \u201d solicit\u0103 primele rezultate de la \u201e {2} \u201d. Num\u0103rul maxim de rezultate care trebuie returnate trebuie s\u0103 fie un num\u0103r pozitiv.
CWWKD1029.first.neg.or.zero.explanation=Num\u0103rul maxim de rezultate ale interog\u0103rii trebuie s\u0103 fie un num\u0103r pozitiv.
CWWKD1029.first.neg.or.zero.useraction=Actualiza\u021bi metoda de stocare pentru a specifica un num\u0103r maxim de rezultate.

CWWKD1030.ql.lacks.entity=CWWKD1030E: Numele entit\u0103\u021bii lipse\u0219te din interogarea \u201e {0} \u201d specificat\u0103 pentru metoda \u201e {1} \u201d a depozitului \u201e {2} \u201d. Pentru \u00eentreb\u0103ri legate de \u201e {3} \u201d, folosi\u021bi formularul: {4}.
CWWKD1030.ql.lacks.entity.explanation=Interogarea con\u021bine o clauz\u0103 care solicit\u0103 numele entit\u0103\u021bii.
CWWKD1030.ql.lacks.entity.useraction=Actualiza\u021bi interogarea pentru metoda de depozit astfel \u00eenc\u00e2t s\u0103 includ\u0103 numele entit\u0103\u021bii.

CWWKD1031.ql.similar.entity=CWWKD1031E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` specific\u0103 o interogare care necesit\u0103 un nume de entitate ` {2} ` care nu a fost g\u0103sit, dar care se potrive\u0219te foarte bine cu numele de entitate ` {3} `. Interogarea este: {4}.
CWWKD1031.ql.similar.entity.explanation=Este posibil ca interogarea s\u0103 con\u021bin\u0103 o eroare tipografic\u0103 \u00een ceea ce prive\u0219te denumirea entit\u0103\u021bii.
CWWKD1031.ql.similar.entity.useraction=Verifica\u021bi interogarea pentru a v\u0103 asigura c\u0103 se utilizeaz\u0103 numele corect al entit\u0103\u021bii.

CWWKD1032.ql.unknown.entity=CWWKD1032E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` specific\u0103 o interogare care necesit\u0103 un nume de entitate ` {2} ` care nu a fost g\u0103sit. Asigura\u021bi-v\u0103 c\u0103 \u201e {2} \u201d este numele unei entit\u0103\u021bi valide. Pentru ca entitatea s\u0103 poat\u0103 fi g\u0103sit\u0103, trebuie s\u0103 atribui\u021bi depozitului o metod\u0103 de ciclu de via\u021b\u0103 care s\u0103 fie adnotat\u0103 cu una dintre adnot\u0103rile de tip \u201e {3} \u201d \u0219i s\u0103 furniza\u021bi entitatea ca parametru al acesteia. O alt\u0103 op\u021biune este ca depozitul s\u0103 extind\u0103 interfa\u021ba ` DataRepository ` sau o alt\u0103 interfa\u021b\u0103 de depozit \u00eencorporat\u0103, cu clasa entit\u0103\u021bii ca prim\u0103 variabil\u0103 de tip. Interogarea este: {4}.
CWWKD1032.ql.unknown.entity.explanation=Este posibil ca interogarea s\u0103 con\u021bin\u0103 o eroare tipografic\u0103 \u00een ceea ce prive\u0219te denumirea entit\u0103\u021bii sau ca depozitul s\u0103 nu specifice clasa principal\u0103 a entit\u0103\u021bii.
CWWKD1032.ql.unknown.entity.useraction=Verifica\u021bi interogarea pentru a v\u0103 asigura c\u0103 se utilizeaz\u0103 numele corect al entit\u0103\u021bii. Verifica\u021bi defini\u021bia depozitului pentru a v\u0103 asigura c\u0103 este specificat\u0103 clasa de entitate primar\u0103 corect\u0103.

CWWKD1033.ql.orderby.disallowed=CWWKD1033E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` nu poate specifica o interogare care s\u0103 includ\u0103 o clauz\u0103 `ORDER BY`, deoarece metoda returneaz\u0103 un obiect de tip ` {2} `. Elimina\u021bi clauza ORDER BY \u0219i folosi\u021bi \u00een schimb adnotarea \u201e {3} \u201d pentru a specifica criterii de sortare statice. Interogarea este: {4}.
CWWKD1033.ql.orderby.disallowed.explanation=Clauza ORDER BY nu este compatibil\u0103 cu paginarea bazat\u0103 pe cursor.
CWWKD1033.ql.orderby.disallowed.useraction=\u00cenlocui\u021bi clauza ORDER BY cu adnot\u0103ri care specific\u0103 criteriile de sortare.

CWWKD1034.ql.req.end.in.where=CWWKD1034E: Interogarea specificat\u0103 de metoda ` {0} ` a interfe\u021bei de depozit ` {1} ` trebuie s\u0103 se \u00eencheie cu o clauz\u0103 `WHERE`, deoarece metoda returneaz\u0103 un obiect de tip ` {2} `. Clauza WHERE se termin\u0103 la pozi\u021bia {3}, dar lungimea interog\u0103rii este {4}. Interogarea este: {5}.
CWWKD1034.ql.req.end.in.where.explanation=Clauza WHERE este obligatorie atunci c\u00e2nd se utilizeaz\u0103 paginarea bazat\u0103 pe cursor.
CWWKD1034.ql.req.end.in.where.useraction=Adaug\u0103 o clauz\u0103 WHERE la interogare.

CWWKD1035.incompat.page.mode=CWWKD1035E: O solicitare de pagin\u0103 cu modul de paginare {0} nu trebuie transmis\u0103 metodei {1} a interfe\u021bei de depozit {2}, deoarece metoda returneaz\u0103 {3} \u00een loc de {4}.
CWWKD1035.incompat.page.mode.explanation=Modul de paginare solicitat nu este compatibil cu tipul de returnare al metodei din depozit.
CWWKD1035.incompat.page.mode.useraction=Utiliza\u021bi tipul de retur \u201ePage\u201d pentru modul de paginare OFFSET \u0219i tipul de retur \u201e CursoredPage \u201d pentru modurile de paginare CURSOR_NEXT \u0219i CURSOR_PREVIOUS.

CWWKD1036.cursor.size.mismatch=CWWKD1036E: Un cursor cu elemente de tipul \u201e {0} \u201d care este transmis metodei \u201e {1} \u201d a interfe\u021bei de depozit \u201e {2} \u201d nu poate fi utilizat cu criterii de sortare de tipul \u201e {3} \u201d, deoarece num\u0103rul \u0219i ordinea elementelor cursorului trebuie s\u0103 corespund\u0103 criteriilor de sortare. Cursorul este format din: {4}. Criteriul de sortare este: {5}.
CWWKD1036.cursor.size.mismatch.explanation=Num\u0103rul elementelor cursorului trebuie s\u0103 corespund\u0103 dimensiunii criteriilor de sortare combinate ale metodei de depozitare.
CWWKD1036.cursor.size.mismatch.useraction=Modifica\u021bi elementele cursorului sau criteriile de sortare astfel \u00eenc\u00e2t ambele s\u0103 aib\u0103 aceea\u0219i dimensiune.

CWWKD1037.cursor.rtrn.mismatch=CWWKD1037E: Nu s-a putut ob\u021bine un cursor din rezultatul metodei ` {0} ` a metodei ` {1} ` a interfe\u021bei de depozit ` {2} `. Interog\u0103rile care utilizeaz\u0103 paginarea bazat\u0103 pe cursor trebuie s\u0103 returneze rezultate de acela\u0219i tip cu tipul entit\u0103\u021bii, \u0219i anume \u201e {3} \u201d. Tipul de returnare al metodei repository este de tip {4}
CWWKD1037.cursor.rtrn.mismatch.explanation=Paginare pe baza cursorului este posibil\u0103 numai atunci c\u00e2nd metoda de stocare returneaz\u0103 tipul de entitate.
CWWKD1037.cursor.rtrn.mismatch.useraction=Actualiza\u021bi metoda de recuperare a datelor din baza de date astfel \u00eenc\u00e2t s\u0103 returneze tipul entit\u0103\u021bii.

CWWKD1038.no.prev.offset.page=CWWKD1038E: Nu se poate solicita un num\u0103r de pagin\u0103 anterior celui de la {0} pentru metoda {1} a interfe\u021bei depozitului {2}, deoarece metoda Page.hasPrevious returneaz\u0103 valoarea false, indic\u00e2nd faptul c\u0103 nu exist\u0103 nicio pagin\u0103 anterioar\u0103.
CWWKD1038.no.prev.offset.page.explanation=Pagina\u021bia offset nu permite numere de pagin\u0103 mai mici dec\u00e2t 1.
CWWKD1038.no.prev.offset.page.useraction=Asigura\u021bi-v\u0103 c\u0103 num\u0103rul paginii solicitate este un num\u0103r pozitiv \u0219i utiliza\u021bi metoda ` Page.hasPrevious ` pentru a v\u0103 asigura c\u0103 este valid\u0103 solicitarea paginii anterioare.

CWWKD1039.no.prev.cursor.page=CWWKD1039E: Nu se poate solicita pagina anterioar\u0103 pentru metoda ` {0} ` a interfe\u021bei de depozit ` {1} `, deoarece metoda ` Page.hasPrevious ` returneaz\u0103 valoarea `false`, indic\u00e2nd faptul c\u0103 nu exist\u0103 o pagin\u0103 anterioar\u0103.
CWWKD1039.no.prev.cursor.page.explanation=Paginare bazat\u0103 pe cursor nu permite solicitarea unei pagini anterioare atunci c\u00e2nd se \u0219tie c\u0103 pagina curent\u0103 con\u021bine rezultatele de la \u00eenceputul setului de date.
CWWKD1039.no.prev.cursor.page.useraction=Folosi\u021bi metoda \u201e Page.hasPrevious \u201d pentru a v\u0103 asigura c\u0103 solicitarea paginii anterioare este valid\u0103.

CWWKD1040.no.next.page=CWWKD1040E: Nu se poate solicita pagina urm\u0103toare pentru metoda ` {0} ` a interfe\u021bei de depozit ` {1} `, deoarece ` {2} ` returneaz\u0103 valoarea `false`, indic\u00e2nd faptul c\u0103 nu exist\u0103 o pagin\u0103 urm\u0103toare.
CWWKD1040.no.next.page.explanation=Nu se poate solicita pagina urm\u0103toare atunci c\u00e2nd se \u0219tie c\u0103 pagina curent\u0103 con\u021bine sf\u00e2r\u0219itul setului de date.
CWWKD1040.no.next.page.useraction=Folosi\u021bi metoda ` hasNext ` pentru a v\u0103 asigura c\u0103 este valid\u0103 solicitarea paginii urm\u0103toare.

CWWKD1041.rtrn.mismatch.pagereq=CWWKD1041E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` are tipul de returnare ` {2} `, dar nu con\u021bine un parametru de tip ` PageRequest ` dup\u0103 parametrii condi\u021biilor de interogare.
CWWKD1041.rtrn.mismatch.pagereq.explanation=Metodele din depozit care au tipurile de returnare \u201ePage\u201d \u0219i \u201e CursoredPage \u201d trebuie s\u0103 aib\u0103 un parametru de tip \u201e PageRequest \u201d.
CWWKD1041.rtrn.mismatch.pagereq.useraction=Ad\u0103uga\u021bi un parametru de tip \u201e PageRequest \u201d la semn\u0103tura metodei din depozit.

CWWKD1042.no.totals=CWWKD1042E: Paginile preluate prin metoda ` {0} ` a interfe\u021bei de depozit ` {1} ` nu includ num\u0103rul total de elemente \u0219i pagini, deoarece solicitarea paginii ` {2} ` specific\u0103 valoarea `false` pentru ` requestTotal `. Pentru a solicita o pagin\u0103 care s\u0103 includ\u0103 num\u0103rul total, utiliza\u021bi metoda PageRequest.withTotal \u00een locul metodei PageRequest.withoutTotal.
CWWKD1042.no.totals.explanation=Metoda \u201e PageRequest.withoutTotal \u201d specific\u0103 faptul c\u0103 paginile solicitate nu includ num\u0103rul total de elemente \u0219i pagini.
CWWKD1042.no.totals.useraction=Folosi\u021bi metoda ` PageRequest.withTotal ` pentru a solicita num\u0103rul total de elemente \u0219i pagini.

CWWKD1043.offset.exceeds.max=CWWKD1043E: Valoarea offset-ului \u201e {0} \u201d necesar\u0103 pentru solicitarea paginii {1}, transmis\u0103 metodei {2} a interfe\u021bei de depozit {3}, dep\u0103\u0219e\u0219te valoarea maxim\u0103 permis\u0103 de {4}.
CWWKD1043.offset.exceeds.max.explanation=Combina\u021bia dintre num\u0103rul paginii \u0219i dimensiunea maxim\u0103 a paginii este prea mare.
CWWKD1043.offset.exceeds.max.useraction=Ad\u0103uga\u021bi criterii de filtrare la interogare pentru a reduce num\u0103rul de rezultate corespunz\u0103toare.

CWWKD1044.invalid.resource.type=CWWKD1044E: Metoda de accesare a resurselor ` {0} ` din depozitul ` {1} ` nu poate returna o resurs\u0103 de tip ` {2} `. Tipurile de returnare acceptate pentru metodele de acces la resurse sunt: {3}
CWWKD1044.invalid.resource.type.explanation=Tipul de returnare al metodei de accesare a resursei nu se num\u0103r\u0103 printre tipurile acceptate de Jakarta Data.
CWWKD1044.invalid.resource.type.useraction=Elimina\u021bi metoda sau modifica\u021bi-o astfel \u00eenc\u00e2t s\u0103 returneze unul dintre tipurile acceptate.

CWWKD1045.unknown.entity.anno=CWWKD1045E: Furnizorul de date Jakarta integrat nu poate oferi o implementare a interfe\u021bei de depozit \u201e {0} \u201d, deoarece clasa de entitate \u201e {1} \u201d, utilizat\u0103 de depozit, include o adnotare de entitate nerecunoscut\u0103. Urm\u0103toarele adnot\u0103ri de entitate se reg\u0103sesc \u00een clasa de entitate: {2}. Adnot\u0103rile acceptate pentru entit\u0103\u021bi sunt: {3}.
CWWKD1045.unknown.entity.anno.explanation=Furnizorul de date Jakarta integrat nu accept\u0103 una dintre adnot\u0103rile entit\u0103\u021bii.
CWWKD1045.unknown.entity.anno.useraction=Elimina\u021bi adnotarea entit\u0103\u021bii nerecunoscute sau utiliza\u021bi atributul \u201eprovider\u201d al adnot\u0103rii \u201eRepository\u201d pentru a selecta un furnizor de date Jakarta care recunoa\u0219te adnotarea entit\u0103\u021bii.

CWWKD1046.result.convert.err=CWWKD1046E: Rezultatul de tip \u201e {0} \u201d al metodei \u201e {1} \u201d din interfa\u021ba \u201e {2} \u201d a depozitului nu poate fi convertit \u00een tipul de returnare \u201e {3} \u201d al metodei depozitului.
CWWKD1046.result.convert.err.explanation=Valoarea rezultatului nu este compatibil\u0103 cu tipul de returnare al metodei din depozit.
CWWKD1046.result.convert.err.useraction=Asigura\u021bi-v\u0103 c\u0103 tipul de returnare al metodei din depozit corespunde cu tipul rezultatului returnat de interogare.

CWWKD1047.result.out.of.range=CWWKD1047E: Rezultatul de tip \u201e {0} \u201d al metodei \u201e {1} \u201d din interfa\u021ba \u201e {2} \u201d a depozitului nu poate fi convertit \u00een tipul de returnare \u201e {3} \u201d al metodei depozitului, deoarece rezultatul nu se \u00eencadreaz\u0103 \u00een intervalul de valori cuprins \u00eentre \u201e {4} \u201d \u0219i \u201e {5} \u201d.
CWWKD1047.result.out.of.range.explanation=Valoarea rezultatului nu este compatibil\u0103 cu tipul de returnare al metodei din depozit, deoarece se afl\u0103 \u00een afara intervalului de valori care pot fi convertite.
CWWKD1047.result.out.of.range.useraction=Modifica\u021bi tipul de returnare al metodei din depozit pentru a permite returnarea valorii.

CWWKD1048.result.exceeds.max=CWWKD1048E: Rezultatul de tip \u201e {0} \u201d al metodei \u201e {1} \u201d din interfa\u021ba \u201e {2} \u201d a depozitului nu poate fi convertit \u00een tipul de returnare \u201e {3} \u201d al metodei depozitului, deoarece valoarea rezultatului dep\u0103\u0219e\u0219te valoarea maxim\u0103 a \u201e {4} \u201d.
CWWKD1048.result.exceeds.max.explanation=Valoarea rezultatului nu este compatibil\u0103 cu tipul de returnare al metodei din depozit, deoarece dep\u0103\u0219e\u0219te valoarea maxim\u0103 care poate fi convertit\u0103 \u00een acel tip.
CWWKD1048.result.exceeds.max.useraction=Modifica\u021bi tipul de returnare al metodei din depozit pentru a permite returnarea valorii.

CWWKD1049.count.convert.err=CWWKD1049E: Valoarea de tip \u201ecount\u201d, de tip \u201e {0} \u201d, provenit\u0103 din metoda \u201e {1} \u201d a interfe\u021bei de depozit \u201e {2} \u201d, nu poate fi convertit\u0103 \u00een tipul de returnare \u201e {3} \u201d al metodei de depozit.
CWWKD1049.count.convert.err.explanation=Valoarea num\u0103rului nu este compatibil\u0103 cu tipul de returnare al metodei din depozit.
CWWKD1049.count.convert.err.useraction=Modifica\u021bi tipul de returnare al metodei din depozit pentru a permite returnarea valorii.

CWWKD1050.opt.lock.exc=CWWKD1050E: Metoda \u201e {0} \u201d a interfe\u021bei depozitului \u201e {1} \u201d nu a g\u0103sit o entitate \u201e {2} \u201d care s\u0103 corespund\u0103 atributelor entit\u0103\u021bii: {3}. Asigura\u021bi-v\u0103 c\u0103 instan\u021ba entit\u0103\u021bii furnizat\u0103 metodei ` {0} ` se bazeaz\u0103 pe cea mai recent\u0103 versiune a entit\u0103\u021bii. Cea mai recent\u0103 versiune a entit\u0103\u021bii poate fi ob\u021binut\u0103 prin metoda `find` sau din valoarea rezultatului uneia dintre urm\u0103toarele metode de ciclu de via\u021b\u0103: ` {4} `.
CWWKD1050.opt.lock.exc.explanation=Nu s-a g\u0103sit nicio entitate corespunz\u0103toare.
CWWKD1050.opt.lock.exc.useraction=Dac\u0103 se preconizeaz\u0103 c\u0103 entitatea nu va fi g\u0103sit\u0103 \u00een baza de date, nu este necesar\u0103 nicio ac\u021biune. \u00cen caz contrar, asigura\u021bi-v\u0103 c\u0103 se utilizeaz\u0103 cea mai recent\u0103 versiune a entit\u0103\u021bii.

CWWKD1051.single.opt.lock.exc=CWWKD1051E: Metoda \u201e {0} \u201d a interfe\u021bei depozitului \u201e {1} \u201d nu a g\u0103sit nicio entitate \u201e {2} \u201d corespunz\u0103toare \u00een baza de date. Asigura\u021bi-v\u0103 c\u0103 instan\u021ba entit\u0103\u021bii furnizat\u0103 metodei ` {0} ` se bazeaz\u0103 pe cea mai recent\u0103 versiune a entit\u0103\u021bii. Cea mai recent\u0103 versiune a entit\u0103\u021bii poate fi ob\u021binut\u0103 prin metoda `find` sau din valoarea rezultatului uneia dintre urm\u0103toarele metode de ciclu de via\u021b\u0103: ` {3} `.
CWWKD1051.single.opt.lock.exc.explanation=Nu s-a g\u0103sit nicio entitate corespunz\u0103toare.
CWWKD1051.single.opt.lock.exc.useraction=Dac\u0103 se preconizeaz\u0103 c\u0103 entitatea nu va fi g\u0103sit\u0103 \u00een baza de date, nu este necesar\u0103 nicio ac\u021biune. \u00cen caz contrar, asigura\u021bi-v\u0103 c\u0103 se utilizeaz\u0103 cea mai recent\u0103 versiune a entit\u0103\u021bii.

CWWKD1052.multi.opt.lock.exc=CWWKD1052E: Metoda \u201e {0} \u201d a interfe\u021bei depozitului \u201e {1} \u201d nu a g\u0103sit entitatea \u201e {2} \u201d din entit\u0103\u021bile \u201e {3} \u201d \u0219i \u201e {4} \u201d \u00een baza de date. Asigura\u021bi-v\u0103 c\u0103 instan\u021bele entit\u0103\u021bilor furnizate metodei ` {0} ` se bazeaz\u0103 pe cea mai recent\u0103 versiune a fiec\u0103rei entit\u0103\u021bi. Cea mai recent\u0103 versiune a unei entit\u0103\u021bi poate fi ob\u021binut\u0103 prin metoda `find` sau din valoarea rezultatului uneia dintre urm\u0103toarele metode ale ciclului de via\u021b\u0103: ` {5} `.
CWWKD1052.multi.opt.lock.exc.explanation=Una sau mai multe dintre entit\u0103\u021bi nu au fost g\u0103site \u00een baza de date.
CWWKD1052.multi.opt.lock.exc.useraction=Dac\u0103 se preconizeaz\u0103 c\u0103 o entitate nu va fi g\u0103sit\u0103 \u00een baza de date, nu este necesar\u0103 nicio ac\u021biune. \u00cen caz contrar, asigura\u021bi-v\u0103 c\u0103 se utilizeaz\u0103 cea mai recent\u0103 versiune a fiec\u0103rei entit\u0103\u021bi.

CWWKD1053.empty.result=CWWKD1053E: Tipul de returnare \u201e {0} \u201d al metodei \u201e {1} \u201d din interfa\u021ba de depozit \u201e {2} \u201d nu permite returnarea unui rezultat gol. Dac\u0103 se a\u0219teapt\u0103 un rezultat gol, metoda de tip \u201erepository\u201d trebuie s\u0103 returneze un tablou sau unul dintre urm\u0103toarele tipuri de retur: {3}.
CWWKD1053.empty.result.explanation=Tipul de returnare al metodei din depozit nu permite returnarea unui rezultat gol.
CWWKD1053.empty.result.useraction=Actualizeaz\u0103 metoda de stocare pentru a utiliza unul dintre tipurile de returnare care pot reprezenta un rezultat gol.

CWWKD1054.non.unique.result=CWWKD1054E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` are tipul de returnare ` {2} `, care nu permite returnarea rezultatelor de tip ` {3} `. Pentru a limita rezultatele la un singur rezultat, utiliza\u021bi unul dintre urm\u0103toarele modele Jakarta Data: {4}.
CWWKD1054.non.unique.result.explanation=Tipul de returnare al metodei din depozit nu permite returnarea mai multor rezultate.
CWWKD1054.non.unique.result.useraction=Actualiza\u021bi metoda depozitului astfel \u00eenc\u00e2t s\u0103 utilizeze un tip de returnare care accept\u0103 mai multe rezultate sau actualiza\u021bi metoda depozitului astfel \u00eenc\u00e2t s\u0103 returneze cel mult un singur rezultat.

CWWKD1055.unsupported.entity.attr=CWWKD1055E: Atributul \u201e {0} \u201d al entit\u0103\u021bii \u201e {1} \u201d are un tip neacceptat: \u201e {2} \u201d. Jakarta Data accept\u0103 tipurile de enumerare Java, tipurile temporale \u201e {3} \u201d \u0219i urm\u0103toarele tipuri de baz\u0103: {4}. Furnizorul de date Jakarta integrat accept\u0103, de asemenea, anumite tipuri de date din Jakarta Persistence, cum ar fi elementele \u00eencorporabile. Alternativ, dac\u0103 utiliza\u021bi o entitate Jakarta Persistence, pute\u021bi ad\u0103uga adnotarea \u201e {5} \u201d la atributul \u201e {0} \u201d pentru a furniza o implementare \u201e AttributeConverter \u201d care converte\u0219te un tip neacceptat \u00eentr-un tip acceptat.
CWWKD1055.unsupported.entity.attr.explanation=Jakarta Data nu accept\u0103 tipul utilizat de atributul \u201eentity\u201d.
CWWKD1055.unsupported.entity.attr.useraction=Actualiza\u021bi atributul entit\u0103\u021bii pentru a utiliza unul dintre tipurile acceptate.

CWWKD1056.unsupported.keyword=CWWKD1056E: Metoda \u201e {0} \u201d a interfe\u021bei depozitului \u201e {1} \u201d are un nume care include cuv\u00e2ntul-cheie \u201e {2} \u201d, care nu este un cuv\u00e2nt-cheie acceptat \u00een cadrul modelului \u201eJakarta Data Query by Method Name\u201d.
CWWKD1056.unsupported.keyword.explanation=Numele metodei con\u021bine un cuv\u00e2nt-cheie care nu este recunoscut ca parte a modelului \u201eJakarta Data Query by Method Name\u201d acceptat.
CWWKD1056.unsupported.keyword.useraction=Redenumi\u021bi metoda \u201erepository\u201d pentru a elimina cuv\u00e2ntul-cheie neacceptat.

CWWKD1057.no.args.constr.inacc=CWWKD1057E: Tipul de returnare \u201e {0} \u201d al metodei \u201e {1} \u201d din interfa\u021ba de depozit \u201e {2} \u201d nu este valid pentru o metod\u0103 de depozit, deoarece clasa \u201e {3} \u201d nu dispune de un constructor public f\u0103r\u0103 parametri.
CWWKD1057.no.args.constr.inacc.explanation=Este necesar un constructor public f\u0103r\u0103 parametri pentru a converti rezultatul \u00een clasa specificat\u0103.
CWWKD1057.no.args.constr.inacc.useraction=Actualiza\u021bi metoda din depozit astfel \u00eenc\u00e2t s\u0103 aib\u0103 un tip de returnare acceptat de Jakarta Data sau s\u0103 fie o subclas\u0103 a interfe\u021bei Iterable cu un constructor public f\u0103r\u0103 parametri.

CWWKD1058.no.args.constr.err=CWWKD1058E: Tipul de returnare \u201e {0} \u201d al metodei \u201e {1} \u201d din interfa\u021ba de depozit \u201e {2} \u201d nu este valid pentru o metod\u0103 de depozit, deoarece constructorul clasei \u201e {3} \u201d a generat o eroare: \u201e {4} \u201d.
CWWKD1058.no.args.constr.err.explanation=Constructorul public f\u0103r\u0103 parametri a e\u0219uat din cauza unei erori.
CWWKD1058.no.args.constr.err.useraction=Remedia\u021bi eroarea din constructor sau actualiza\u021bi metoda din depozit pentru a utiliza un alt tip de returnare.

CWWKD1059.attr.cast.err=CWWKD1059E: Metoda ` {0} ` a interfe\u021bei ` {1} ` nu poate accesa atributul ` {2} ` al entit\u0103\u021bii ` {3} `, deoarece c\u00e2mpul sau metoda ` {4} ` a clasei ` {5} ` este incompatibil\u0103 cu o valoare de tip ` {6} `.
CWWKD1059.attr.cast.err.explanation=Un atribut al entit\u0103\u021bii sau un atribut asociat din ierarhia acesteia nu este compatibil cu tipul a\u0219teptat.
CWWKD1059.attr.cast.err.useraction=Analiza\u021bi modelul entit\u0103\u021bii \u0219i verifica\u021bi dac\u0103 pentru fiecare atribut sunt utilizate tipurile corespunz\u0103toare.

CWWKD1060.name.out.of.scope=CWWKD1060E: Interfa\u021ba de depozit \u201e {0} \u201d din aplica\u021bia \u201e {1} \u201d configureaz\u0103 o valoare de tip \u201e {2} \u201d pentru atributul \u201e {3} \u201d, \u00eens\u0103 numele de tip \u201e {3} \u201d nu sunt accesibile artefactului care furnizeaz\u0103 interfa\u021ba de depozit. Folosi\u021bi \u00een schimb un nume de tip \u201e {4} \u201d.
CWWKD1060.name.out.of.scope.explanation=Spa\u021biul de nume specificat nu este accesibil din artefactul \u00een care este definit\u0103 interfa\u021ba depozitului.
CWWKD1060.name.out.of.scope.useraction=Actualiza\u021bi adnotarea Repository pentru a specifica un nume de magazin de date care s\u0103 fie vizibil pentru modulul sau biblioteca care furnizeaz\u0103 interfa\u021ba de depozit.

CWWKD1061.comp.name.in.ejb=CWWKD1061E: Una sau mai multe interfe\u021be de depozit ( {0} ) definite \u00een modulul enterprise bean \u201e {1} \u201d al aplica\u021biei \u201e {2} \u201d configureaz\u0103 o valoare de tip \u201e {3} \u201d pentru atributul \u201e {4} \u201d. Cu toate acestea, modulele de tip \u201eenterprise bean\u201d nu au acces la numele de tip \u201e {5} \u201d. Folosi\u021bi un nume dintr-unul dintre urm\u0103toarele spa\u021bii de nume: {6}.
CWWKD1061.comp.name.in.ejb.explanation=Spa\u021biul de nume specificat nu este accesibil modulului Enterprise Bean \u00een care este definit\u0103 interfa\u021ba depozitului.
CWWKD1061.comp.name.in.ejb.useraction=Actualiza\u021bi adnotarea Repository pentru a specifica un nume de magazin de date vizibil pentru modulul enterprise bean care furnizeaz\u0103 interfa\u021ba de tip repository.

CWWKD1062.resource.not.found=CWWKD1062E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` nu poate localiza resursa ` {2} ` folosind filtrul ` {3} `.
CWWKD1062.resource.not.found.explanation=Resursa nu a fost g\u0103sit\u0103.
CWWKD1062.resource.not.found.useraction=Asigura\u021bi-v\u0103 c\u0103 resursa specificat\u0103 \u0219i toate celelalte resurse de care depinde exist\u0103 \u0219i sunt configurate corect.

CWWKD1063.unsupported.resource=CWWKD1063E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` nu poate ob\u021bine o resurs\u0103 de tip ` {2} `, deoarece furnizorul Jakarta Persistence nu accept\u0103 opera\u021biunea de \u201eunwrap\u201d care returneaz\u0103 o instan\u021b\u0103 de tip ` {3} `.
CWWKD1063.unsupported.resource.explanation=Furnizorul Jakarta Persistence nu accept\u0103 opera\u021biunea de \u201eunwrap\u201d care returneaz\u0103 tipul de resurs\u0103 specificat.
CWWKD1063.unsupported.resource.useraction=Elimina\u021bi metoda de acces la resurse care nu este acceptat\u0103 din interfa\u021ba depozitului.

CWWKD1064.datastore.error=CWWKD1064E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` nu poate accesa baza de date ` {2} ` a depozitului din cauza urm\u0103toarei erori: {3}.
CWWKD1064.datastore.error.explanation=A ap\u0103rut o eroare la \u00eencercarea de a accesa baza de date.
CWWKD1064.datastore.error.useraction=Asigura\u021bi-v\u0103 c\u0103 magazinul de date specificat \u0219i toate celelalte resurse de care depinde exist\u0103 \u0219i sunt configurate corect.

CWWKD1065.ddlgen.timeout=CWWKD1065E: Generarea DDL pentru una sau mai multe interfe\u021be de depozit ( {0} ) a e\u0219uat deoarece magazinul de date {1} nu a finalizat generarea DDL \u00een termen de {2} secunde pentru urm\u0103toarele entit\u0103\u021bi: {3}.
CWWKD1065.ddlgen.timeout.explanation=\u00cencercarea de generare a DDL a expirat \u0219i nu s-a finalizat.
CWWKD1065.ddlgen.timeout.useraction=Re\u00eencepe\u021bi generarea DDL atunci c\u00e2nd sistemul \u0219i baza de date nu sunt suprasolicitate.

CWWKD1066.ddlgen.failed=CWWKD1066E: Generarea DDL pentru una sau mai multe interfe\u021be de depozit ( {0} ) care utilizeaz\u0103 baza de date {1} a \u00eent\u00e2mpinat o eroare \u00een timpul gener\u0103rii DDL pentru urm\u0103toarele entit\u0103\u021bi: {2}. Eroarea este: {3}.
CWWKD1066.ddlgen.failed.explanation=\u00cencercarea de generare a DDL-ului a e\u0219uat \u0219i nu s-a finalizat.
CWWKD1066.ddlgen.failed.useraction=Analiza\u021bi eroarea \u0219i efectua\u021bi modific\u0103rile necesare la nivelul interfe\u021bei depozitului, al entit\u0103\u021bilor, al configura\u021biei magazinului de date sau al bazei de date.

CWWKD1067.ddlgen.emf.timeout=CWWKD1067E: Generarea DDL pentru una sau mai multe interfe\u021be de depozit ( {0} ) a e\u0219uat deoarece baza de date {1} nu era disponibil\u0103 sau nu a putut pune la dispozi\u021bie urm\u0103toarele entit\u0103\u021bi \u00een termen de {2} secunde: {3}.
CWWKD1067.ddlgen.emf.timeout.explanation=Timpul alocat pentru ob\u021binerea resurselor necesare gener\u0103rii DDL a expirat, iar opera\u021biunea nu s-a finalizat.
CWWKD1067.ddlgen.emf.timeout.useraction=Re\u00eencepe\u021bi generarea DDL atunci c\u00e2nd sistemul \u0219i baza de date nu sunt suprasolicitate.

CWWKD1068.entity.name.conflict=CWWKD1068E: Interfa\u021ba depozitului \u201e {0} \u201d con\u021bine mai multe entit\u0103\u021bi denumite \u201e {1} \u201d, care sunt furnizate de diferite clase: {2}. Utiliza\u021bi urm\u0103toarele adnot\u0103ri de entitate Jakarta Persistence pentru a atribui un nume unic de entitate \u0219i un nume de tabel fiec\u0103rei clase de entitate: {3}.
CWWKD1068.entity.name.conflict.explanation=Numele entit\u0103\u021bilor \u0219i ale tabelelor sunt deduse din numele clasei f\u0103r\u0103 calificativ sau sunt atribuite prin adnot\u0103rile Jakarta Persistence.
CWWKD1068.entity.name.conflict.useraction=Redenumi\u021bi entit\u0103\u021bile sau ad\u0103uga\u021bi adnot\u0103ri Jakarta Persistence pentru a rezolva \u00een mod explicit conflictul de nume.

CWWKD1069.record.entity.name.conflict=CWWKD1069E: Interfa\u021ba depozitului \u201e {0} \u201d con\u021bine mai multe entit\u0103\u021bi denumite \u201e {1} \u201d, care sunt furnizate de diferite clase: {2}. Atunci c\u00e2nd \u00eenregistr\u0103rile Java sunt utilizate ca entit\u0103\u021bi, trebuie s\u0103 fie posibil\u0103 ad\u0103ugarea sufixului \u201eEntity\u201d la numele entit\u0103\u021bii f\u0103r\u0103 a genera un conflict de nume. De exemplu: {2}.
CWWKD1069.record.entity.name.conflict.explanation=Numele entit\u0103\u021bilor \u0219i ale tabelelor sunt deduse din numele clasei f\u0103r\u0103 calificativ sau sunt atribuite prin adnot\u0103rile Jakarta Persistence.
CWWKD1069.record.entity.name.conflict.useraction=Redenumi\u021bi entit\u0103\u021bile sau trece\u021bi la entit\u0103\u021bile Jakarta Persistence pentru a rezolva conflictul de nume.

CWWKD1070.record.convert.err=CWWKD1070E: \u00cenregistrarea de tip \u201e {0} \u201d furnizat\u0103 metodei \u201e {1} \u201d a interfe\u021bei de depozit \u201e {2} \u201d nu poate fi utilizat\u0103 ca entitate din cauza urm\u0103toarei erori: {3}.
CWWKD1070.record.convert.err.explanation=Nu este posibil\u0103 utilizarea \u00eenregistr\u0103rii Java ca entitate.
CWWKD1070.record.convert.err.useraction=Defini\u021bi entitatea ca entitate Jakarta Persistence, \u00een loc s\u0103 utiliza\u021bi o entitate de tip \u00eenregistrare Java.

CWWKD1071.record.with.type.var=CWWKD1071E: \u00cenregistrarea \u201e {0} \u201d este utilizat\u0103 ca entitate de una sau mai multe dintre interfe\u021bele depozitului ( {1} ) din artefactul aplica\u021biei {2}, \u00eens\u0103 \u00eenregistrarea nu poate fi o entitate deoarece con\u021bine una sau mai multe variabile de tip: {3}.
CWWKD1071.record.with.type.var.explanation=Clasele de entit\u0103\u021bi nu pot con\u021bine variabile de tip generic.
CWWKD1071.record.with.type.var.useraction=Elimina\u021bi variabilele de tip din \u00eenregistrare.

CWWKD1072.record.comp.conflict=CWWKD1072E: \u00cenregistrarea \u201e {0} \u201d este utilizat\u0103 ca entitate de una sau mai multe dintre interfe\u021bele de depozit ( {1} ) din artefactul aplica\u021biei {2}, \u00eens\u0103 \u00eenregistrarea nu poate fi considerat\u0103 entitate deoarece at\u00e2t componenta {3}, c\u00e2t \u0219i componenta {4} se refer\u0103 la acela\u0219i nume de atribut de entitate.
CWWKD1072.record.comp.conflict.explanation=Numele atributelor entit\u0103\u021bilor trebuie s\u0103 fie unice, indiferent de majuscule \u0219i minuscule.
CWWKD1072.record.comp.conflict.useraction=Redenumi\u021bi una dintre componentele \u00eenregistr\u0103rii pentru a evita conflictul.

CWWKD1073.offset.exceeds.max=CWWKD1073E: Punctul de pornire al limitelor de tip \u201e {0} \u201d (Limit\u0103 de tip \u201e {1} \u201d) furnizat metodei \u201e {2} \u201d a interfe\u021bei de tip \u201e {3} \u201d a depozitului dep\u0103\u0219e\u0219te valoarea maxim\u0103 permis\u0103 de \u201e {4} \u201d.
CWWKD1073.offset.exceeds.max.explanation=Valoarea ini\u021bial\u0103 a limitei este prea mare.
CWWKD1073.offset.exceeds.max.useraction=Ad\u0103uga\u021bi criterii de filtrare la interogare pentru a reduce num\u0103rul de rezultate corespunz\u0103toare.

CWWKD1074.qbmn.incompat.keywords=CWWKD1074E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` nu trebuie s\u0103 combine cuv\u00e2ntul-cheie ` {2} ` cu cuv\u00e2ntul-cheie ` {3} ` \u00een aceea\u0219i condi\u021bie de tip \u201eInterogare dup\u0103 numele metodei\u201d.
CWWKD1074.qbmn.incompat.keywords.explanation=Cuvintele-cheie specificate pentru \u201eInterogare dup\u0103 numele metodei\u201d nu sunt compatibile \u00eentre ele.
CWWKD1074.qbmn.incompat.keywords.useraction=Redenumi\u021bi metoda astfel \u00eenc\u00e2t cuvintele-cheie s\u0103 nu fie combinate \u00een aceea\u0219i condi\u021bie.

CWWKD1075.entity.attr.conflict=CWWKD1075E: Entitatea \u201e {0} \u201d nu poate avea un atribut numit \u201e {1} \u201d \u0219i un atribut numit \u201e {2} \u201d, deoarece specifica\u021bia Jakarta Data consider\u0103 c\u0103 aceste nume sunt aliasuri pentru acela\u0219i atribut al entit\u0103\u021bii.
CWWKD1075.entity.attr.conflict.explanation=Exist\u0103 o coliziune \u00eentre numele a dou\u0103 atribute ale entit\u0103\u021bilor din cauza caracterului de subliniere.
CWWKD1075.entity.attr.conflict.useraction=Nu folosi\u021bi caracterul de subliniere \u00een numele atributelor entit\u0103\u021bilor.

CWWKD1076.repo.disposed=CWWKD1076E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` nu poate fi invocat\u0103 deoarece aplica\u021bia care define\u0219te depozitul s-a oprit. Instan\u021ba depozitului este {2}.
CWWKD1076.repo.disposed.explanation=Metodele depozitului nu trebuie utilizate \u00een afara ciclului de via\u021b\u0103 al aplica\u021biei care define\u0219te depozitul.
CWWKD1076.repo.disposed.useraction=Asigura\u021bi-v\u0103 c\u0103 metoda de tip \u201erepository\u201d nu este utilizat\u0103 \u00een afara domeniului de aplicare al aplica\u021biei care define\u0219te acest tip de metod\u0103.

CWWKD1077.defaultds.not.found=CWWKD1077E: Artefactul aplica\u021biei {0} dispune de una sau mai multe interfe\u021be de depozit ( {1} ) care utilizeaz\u0103 sau folosesc implicit magazinul de date {2}. Acest magazin de date trebuie configurat \u00een set\u0103rile serverului prin definirea unui element \u201e dataSource \u201d cu identificatorul \u201e DefaultDataSource \u201d. De exemplu, {3} Alternativ, se poate atribui valorii \u201e dataStore \u201d a adnot\u0103rii Repository identificatorul unui element databaseStore sau numele JNDI al unei referin\u021be la o surs\u0103 de date sau al unei referin\u021be la o unitate de persisten\u021b\u0103 accesibile artefactului aplica\u021biei. Un element \u201e databaseStore \u201d poate fi definit \u00een configura\u021bia serverului. De exemplu, {4} O component\u0103 a aplica\u021biei poate utiliza adnotarea \u201eResource\u201d pentru a defini o referin\u021b\u0103 la o surs\u0103 de date. De exemplu, {5}, care impune ca configura\u021bia serverulu\
    i s\u0103 includ\u0103 un element de configurare dataSource cu un atribut {6}. O component\u0103 a aplica\u021biei poate utiliza adnotarea \u201e PersistenceUnit \u201d pentru a defini o referin\u021b\u0103 la o unitate de persisten\u021b\u0103. De exemplu, {7}, care impune ca fi\u0219ierul \u201e persistence.xml \u201d s\u0103 con\u021bin\u0103 un element \u201epersistence-unit\u201d cu un atribut \u201ename\u201d corespunz\u0103tor. De exemplu, {8}
CWWKD1077.defaultds.not.found.explanation=Bazele de date Jakarta utilizeaz\u0103 \u00een mod implicit sursa de date implicit\u0103 a Jakarta EE, care trebuie configurat\u0103 \u00een set\u0103rile serverului.
CWWKD1077.defaultds.not.found.useraction=Configura\u021bi sursa de date implicit\u0103 Jakarta EE sau specifica\u021bi un alt magazin de date pentru depozit.

CWWKD1078.datastore.not.found=CWWKD1078E: Una sau mai multe interfe\u021be de depozit ( {0} ) din artefactul aplica\u021biei {1} specific\u0103 un magazin de date {2} care nu corespunde cu ID-ul unui element dataSource sau al unui element databaseStore din configura\u021bia serverului, sau nu corespunde cu numele JNDI al unei surse de date, al unei referin\u021be la o resurs\u0103 de surs\u0103 de date sau al unei referin\u021be la o unitate de persisten\u021b\u0103 accesibil\u0103 artefactului aplica\u021biei, sau una dintre resursele asociate nu este configurat\u0103 corect. Un element \u201e dataSource \u201d poate fi definit \u00een configura\u021bia serverului. De exemplu, {3}. \u00cen configura\u021bia serverului se poate defini un element de tip \u201e databaseStore \u201d. De exemplu, {4} O component\u0103 a aplica\u021biei poate utiliza adnotarea \u201eResource\u201d pentru a defini o referin\u021b\u0103 la o surs\u0103 de date. De exemplu, {5}, care impune ca configura\u021bia serverulu\
    i s\u0103 includ\u0103 un element de configurare dataSource cu un atribut {6}. O component\u0103 a aplica\u021biei poate utiliza adnotarea \u201e PersistenceUnit \u201d pentru a defini o referin\u021b\u0103 la o unitate de persisten\u021b\u0103. De exemplu, {7}, care impune ca fi\u0219ierul \u201e persistence.xml \u201d s\u0103 con\u021bin\u0103 un element \u201epersistence-unit\u201d cu un atribut \u201ename\u201d corespunz\u0103tor. De exemplu, {8}
CWWKD1078.datastore.not.found.explanation=Baza de date a unui depozit de date Jakarta poate fi ID-ul unui element \u201e dataSource \u201d sau al unui element \u201e databaseStore \u201d din configura\u021bia serverului, sau poate fi un nume JNDI al unei surse de date, al unei referin\u021be la o resurs\u0103 de surs\u0103 de date sau al unei referin\u021be la o unitate de persisten\u021b\u0103.
CWWKD1078.datastore.not.found.useraction=Asigura\u021bi-v\u0103 c\u0103 resursa este configurat\u0103 corect. Dac\u0103 utiliza\u021bi un nume JNDI, asigura\u021bi-v\u0103 c\u0103 domeniul de aplicare al acestuia permite accesul la resurs\u0103 din partea artefactului aplica\u021biei care furnizeaz\u0103 depozitul.

CWWKD1079.jndi.not.found=CWWKD1079E: Una sau mai multe interfe\u021be de depozit ( {0} ) din artefactul aplica\u021biei {1} specific\u0103 un magazin de date cu numele JNDI {2}, dar o surs\u0103 de date, o referin\u021b\u0103 la resursa sursei de date sau o referin\u021b\u0103 la unitatea de persisten\u021b\u0103 cu acel nume JNDI nu este accesibil\u0103 artefactului aplica\u021biei, sau una dintre resursele asociate nu este configurat\u0103 corect. O component\u0103 a aplica\u021biei poate utiliza adnotarea \u201eResource\u201d pentru a defini o referin\u021b\u0103 la o surs\u0103 de date. De exemplu, {3}, care indic\u0103 un element de configurare a serverului dataSource cu un atribut {4}. O component\u0103 a aplica\u021biei poate utiliza adnotarea \u201e PersistenceUnit \u201d pentru a defini o referin\u021b\u0103 la o unitate de persisten\u021b\u0103. De exemplu, {5}, care impune ca fi\u0219ierul \u201e persistence.xml \u201d s\u0103 con\u021bin\u0103 un element \u201epersistence-unit\u201d c\
    u un atribut \u201ename\u201d corespunz\u0103tor. De exemplu, {6} O component\u0103 a aplica\u021biei poate utiliza adnotarea DataSourceDefinition pentru a defini o surs\u0103 de date. Alternativ, un element de tip \u201e dataSource \u201d poate defini o surs\u0103 de date \u00een configura\u021bia serverului. De exemplu, {7}
CWWKD1079.jndi.not.found.explanation=Atunci c\u00e2nd magazinul de date al unui depozit Jakarta Data este setat s\u0103 utilizeze un nume JNDI al unei surse de date, o referin\u021b\u0103 la o resurs\u0103 de surs\u0103 de date sau o referin\u021b\u0103 la o unitate de persisten\u021b\u0103, numele JNDI trebuie s\u0103 fie accesibil artefactului aplica\u021biei care furnizeaz\u0103 depozitul, iar sursa de date sau unitatea de persisten\u021b\u0103 trebuie s\u0103 fie configurate corect.
CWWKD1079.jndi.not.found.useraction=Asigura\u021bi-v\u0103 c\u0103 resursa este configurat\u0103 corect \u0219i c\u0103 domeniul de aplicare al numelui JNDI permite accesul la resurs\u0103 din partea artefactului aplica\u021biei care furnizeaz\u0103 depozitul.

CWWKD1080.datastore.general.err=CWWKD1080E: Una sau mai multe interfe\u021be de depozit ( {0} ) din artefactul aplica\u021biei {1} nu sunt disponibile din cauza unei erori. Eroarea ar putea fi cauzat\u0103 de o problem\u0103 de configurare sau de faptul c\u0103 baza de date {2} a depozitului nu este disponibil\u0103. Eroarea este: {3}.
CWWKD1080.datastore.general.err.explanation=O eroare \u00eempiedic\u0103 utilizarea depozitelor specificate.
CWWKD1080.datastore.general.err.useraction=Identifica\u021bi interfe\u021bele depozitului \u0219i configura\u021bia bazei de date \u0219i efectua\u021bi modific\u0103rile necesare, dac\u0103 este cazul.

CWWKD1081.entity.general.err=CWWKD1081E: Din cauza unei erori, entitatea {0} nu este disponibil\u0103 pentru una sau mai multe interfe\u021be de depozit ( {1} ) care utilizeaz\u0103 magazinul de date {2}. Eroarea este {3}.
CWWKD1081.entity.general.err.explanation=O eroare \u00eempiedic\u0103 utilizarea entit\u0103\u021bii specificate.
CWWKD1081.entity.general.err.useraction=Identifica\u021bi entitatea \u0219i efectua\u021bi corec\u021biile necesare.

CWWKD1082.entity.classes.missing=CWWKD1082E: Unitatea de persisten\u021b\u0103 pentru magazinul de date {0} nu define\u0219te una sau mai multe clase de entit\u0103\u021bi ( {1} ) necesare uneia sau mai multor interfe\u021be de depozit ( {2} ) care utilizeaz\u0103 magazinul de date.
CWWKD1082.entity.classes.missing.explanation=Repozitoriile utilizeaz\u0103 clase de entit\u0103\u021bi care trebuie definite \u00een unitatea de persisten\u021b\u0103.
CWWKD1082.entity.classes.missing.useraction=Include\u021bi toate clasele de entit\u0103\u021bi \u00een unitatea de persisten\u021b\u0103.

CWWKD1083.dup.method.param=CWWKD1083E: Mai mul\u021bi parametri din metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` corespund parametrului numit: ` {2} `. Pute\u021bi ad\u0103uga o adnotare de tip \u201e {3} \u201d unui parametru al metodei pentru a specifica parametrul cu nume din limbajul de interogare. Alternativ, po\u021bi activa op\u021biunea de compilare -parameters \u0219i defini un parametru de metod\u0103 sub forma \u201e {4} \u201d, care nu necesit\u0103 adnotarea Param.
CWWKD1083.dup.method.param.explanation=Fiecare parametru al metodei trebuie s\u0103 corespund\u0103 exact unui singur parametru al interog\u0103rii.
CWWKD1083.dup.method.param.useraction=Verifica\u021bi dac\u0103 fiecare dintre parametrii metodei specific\u0103 parametrul numit corect. Elimina\u021bi parametrii de metod\u0103 duplicati. 
CWWKD1084.missing.named.params=CWWKD1084E: Parametrii metodei ` {0} ` din interfa\u021ba depozitului ` {1} ` nu definesc parametrii numi\u021bi ( {2} ) solicita\u021bi de valoarea adnot\u0103rii `Query`: {3}. Pute\u021bi defini un parametru cu nume pentru interogare prin plasarea adnot\u0103rii Param pe un parametru corespunz\u0103tor al metodei. De exemplu, {4}. Alternativ, dac\u0103 activa\u021bi op\u021biunea de compilare -parameters, pute\u021bi omite adnotarea Param dac\u0103 denumi\u021bi parametrul metodei astfel \u00eenc\u00e2t s\u0103 aib\u0103 acela\u0219i nume ca \u0219i parametrul numit. De exemplu, dac\u0103 String este tipul parametrului numit, parametrul metodei poate fi de tipul \u201e {5} \u201d, caz \u00een care nu este necesar\u0103 adnotarea Param.
CWWKD1084.missing.named.params.explanation=Valoarea adnot\u0103rii Query necesit\u0103 unul sau mai mul\u021bi parametri denumi\u021bi care nu sunt furniza\u021bi de metoda depozitului.
CWWKD1084.missing.named.params.useraction=Ad\u0103uga\u021bi parametri la metoda de depozitare pentru a specifica parametrii numi\u021bi care lipsesc.

CWWKD1085.extra.method.params=CWWKD1085E: Parametrii metodei ` {0} ` din interfa\u021ba depozitului ` {1} ` definesc parametrii de interogare ( {2} ), care nu corespund niciunui parametru numit ( {3} ) utilizat de valoarea adnot\u0103rii `Query`: {4}.
CWWKD1085.extra.method.params.explanation=To\u021bi parametrii metodei trebuie s\u0103 fie utiliza\u021bi de interogare sau s\u0103 fie de tipurile de parametri definite de Jakarta Data.
CWWKD1085.extra.method.params.useraction=Elimina\u021bi parametrii de metod\u0103 \u00een plus.

CWWKD1086.named.params.unused=CWWKD1086E: Parametrii metodei ` {0} ` din interfa\u021ba depozitului ` {1} ` definesc parametri cu nume ( {2} ), care nu sunt utiliza\u021bi \u00een valoarea adnot\u0103rii `Query`: {3}. Pute\u021bi face referire la parametrii cu nume \u00eentr-o interogare folosind caracterul : urmat de numele parametrului. De exemplu, {4}. Parametrii de pozi\u021bie dintr-o interogare pot fi indica\u021bi folosind simbolul? caracter urmat de o valoare ordinal\u0103, \u00eencep\u00e2nd cu?1. Evita\u021bi s\u0103 ad\u0103uga\u021bi adnotarea \u201eParam\u201d la parametrii metodelor atunci c\u00e2nd interogarea utilizeaz\u0103 parametri pozi\u021bionali sau nu are parametri.
CWWKD1086.named.params.unused.explanation=Adnotarea Param poate fi utilizat\u0103 numai atunci c\u00e2nd interogarea con\u021bine parametri denumi\u021bi.
CWWKD1086.named.params.unused.useraction=Elimina\u021bi adnotarea \u201eParam\u201d sau modifica\u021bi interogarea astfel \u00eenc\u00e2t s\u0103 utilizeze parametri denumi\u021bi.

CWWKD1087.null.param=CWWKD1087E: Parametrul \u201e {0} \u201d al metodei \u201e {1} \u201d din interfa\u021ba depozitului \u201e {2} \u201d are valoarea nul\u0103. Introduce\u021bi o valoare diferit\u0103 de nul.
CWWKD1087.null.param.explanation=Valoarea parametrului nu trebuie s\u0103 fie nul\u0103.
CWWKD1087.null.param.useraction=Specifica\u021bi o valoare diferit\u0103 de nul pentru acest parametru.

CWWKD1088.empty.sorts=CWWKD1088E: Criteriile de sortare specificate prin parametrul \u201e {0} \u201d al metodei \u201e {1} \u201d din interfa\u021ba depozitului \u201e {2} \u201d sunt goale.
CWWKD1088.empty.sorts.explanation=Criteriile de sortare nu trebuie s\u0103 fie goale.
CWWKD1088.empty.sorts.useraction=Specifica\u021bi o valoare pentru criteriile de sortare.

CWWKD1089.unordered.pagination=CWWKD1089E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` trebuie s\u0103 specifice criteriile de sortare, deoarece metoda returneaz\u0103 o valoare de tip ` {2} `. Datele neordonate nu pot fi \u00eemp\u0103r\u021bite \u00een pagini.
CWWKD1089.unordered.pagination.explanation=Paginarea necesit\u0103 date ordonate.
CWWKD1089.unordered.pagination.useraction=Utiliza\u021bi adnotarea \u201e OrderBy \u201d pentru a defini criteriile de sortare pentru metoda de tip \u201erepository\u201d.

CWWKD1090.orderby.conflict=CWWKD1090E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` nu poate combina adnotarea ` OrderBy ` cu cuv\u00e2ntul-cheie ` OrderBy `.
CWWKD1090.orderby.conflict.explanation=Adnotarea \u201e OrderBy \u201d nu este compatibil\u0103 cu cuv\u00e2ntul-cheie \u201e OrderBy \u201d.
CWWKD1090.orderby.conflict.useraction=Utiliza\u021bi numai adnotarea \u201e OrderBy \u201d sau cuv\u00e2ntul-cheie \u201e OrderBy \u201d.

CWWKD1091.method.name.parse.err=CWWKD1091E: Nu s-a g\u0103sit un atribut al entit\u0103\u021bii numit \u201e {0} \u201d \u00een clasa de entitate \u201e {1} \u201d pentru metoda \u201e {2} \u201d a interfe\u021bei de depozit \u201e {3} \u201d. Asigura\u021bi-v\u0103 c\u0103 metoda din depozit are fie un nume care respect\u0103 modelul \u201eInterogare dup\u0103 numele metodei\u201d, fie este adnotat\u0103 cu una dintre urm\u0103toarele: {4}. Numele de atribute valide pentru entitate sunt: {5}.
CWWKD1091.method.name.parse.err.explanation=Numele metodei din depozit a fost analizat conform modelului \u201eInterogare dup\u0103 numele metodei\u201d, deoarece metoda din depozit nu are o adnotare Jakarta Data care s\u0103 indice tipul opera\u021biunii.
CWWKD1091.method.name.parse.err.useraction=Corecta\u021bi numele metodei din depozit sau ad\u0103uga\u021bi o adnotare la metoda din depozit pentru a indica o opera\u021biune Jakarta Data, cum ar fi Query, Find sau Save.

CWWKD1092.lifecycle.arg.empty=CWWKD1092E: Metoda ` {0} ` din depozitul ` {1} ` nu accept\u0103 un parametru ` {2} ` gol. Valoarea parametrului trebuie s\u0103 con\u021bin\u0103 cel pu\u021bin o entitate.
CWWKD1092.lifecycle.arg.empty.explanation=Metodele Insert, Update, Save \u0219i Delete
 require cel pu\u021bin o entitate.
CWWKD1092.lifecycle.arg.empty.useraction=Asigura\u021bi-v\u0103 c\u0103 matricea, lista sau fluxul furnizat metodei con\u021bine cel pu\u021bin o entitate.

CWWKD1093.fn.not.applicable=CWWKD1093E: Func\u021bia \u201e {0} \u201d nu poate fi evaluat\u0103 pentru entitatea \u201e {1} \u201d utilizat\u0103 de metoda \u201e {2} \u201d a interfe\u021bei de depozit \u201e {3} \u201d. Entitatea nu are un atribut care s\u0103 fie marcat cu \u201e {4} \u201d sau din care s\u0103 se poat\u0103 deduce \u201e {0} \u201d.
CWWKD1093.fn.not.applicable.explanation=Func\u021bia nu poate fi utilizat\u0103 pentru entitate, deoarece aceasta nu are un atribut ID sau de versiune.
CWWKD1093.fn.not.applicable.useraction=Nu utiliza\u021bi func\u021bia \u00een limbajul de interogare sau \u00een parametrii metodei de stocare.

CWWKD1094.return.mismatch=CWWKD1094E: Metoda ` {0} ` a interfe\u021bei ` {1} ` are tipul de returnare ` {2} `, care nu permite returnarea num\u0103rului de entit\u0103\u021bi, ` {3} `, pe care metoda de tip depozit le accept\u0103 ca parametru. Tipurile de returnare valide pentru o metod\u0103 de tip \u201e {4} \u201d care accept\u0103 mai multe entit\u0103\u021bi includ: {5}.
CWWKD1094.return.mismatch.explanation=O metod\u0103 din ciclul de via\u021b\u0103 al unui depozit care returneaz\u0103 entit\u0103\u021bi trebuie s\u0103 poat\u0103 returna acela\u0219i num\u0103r de entit\u0103\u021bi pe care \u00eel accept\u0103 metoda.
CWWKD1094.return.mismatch.useraction=Actualiza\u021bi metoda de tip \u201erepository\u201d astfel \u00eenc\u00e2t s\u0103 utilizeze un tip de returnare care poate returna mai multe entit\u0103\u021bi sau actualiza\u021bi metoda de tip \u201erepository\u201d astfel \u00eenc\u00e2t s\u0103 accepte o singur\u0103 entitate.

CWWKD1095.repo.err=CWWKD1095E: Nu se poate furniza o implementare a interfe\u021bei de tip \u201e {0} \u201d din cauza unei erori. Adnotarea depozitului este {1}. Clasa principal\u0103 a entit\u0103\u021bilor este \u201e {2} \u201d. Eroarea este: {3}
CWWKD1095.repo.err.explanation=Furnizorul de date Jakarta integrat nu poate furniza o instan\u021b\u0103 a depozitului din cauza unei erori.
CWWKD1095.repo.err.useraction=Analiza\u021bi eroarea \u0219i remedia\u021bi problema la nivelul interfe\u021bei depozitului, al entit\u0103\u021bilor, al configura\u021biei magazinului de date sau al bazei de date.

CWWKD1096.orderby.incompat=CWWKD1096E: Metoda ` {0} ` din depozitul ` {1} ` are o adnotare ` OrderBy `, dar metoda ` {0} ` nu este o opera\u021biune de c\u0103utare sau de \u0219tergere care returneaz\u0103 entit\u0103\u021bi.
CWWKD1096.orderby.incompat.explanation=Adnotarea \u201e OrderBy \u201d nu este compatibil\u0103 cu tipul opera\u021biunii de depozit.
CWWKD1096.orderby.incompat.useraction=Elimina\u021bi adnotarea \u201e OrderBy \u201d.

CWWKD1097.param.incompat=CWWKD1097E: Metoda ` {0} ` din depozitul ` {1} ` are un parametru ` {2} `, dar metoda ` {0} ` nu este o opera\u021biune de c\u0103utare sau de \u0219tergere care returneaz\u0103 entit\u0103\u021bi.
CWWKD1097.param.incompat.explanation=Parametrii \u201eOrder\u201d, \u201eSort\u201d \u0219i \u201eLimit\u201d nu sunt compatibili cu acest tip de opera\u021biune de depozit.
CWWKD1097.param.incompat.useraction=Elimina\u021bi parametrul \u201eOrder\u201d, \u201eSort\u201d sau \u201eLimit\u201d.

CWWKD1098.spec.param.position.err=CWWKD1098E: Metoda ` {0} ` din depozitul ` {1} ` are un parametru ` {2} ` care este plasat \u00eenaintea parametrilor de interogare. Tipurile de parametri care au o semnifica\u021bie special\u0103 \u00een Jakarta Data ( {3} ) trebuie plasate dup\u0103 ceilal\u021bi parametri \u00een semn\u0103tura metodei din depozit.
CWWKD1098.spec.param.position.err.explanation=Atunci c\u00e2nd tipurile de parametri definite de Jakarta Data sunt incluse \u00een semn\u0103tura unei metode din depozit, acestea trebuie plasate dup\u0103 to\u021bi parametrii de interogare.
CWWKD1098.spec.param.position.err.useraction=Muta\u021bi tipurile de parametri defini\u021bi special \u00een Jakarta Data la sf\u00e2r\u0219itul semn\u0103turii metodei din depozit.

CWWKD1099.first.keyword.incompat=CWWKD1099E: Metoda \u201e {0} \u201d din depozitul \u201e {1} \u201d are un nume care include cuv\u00e2ntul-cheie \u201eFirst\u201d, ceea ce este incompatibil cu parametrul \u201e {2} \u201d al metodei.
CWWKD1099.first.keyword.incompat.explanation=O interogare de tip \u201eQuery by Method Name\u201d care include un parametru \u201eLimit\u201d sau \u201e PageRequest \u201d nu poate utiliza cuv\u00e2ntul-cheie \u201eFirst\u201d.
CWWKD1099.first.keyword.incompat.useraction=Elimina\u021bi cuv\u00e2ntul-cheie \u201eFirst\u201d din numele metodei.

CWWKD1100.cursor.requires.sort=CWWKD1100E: Metoda ` {0} ` din depozitul ` {1} ` returneaz\u0103 ` {2} `, dar nu are o adnotare ` OrderBy ` \u0219i niciunul dintre urm\u0103torii parametri pentru a specifica criteriile de sortare: ` {3} `. Criteriile de sortare sunt obligatorii pentru paginarea bazat\u0103 pe cursor \u0219i nu pot fi specificate \u00een clauza ORDER BY a unei valori a adnot\u0103rii Query.
CWWKD1100.cursor.requires.sort.explanation=Paginationa bazat\u0103 pe cursor necesit\u0103 criterii de sortare.
CWWKD1100.cursor.requires.sort.useraction=Elimin\u0103 clauza ORDER BY din valoarea adnot\u0103rii Query, dac\u0103 aceasta exist\u0103. Ad\u0103uga\u021bi o adnotare de tip \u201e OrderBy \u201d sau un parametru al metodei din depozit pentru a specifica criteriile de sortare.

CWWKD1101.attr.subset.mismatch=CWWKD1101E: Tipul de returnare \u201e {0} \u201d al metodei \u201e {1} \u201d din depozitul \u201e {2} \u201d utilizeaz\u0103 tipul de \u00eenregistrare Java \u201e {3} \u201d pentru a defini rezultatele ca fiind un subset al atributelor entit\u0103\u021bii: {4}. Cu toate acestea, cel pu\u021bin unul dintre numele atributelor solicitate nu este prezent \u00een entitatea \u201e {5} \u201d. Pentru a returna un subset de atribute ale entit\u0103\u021bii sub forma unui \u00eenregistrare Java, asigura\u021bi-v\u0103 c\u0103 numele componentelor \u00eenregistr\u0103rii se reg\u0103sesc \u00een urm\u0103torul set de nume de atribute valide pentru entitatea \u201e {5} \u201d: {6}. Alternativ, utiliza\u021bi adnotarea \u201eSelect\u201d pentru a atribui nume valide atributelor entit\u0103\u021bii. Pentru a returna un singur atribut al entit\u0103\u021bii care are un tip de \u00eenregistrare Java, ad\u0103uga\u021bi o adnotare \u201eSelect\u201d metodei \u201e {1} \u201d \u0219\
    i atribui\u021bi valoarea membrului acesteia numelui atributului entit\u0103\u021bii.
CWWKD1101.attr.subset.mismatch.explanation=Atunci c\u00e2nd se utilizeaz\u0103 \u00eenregistr\u0103ri Java pentru a prelua un subset de atribute ale entit\u0103\u021bii, toate componentele \u00eenregistr\u0103rii trebuie s\u0103 corespund\u0103 unor atribute valide ale entit\u0103\u021bii.
CWWKD1101.attr.subset.mismatch.useraction=Redenumi\u021bi componentele \u00eenregistr\u0103rii astfel \u00eenc\u00e2t s\u0103 corespund\u0103 cu nume valide de atribute ale entit\u0103\u021bii sau utiliza\u021bi adnotarea Select pentru a solicita \u00een mod explicit atributele entit\u0103\u021bii dup\u0103 numele lor.

CWWKD1102.incompat.query.result=CWWKD1102E: Metoda ` {0} ` din depozitul ` {1} ` are tipul de returnare ` {2} `, dar furnizorul Jakarta Persistence a efectuat o interogare cu rezultate de tipul ` {3} `. Verifica\u021bi dac\u0103 furnizorul de persisten\u021b\u0103 Jakarta permite interogarea tipurilor de atribute ale entit\u0103\u021bilor selectate de metoda ` {0} `. Verifica\u021bi dac\u0103 exist\u0103 alte cauze de incompatibilitate \u00een cazul \u00een care furnizorul Jakarta permite interogarea tipurilor de atribute ale entit\u0103\u021bilor selectate de metoda ` {0} `.
CWWKD1102.incompat.query.result.explanation=Furnizorii de servicii Persistence din Jakarta nu permit returnarea tuturor tipurilor de atribute ale entit\u0103\u021bilor. Dac\u0103 furnizorul din Jakarta returneaz\u0103 totu\u0219i tipul de atribute ale entit\u0103\u021bii selectat de metod\u0103, exist\u0103 o alt\u0103 cauz\u0103 de incompatibilitate. De exemplu, este posibil ca furnizorul Jakarta Persistence s\u0103 aib\u0103 o eroare sau ca semn\u0103tura metodei din depozit s\u0103 con\u021bin\u0103 o eroare.
CWWKD1102.incompat.query.result.useraction=Dac\u0103 tipul de atribute ale entit\u0103\u021bii selectate de metod\u0103 nu este permis, modifica\u021bi interogarea pentru a prelua \u00eentreaga entitate sau un set diferit de atribute ale entit\u0103\u021bii permise de furnizorul Jakarta Persistence. Dac\u0103 tipul atributelor entit\u0103\u021bii selectate de metod\u0103 este permis, verifica\u021bi dac\u0103 exist\u0103 alte cauze de incompatibilitate.

CWWKD1103.incompat.query.result=CWWKD1103E: Metoda ` {0} ` din depozitul ` {1} ` are tipul de returnare ` {2} `, dar furnizorul Jakarta Persistence a efectuat o interogare de tip ` {3} `, cu rezultate de tipul ` {4} `. Verifica\u021bi dac\u0103 furnizorul de persisten\u021b\u0103 Jakarta permite interogarea tipurilor de atribute ale entit\u0103\u021bilor selectate de metoda ` {0} `. Verifica\u021bi dac\u0103 exist\u0103 alte cauze de incompatibilitate \u00een cazul \u00een care furnizorul Jakarta permite interogarea tipurilor de atribute ale entit\u0103\u021bilor selectate de metoda ` {0} `.
CWWKD1103.incompat.query.result.explanation=Furnizorii de servicii Persistence din Jakarta nu permit returnarea tuturor tipurilor de atribute ale entit\u0103\u021bilor. Dac\u0103 furnizorul din Jakarta returneaz\u0103 totu\u0219i tipul de atribute ale entit\u0103\u021bii selectat de metod\u0103, exist\u0103 o alt\u0103 cauz\u0103 de incompatibilitate. De exemplu, este posibil ca furnizorul Jakarta Persistence s\u0103 aib\u0103 o eroare sau ca semn\u0103tura metodei din depozit s\u0103 con\u021bin\u0103 o eroare.
CWWKD1103.incompat.query.result.useraction=Dac\u0103 tipul de atribute ale entit\u0103\u021bii selectate de metod\u0103 nu este permis, modifica\u021bi interogarea pentru a prelua \u00eentreaga entitate sau un set diferit de atribute ale entit\u0103\u021bii permise de furnizorul Jakarta Persistence. Dac\u0103 tipul atributelor entit\u0103\u021bii selectate de metod\u0103 este permis, verifica\u021bi dac\u0103 exist\u0103 alte cauze de incompatibilitate.

CWWKD1104.empty.anno.value=CWWKD1104E: Valoarea goal\u0103 pentru clasa String nu este o valoare valid\u0103 pentru adnotarea \u201e {0} \u201d, utilizat\u0103 \u00een cadrul metodei \u201e {1} \u201d a depozitului \u201e {2} \u201d.
CWWKD1104.empty.anno.value.explanation=Valoarea \u201eempty\u201d pentru clasa String nu este acceptat\u0103. Valoarea acceptat\u0103 depinde de tipul de adnotare. De exemplu, dac\u0103 adnotarea este de tip Param, atunci valorile valide sunt numele parametrilor care sunt utiliza\u021bi \u00een cadrul valorii adnot\u0103rii Query.
CWWKD1104.empty.anno.value.useraction=Dac\u0103 adnotarea nu este necesar\u0103, elimina\u021bi-o din metoda de stocare. \u00cen caz contrar, specifica\u021bi o valoare valid\u0103 pentru adnotare.

CWWKD1105.keyword.in.orderby=CWWKD1105E: Clauza \u201e OrderBy \u201d a metodei \u201e {0} \u201d din depozitul \u201e {1} \u201d nu poate fi analizat\u0103, deoarece atributul entit\u0103\u021bii \u201e {2} \u201d al entit\u0103\u021bii \u201e {3} \u201d con\u021bine cuv\u00e2ntul-cheie \u201e {4} \u201d al modelului \u201eJakarta Data Query by Method Name\u201d. Elimina\u021bi clauza \u201e OrderBy \u201d din numele metodei \u201e {0} \u201d \u0219i folosi\u021bi \u00een schimb adnotarea \u201e OrderBy \u201d.
CWWKD1105.keyword.in.orderby.explanation=Numele atributelor entit\u0103\u021bilor care con\u021bin cuvinte-cheie Jakarta Data nu pot fi utilizate \u00een denumirile metodelor din depozit care respect\u0103 modelul \u201eInterogare dup\u0103 numele metodei\u201d din Jakarta Data.
CWWKD1105.keyword.in.orderby.useraction=Redenumi\u021bi atributul entit\u0103\u021bii sau trece\u021bi la adnotarea \u201e OrderBy \u201d pentru a specifica ordinea.

CWWKD1106.init.timed.out=CWWKD1106E: Repozitoriul {0}, care necesit\u0103 magazinul de date {1} \u0219i este furnizat sau utilizat de artefactul aplica\u021biei {2}, nu a devenit disponibil \u00een termen de {3} secunde. Asigura\u021bi-v\u0103 c\u0103 artefactul aplica\u021biei {2} porne\u0219te \u0219i c\u0103 resursa de stocare a datelor {1}, specificat\u0103 ca valoare dataStore a adnot\u0103rii Repository, este configurat\u0103 corect \u0219i este accesibil\u0103 artefactului aplica\u021biei \u00een momentul \u00een care se acceseaz\u0103 pentru prima dat\u0103 depozitul {0}.
CWWKD1106.init.timed.out.explanation=Depozitul nu a devenit disponibil \u00een intervalul de timp alocat.
CWWKD1106.init.timed.out.useraction=Verifica\u021bi configura\u021bia serviciului de gestionare a versiunilor ( dataStore ) \u0219i asigura\u021bi-v\u0103 c\u0103 este accesibil pentru artefactele aplica\u021biei care definesc \u0219i utilizeaz\u0103 acest depozit. Asigura\u021bi-v\u0103, de asemenea, c\u0103 aplica\u021bia \u0219i toate modulele sale pornesc cu succes.

CWWKD1107.init.timed.out.checkpoint=CWWKD1107E: Artefactul aplica\u021biei \u201e {0} \u201d a accesat depozitul \u201e {1} \u201d \u00eenainte ca un punct de control al aplica\u021biei s\u0103 fie finalizat. Actualiza\u021bi aplica\u021bia \u201e {0} \u201d pentru a evita utilizarea depozitului \u00eenainte de un punct de control.
CWWKD1107.init.timed.out.checkpoint.explanation=Aplica\u021biile nu pot utiliza depozitele \u00eenainte de finalizarea unui punct de control.
CWWKD1107.init.timed.out.checkpoint.useraction=Evita\u021bi s\u0103 utiliza\u021bi depozitul p\u00e2n\u0103 la finalizarea punctului de control.

CWWKD1108.missing.entity.anno=CWWKD1108E: Clasa de entitate \u201e {0} \u201d necesit\u0103 adnotarea \u201e {1} \u201d, deoarece adnotarea \u201e {2} \u201d este aplicat\u0103 elementului \u201e {3} \u201d al clasei de entitate.
CWWKD1108.missing.entity.anno.explanation=Clasele de entit\u0103\u021bi care utilizeaz\u0103 adnot\u0103ri
 from pachetul \u201e jakarta.persistence \u201d trebuie, de asemenea, s\u0103 fie adnotat cu entitatea
 annotation din specifica\u021bia Jakarta Persistence.
CWWKD1108.missing.entity.anno.useraction=Aplica\u021bi adnotarea Entity la
 entity sau s\u0103 elimine adnot\u0103rile Jakarta Persistence din elementele sale.

CWWKD1109.jpa.anno.on.record=CWWKD1109E: Adnotarea ` {0} ` nu este permis\u0103 \u00een cadrul metodei ` {1} ` a clasei de entitate ` {2} `, deoarece clasa de entitate ` {2} ` este un \u00eenregistrare Java.
CWWKD1109.jpa.anno.on.record.explanation=Jakarta: Adnot\u0103rile de persisten\u021b\u0103 nu sunt permise \u00een cazul \u00eenregistr\u0103rilor Java.
CWWKD1109.jpa.anno.on.record.useraction=Trece\u021bi la o clas\u0103 de entitate Jakarta Persistence sau elimina\u021bi adnotarea Jakarta Persistence din \u00eenregistrarea Java.

CWWKD1110.incompat.with.collection=CWWKD1110E: Metoda \u201e {0} \u201d a interfe\u021bei de depozit \u201e {1} \u201d are un nume care include cuv\u00e2ntul-cheie \u201e {2} \u201d, ceea ce este incompatibil cu atributul \u201e {3} \u201d al entit\u0103\u021bii \u201e {4} \u201d, deoarece acest atribut are tipul de colec\u021bie. Urm\u0103toarele cuvinte-cheie pentru interog\u0103ri dup\u0103 numele metodei pot fi utilizate cu atributele entit\u0103\u021bilor care au un tip de colec\u021bie: {5}.
CWWKD1110.incompat.with.collection.explanation=Unele dintre cuvintele-cheie din \u201eQuery by Method Name\u201d nu sunt compatibile cu atributele entit\u0103\u021bilor care au un tip de colec\u021bie.
CWWKD1110.incompat.with.collection.useraction=Actualiza\u021bi metoda de stocare pentru a evita utilizarea cuv\u00e2ntului-cheie care nu este compatibil cu tipul colec\u021biei.

CWWKD1111.unsupported.convert=CWWKD1111E: Implementarea {0} AttributeConverter converte\u0219te valorile de tip {1} \u00een tipul {2}, care nu este acceptat de specifica\u021bia Jakarta Data. Specifica\u021bia Jakarta Data accept\u0103 tipurile de enumerare Java, tipurile temporale {3} \u0219i urm\u0103toarele tipuri de baz\u0103: {4}. Furnizorul de date Jakarta integrat accept\u0103, de asemenea, anumite tipuri de persisten\u021b\u0103 Jakarta.
CWWKD1111.unsupported.convert.explanation=Implementarea \u201e AttributeConverter \u201d nu poate fi utilizat\u0103 \u00eempreun\u0103 cu furnizorul de date Jakarta integrat, deoarece aceasta converte\u0219te valorile \u00eentr-un tip neacceptat.
CWWKD1111.unsupported.convert.useraction=Actualiza\u021bi implementarea metodei ` AttributeConverter ` pentru a converti valorile \u00eentr-unul dintre tipurile acceptate.

CWWKD1112.record.entity.verify.err=CWWKD1112W: A fost definit\u0103 o clas\u0103 de entitate pentru \u00eenregistrarea \u201e {0} \u201d, dar este posibil ca aceasta s\u0103 nu func\u021bioneze. Verificarea octe\u021bilor clasei de entitate Jakarta Persistence, generat\u0103 pentru clasa de entitate, a e\u0219uat. Clasa de entitate definit\u0103 este utilizat\u0103 de una sau mai multe interfe\u021be de depozit ( {1} ) \u00een artefactul aplica\u021biei {2}. Eroarea este: {3}.
CWWKD1112.record.entity.verify.err.explanation=Atunci c\u00e2nd un depozit utilizeaz\u0103 o entitate de tip \u00eenregistrare, se genereaz\u0103 o entitate Jakarta Persistence care reprezint\u0103 entitatea de tip \u00eenregistrare. Verificarea octe\u021bilor clasei de entitate Jakarta Persistence generate a e\u0219uat.
CWWKD1112.record.entity.verify.err.useraction=Verifica\u021bi dac\u0103 implementarea entit\u0103\u021bii de \u00eenregistrare respect\u0103 cerin\u021bele \u0219i conven\u021biile aplicabile unei entit\u0103\u021bi de \u00eenregistrare.

CWWKD1113.server.stopping=CWWKD1113I: Unul sau mai multe depozite ( {0} ) nu s-au ini\u021bializat deoarece serverul se opre\u0219te.
CWWKD1113.server.stopping.explanation=Serverul se opre\u0219te \u0219i nu va \u00eencerca s\u0103 ini\u021bializeze depozitele.
CWWKD1113.server.stopping.useraction=Nu este necesar\u0103 nicio ac\u0163iune.

CWWKD1114.app.stopping=CWWKD1114I: Unul sau mai multe depozite ( {0} ) nu s-au ini\u021bializat deoarece aplica\u021bia {1} se afl\u0103 \u00een starea {2}.
CWWKD1114.app.stopping.explanation=Aplica\u021bia se opre\u0219te sau s-a oprit \u0219i nu va \u00eencerca s\u0103 ini\u021bializeze depozitele.
CWWKD1114.app.stopping.useraction=Porni\u021bi aplica\u021bia pentru a activa depozitele.

CWWKD1115.app.unavailable=CWWKD1115E: Unul sau mai multe depozite ( {0} ) nu s-au ini\u021bializat deoarece aplica\u021bia {1} nu este disponibil\u0103.
CWWKD1115.app.unavailable.explanation=Aplica\u021bia care define\u0219te depozitele nu este disponibil\u0103. Depozitele nu pot fi ini\u021bializate.
CWWKD1115.app.unavailable.useraction=Porni\u021bi aplica\u021bia pentru a activa depozitele.

CWWKD1116.resource.unavailable=CWWKD1116E: Unul sau mai multe depozite ( {0} ) nu s-au ini\u021bializat deoarece resursa {1} nu a devenit disponibil\u0103 \u00een termen de {2} secunde.
CWWKD1116.resource.unavailable.explanation=O resurs\u0103 necesar\u0103 pentru depozite nu a devenit disponibil\u0103.
CWWKD1116.resource.unavailable.useraction=Verifica\u021bi configura\u021bia resurselor utilizate de depozite.

CWWKD1117.anno.constraint.conflict=CWWKD1117E: Parametrul \u201e {0} \u201d al metodei \u201e {1} \u201d din interfa\u021ba depozitului \u201e {2} \u201d nu poate fi adnotat cu adnot\u0103rile: \u201e {3} \u201d. Una sau mai multe dintre adnot\u0103ri sunt incompatibile cu tipul \u201e {4} \u201d al parametrului metodei de depozit.
CWWKD1117.anno.constraint.conflict.explanation=Constr\u00e2ngerea \u0219i subtipurile sale nu pot fi combinate cu alte adnot\u0103ri de parametri \u00een afar\u0103 de adnotarea \u201eBy\u201d.
CWWKD1117.anno.constraint.conflict.useraction=Elimina\u021bi adnotarea care genereaz\u0103 conflictul sau specifica\u021bi tipul atributului entit\u0103\u021bii \u00een locul unui tip de constr\u00e2ngere.

CWWKD1118.param.anno.conflict=CWWKD1118E: Parametrul \u201e {0} \u201d al metodei \u201e {1} \u201d din interfa\u021ba depozitului \u201e {2} \u201d nu poate fi adnotat cu adnot\u0103rile: \u201e {3} \u201d. Dou\u0103 sau mai multe adnot\u0103ri sunt \u00een contradic\u021bie \u00eentre ele.
CWWKD1118.param.anno.conflict.explanation=Combina\u021bia de adnot\u0103ri ale parametrilor nu este valid\u0103.
CWWKD1118.param.anno.conflict.useraction=Elimina\u021bi una sau mai multe dintre adnot\u0103rile care intr\u0103 \u00een conflict din parametrul metodei din depozit.

CWWKD1119.keyword.prevents.count=CWWKD1119E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` preia pagini care nu includ num\u0103rul total de elemente \u0219i pagini, deoarece interogarea con\u021bine cuv\u00e2ntul-cheie ` {2} `. Interogarea complet\u0103 este: {3}.
CWWKD1119.keyword.prevents.count.explanation=Cuv\u00e2ntul cheie nu este compatibil cu func\u021bia de num\u0103rare total\u0103 a elementelor \u0219i a paginilor.
CWWKD1119.keyword.prevents.count.useraction=\u00cenlocui\u021bi interogarea cu una care nu utilizeaz\u0103 cuv\u00e2ntul-cheie sau evita\u021bi s\u0103 solicita\u021bi num\u0103rul total de elemente \u0219i pagini.

CWWKD1120.cursor.keyword.mismatch=CWWKD1120E: Metoda ` {0} ` a interfe\u021bei depozitului ` {1} ` specific\u0103 o interogare care include cuv\u00e2ntul-cheie ` {2} `, care este incompatibil cu paginarea bazat\u0103 pe cursor. Interog\u0103rile care utilizeaz\u0103 paginarea bazat\u0103 pe cursor trebuie s\u0103 se \u00eencheie cu o clauz\u0103 WHERE \u0219i nu trebuie s\u0103 includ\u0103 subinterog\u0103ri. Interogarea este: {3}.
CWWKD1120.cursor.keyword.mismatch.explanation=Cuvintele-cheie precum GROUP BY, HAVING, ORDER BY, EXCEPT, INTERSECT \u0219i UNION nu sunt compatibile cu paginarea bazat\u0103 pe cursor.
CWWKD1120.cursor.keyword.mismatch.useraction=Rescrie\u021bi interogarea astfel \u00eenc\u00e2t s\u0103 includ\u0103 doar clauzele: SELECT, FROM \u0219i WHERE.

CWWKD1121.record.lacks.id=CWWKD1121E: \u00cenregistrarea \u201e {0} \u201d nu poate fi utilizat\u0103 ca entitate, deoarece nu are un identificator unic. Una dintre componentele \u00eenregistr\u0103rii ( {1} ) trebuie s\u0103 se numeasc\u0103 \u201eid\u201d, s\u0103 aib\u0103 un nume care se termin\u0103 cu \u201e_id\u201d, \u201eId\u201d sau \u201eID\u201d sau s\u0103 fie de tipul \u201e java.util.UUID \u201d.
CWWKD1121.record.lacks.id.explanation=Entit\u0103\u021bile trebuie s\u0103 aib\u0103 un atribut de identificare unic.
CWWKD1121.record.lacks.id.useraction=Ad\u0103uga\u021bi sau redenumi\u021bi o component\u0103 de \u00eenregistrare pentru a respecta una dintre conven\u021biile men\u021bionate privind atribuirea unui identificator unic.

CWWKD1122.entity.lacks.id=CWWKD1122E: Clasa \u201e {0} \u201d nu poate fi utilizat\u0103 ca entitate, deoarece nu dispune de un identificator unic. Pentru a atribui un identificator unic, asigura\u021bi-v\u0103 c\u0103 func\u021bia \u201e {1} \u201d este activat\u0103, ad\u0103uga\u021bi adnotarea @ jakarta.persistence.Entity la clasa entit\u0103\u021bii \u0219i ad\u0103uga\u021bi adnotarea @ jakarta.persistence.Id la cel mult un c\u00e2mp sau o metod\u0103 getter a clasei entit\u0103\u021bii. Alternativ, pute\u021bi folosi un fi\u0219ier de tip \u201e META-INF/orm.xml \u201d pentru a defini entitatea \u0219i identificatorul s\u0103u unic.
CWWKD1122.entity.lacks.id.explanation=Entit\u0103\u021bile trebuie s\u0103 aib\u0103 un atribut de identificare unic.
CWWKD1122.entity.lacks.id.useraction=Activa\u021bi func\u021bia Jakarta Persistence \u0219i urma\u021bi modelul de entit\u0103\u021bi Jakarta Persistence pentru a atribui un identificator unic.

CWWKD1123.sort.incompat.with.cursor=CWWKD1123E: Nu se poate deduce un cursor pentru o pagin\u0103 de rezultate solicitat\u0103, deoarece unul dintre criteriile de sortare furnizate metodei ` {0} ` a depozitului ` {1} ` nu este un atribut al entit\u0103\u021bii: {2}. Utiliza\u021bi metoda ` {3} ` pentru a crea un cursor care s\u0103 corespund\u0103 criteriilor de sortare, apoi transmite\u021bi acest cursor c\u0103tre metoda ` afterCursor ` sau ` beforeCursor ` a unei clase ` PageRequest `. Alternativ, modifica\u021bi criteriile de sortare astfel \u00eenc\u00e2t s\u0103 includ\u0103 doar numele atributelor entit\u0103\u021bilor. Numele de atribute valide pentru clasa de entit\u0103\u021bi \u201e {4} \u201d sunt: \u201e {5} \u201d.
CWWKD1123.sort.incompat.with.cursor.explanation=Pentru a crea automat un cursor pe baza criteriilor de sortare, fiecare dintre aceste criterii trebuie s\u0103 sorteze dup\u0103 numele unui singur atribut al entit\u0103\u021bii.
CWWKD1123.sort.incompat.with.cursor.useraction=Furniza\u021bi un cursor care s\u0103 corespund\u0103 criteriilor de sortare. Alternativ, pute\u021bi trece la paginarea bazat\u0103 pe offset sau pute\u021bi modifica criteriile de sortare pentru a sorta numai dup\u0103 atributele entit\u0103\u021bilor.
