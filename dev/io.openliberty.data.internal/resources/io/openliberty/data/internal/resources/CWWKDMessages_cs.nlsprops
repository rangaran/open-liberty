#CMVCPATHNAME io.openliberty.data.internal/resources/io/openliberty/data/internal/persistence/resources/CWWKDMessages.nlsprops
#ISMESSAGEFILE TRUE
#NLS_ENCODING=UNICODE
#
#COMPONENTPREFIX CWWKD
#COMPONENTNAMEFOR CWWKD Jakarta Data
#
# NLS_MESSAGEFORMAT_VAR
#
#   Strings in this file which contain replacement variables are processed by the MessageFormat 
#   class (single quote must be coded as 2 consecutive single quotes ''). Strings in this file 
#   which do NOT contain replacement variables are NOT processed by the MessageFormat class 
#   (single quote must be coded as one single quote '). 

# All messages must use the range CWWKD1000 to CWWKD1399

CWWKD1000.repo.general.err=CWWKD1000E: V metod\u011b ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` do\u0161lo k chyb\u011b. Tato chyba m\u016f\u017ee znamenat, \u017ee metoda repozit\u00e1\u0159e nen\u00ed platn\u00e1. Chyba zn\u00ed: {2}.
CWWKD1000.repo.general.err.explanation=U zadan\u00e9 metody repozit\u00e1\u0159e byla zji\u0161t\u011bna chyba.
CWWKD1000.repo.general.err.useraction=Najd\u011bte rozhran\u00ed a metodu \u00falo\u017ei\u0161t\u011b a zjist\u011bte, zda jsou nutn\u00e9 opravy.

CWWKD1001.no.primary.entity=CWWKD1001E: Metoda \u00falo\u017ei\u0161t\u011b typu \u201e {0} \u201c vy\u017eaduje t\u0159\u00eddu entity, av\u0161ak rozhran\u00ed \u00falo\u017ei\u0161t\u011b typu \u201e {1} \u201c \u017e\u00e1dnou prim\u00e1rn\u00ed t\u0159\u00eddu entity nestanov\u00ed. Chcete-li tuto chybu opravit, m\u016f\u017ee rozhran\u00ed repozit\u00e1\u0159e typu \u201e {1} \u201c roz\u0161i\u0159ovat jeden z vestav\u011bn\u00fdch nad\u0159azen\u00fdch typ\u016f repozit\u00e1\u0159\u016f, nap\u0159\u00edklad \u201e {2} \u201c, a jako prvn\u00ed typov\u00fd parametr zadat t\u0159\u00eddu entity.
CWWKD1001.no.primary.entity.explanation=Metody repozit\u00e1\u0159e, kter\u00e9 nemaj\u00ed vlastn\u00ed t\u0159\u00eddu entity, vy\u017eaduj\u00ed, aby repozit\u00e1\u0159 definoval prim\u00e1rn\u00ed t\u0159\u00eddu entity.
CWWKD1001.no.primary.entity.useraction=Definujte prim\u00e1rn\u00ed t\u0159\u00eddu entit pro \u00falo\u017ei\u0161t\u011b.

CWWKD1002.method.annos.err=CWWKD1002E: Metoda ` {0} ` rozhran\u00ed repozit\u00e1\u0159e ` {1} ` je opat\u0159ena kombinac\u00ed anotac\u00ed, kter\u00e1 nen\u00ed platn\u00e1: ` {2} `.
CWWKD1002.method.annos.err.explanation=Tato kombinace anotac\u00ed nen\u00ed u jedn\u00e9 metody repozit\u00e1\u0159e platn\u00e1.
CWWKD1002.method.annos.err.useraction=Najd\u011bte rozhran\u00ed a metodu repozit\u00e1\u0159e a ur\u010dete spr\u00e1vnou kombinaci anotac\u00ed metod.

CWWKD1003.rtrn.err=CWWKD1003E: Typ n\u00e1vratov\u00e9 hodnoty ` {0} ` metody ` {1} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {2} ` nen\u00ed platn\u00fdm typem n\u00e1vratov\u00e9 hodnoty pro metodu ` {3} ` \u00falo\u017ei\u0161t\u011b. Mezi platn\u00e9 typy n\u00e1vratov\u00fdch hodnot pat\u0159\u00ed: {4}
CWWKD1003.rtrn.err.explanation=Typ n\u00e1vratov\u00e9 hodnoty metody nen\u00ed jedn\u00edm z podporovan\u00fdch typ\u016f n\u00e1vratov\u00fdch hodnot pro dan\u00fd typ metody \u00falo\u017ei\u0161t\u011b.
CWWKD1003.rtrn.err.useraction=Informace o anotac\u00edch Insert, Update a Save najdete v dokumentaci Javadoc k Jakarta Data, platn\u00e9 typy n\u00e1vratov\u00fdch hodnot pak v dokumentaci k dotaz\u016fm podle n\u00e1zvu metody.

CWWKD1004.general.rtrn.err=CWWKD1004E: Typ n\u00e1vratov\u00e9 hodnoty ` {0} ` metody ` {1} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {2} ` nen\u00ed platn\u00fdm typem n\u00e1vratov\u00e9 hodnoty pro metodu \u00falo\u017ei\u0161t\u011b.
CWWKD1004.general.rtrn.err.explanation=Typ n\u00e1vratov\u00e9 hodnoty metody nen\u00ed jedn\u00edm z typ\u016f n\u00e1vratov\u00fdch hodnot podporovan\u00fdch pro dan\u00fd typ metody \u00falo\u017ei\u0161t\u011b.
CWWKD1004.general.rtrn.err.useraction=Seznam platn\u00fdch typ\u016f n\u00e1vratov\u00fdch hodnot pro dan\u00fd typ metody \u00falo\u017ei\u0161t\u011b najdete v dokumentaci Jakarta Data Javadoc.

CWWKD1005.find.rtrn.err=CWWKD1005E: Metoda ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` nen\u00ed platn\u00e1. Metoda definuje typ n\u00e1vratov\u00e9 hodnoty typu \u201e {2} \u201c, kter\u00fd nelze p\u0159ev\u00e9st z typov\u00e9 entity \u201e {3} \u201c. Typ v\u00fdsledku operace find mus\u00ed b\u00fdt typ entity, typ atributu entity vybran\u00fd anotac\u00ed Select, z\u00e1znam Java slo\u017een\u00fd z atribut\u016f entity nebo typ vybran\u00fd dotazem zadan\u00fdm v anotaci Query. Typ n\u00e1vratov\u00e9 hodnoty metody `find` v repozit\u00e1\u0159i m\u016f\u017ee b\u00fdt typem v\u00fdsledku, polem tohoto typu nebo kter\u00fdmkoli z n\u00e1sleduj\u00edc\u00edch typ\u016f, kter\u00e9 jsou parametrizov\u00e1ny typem v\u00fdsledku: ` {4} `.
CWWKD1005.find.rtrn.err.explanation=Typ n\u00e1vratov\u00e9 hodnoty t\u00e9to metody nen\u00ed jedn\u00edm z typ\u016f podporovan\u00fdch pro metody vyhled\u00e1v\u00e1n\u00ed v repozit\u00e1\u0159i.
CWWKD1005.find.rtrn.err.useraction=Seznam platn\u00fdch typ\u016f n\u00e1vratov\u00fdch hodnot pro metody vyhled\u00e1v\u00e1n\u00ed v \u00falo\u017ei\u0161ti najdete v dokumentaci Jakarta Data Javadoc.

CWWKD1006.delete.rtrn.err=CWWKD1006E: Typ n\u00e1vratov\u00e9 hodnoty ` {0} ` metody ` {1} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {2} ` nen\u00ed platn\u00fdm typem n\u00e1vratov\u00e9 hodnoty pro operaci odstran\u011bn\u00ed. Typ n\u00e1vratov\u00e9 hodnoty mus\u00ed b\u00fdt void, long, int, boolean, pole, List nebo Optional. Typ n\u00e1vratov\u00e9 hodnoty `void` nevrac\u00ed \u017e\u00e1dnou hodnotu. Typ n\u00e1vratov\u00e9 hodnoty long nebo int ud\u00e1v\u00e1 po\u010det odstran\u011bn\u00fdch polo\u017eek. Typ n\u00e1vratov\u00e9 hodnoty boolean ud\u00e1v\u00e1, zda byly n\u011bjak\u00e9 entity odstran\u011bny. Typ n\u00e1vratov\u00e9 hodnoty typu pole, seznamu nebo Optional, kter\u00fd je parametrizov\u00e1n bu\u010f t\u0159\u00eddou entit typu {3}, nebo t\u0159\u00eddou jedine\u010dn\u00fdch identifik\u00e1tor\u016f typu {4}, vrac\u00ed odstran\u011bn\u00e9 entity nebo ID entit.
CWWKD1006.delete.rtrn.err.explanation=Typ n\u00e1vratov\u00e9 hodnoty metody nen\u00ed jedn\u00edm z typ\u016f podporovan\u00fdch pro operaci odstran\u011bn\u00ed.
CWWKD1006.delete.rtrn.err.useraction=Upravte metodu repozit\u00e1\u0159e tak, aby pou\u017e\u00edvala jeden z podporovan\u00fdch typ\u016f n\u00e1vratov\u00fdch hodnot.

CWWKD1007.updel.rtrn.err=CWWKD1007E: Typ n\u00e1vratov\u00e9 hodnoty ` {0} ` metody ` {1} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {2} ` nen\u00ed platn\u00fdm typem n\u00e1vratov\u00e9 hodnoty pro operaci \u00falo\u017ei\u0161t\u011b typu ` {3} `. Typ n\u00e1vratov\u00e9 hodnoty mus\u00ed b\u00fdt bu\u010f void, long, int nebo boolean. Typ n\u00e1vratov\u00e9 hodnoty `void` nevrac\u00ed \u017e\u00e1dnou hodnotu. Typ n\u00e1vratov\u00e9 hodnoty long nebo int vrac\u00ed po\u010det odpov\u00eddaj\u00edc\u00edch entit. Typ n\u00e1vratov\u00e9 hodnoty boolean ud\u00e1v\u00e1, zda se na\u0161ly n\u011bjak\u00e9 shody.
CWWKD1007.updel.rtrn.err.explanation=Typ n\u00e1vratov\u00e9 hodnoty metody nen\u00ed jedn\u00edm z typ\u016f podporovan\u00fdch pro operace aktualizace nebo odstran\u011bn\u00ed.
CWWKD1007.updel.rtrn.err.useraction=Upravte metodu repozit\u00e1\u0159e tak, aby pou\u017e\u00edvala jeden z podporovan\u00fdch typ\u016f n\u00e1vratov\u00fdch hodnot.

CWWKD1008.ambig.rtrn.err=CWWKD1008E: Typ n\u00e1vratov\u00e9 hodnoty ` {0} ` metody ` {1} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {2} ` je jako n\u00e1vratov\u00fd typ nejednozna\u010dn\u00fd, proto\u017ee odpov\u00edd\u00e1 n\u011bkolika atribut\u016fm entity: ` {3} `. Metoda repozit\u00e1\u0159e mus\u00ed p\u0159ej\u00edt na anotaci Query a pou\u017e\u00edt dotaz s klauzul\u00ed SELECT, kter\u00e1 ur\u010duje, kter\u00fd atribut entity se m\u00e1 vr\u00e1tit.
CWWKD1008.ambig.rtrn.err.explanation=Typ n\u00e1vratov\u00e9 hodnoty metody nen\u00ed jedn\u00edm z typ\u016f podporovan\u00fdch pro metodu delete.
CWWKD1008.ambig.rtrn.err.useraction=Upravte metodu repozit\u00e1\u0159e tak, aby k v\u00fdb\u011bru atributu entity pou\u017e\u00edvala anotaci Query.

CWWKD1009.lifecycle.param.err=CWWKD1009E: Metoda ` {0} ` rozhran\u00ed repozit\u00e1\u0159e ` {1} ` nem\u016f\u017ee m\u00edt parametry typu ` {2} `, proto\u017ee je ozna\u010dena anotac\u00ed \u017eivotn\u00edho cyklu ` {3} `. Metody repozit\u00e1\u0159e, kter\u00e9 jsou opat\u0159eny anotac\u00ed \u017eivotn\u00edho cyklu, mus\u00ed m\u00edt p\u0159esn\u011b jeden parametr, kter\u00fdm mus\u00ed b\u00fdt entita nebo pole \u010di seznam t\u00e9to entity.
CWWKD1009.lifecycle.param.err.explanation=Metody \u017eivotn\u00edho cyklu mus\u00ed m\u00edt jedin\u00fd parametr typu entity.
CWWKD1009.lifecycle.param.err.useraction=Upravte metodu repozit\u00e1\u0159e tak, aby p\u0159ij\u00edmala jedin\u00fd parametr, kter\u00fdm m\u016f\u017ee b\u00fdt entita, pole entit nebo seznam entit.

CWWKD1010.unknown.entity.attr=CWWKD1010E: V t\u0159\u00edd\u011b entity \u201e {1} \u201c nebylo nalezeno atribut entity s n\u00e1zvem \u201e {0} \u201c pro metodu \u201e {2} \u201c rozhran\u00ed \u00falo\u017ei\u0161t\u011b \u201e {3} \u201c. Platn\u00e9 n\u00e1zvy atribut\u016f pro tuto entitu jsou: {4}.
CWWKD1010.unknown.entity.attr.explanation=Metoda repozit\u00e1\u0159e se pokou\u0161\u00ed pou\u017e\u00edt atribut entity, kter\u00fd neexistuje.
CWWKD1010.unknown.entity.attr.useraction=Upravte metodu repozit\u00e1\u0159e tak, aby odpov\u00eddala platn\u00e9mu atributu definovan\u00e9mu entitou.

CWWKD1011.unknown.method.pattern=CWWKD1011E: Metoda ` {0} ` rozhran\u00ed repozit\u00e1\u0159e ` {1} ` neodpov\u00edd\u00e1 \u017e\u00e1dn\u00e9mu z definovan\u00fdch vzor\u016f Jakarta Data. Metoda \u00falo\u017ei\u0161t\u011b mus\u00ed bu\u010f pou\u017e\u00edvat anotace, b\u00fdt metodou pro p\u0159\u00edstup k prost\u0159edk\u016fm, nebo b\u00fdt pojmenov\u00e1na podle vzoru \u201eQuery by Method Name\u201c. K definov\u00e1n\u00ed operac\u00ed se pou\u017e\u00edvaj\u00ed anotace, jako je nap\u0159\u00edklad {2}. Metoda pro p\u0159\u00edstup k prost\u0159edk\u016fm nesm\u00ed obsahovat \u017e\u00e1dn\u00e9 parametry a mus\u00ed vracet jeden z typ\u016f {3}. Vzor \u201eDotaz podle n\u00e1zvu metody\u201c mus\u00ed za\u010d\u00ednat jedn\u00edm z kl\u00ed\u010dov\u00fdch slov typu \u201e {4} \u201c, za kter\u00fdm n\u00e1sleduje 0 nebo v\u00edce znak\u016f. N\u00e1zvy metod mohou tak\u00e9 obsahovat kl\u00ed\u010dov\u00e9 slovo By a jednu nebo v\u00edce podm\u00ednek odd\u011blen\u00fdch odd\u011b\
    lova\u010dem. P\u0159\u00edklady platn\u00fdch n\u00e1zv\u016f metod repozit\u00e1\u0159e jsou: {5}.
CWWKD1011.unknown.method.pattern.explanation=Metody repozit\u00e1\u0159e mus\u00ed odpov\u00eddat vzor\u016fm definovan\u00fdm v Jakarta Data.
CWWKD1011.unknown.method.pattern.useraction=Upravte metodu repozit\u00e1\u0159e tak, aby odpov\u00eddala n\u011bkter\u00e9mu ze vzor\u016f z Jakarta Data.

CWWKD1012.fd.missing.param.anno=CWWKD1012E: Parametr \u201e {0} \u201c metody \u201e {1} \u201c rozhran\u00ed \u00falo\u017ei\u0161t\u011b \u201e {2} \u201c neodpov\u00edd\u00e1 atributu entity. Parametry, kter\u00e9 neodpov\u00eddaj\u00ed atributu entity, mus\u00ed b\u00fdt ozna\u010deny anotac\u00ed `By` nebo mus\u00ed m\u00edt jeden ze speci\u00e1ln\u00edch typ\u016f parametr\u016f: ` {3} `. Chcete-li definovat podm\u00ednku pro omezen\u00ed v\u00fdsledk\u016f dotazu, mus\u00ed b\u00fdt parametr ozna\u010den anotac\u00ed \u201eBy\u201c a hodnotou t\u00e9to anotace mus\u00ed b\u00fdt n\u00e1zev atributu entity. P\u0159\u00edpadn\u011b zapn\u011bte kompila\u010dn\u00ed volbu -parameters a p\u0159i\u0159a\u010fte parametru stejn\u00fd n\u00e1zev jako m\u00e1 atribut entity.
CWWKD1012.fd.missing.param.anno.explanation=Parametry metod pro vyhled\u00e1v\u00e1n\u00ed a maz\u00e1n\u00ed v \u00falo\u017ei\u0161ti mus\u00ed odpov\u00eddat atribut\u016fm entit nebo b\u00fdt speci\u00e1ln\u00edmi typy parametr\u016f definovan\u00fdmi v Jakarta Data.
CWWKD1012.fd.missing.param.anno.useraction=Upravte metodu repozit\u00e1\u0159e tak, aby v\u0161echny parametry odpov\u00eddaly atribut\u016fm entit nebo m\u011bly jeden ze speci\u00e1ln\u00edch typ\u016f parametr\u016f Jakarta Data.

CWWKD1013.cde.missing.param.anno=CWWKD1013E: Parametr \u201e {0} \u201c metody \u201e {1} \u201c rozhran\u00ed \u00falo\u017ei\u0161t\u011b \u201e {2} \u201c neodpov\u00edd\u00e1 atributu entity. Parametry, kter\u00e9 neodpov\u00eddaj\u00ed atributu entity, mus\u00ed b\u00fdt ozna\u010deny anotac\u00ed \u201eBy\u201c a hodnota t\u00e9to anotace mus\u00ed b\u00fdt nastavena na n\u00e1zev atributu entity. P\u0159\u00edpadn\u011b zapn\u011bte kompila\u010dn\u00ed volbu -parameters a p\u0159i\u0159a\u010fte parametru stejn\u00fd n\u00e1zev jako m\u00e1 atribut entity.
CWWKD1013.cde.missing.param.anno.explanation=Parametry metod count, delete a exists v \u00falo\u017ei\u0161ti mus\u00ed odpov\u00eddat atribut\u016fm entity.
CWWKD1013.cde.missing.param.anno.useraction=Upravte metodu repozit\u00e1\u0159e tak, aby v\u0161echny parametry odpov\u00eddaly atribut\u016fm entity.

CWWKD1014.upd.missing.param.anno=CWWKD1014E: Metoda ` {0} ` v repozit\u00e1\u0159i ` {1} ` nen\u00ed platnou metodou `Update` \u017eivotn\u00edho cyklu, proto\u017ee m\u00e1 parametry typu ` {2} `. Metody repozit\u00e1\u0159e, kter\u00e9 jsou opat\u0159eny anotac\u00ed \u017eivotn\u00edho cyklu, mus\u00ed m\u00edt p\u0159esn\u011b jeden parametr, kter\u00fdm mus\u00ed b\u00fdt entita, pole entit nebo seznam entit. Metoda ` {0} ` rovn\u011b\u017e nen\u00ed platnou aktualiza\u010dn\u00ed operac\u00ed zalo\u017eenou na parametrech, proto\u017ee parametr metody ` {3} ` neobsahuje anotaci (` {4} `), kter\u00e1 by ozna\u010dovala n\u00e1zev atributu entity. P\u0159\u00edpadn\u011b zapn\u011bte kompila\u010dn\u00ed volbu -parameters a p\u0159i\u0159a\u010fte parametru stejn\u00fd n\u00e1zev jako m\u00e1 atribut entity.
CWWKD1014.upd.missing.param.anno.explanation=Parametry metod aktualizace \u00falo\u017ei\u0161t\u011b mus\u00ed odpov\u00eddat atribut\u016fm entit. Alternativn\u011b mus\u00ed metody \u017eivotn\u00edho cyklu m\u00edt pouze jeden parametr typu entity.
CWWKD1014.upd.missing.param.anno.useraction=Upravte metodu repozit\u00e1\u0159e tak, aby v\u0161echny parametry odpov\u00eddaly atribut\u016fm entity. P\u0159\u00edpadn\u011b upravte metodu repozit\u00e1\u0159e tak, aby m\u011bla jedin\u00fd parametr, kter\u00fdm m\u016f\u017ee b\u00fdt entita, pole entit nebo seznam entit.

CWWKD1015.null.entity.param=CWWKD1015E: Metoda ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` nem\u016f\u017ee p\u0159ijmout entitu typu null.
CWWKD1015.null.entity.param.explanation=Metody \u017eivotn\u00edho cyklu vy\u017eaduj\u00ed instanci entity, kter\u00e1 nen\u00ed null.
CWWKD1015.null.entity.param.useraction=Upravte k\u00f3d aplikace tak, aby se zabr\u00e1nilo p\u0159ed\u00e1n\u00ed hodnoty entity typu null metod\u011b \u00falo\u017ei\u0161t\u011b.

CWWKD1016.incompat.entity.param=CWWKD1016E: Metoda ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` vy\u017eaduje entitu typu ` {2} `, ale byla zad\u00e1na hodnota typu ` {3} `.
CWWKD1016.incompat.entity.param.explanation=Metoda \u017eivotn\u00edho cyklu p\u0159ij\u00edm\u00e1 pouze hodnoty entit deklarovan\u00e9ho typu.
CWWKD1016.incompat.entity.param.useraction=Upravte k\u00f3d aplikace tak, aby p\u0159ed\u00e1val hodnotu entity stejn\u00e9ho typu, jak\u00fd deklaruje metoda repozit\u00e1\u0159e.

CWWKD1017.dup.special.param=CWWKD1017E: Metoda ` {0} ` v repozit\u00e1\u0159i ` {1} ` nesm\u00ed m\u00edt v\u00edce parametr\u016f ` {2} `.
CWWKD1017.dup.special.param.explanation=N\u011bkter\u00e9 speci\u00e1ln\u00ed parametry Jakarta Data, v\u010detn\u011b Limit a PageRequest,, se nesm\u00ed v podpisu metody repozit\u00e1\u0159e vyskytovat v\u00edcekr\u00e1t.
CWWKD1017.dup.special.param.useraction=Upravte podpis metody repozit\u00e1\u0159e tak, aby obsahoval nanejv\u00fd\u0161 jeden v\u00fdskyt speci\u00e1ln\u00edho typu parametru Jakarta Data.

CWWKD1018.confl.special.param=CWWKD1018E: Metoda ` {0} ` v repozit\u00e1\u0159i ` {1} ` nem\u016f\u017ee m\u00edt parametry ` {2} ` a ` {3} `.
CWWKD1018.confl.special.param.explanation=N\u011bkter\u00e9 speci\u00e1ln\u00ed parametry Jakarta Data, jako jsou Limit a PageRequest,, nelze kombinovat v r\u00e1mci jedn\u00e9 signatury metody repozit\u00e1\u0159e.
CWWKD1018.confl.special.param.useraction=Aktualizujte repozit\u00e1\u0159 tak, aby v jedn\u00e9 signatu\u0159e metody nebyly pou\u017eity oba speci\u00e1ln\u00ed typy parametr\u016f Jakarta Data.

CWWKD1019.mixed.positional.named=CWWKD1019E: Metoda ` {0} ` rozhran\u00ed repozit\u00e1\u0159e ` {1} ` nesm\u00ed obsahovat dotaz, kter\u00fd kombinuje pozi\u010dn\u00ed a pojmenovan\u00e9 parametry. Rozhran\u00ed definuje kombinaci pozi\u010dn\u00edch parametr\u016f {2} a pojmenovan\u00fdch parametr\u016f {3} {4} pro hodnotu anotace Query: {5}. Dotaz s pozi\u010dn\u00edmi parametry mus\u00ed ka\u017ed\u00fd parametr ozna\u010dovat jeho po\u0159adov\u00fdm \u010d\u00edslem, po\u010d\u00ednaje?1, a parametry metody nesm\u00ed obsahovat anotaci Param. V dotazu s pojmenovan\u00fdmi parametry mus\u00ed b\u00fdt ka\u017ed\u00fd parametr ozna\u010den sv\u00fdm n\u00e1zvem, nap\u0159\u00edklad {6}, a parametry metody mus\u00ed b\u00fdt opat\u0159eny anotac\u00ed Param, nap\u0159\u00edklad {7}. Alternativn\u011b lze pomoc\u00ed kompila\u010dn\u00ed volby -parameters nastavit, aby parametry metod odkazovaly na pojmenovan\u00e9 parametry na z\u00e1klad\u011b shody jejich n\u00e1zv\u016f, nap\u0159\u00edkla\
    d {8}.
CWWKD1019.mixed.positional.named.explanation=Dotazy s parametry mus\u00ed pou\u017e\u00edvat bu\u010f v\u0161echny pojmenovan\u00e9 parametry, nebo v\u0161echny pozi\u010dn\u00ed parametry, nikoli jejich kombinaci.
CWWKD1019.mixed.positional.named.useraction=Upravte metodu repozit\u00e1\u0159e tak, aby pou\u017e\u00edvala pouze pojmenovan\u00e9 parametry nebo pouze pozi\u010dn\u00ed parametry.

CWWKD1020.invalid.param.type=CWWKD1020E: Parametry metody ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` nesm\u00ed b\u00fdt typu ` {2} `, proto\u017ee tato metoda \u00falo\u017ei\u0161t\u011b p\u0159edstavuje operaci typu ` {3} `.
CWWKD1020.invalid.param.type.explanation=Tento typ parametru nen\u00ed u tohoto typu metody povolen.
CWWKD1020.invalid.param.type.useraction=Upravte metodu repozit\u00e1\u0159e tak, aby pro ka\u017edou hodnotu pot\u0159ebnou pro porovn\u00e1n\u00ed definovala parametr metody.

CWWKD1021.insufficient.params=CWWKD1021E: Metoda ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` m\u00e1 parametry ` {2} `, av\u0161ak podm\u00ednky dotazu definovan\u00e9 touto metodou vy\u017eaduj\u00ed parametry ` {3} `. Odkaz na tuto metodu je: {4}.
CWWKD1021.insufficient.params.explanation=Podm\u00ednky dotazu, kter\u00e9 definuj\u00ed porovn\u00e1n\u00ed hodnot, vy\u017eaduj\u00ed odpov\u00eddaj\u00edc\u00ed po\u010det parametr\u016f metody \u00falo\u017ei\u0161t\u011b, do nich\u017e se tyto hodnoty zad\u00e1vaj\u00ed.
CWWKD1021.insufficient.params.useraction=Upravte metodu repozit\u00e1\u0159e tak, aby pro ka\u017edou hodnotu pot\u0159ebnou pro porovn\u00e1n\u00ed definovala parametr metody.

CWWKD1022.too.many.params=CWWKD1022E: Podm\u00ednky dotazu metody ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` vy\u017eaduj\u00ed parametry ` {2} `, zat\u00edmco podpis metody \u00falo\u017ei\u0161t\u011b obsahuje parametry ` {3} `. Odkaz na tuto metodu je: {4}.
CWWKD1022.too.many.params.explanation=Podm\u00ednky dotazu, kter\u00e9 definuj\u00ed porovn\u00e1n\u00ed hodnot, vy\u017eaduj\u00ed odpov\u00eddaj\u00edc\u00ed po\u010det parametr\u016f metody \u00falo\u017ei\u0161t\u011b, do nich\u017e se tyto hodnoty zad\u00e1vaj\u00ed. Dal\u0161\u00ed parametry nejsou povoleny.
CWWKD1022.too.many.params.useraction=Aktualizujte podpis metody repozit\u00e1\u0159e tak, aby byly odstran\u011bny nadbyte\u010dn\u00e9 parametry, kter\u00e9 neodpov\u00eddaj\u00ed deklarovan\u00fdm podm\u00ednk\u00e1m.

CWWKD1023.extra.param=CWWKD1023E: Podm\u00ednky dotazu metody ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` vy\u017eaduj\u00ed parametry ` {2} `, av\u0161ak tato metoda \u00falo\u017ei\u0161t\u011b obsahuje nav\u00edc parametr ` {3} `. Odkaz na tuto metodu je: {4}.
CWWKD1023.extra.param.explanation=Podm\u00ednky dotazu, kter\u00e9 definuj\u00ed porovn\u00e1n\u00ed hodnot, vy\u017eaduj\u00ed odpov\u00eddaj\u00edc\u00ed po\u010det parametr\u016f metody \u00falo\u017ei\u0161t\u011b, do nich\u017e se tyto hodnoty zad\u00e1vaj\u00ed. Dal\u0161\u00ed parametry nejsou povoleny.
CWWKD1023.extra.param.useraction=Aktualizujte podpis metody repozit\u00e1\u0159e tak, aby byly odstran\u011bny nadbyte\u010dn\u00e9 parametry, kter\u00e9 neodpov\u00eddaj\u00ed deklarovan\u00fdm podm\u00ednk\u00e1m.

CWWKD1024.missing.entity.attr=CWWKD1024E: V metod\u011b ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` chyb\u00ed n\u00e1zev atributu entity nebo byl p\u0159ed\u00e1n parametr, kter\u00fd tento n\u00e1zev neobsahuje. Platn\u00e9 n\u00e1zvy atribut\u016f pro t\u0159\u00eddu entit \u201e {2} \u201c jsou: {3}.
CWWKD1024.missing.entity.attr.explanation=Podm\u00ednky dotazu a krit\u00e9ria \u0159azen\u00ed pro metodu repozit\u00e1\u0159e mus\u00ed obsahovat n\u00e1zev atributu entity.
CWWKD1024.missing.entity.attr.useraction=Zkontrolujte deklaraci a pou\u017eit\u00ed metody repozit\u00e1\u0159e, abyste se ujistili, \u017ee pro ka\u017edou podm\u00ednku dotazu a ka\u017ed\u00e9 t\u0159\u00eddic\u00ed krit\u00e9rium je zad\u00e1n n\u00e1zev atributu entity.

CWWKD1025.missing.id.attr=CWWKD1025E: T\u0159\u00edda entity typu \u201e {0} \u201c, kterou vyu\u017e\u00edv\u00e1 metoda \u201e {1} \u201c rozhran\u00ed \u00falo\u017ei\u0161t\u011b \u201e {2} \u201c, nem\u00e1 atribut ID.
CWWKD1025.missing.id.attr.explanation=Metody repozit\u00e1\u0159e, kter\u00e9 entitu odstran\u00ed a vr\u00e1t\u00ed, mus\u00ed obsahovat atribut ID.
CWWKD1025.missing.id.attr.useraction=Pokud entita nem\u00e1 \u017e\u00e1dn\u00fd atribut ur\u010den\u00fd jako ID, definujte samostatn\u00e9 metody \u00falo\u017ei\u0161t\u011b, kter\u00e9 entitu vyhledaj\u00ed a odstran\u00ed.

CWWKD1026.ignore.case.not.text=CWWKD1026E: Atribut \u201e {0} \u201c entity \u201e {1} \u201c nen\u00ed znak ani posloupnost znak\u016f; proto krit\u00e9ria \u0159azen\u00ed \u201e {2} \u201c nesm\u00ed ur\u010dovat ignorov\u00e1n\u00ed velk\u00fdch a mal\u00fdch p\u00edsmen. Typ atributu je \u201e {3} \u201c a byl p\u0159ed\u00e1n metod\u011b \u201e {4} \u201c rozhran\u00ed \u00falo\u017ei\u0161t\u011b \u201e {5} \u201c.
CWWKD1026.ignore.case.not.text.explanation=T\u0159\u00edd\u011bn\u00ed bez rozli\u0161ov\u00e1n\u00ed velk\u00fdch a mal\u00fdch p\u00edsmen je mo\u017en\u00e9 pouze u atribut\u016f entit, kter\u00e9 obsahuj\u00ed text.
CWWKD1026.ignore.case.not.text.useraction=Ujist\u011bte se, \u017ee se krit\u00e9ria \u0159azen\u00ed vztahuj\u00ed na spr\u00e1vn\u00fd atribut entity, a odstra\u0148te pokyn k ignorov\u00e1n\u00ed velk\u00fdch a mal\u00fdch p\u00edsmen, pokud tento atribut entity nep\u0159edstavuje text.

CWWKD1027.datastore.lacks.java.comp=CWWKD1027E: Jedno nebo v\u00edce rozhran\u00ed \u00falo\u017ei\u0161t\u011b ( {0} ) z artefaktu aplikace {1} uv\u00e1d\u00ed hodnotu {2} dataStore, kter\u00e1 neodpov\u00edd\u00e1 odkazu na zdroj dat ani odkazu na jednotku perzistence, proto\u017ee postr\u00e1d\u00e1 p\u0159edponu jmenn\u00e9ho prostoru java:comp/env/. Zva\u017ete zm\u011bnu anotace Repository tak, aby obsahovala specifikaci {3}.
CWWKD1027.datastore.lacks.java.comp.explanation=N\u00e1zvy JNDI odkaz\u016f na zdroje dat a odkazy na jednotky perzistence mus\u00ed obsahovat p\u0159edponu jmenn\u00e9ho prostoru java:.
CWWKD1027.datastore.lacks.java.comp.useraction=Ujist\u011bte se, \u017ee hodnota datov\u00e9ho \u00falo\u017ei\u0161t\u011b v anotaci Repository obsahuje p\u0159edponu jmenn\u00e9ho prostoru java:, pokud tato hodnota ozna\u010duje JNDI n\u00e1zev odkazu na zdroj dat nebo odkaz na jednotku perzistence.

CWWKD1028.first.exceeds.max=CWWKD1028E: Metoda ` {0} ` rozhran\u00ed repozit\u00e1\u0159e ` {1} ` po\u017eaduje prvn\u00ed v\u00fdsledky z adresy ` {2} `, co\u017e p\u0159ekra\u010duje maxim\u00e1ln\u00ed povolen\u00fd po\u010det v\u00fdsledk\u016f: ` {3} `.
CWWKD1028.first.exceeds.max.explanation=Maxim\u00e1ln\u00ed po\u010det v\u00fdsledk\u016f dotazu je omezen syst\u00e9mov\u00fdmi omezen\u00edmi a zadanou hodnotou.
CWWKD1028.first.exceeds.max.useraction=Sni\u017ete po\u017eadovan\u00fd maxim\u00e1ln\u00ed po\u010det v\u00fdsledk\u016f dotazu na ni\u017e\u0161\u00ed hodnotu.

CWWKD1029.first.neg.or.zero=CWWKD1029E: Metoda ` {0} ` rozhran\u00ed repozit\u00e1\u0159e ` {1} ` vy\u017e\u00e1d\u00e1 prvn\u00ed v\u00fdsledky z adresy ` {2} `. Po\u017eadovan\u00fd maxim\u00e1ln\u00ed po\u010det v\u00fdsledk\u016f, kter\u00e9 maj\u00ed b\u00fdt vr\u00e1ceny, mus\u00ed b\u00fdt kladn\u00e9 \u010d\u00edslo.
CWWKD1029.first.neg.or.zero.explanation=Maxim\u00e1ln\u00ed po\u010det v\u00fdsledk\u016f dotazu mus\u00ed b\u00fdt kladn\u00e9 \u010d\u00edslo.
CWWKD1029.first.neg.or.zero.useraction=Upravte metodu repozit\u00e1\u0159e tak, aby ur\u010dovala maxim\u00e1ln\u00ed po\u010det v\u00fdsledk\u016f.

CWWKD1030.ql.lacks.entity=CWWKD1030E: V dotazu typu \u201e {0} \u201c, kter\u00fd je zad\u00e1n pro metodu \u201e {1} \u201c repozit\u00e1\u0159e \u201e {2} \u201c, chyb\u00ed n\u00e1zev entity. V p\u0159\u00edpad\u011b dotaz\u016f ohledn\u011b slu\u017eby \u201e {3} \u201c pou\u017eijte tento formul\u00e1\u0159: {4}.
CWWKD1030.ql.lacks.entity.explanation=Dotaz obsahuje podm\u00ednku, kter\u00e1 vy\u017eaduje n\u00e1zev entity.
CWWKD1030.ql.lacks.entity.useraction=Upravte dotaz pro metodu repozit\u00e1\u0159e tak, aby obsahoval n\u00e1zev entity.

CWWKD1031.ql.similar.entity=CWWKD1031E: Metoda ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` definuje dotaz, kter\u00fd vy\u017eaduje n\u00e1zev entity ` {2} `, kter\u00fd nebyl nalezen, ale velmi se podob\u00e1 n\u00e1zvu entity ` {3} `. Dotaz zn\u00ed: {4}.
CWWKD1031.ql.similar.entity.explanation=V dotazu se mo\u017en\u00e1 vyskytuje p\u0159eklep v n\u00e1zvu entity.
CWWKD1031.ql.similar.entity.useraction=Zkontrolujte dotaz a ujist\u011bte se, \u017ee je pou\u017eit spr\u00e1vn\u00fd n\u00e1zev entity.

CWWKD1032.ql.unknown.entity=CWWKD1032E: Metoda ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` specifikuje dotaz, kter\u00fd vy\u017eaduje n\u00e1zev entity ` {2} `, kter\u00fd nebyl nalezen. Ujist\u011bte se, \u017ee \u201e {2} \u201c je n\u00e1zev platn\u00e9ho subjektu. Aby bylo mo\u017en\u00e9 entitu vyhledat, p\u0159i\u0159a\u010fte \u00falo\u017ei\u0161ti metodu \u017eivotn\u00edho cyklu, kter\u00e1 je ozna\u010dena jednou z anotac\u00ed typu \u201e {3} \u201c, a jako jej\u00ed parametr zadejte danou entitu. Alternativn\u011b m\u016f\u017eete nastavit, aby repozit\u00e1\u0159 roz\u0161i\u0159oval rozhran\u00ed ` DataRepository ` nebo jin\u00e9 vestav\u011bn\u00e9 rozhran\u00ed repozit\u00e1\u0159e, p\u0159i\u010dem\u017e t\u0159\u00edda entity bude prvn\u00ed typovou prom\u011bnnou. Dotaz zn\u00ed: {4}.
CWWKD1032.ql.unknown.entity.explanation=V dotazu se mo\u017en\u00e1 vyskytuje p\u0159eklep v n\u00e1zvu entity, nebo \u00falo\u017ei\u0161t\u011b neuv\u00e1d\u00ed jej\u00ed prim\u00e1rn\u00ed t\u0159\u00eddu entity.
CWWKD1032.ql.unknown.entity.useraction=Zkontrolujte dotaz a ujist\u011bte se, \u017ee je pou\u017eit spr\u00e1vn\u00fd n\u00e1zev entity. Zkontrolujte definici repozit\u00e1\u0159e, abyste se ujistili, \u017ee je zad\u00e1na spr\u00e1vn\u00e1 t\u0159\u00edda prim\u00e1rn\u00ed entity.

CWWKD1033.ql.orderby.disallowed=CWWKD1033E: Metoda ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` nem\u016f\u017ee specifikovat dotaz obsahuj\u00edc\u00ed klauzuli `ORDER BY`, proto\u017ee tato metoda vrac\u00ed typ ` {2} `. Odstra\u0148te klauzuli ORDER BY a m\u00edsto toho pou\u017eijte anotaci ` {3} ` k zad\u00e1n\u00ed statick\u00fdch krit\u00e9ri\u00ed \u0159azen\u00ed. Dotaz zn\u00ed: {4}.
CWWKD1033.ql.orderby.disallowed.explanation=Klauzule ORDER BY nen\u00ed kompatibiln\u00ed s paginac\u00ed zalo\u017eenou na kurzorech.
CWWKD1033.ql.orderby.disallowed.useraction=Nahra\u010fte klauzuli ORDER BY anotacemi, kter\u00e9 ur\u010duj\u00ed krit\u00e9ria \u0159azen\u00ed.

CWWKD1034.ql.req.end.in.where=CWWKD1034E: Dotaz zadan\u00fd metodou ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` mus\u00ed kon\u010dit klauzul\u00ed `WHERE`, proto\u017ee tato metoda vrac\u00ed seznam ` {2} `. Klauzule WHERE kon\u010d\u00ed na pozici {3}, ale d\u00e9lka dotazu je {4}. Dotaz zn\u00ed: {5}.
CWWKD1034.ql.req.end.in.where.explanation=P\u0159i pou\u017eit\u00ed str\u00e1nkov\u00e1n\u00ed zalo\u017een\u00e9ho na kurzoru je nutn\u00e9 pou\u017e\u00edt klauzuli WHERE.
CWWKD1034.ql.req.end.in.where.useraction=Do dotazu p\u0159idejte klauzuli WHERE.

CWWKD1035.incompat.page.mode=CWWKD1035E: \u017d\u00e1dost o str\u00e1nku s re\u017eimem str\u00e1nkov\u00e1n\u00ed {0} nesm\u00ed b\u00fdt p\u0159ed\u00e1na metod\u011b {1} rozhran\u00ed \u00falo\u017ei\u0161t\u011b {2}, proto\u017ee tato metoda vrac\u00ed {3} nam\u00edsto {4}.
CWWKD1035.incompat.page.mode.explanation=Po\u017eadovan\u00fd re\u017eim str\u00e1nkov\u00e1n\u00ed nen\u00ed kompatibiln\u00ed s typem n\u00e1vratov\u00e9 hodnoty metody repozit\u00e1\u0159e.
CWWKD1035.incompat.page.mode.useraction=Pro re\u017eim str\u00e1nkov\u00e1n\u00ed OFFSET pou\u017eijte typ n\u00e1vratov\u00e9 hodnoty Page a pro re\u017eimy str\u00e1nkov\u00e1n\u00ed CURSOR_NEXT a CURSOR_PREVIOUS typ n\u00e1vratov\u00e9 hodnoty CursoredPage.

CWWKD1036.cursor.size.mismatch=CWWKD1036E: Kurzor obsahuj\u00edc\u00ed prvky typu ` {0} `, kter\u00fd je p\u0159ed\u00e1n metod\u011b ` {1} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {2} `, nelze pou\u017e\u00edt s t\u0159\u00eddic\u00edmi krit\u00e9rii typu ` {3} `, proto\u017ee po\u010det a po\u0159ad\u00ed prvk\u016f kurzoru mus\u00ed odpov\u00eddat t\u011bmto t\u0159\u00eddic\u00edm krit\u00e9ri\u00edm. Kurzor se skl\u00e1d\u00e1 z: {4}. Krit\u00e9rium \u0159azen\u00ed je: {5}.
CWWKD1036.cursor.size.mismatch.explanation=Po\u010det prvk\u016f kurzoru se mus\u00ed shodovat s velikost\u00ed kombinovan\u00fdch t\u0159\u00eddic\u00edch krit\u00e9ri\u00ed metody \u00falo\u017ei\u0161t\u011b.
CWWKD1036.cursor.size.mismatch.useraction=Upravte prvky kurzoru nebo krit\u00e9ria \u0159azen\u00ed tak, aby m\u011bly stejnou velikost.

CWWKD1037.cursor.rtrn.mismatch=CWWKD1037E: Nelze z\u00edskat kurzor z v\u00fdsledku metody ` {0} ` metody ` {1} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {2} `. Dotazy vyu\u017e\u00edvaj\u00edc\u00ed str\u00e1nkov\u00e1n\u00ed zalo\u017een\u00e9 na kurzoru mus\u00ed vracet v\u00fdsledky stejn\u00e9ho typu jako typ entity, tedy typu ` {3} `. Typ n\u00e1vratov\u00e9 hodnoty metody repozit\u00e1\u0159e je ` {4} `.
CWWKD1037.cursor.rtrn.mismatch.explanation=Str\u00e1nkov\u00e1n\u00ed pomoc\u00ed kurzoru je mo\u017en\u00e9 pouze v p\u0159\u00edpad\u011b, \u017ee metoda repozit\u00e1\u0159e vrac\u00ed typ entity.
CWWKD1037.cursor.rtrn.mismatch.useraction=Upravte metodu repozit\u00e1\u0159e tak, aby vracela typ entity.

CWWKD1038.no.prev.offset.page=CWWKD1038E: \u010c\u00edslo str\u00e1nky p\u0159edch\u00e1zej\u00edc\u00ed {0} nelze pro metodu {1} rozhran\u00ed repozit\u00e1\u0159e {2} po\u017eadovat, proto\u017ee metoda Page.hasPrevious vrac\u00ed hodnotu false, co\u017e znamen\u00e1, \u017ee neexistuje \u017e\u00e1dn\u00e1 p\u0159edchoz\u00ed str\u00e1nka.
CWWKD1038.no.prev.offset.page.explanation=P\u0159i posunut\u00e9m \u010d\u00edslov\u00e1n\u00ed str\u00e1nek nelze pou\u017e\u00edt \u010d\u00edsla str\u00e1nek men\u0161\u00ed ne\u017e 1.
CWWKD1038.no.prev.offset.page.useraction=Ujist\u011bte se, \u017ee \u010d\u00edslo po\u017eadovan\u00e9 str\u00e1nky je kladn\u00e9, a pomoc\u00ed metody ` Page.hasPrevious ` ov\u011b\u0159te, zda je platn\u00e9 vy\u017e\u00e1dat si p\u0159edchoz\u00ed str\u00e1nku.

CWWKD1039.no.prev.cursor.page=CWWKD1039E: U rozhran\u00ed \u00falo\u017ei\u0161t\u011b {1} nelze pomoc\u00ed metody {0} vy\u017e\u00e1dat p\u0159edchoz\u00ed str\u00e1nku, proto\u017ee metoda Page.hasPrevious vrac\u00ed hodnotu false, co\u017e znamen\u00e1, \u017ee \u017e\u00e1dn\u00e1 p\u0159edchoz\u00ed str\u00e1nka neexistuje.
CWWKD1039.no.prev.cursor.page.explanation=Str\u00e1nkov\u00e1n\u00ed pomoc\u00ed kurzoru neumo\u017e\u0148uje vyvolat p\u0159edchoz\u00ed str\u00e1nku, pokud je zn\u00e1mo, \u017ee aktu\u00e1ln\u00ed str\u00e1nka obsahuje v\u00fdsledky na za\u010d\u00e1tku datov\u00e9ho souboru.
CWWKD1039.no.prev.cursor.page.useraction=Pomoc\u00ed metody ` Page.hasPrevious ` ov\u011b\u0159te, zda je mo\u017en\u00e9 vy\u017e\u00e1dat si p\u0159edchoz\u00ed str\u00e1nku.

CWWKD1040.no.next.page=CWWKD1040E: U metody ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` nelze vy\u017e\u00e1dat dal\u0161\u00ed str\u00e1nku, proto\u017ee metoda ` {2} ` vrac\u00ed hodnotu `false`, co\u017e znamen\u00e1, \u017ee \u017e\u00e1dn\u00e1 dal\u0161\u00ed str\u00e1nka neexistuje.
CWWKD1040.no.next.page.explanation=Nelze vy\u017e\u00e1dat dal\u0161\u00ed str\u00e1nku, pokud je zn\u00e1mo, \u017ee aktu\u00e1ln\u00ed str\u00e1nka obsahuje konec datov\u00e9ho souboru.
CWWKD1040.no.next.page.useraction=Pomoc\u00ed metody ` hasNext ` ov\u011b\u0159te, zda je mo\u017en\u00e9 vy\u017e\u00e1dat si dal\u0161\u00ed str\u00e1nku.

CWWKD1041.rtrn.mismatch.pagereq=CWWKD1041E: Metoda ` {0} ` rozhran\u00ed repozit\u00e1\u0159e ` {1} ` m\u00e1 n\u00e1vratov\u00fd typ ` {2} `, ale za parametry pro podm\u00ednky dotazu chyb\u00ed parametr typu ` PageRequest `.
CWWKD1041.rtrn.mismatch.pagereq.explanation=Metody repozit\u00e1\u0159e s typy n\u00e1vratov\u00fdch hodnot `Page` a ` CursoredPage ` mus\u00ed m\u00edt parametr ` PageRequest `.
CWWKD1041.rtrn.mismatch.pagereq.useraction=Do podpisu metody repozit\u00e1\u0159e p\u0159idejte parametr ` PageRequest `.

CWWKD1042.no.totals=CWWKD1042E: Str\u00e1nky na\u010dten\u00e9 metodou ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` neobsahuj\u00ed celkov\u00fd po\u010det prvk\u016f a str\u00e1nek, proto\u017ee po\u017eadavek na str\u00e1nku ` {2} ` m\u00e1 pro parametr ` requestTotal ` nastavenu hodnotu `false`. Chcete-li vy\u017e\u00e1dat str\u00e1nku s uveden\u00fdm celkov\u00fdm po\u010dtem, pou\u017eijte metodu PageRequest.withTotal nam\u00edsto metody PageRequest.withoutTotal.
CWWKD1042.no.totals.explanation=Metoda \u201e PageRequest.withoutTotal \u201c ur\u010duje, \u017ee po\u017eadovan\u00e9 str\u00e1nky neobsahuj\u00ed celkov\u00fd po\u010det prvk\u016f a str\u00e1nek.
CWWKD1042.no.totals.useraction=Pomoc\u00ed metody ` PageRequest.withTotal ` m\u016f\u017eete zjistit celkov\u00fd po\u010det prvk\u016f a str\u00e1nek.

CWWKD1043.offset.exceeds.max=CWWKD1043E: Offset \u201e {0} \u201c, kter\u00fd je pot\u0159ebn\u00fd pro po\u017eadavek na str\u00e1nku {1} a kter\u00fd je p\u0159ed\u00e1n metod\u011b {2} rozhran\u00ed \u00falo\u017ei\u0161t\u011b {3}, p\u0159ekra\u010duje maxim\u00e1ln\u00ed povolenou hodnotu {4}.
CWWKD1043.offset.exceeds.max.explanation=Sou\u010det po\u010dtu stran a maxim\u00e1ln\u00ed velikosti str\u00e1nky je p\u0159\u00edli\u0161 velk\u00fd.
CWWKD1043.offset.exceeds.max.useraction=Do dotazu p\u0159idejte omezen\u00ed, abyste sn\u00ed\u017eili po\u010det odpov\u00eddaj\u00edc\u00edch v\u00fdsledk\u016f.

CWWKD1044.invalid.resource.type=CWWKD1044E: Metoda pro p\u0159\u00edstup k prost\u0159edk\u016fm typu \u201e {0} \u201c v \u00falo\u017ei\u0161ti typu \u201e {1} \u201c nem\u016f\u017ee vr\u00e1tit prost\u0159edek typu \u201e {2} \u201c. Metody pro p\u0159\u00edstup k prost\u0159edk\u016fm podporuj\u00ed n\u00e1sleduj\u00edc\u00ed typy n\u00e1vratov\u00fdch hodnot: {3}
CWWKD1044.invalid.resource.type.explanation=Typ n\u00e1vratov\u00e9 hodnoty metody pro p\u0159\u00edstup k prost\u0159edku nen\u00ed jedn\u00edm z typ\u016f podporovan\u00fdch v Jakarta Data.
CWWKD1044.invalid.resource.type.useraction=Odstra\u0148te tuto metodu nebo ji upravte tak, aby vracela jeden z podporovan\u00fdch typ\u016f.

CWWKD1045.unknown.entity.anno=CWWKD1045E: Vestav\u011bn\u00fd datov\u00fd poskytovatel Jakarta Data nem\u016f\u017ee poskytnout implementaci rozhran\u00ed \u00falo\u017ei\u0161t\u011b typu \u201e {0} \u201c, proto\u017ee t\u0159\u00edda entity typu \u201e {1} \u201c, kterou \u00falo\u017ei\u0161t\u011b pou\u017e\u00edv\u00e1, obsahuje nezn\u00e1mou anotaci entity. V t\u0159\u00edd\u011b entity se nach\u00e1zej\u00ed n\u00e1sleduj\u00edc\u00ed anotace entit: {2}. Podporovan\u00e9 anotace entit jsou: {3}.
CWWKD1045.unknown.entity.anno.explanation=Integrovan\u00fd datov\u00fd poskytovatel Jakarta nepodporuje jednu z anotac\u00ed entit.
CWWKD1045.unknown.entity.anno.useraction=Odstra\u0148te anotaci entity, kter\u00e1 nen\u00ed rozpozn\u00e1na, nebo pou\u017eijte atribut provider anotace Repository k v\u00fdb\u011bru poskytovatele Jakarta Data, kter\u00fd tuto anotaci entity rozpozn\u00e1.

CWWKD1046.result.convert.err=CWWKD1046E: V\u00fdsledek typu ` {0} ` metody ` {1} ` rozhran\u00ed repozit\u00e1\u0159e ` {2} ` nelze p\u0159ev\u00e9st na typ n\u00e1vratov\u00e9 hodnoty ` {3} ` t\u00e9to metody repozit\u00e1\u0159e.
CWWKD1046.result.convert.err.explanation=Hodnota v\u00fdsledku nen\u00ed kompatibiln\u00ed s typem n\u00e1vratov\u00e9 hodnoty metody repozit\u00e1\u0159e.
CWWKD1046.result.convert.err.useraction=Zajist\u011bte, aby typ n\u00e1vratov\u00e9 hodnoty metody repozit\u00e1\u0159e odpov\u00eddal typu v\u00fdsledku vr\u00e1cen\u00e9ho dotazem.

CWWKD1047.result.out.of.range=CWWKD1047E: V\u00fdsledek typu ` {0} ` metody ` {1} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {2} ` nelze p\u0159ev\u00e9st na n\u00e1vratov\u00fd typ ` {3} ` t\u00e9to metody \u00falo\u017ei\u0161t\u011b, proto\u017ee v\u00fdsledek nespad\u00e1 do rozsahu hodnot od ` {4} ` do ` {5} `.
CWWKD1047.result.out.of.range.explanation=Hodnota v\u00fdsledku nen\u00ed kompatibiln\u00ed s typem n\u00e1vratov\u00e9 hodnoty metody repozit\u00e1\u0159e, proto\u017ee le\u017e\u00ed mimo rozsah hodnot, kter\u00e9 lze p\u0159ev\u00e9st.
CWWKD1047.result.out.of.range.useraction=Upravte typ n\u00e1vratov\u00e9 hodnoty metody repozit\u00e1\u0159e tak, aby bylo mo\u017en\u00e9 hodnotu vr\u00e1tit.

CWWKD1048.result.exceeds.max=CWWKD1048E: V\u00fdsledek typu ` {0} ` metody ` {1} ` rozhran\u00ed repozit\u00e1\u0159e ` {2} ` nelze p\u0159ev\u00e9st na n\u00e1vratov\u00fd typ ` {3} ` t\u00e9to metody repozit\u00e1\u0159e, proto\u017ee hodnota v\u00fdsledku p\u0159ekra\u010duje maxim\u00e1ln\u00ed hodnotu ` {4} `.
CWWKD1048.result.exceeds.max.explanation=Hodnota v\u00fdsledku nen\u00ed kompatibiln\u00ed s typem n\u00e1vratov\u00e9 hodnoty metody repozit\u00e1\u0159e, proto\u017ee p\u0159ekra\u010duje maxim\u00e1ln\u00ed hodnotu, kterou lze p\u0159ev\u00e9st na tento typ.
CWWKD1048.result.exceeds.max.useraction=Upravte typ n\u00e1vratov\u00e9 hodnoty metody repozit\u00e1\u0159e tak, aby bylo mo\u017en\u00e9 hodnotu vr\u00e1tit.

CWWKD1049.count.convert.err=CWWKD1049E: Hodnotu po\u010d\u00edtadla typu ` {0} `, z\u00edskanou z metody ` {1} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {2} `, nelze p\u0159ev\u00e9st na typ n\u00e1vratov\u00e9 hodnoty ` {3} ` t\u00e9to metody \u00falo\u017ei\u0161t\u011b.
CWWKD1049.count.convert.err.explanation=Hodnota po\u010d\u00edtadla nen\u00ed kompatibiln\u00ed s typem n\u00e1vratov\u00e9 hodnoty metody \u00falo\u017ei\u0161t\u011b.
CWWKD1049.count.convert.err.useraction=Upravte typ n\u00e1vratov\u00e9 hodnoty metody repozit\u00e1\u0159e tak, aby bylo mo\u017en\u00e9 hodnotu vr\u00e1tit.

CWWKD1050.opt.lock.exc=CWWKD1050E: Metoda ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` nena\u0161la entitu ` {2} `, kter\u00e1 by odpov\u00eddala atribut\u016fm entity: ` {3} `. Ov\u011b\u0159te, zda instance entity p\u0159edan\u00e1 metod\u011b ` {0} ` vych\u00e1z\u00ed z nejnov\u011bj\u0161\u00ed verze entity. Nejnov\u011bj\u0161\u00ed verzi entity lze z\u00edskat pomoc\u00ed metody find nebo z v\u00fdsledn\u00e9 hodnoty jedn\u00e9 z n\u00e1sleduj\u00edc\u00edch metod \u017eivotn\u00edho cyklu: {4}.
CWWKD1050.opt.lock.exc.explanation=Nebylo nalezeno \u017e\u00e1dn\u00e9 odpov\u00eddaj\u00edc\u00ed z\u00e1znamy.
CWWKD1050.opt.lock.exc.useraction=Pokud se p\u0159edpokl\u00e1d\u00e1, \u017ee dan\u00fd subjekt v datab\u00e1zi nenajdeme, nen\u00ed t\u0159eba nic podnikat. V opa\u010dn\u00e9m p\u0159\u00edpad\u011b se ujist\u011bte, \u017ee je pou\u017eita nejnov\u011bj\u0161\u00ed verze entity.

CWWKD1051.single.opt.lock.exc=CWWKD1051E: Metoda ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` nena\u0161la v datab\u00e1zi odpov\u00eddaj\u00edc\u00ed entitu ` {2} `. Ov\u011b\u0159te, zda instance entity p\u0159edan\u00e1 metod\u011b ` {0} ` vych\u00e1z\u00ed z nejnov\u011bj\u0161\u00ed verze entity. Nejnov\u011bj\u0161\u00ed verzi entity lze z\u00edskat pomoc\u00ed metody find nebo z v\u00fdsledn\u00e9 hodnoty jedn\u00e9 z n\u00e1sleduj\u00edc\u00edch metod \u017eivotn\u00edho cyklu: {3}.
CWWKD1051.single.opt.lock.exc.explanation=Nebylo nalezeno \u017e\u00e1dn\u00e9 odpov\u00eddaj\u00edc\u00ed z\u00e1znamy.
CWWKD1051.single.opt.lock.exc.useraction=Pokud se p\u0159edpokl\u00e1d\u00e1, \u017ee dan\u00fd subjekt v datab\u00e1zi nenajdeme, nen\u00ed t\u0159eba nic podnikat. V opa\u010dn\u00e9m p\u0159\u00edpad\u011b se ujist\u011bte, \u017ee je pou\u017eita nejnov\u011bj\u0161\u00ed verze entity.

CWWKD1052.multi.opt.lock.exc=CWWKD1052E: Metoda ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` nena\u0161la v datab\u00e1zi entitu ` {2} ` z \u00falo\u017ei\u0161t\u011b ` {3} ` a ` {4} `. Ov\u011b\u0159te, zda jsou instance entit, kter\u00e9 jsou p\u0159ed\u00e1ny metod\u011b ` {0} `, zalo\u017eeny na nejnov\u011bj\u0161\u00ed verzi p\u0159\u00edslu\u0161n\u00e9 entity. Nejnov\u011bj\u0161\u00ed verzi entity lze z\u00edskat pomoc\u00ed metody `find` nebo z v\u00fdsledn\u00e9 hodnoty jedn\u00e9 z n\u00e1sleduj\u00edc\u00edch metod \u017eivotn\u00edho cyklu: ` {5} `.
CWWKD1052.multi.opt.lock.exc.explanation=Jeden nebo v\u00edce subjekt\u016f nebylo v datab\u00e1zi nalezeno.
CWWKD1052.multi.opt.lock.exc.useraction=Pokud se p\u0159edpokl\u00e1d\u00e1, \u017ee dan\u00fd subjekt v datab\u00e1zi nebude nalezen, nen\u00ed t\u0159eba podnikat \u017e\u00e1dn\u00e9 kroky. V opa\u010dn\u00e9m p\u0159\u00edpad\u011b se ujist\u011bte, \u017ee je pou\u017eita nejnov\u011bj\u0161\u00ed verze ka\u017ed\u00e9 entity.

CWWKD1053.empty.result=CWWKD1053E: Typ n\u00e1vratov\u00e9 hodnoty ` {0} ` metody ` {1} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {2} ` neumo\u017e\u0148uje vr\u00e1tit pr\u00e1zdn\u00fd v\u00fdsledek. Pokud se o\u010dek\u00e1v\u00e1 pr\u00e1zdn\u00fd v\u00fdsledek, mus\u00ed metoda repozit\u00e1\u0159e vr\u00e1tit pole nebo jeden z n\u00e1sleduj\u00edc\u00edch typ\u016f n\u00e1vratov\u00fdch hodnot: {3}.
CWWKD1053.empty.result.explanation=Typ n\u00e1vratov\u00e9 hodnoty metody repozit\u00e1\u0159e neumo\u017e\u0148uje, aby metoda vr\u00e1tila pr\u00e1zdn\u00fd v\u00fdsledek.
CWWKD1053.empty.result.useraction=Upravte metodu repozit\u00e1\u0159e tak, aby pou\u017e\u00edvala jeden z typ\u016f n\u00e1vratov\u00fdch hodnot, kter\u00fd m\u016f\u017ee p\u0159edstavovat pr\u00e1zdn\u00fd v\u00fdsledek.

CWWKD1054.non.unique.result=CWWKD1054E: Metoda ` {0} ` rozhran\u00ed repozit\u00e1\u0159e ` {1} ` m\u00e1 n\u00e1vratov\u00fd typ ` {2} `, kter\u00fd neumo\u017e\u0148uje vracet v\u00fdsledky typu ` {3} `. Chcete-li omezit v\u00fdstup na jedin\u00fd v\u00fdsledek, pou\u017eijte jeden z n\u00e1sleduj\u00edc\u00edch vzor\u016f Jakarta Data: {4}.
CWWKD1054.non.unique.result.explanation=Typ n\u00e1vratov\u00e9 hodnoty metody repozit\u00e1\u0159e neumo\u017e\u0148uje vr\u00e1tit v\u00edce v\u00fdsledk\u016f.
CWWKD1054.non.unique.result.useraction=Upravte metodu repozit\u00e1\u0159e tak, aby pou\u017e\u00edvala typ n\u00e1vratov\u00e9 hodnoty podporuj\u00edc\u00ed v\u00edce v\u00fdsledk\u016f, nebo ji upravte tak, aby vracela nanejv\u00fd\u0161 jeden v\u00fdsledek.

CWWKD1055.unsupported.entity.attr=CWWKD1055E: Atribut \u201e {0} \u201c entity \u201e {1} \u201c m\u00e1 nepodporovan\u00fd typ: \u201e {2} \u201c. Jakarta Data podporuje typy v\u00fd\u010dt\u016f jazyka Java, \u010dasov\u00e9 typy z bal\u00ed\u010dku \u201e {3} \u201c a n\u00e1sleduj\u00edc\u00ed z\u00e1kladn\u00ed typy: {4}. Integrovan\u00fd datov\u00fd poskytovatel Jakarta Data Provider podporuje tak\u00e9 n\u011bkter\u00e9 typy Jakarta Persistence, nap\u0159\u00edklad embeddables. Alternativn\u011b, pokud pou\u017e\u00edv\u00e1te entitu Jakarta Persistence, m\u016f\u017eete k atributu ` {0} ` p\u0159idat anotaci ` {5} `, \u010d\u00edm\u017e poskytnete implementaci ` AttributeConverter `, kter\u00e1 p\u0159evede nepodporovan\u00fd typ na podporovan\u00fd typ.
CWWKD1055.unsupported.entity.attr.explanation=Jakarta Data nepodporuje typ pou\u017eit\u00fd v atributu entity.
CWWKD1055.unsupported.entity.attr.useraction=Upravte atribut entity tak, aby pou\u017e\u00edval jeden z podporovan\u00fdch typ\u016f.

CWWKD1056.unsupported.keyword=CWWKD1056E: Metoda ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` m\u00e1 n\u00e1zev, kter\u00fd obsahuje kl\u00ed\u010dov\u00e9 slovo ` {2} `, co\u017e nen\u00ed kl\u00ed\u010dov\u00e9 slovo podporovan\u00e9 vzorem \u201eJakarta Data Query by Method Name\u201c.
CWWKD1056.unsupported.keyword.explanation=N\u00e1zev metody obsahuje kl\u00ed\u010dov\u00e9 slovo, kter\u00e9 nen\u00ed rozpozn\u00e1no jako sou\u010d\u00e1st podporovan\u00e9ho vzoru \u201eJakarta Data Query by Method Name\u201c.
CWWKD1056.unsupported.keyword.useraction=P\u0159ejmenujte metodu repozit\u00e1\u0159e tak, aby neobsahovala nepodporovan\u00e9 kl\u00ed\u010dov\u00e9 slovo.

CWWKD1057.no.args.constr.inacc=CWWKD1057E: Typ n\u00e1vratov\u00e9 hodnoty ` {0} ` metody ` {1} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {2} ` nen\u00ed pro metodu \u00falo\u017ei\u0161t\u011b platn\u00fd, proto\u017ee t\u0159\u00edda ` {3} ` neobsahuje ve\u0159ejn\u00fd konstruktor bez parametr\u016f.
CWWKD1057.no.args.constr.inacc.explanation=K p\u0159evodu v\u00fdsledku do zadan\u00e9 t\u0159\u00eddy je zapot\u0159eb\u00ed ve\u0159ejn\u00fd konstruktor bez parametr\u016f.
CWWKD1057.no.args.constr.inacc.useraction=Upravte metodu repozit\u00e1\u0159e tak, aby m\u011bla typ n\u00e1vratov\u00e9 hodnoty podporovan\u00fd knihovnou Jakarta Data, nebo aby byla podt\u0159\u00eddou rozhran\u00ed Iterable s ve\u0159ejn\u00fdm konstruktorem bez parametr\u016f.

CWWKD1058.no.args.constr.err=CWWKD1058E: Typ n\u00e1vratov\u00e9 hodnoty ` {0} ` metody ` {1} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {2} ` nen\u00ed pro metodu \u00falo\u017ei\u0161t\u011b platn\u00fd, proto\u017ee konstruktor t\u0159\u00eddy ` {3} ` vyvolal chybu: ` {4} `.
CWWKD1058.no.args.constr.err.explanation=Ve\u0159ejn\u00fd konstruktor bez parametr\u016f selhal kv\u016fli chyb\u011b.
CWWKD1058.no.args.constr.err.useraction=Opravte chybu v konstruktoru nebo upravte metodu repozit\u00e1\u0159e tak, aby pou\u017e\u00edvala jin\u00fd typ n\u00e1vratov\u00e9 hodnoty.

CWWKD1059.attr.cast.err=CWWKD1059E: Metoda ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` nem\u016f\u017ee p\u0159istupovat k atributu ` {2} ` entity ` {3} `, proto\u017ee pole nebo metoda ` {4} ` t\u0159\u00eddy ` {5} ` nen\u00ed kompatibiln\u00ed s hodnotou typu ` {6} `.
CWWKD1059.attr.cast.err.explanation=Atribut entity nebo souvisej\u00edc\u00ed atribut z jej\u00ed hierarchie nen\u00ed kompatibiln\u00ed s o\u010dek\u00e1van\u00fdm typem.
CWWKD1059.attr.cast.err.useraction=Projd\u011bte si model entity a ov\u011b\u0159te, zda jsou u ka\u017ed\u00e9ho atributu pou\u017eity spr\u00e1vn\u00e9 typy.

CWWKD1060.name.out.of.scope=CWWKD1060E: Rozhran\u00ed \u00falo\u017ei\u0161t\u011b \u201e {0} \u201c v aplikaci \u201e {1} \u201c nastavuje hodnotu \u201e {2} \u201c pro atribut \u201e {3} \u201c, av\u0161ak n\u00e1zvy \u201e {3} \u201c nejsou dostupn\u00e9 pro artefakt, kter\u00fd toto rozhran\u00ed \u00falo\u017ei\u0161t\u011b poskytuje. Pou\u017eijte m\u00edsto toho n\u00e1zev typu \u201e {4} \u201c.
CWWKD1060.name.out.of.scope.explanation=Z artefaktu, ve kter\u00e9m je definov\u00e1no rozhran\u00ed \u00falo\u017ei\u0161t\u011b, nen\u00ed mo\u017en\u00e9 p\u0159istupovat k uveden\u00e9mu jmenn\u00e9mu prostoru.
CWWKD1060.name.out.of.scope.useraction=Upravte anotaci Repository tak, aby obsahovala n\u00e1zev \u00falo\u017ei\u0161t\u011b dat, kter\u00fd je viditeln\u00fd pro modul nebo knihovnu poskytuj\u00edc\u00ed rozhran\u00ed \u00falo\u017ei\u0161t\u011b.

CWWKD1061.comp.name.in.ejb=CWWKD1061E: Jedno nebo v\u00edce rozhran\u00ed \u00falo\u017ei\u0161t\u011b ( {0} ), kter\u00e1 jsou definov\u00e1na v modulu podnikov\u00e9ho bean {1} aplikace {2}, konfiguruj\u00ed hodnotu {3} pro atribut {4}. Moduly podnikov\u00fdch bean\u016f v\u0161ak nemaj\u00ed p\u0159\u00edstup k n\u00e1zv\u016fm typu \u201e {5} \u201c. Pou\u017eijte n\u00e1zev z n\u011bkter\u00e9ho z n\u00e1sleduj\u00edc\u00edch jmenn\u00fdch prostor\u016f: {6}.
CWWKD1061.comp.name.in.ejb.explanation=Modul podnikov\u00e9ho bean, ve kter\u00e9m je definov\u00e1no rozhran\u00ed \u00falo\u017ei\u0161t\u011b, nem\u00e1 p\u0159\u00edstup k uveden\u00e9mu jmenn\u00e9mu prostoru.
CWWKD1061.comp.name.in.ejb.useraction=Upravte anotaci Repository tak, aby obsahovala n\u00e1zev datov\u00e9ho \u00falo\u017ei\u0161t\u011b, kter\u00fd je viditeln\u00fd pro modul podnikov\u00e9ho bean, jen\u017e poskytuje rozhran\u00ed \u00falo\u017ei\u0161t\u011b.

CWWKD1062.resource.not.found=CWWKD1062E: Metoda ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` nedok\u00e1\u017ee naj\u00edt zdroj ` {2} ` s filtrem ` {3} `.
CWWKD1062.resource.not.found.explanation=Zdroje nebylo nalezeno.
CWWKD1062.resource.not.found.useraction=Ujist\u011bte se, \u017ee zadan\u00fd zdroj a v\u0161echny ostatn\u00ed zdroje, na nich\u017e z\u00e1vis\u00ed, existuj\u00ed a jsou spr\u00e1vn\u011b nakonfigurov\u00e1ny.

CWWKD1063.unsupported.resource=CWWKD1063E: Metoda ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` nem\u016f\u017ee z\u00edskat zdroj typu ` {2} `, proto\u017ee poskytovatel Jakarta Persistence nepodporuje operaci `unwrap`, kter\u00e1 vrac\u00ed instanci typu ` {3} `.
CWWKD1063.unsupported.resource.explanation=Poskytovatel Jakarta Persistence nepodporuje operaci unwrap, kter\u00e1 by vracela zadan\u00fd typ zdroje.
CWWKD1063.unsupported.resource.useraction=Odstra\u0148te z rozhran\u00ed \u00falo\u017ei\u0161t\u011b metodu pro p\u0159\u00edstup k prost\u0159edk\u016fm, kter\u00e1 ji\u017e nen\u00ed podporov\u00e1na.

CWWKD1064.datastore.error=CWWKD1064E: Metoda ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` nem\u016f\u017ee z\u00edskat datov\u00fd \u00falo\u017ei\u0161t\u011b ` {2} ` pro dan\u00e9 \u00falo\u017ei\u0161t\u011b z d\u016fvodu n\u00e1sleduj\u00edc\u00ed chyby: ` {3} `.
CWWKD1064.datastore.error.explanation=P\u0159i pokusu o na\u010dten\u00ed datov\u00e9ho \u00falo\u017ei\u0161t\u011b do\u0161lo k chyb\u011b.
CWWKD1064.datastore.error.useraction=Ujist\u011bte se, \u017ee zadan\u00e9 \u00falo\u017ei\u0161t\u011b dat a v\u0161echny ostatn\u00ed zdroje, na nich\u017e z\u00e1vis\u00ed, existuj\u00ed a jsou spr\u00e1vn\u011b nakonfigurov\u00e1ny.

CWWKD1065.ddlgen.timeout=CWWKD1065E: Generov\u00e1n\u00ed DDL pro jedno nebo v\u00edce rozhran\u00ed \u00falo\u017ei\u0161t\u011b ( {0} ) selhalo, proto\u017ee datov\u00fd \u00falo\u017ei\u0161t\u011b {1} nedokon\u010dilo generov\u00e1n\u00ed DDL do {2} sekund u n\u00e1sleduj\u00edc\u00edch entit: {3}.
CWWKD1065.ddlgen.timeout.explanation=Pokus o generov\u00e1n\u00ed DDL vypr\u0161el a nebyl dokon\u010den.
CWWKD1065.ddlgen.timeout.useraction=Zkuste generov\u00e1n\u00ed DDL znovu, a\u017e syst\u00e9m a datab\u00e1ze nebudou zat\u00ed\u017eeny.

CWWKD1066.ddlgen.failed=CWWKD1066E: P\u0159i generov\u00e1n\u00ed DDL pro jedno nebo v\u00edce rozhran\u00ed \u00falo\u017ei\u0161t\u011b ( {0} ), kter\u00e1 vyu\u017e\u00edvaj\u00ed datov\u00fd \u00falo\u017ei\u0161t\u011b {1}, do\u0161lo k chyb\u011b p\u0159i generov\u00e1n\u00ed DDL pro n\u00e1sleduj\u00edc\u00ed entity: {2}. Chyba zn\u00ed: {3}.
CWWKD1066.ddlgen.failed.explanation=Pokus o generov\u00e1n\u00ed DDL selhal a nebyl dokon\u010den.
CWWKD1066.ddlgen.failed.useraction=Zjist\u011bte p\u0159\u00ed\u010dinu chyby a prove\u010fte opravy v rozhran\u00ed repozit\u00e1\u0159e, entit\u00e1ch, konfiguraci \u00falo\u017ei\u0161t\u011b dat nebo v datab\u00e1zi.

CWWKD1067.ddlgen.emf.timeout=CWWKD1067E: Vytvo\u0159en\u00ed DDL pro jedno nebo v\u00edce rozhran\u00ed \u00falo\u017ei\u0161t\u011b ( {0} ) selhalo, proto\u017ee datov\u00e9 \u00falo\u017ei\u0161t\u011b {1} nebylo dostupn\u00e9 nebo nebylo schopno zp\u0159\u00edstupnit n\u00e1sleduj\u00edc\u00ed entity do {2} sekund: {3}.
CWWKD1067.ddlgen.emf.timeout.explanation=\u010casov\u00fd limit pro na\u010dten\u00ed prost\u0159edk\u016f pot\u0159ebn\u00fdch k generov\u00e1n\u00ed DDL vypr\u0161el a operace nebyla dokon\u010dena.
CWWKD1067.ddlgen.emf.timeout.useraction=Zkuste generov\u00e1n\u00ed DDL znovu, a\u017e syst\u00e9m a datab\u00e1ze nebudou zat\u00ed\u017eeny.

CWWKD1068.entity.name.conflict=CWWKD1068E: Rozhran\u00ed repozit\u00e1\u0159e \u201e {0} \u201c obsahuje n\u011bkolik entit s n\u00e1zvem \u201e {1} \u201c, kter\u00e9 jsou poskytov\u00e1ny r\u016fzn\u00fdmi t\u0159\u00eddami: {2}. K p\u0159i\u0159azen\u00ed jedine\u010dn\u00e9ho n\u00e1zvu entity a n\u00e1zvu tabulky ka\u017ed\u00e9 t\u0159\u00edd\u011b entity pou\u017eijte n\u00e1sleduj\u00edc\u00ed anotace entit v Jakarta Persistence: {3}.
CWWKD1068.entity.name.conflict.explanation=N\u00e1zvy entit a tabulek se odvozuj\u00ed z neup\u0159esn\u011bn\u00e9ho n\u00e1zvu t\u0159\u00eddy nebo se p\u0159i\u0159azuj\u00ed pomoc\u00ed anotac\u00ed Jakarta Persistence.
CWWKD1068.entity.name.conflict.useraction=P\u0159ejmenujte entity nebo p\u0159idejte anotace Jakarta Persistence, abyste tento konflikt n\u00e1zv\u016f v\u00fdslovn\u011b vy\u0159e\u0161ili.

CWWKD1069.record.entity.name.conflict=CWWKD1069E: Rozhran\u00ed repozit\u00e1\u0159e \u201e {0} \u201c obsahuje n\u011bkolik entit s n\u00e1zvem \u201e {1} \u201c, kter\u00e9 jsou poskytov\u00e1ny r\u016fzn\u00fdmi t\u0159\u00eddami: {2}. Pokud se z\u00e1znamy jazyka Java pou\u017e\u00edvaj\u00ed jako entity, mus\u00ed b\u00fdt rovn\u011b\u017e mo\u017en\u00e9 p\u0159ipojit k n\u00e1zvu entity p\u0159\u00edponu \u201eEntity\u201c, ani\u017e by t\u00edm do\u0161lo ke konfliktu n\u00e1zv\u016f. Nap\u0159\u00edklad: {2}.
CWWKD1069.record.entity.name.conflict.explanation=N\u00e1zvy entit a tabulek se odvozuj\u00ed z neup\u0159esn\u011bn\u00e9ho n\u00e1zvu t\u0159\u00eddy nebo se p\u0159i\u0159azuj\u00ed pomoc\u00ed anotac\u00ed Jakarta Persistence.
CWWKD1069.record.entity.name.conflict.useraction=P\u0159ejmenujte entity nebo p\u0159ejd\u011bte na entity Jakarta Persistence, abyste vy\u0159e\u0161ili konflikt n\u00e1zv\u016f.

CWWKD1070.record.convert.err=CWWKD1070E: Z\u00e1znam typu \u201e {0} \u201c, kter\u00fd je p\u0159ed\u00e1n metod\u011b \u201e {1} \u201c rozhran\u00ed \u00falo\u017ei\u0161t\u011b \u201e {2} \u201c, nelze pou\u017e\u00edt jako entitu z d\u016fvodu n\u00e1sleduj\u00edc\u00ed chyby: {3}.
CWWKD1070.record.convert.err.explanation=Z\u00e1znam Java nelze pou\u017e\u00edt jako entitu.
CWWKD1070.record.convert.err.useraction=Definujte entitu jako entitu Jakarta Persistence nam\u00edsto pou\u017eit\u00ed entity typu Java Record.

CWWKD1071.record.with.type.var=CWWKD1071E: Z\u00e1znam typu \u201e {0} \u201c je pou\u017e\u00edv\u00e1n jako entita jedn\u00edm nebo v\u00edce rozhran\u00edmi \u00falo\u017ei\u0161t\u011b ( {1} ) v artefaktu aplikace \u201e {2} \u201c, av\u0161ak tento z\u00e1znam nem\u016f\u017ee b\u00fdt entitou, proto\u017ee obsahuje jednu nebo v\u00edce typov\u00fdch prom\u011bnn\u00fdch: {3}.
CWWKD1071.record.with.type.var.explanation=T\u0159\u00eddy entit nemohou obsahovat generick\u00e9 typov\u00e9 prom\u011bnn\u00e9.
CWWKD1071.record.with.type.var.useraction=Odstra\u0148te typov\u00e9 prom\u011bnn\u00e9 ze z\u00e1znamu.

CWWKD1072.record.comp.conflict=CWWKD1072E: Z\u00e1znam \u201e {0} \u201c je pou\u017e\u00edv\u00e1n jako entita jedn\u00edm nebo v\u00edce rozhran\u00edmi \u00falo\u017ei\u0161t\u011b ( {1} ) v artefaktu aplikace \u201e {2} \u201c, av\u0161ak tento z\u00e1znam nem\u016f\u017ee b\u00fdt entitou, proto\u017ee jeho komponenty \u201e {3} \u201c a \u201e {4} \u201c odkazuj\u00ed na stejn\u00fd n\u00e1zev atributu entity.
CWWKD1072.record.comp.conflict.explanation=N\u00e1zvy atribut\u016f entit mus\u00ed b\u00fdt jedine\u010dn\u00e9 bez ohledu na velikost p\u00edsmen.
CWWKD1072.record.comp.conflict.useraction=P\u0159ejmenujte jednu ze slo\u017eek z\u00e1znamu, abyste p\u0159ede\u0161li konfliktu.

CWWKD1073.offset.exceeds.max=CWWKD1073E: Po\u010d\u00e1te\u010dn\u00ed hodnota limitu {1} v souboru {0}, kter\u00e1 je p\u0159ed\u00e1na metod\u011b {2} rozhran\u00ed \u00falo\u017ei\u0161t\u011b {3}, p\u0159ekra\u010duje maxim\u00e1ln\u00ed povolenou hodnotu {4}.
CWWKD1073.offset.exceeds.max.explanation=Po\u010d\u00e1te\u010dn\u00ed hodnota limity je p\u0159\u00edli\u0161 velk\u00e1.
CWWKD1073.offset.exceeds.max.useraction=Do dotazu p\u0159idejte omezen\u00ed, abyste sn\u00ed\u017eili po\u010det odpov\u00eddaj\u00edc\u00edch v\u00fdsledk\u016f.

CWWKD1074.qbmn.incompat.keywords=CWWKD1074E: Metoda ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` nesm\u00ed v jedn\u00e9 podm\u00ednce typu \u201eQuery by Method Name\u201c kombinovat kl\u00ed\u010dov\u00e1 slova ` {2} ` a ` {3} `.
CWWKD1074.qbmn.incompat.keywords.explanation=Uveden\u00e1 kl\u00ed\u010dov\u00e1 slova pro dotazov\u00e1n\u00ed podle n\u00e1zvu metody nejsou vz\u00e1jemn\u011b kompatibiln\u00ed.
CWWKD1074.qbmn.incompat.keywords.useraction=P\u0159ejmenujte metodu tak, aby se kl\u00ed\u010dov\u00e1 slova ve stejn\u00e9 podm\u00ednce nespojovala.

CWWKD1075.entity.attr.conflict=CWWKD1075E: Entita typu \u201e {0} \u201c nem\u016f\u017ee m\u00edt atribut s n\u00e1zvem \u201e {1} \u201c a z\u00e1rove\u0148 atribut s n\u00e1zvem \u201e {2} \u201c, proto\u017ee specifikace Jakarta Data pova\u017euje tyto n\u00e1zvy za aliasy stejn\u00e9ho atributu entity.
CWWKD1075.entity.attr.conflict.explanation=V n\u00e1zvech dvou atribut\u016f entit doch\u00e1z\u00ed ke kolizi kv\u016fli znaku podtr\u017e\u00edtka.
CWWKD1075.entity.attr.conflict.useraction=V n\u00e1zvech atribut\u016f entit nepou\u017e\u00edvejte znak podtr\u017e\u00edtka.

CWWKD1076.repo.disposed=CWWKD1076E: Metodu ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` nelze vyvolat, proto\u017ee aplikace, kter\u00e1 toto \u00falo\u017ei\u0161t\u011b definuje, byla ukon\u010dena. Instance repozit\u00e1\u0159e je {2}.
CWWKD1076.repo.disposed.explanation=Metody \u00falo\u017ei\u0161t\u011b se nesm\u00ed pou\u017e\u00edvat mimo \u017eivotn\u00ed cyklus aplikace, kter\u00e1 dan\u00e9 \u00falo\u017ei\u0161t\u011b definuje.
CWWKD1076.repo.disposed.useraction=Zajist\u011bte, aby metoda repozit\u00e1\u0159e nebyla pou\u017e\u00edv\u00e1na mimo rozsah aplikace, kter\u00e1 tento repozit\u00e1\u0159 definuje.

CWWKD1077.defaultds.not.found=CWWKD1077E: Aplikace typu \u201e {0} \u201c m\u00e1 jedno nebo v\u00edce rozhran\u00ed \u00falo\u017ei\u0161t\u011b ( {1} ), kter\u00e1 vyu\u017e\u00edvaj\u00ed datov\u00e9 \u00falo\u017ei\u0161t\u011b typu \u201e {2} \u201c nebo jej maj\u00ed nastaveno jako v\u00fdchoz\u00ed. Tento datov\u00fd \u00falo\u017ei\u0161t\u011b je nutn\u00e9 nakonfigurovat v nastaven\u00ed serveru tak, \u017ee se definuje prvek ` dataSource ` s identifik\u00e1torem ` DefaultDataSource `. Nap\u0159\u00edklad: {3} P\u0159\u00edpadn\u011b nastavte hodnotu dataStore v anotaci Repository tak, aby odpov\u00eddala identifik\u00e1toru prvku databaseStore nebo JNDI n\u00e1zvu odkazu na zdroj dat \u010di odkazu na jednotku perzistence, ke kter\u00e9mu m\u00e1 artefakt aplikace p\u0159\u00edstup. V konfiguraci serveru lze definovat prvek typu \u201e databaseStore \u201c. Nap\u0159\u00edklad {4}. Aplika\u010dn\u00ed komponenta m\u016f\u017ee pomoc\u00ed anotace Resource definovat odkaz na zdroj dat. \
    Nap\u0159\u00edklad {5}, kter\u00fd vy\u017eaduje, aby konfigurace serveru obsahovala konfigura\u010dn\u00ed prvek dataSource s atributem {6}. Aplika\u010dn\u00ed komponenta m\u016f\u017ee pomoc\u00ed anotace ` PersistenceUnit ` definovat odkaz na jednotku perzistence. Nap\u0159\u00edklad {7}, kter\u00fd vy\u017eaduje, aby soubor ` persistence.xml ` obsahoval prvek `persistence-unit` s odpov\u00eddaj\u00edc\u00edm atributem `name`. Nap\u0159\u00edklad {8}
CWWKD1077.defaultds.not.found.explanation=\u00dalo\u017ei\u0161t\u011b dat v Jakarta EE pou\u017e\u00edvaj\u00ed jako v\u00fdchoz\u00ed zdroj dat v\u00fdchoz\u00ed zdroj dat Jakarta EE, kter\u00fd je nutn\u00e9 nakonfigurovat v nastaven\u00ed serveru.
CWWKD1077.defaultds.not.found.useraction=Nakonfigurujte v\u00fdchoz\u00ed datov\u00fd zdroj Jakarta EE nebo pro \u00falo\u017ei\u0161t\u011b zadejte jin\u00fd datov\u00fd zdroj.

CWWKD1078.datastore.not.found=CWWKD1078E: Jedno nebo v\u00edce rozhran\u00ed \u00falo\u017ei\u0161t\u011b ( {0} ) z artefaktu aplikace {1} odkazuje na datov\u00e9 \u00falo\u017ei\u0161t\u011b {2}, kter\u00e9 neodpov\u00edd\u00e1 identifik\u00e1toru prvku dataSource nebo prvku databaseStore v konfiguraci serveru, nebo neodpov\u00edd\u00e1 JNDI n\u00e1zvu datov\u00e9ho zdroje, odkazu na datov\u00fd zdroj \u010di odkazu na perzisten\u010dn\u00ed jednotku, ke kter\u00fdm m\u00e1 artefakt aplikace p\u0159\u00edstup, p\u0159\u00edpadn\u011b nen\u00ed n\u011bkter\u00fd z t\u011bchto souvisej\u00edc\u00edch zdroj\u016f spr\u00e1vn\u011b nakonfigurov\u00e1n. V konfiguraci serveru lze definovat prvek typu \u201e dataSource \u201c. Nap\u0159\u00edklad {3} V konfiguraci serveru lze definovat prvek databaseStore. Nap\u0159\u00edklad {4}. Aplika\u010dn\u00ed komponenta m\u016f\u017ee pomoc\u00ed anotace Resource definovat odkaz na zdroj dat. Nap\u0159\u00edklad {5}, kter\u00fd vy\u017eaduje, aby konfigurace se\
    rveru obsahovala konfigura\u010dn\u00ed prvek dataSource s atributem {6}. Aplika\u010dn\u00ed komponenta m\u016f\u017ee pomoc\u00ed anotace ` PersistenceUnit ` definovat odkaz na jednotku perzistence. Nap\u0159\u00edklad {7}, kter\u00fd vy\u017eaduje, aby soubor ` persistence.xml ` obsahoval prvek `persistence-unit` s odpov\u00eddaj\u00edc\u00edm atributem `name`. Nap\u0159\u00edklad {8}
CWWKD1078.datastore.not.found.explanation=\u00dalo\u017ei\u0161t\u011bm dat v r\u00e1mci repozit\u00e1\u0159e Jakarta Data m\u016f\u017ee b\u00fdt ID prvku \u201e dataSource \u201c nebo \u201e databaseStore \u201c v konfiguraci serveru, p\u0159\u00edpadn\u011b JNDI n\u00e1zev datov\u00e9ho zdroje, odkaz na zdroj datov\u00e9ho zdroje nebo odkaz na jednotku perzistence.
CWWKD1078.datastore.not.found.useraction=Ujist\u011bte se, \u017ee je zdroj spr\u00e1vn\u011b nakonfigurov\u00e1n. P\u0159i pou\u017eit\u00ed n\u00e1zvu JNDI se ujist\u011bte, \u017ee rozsah platnosti tohoto n\u00e1zvu umo\u017e\u0148uje p\u0159\u00edstup k dan\u00e9mu zdroji pro aplika\u010dn\u00ed artefakt, kter\u00fd poskytuje \u00falo\u017ei\u0161t\u011b.

CWWKD1079.jndi.not.found=CWWKD1079E: Jedno nebo v\u00edce rozhran\u00ed \u00falo\u017ei\u0161t\u011b ( {0} ) z artefaktu aplikace {1} specifikuje datov\u00e9 \u00falo\u017ei\u0161t\u011b s n\u00e1zvem JNDI {2}, av\u0161ak artefakt aplikace nem\u00e1 p\u0159\u00edstup k datov\u00e9mu zdroji, odkazu na zdroj datov\u00e9ho zdroje nebo odkazu na jednotku perzistence s t\u00edmto n\u00e1zvem JNDI, p\u0159\u00edpadn\u011b nen\u00ed n\u011bkter\u00fd z t\u011bchto souvisej\u00edc\u00edch zdroj\u016f spr\u00e1vn\u011b nakonfigurov\u00e1n. Aplika\u010dn\u00ed komponenta m\u016f\u017ee pomoc\u00ed anotace Resource definovat odkaz na zdroj dat. Nap\u0159\u00edklad {3}, kter\u00fd odkazuje na konfigura\u010dn\u00ed prvek serveru dataSource s atributem {4}. Aplika\u010dn\u00ed komponenta m\u016f\u017ee pomoc\u00ed anotace ` PersistenceUnit ` definovat odkaz na jednotku perzistence. Nap\u0159\u00edklad {5}, kter\u00fd vy\u017eaduje, aby soubor ` persistence.xml ` obsahoval prvek `persistence-unit` s odpov\u00ed\
    daj\u00edc\u00edm atributem `name`. Nap\u0159\u00edklad {6}. Aplika\u010dn\u00ed komponenta m\u016f\u017ee k definici zdroje dat pou\u017e\u00edt anotaci DataSourceDefinition. Alternativn\u011b lze zdroj dat definovat v konfiguraci serveru pomoc\u00ed prvku ` dataSource `. Nap\u0159\u00edklad {7}
CWWKD1079.jndi.not.found.explanation=Pokud je \u00falo\u017ei\u0161t\u011b dat v r\u00e1mci Jakarta Data nastaveno na JNDI n\u00e1zev datov\u00e9ho zdroje, odkaz na datov\u00fd zdroj nebo odkaz na perzisten\u010dn\u00ed jednotku, mus\u00ed b\u00fdt tento JNDI n\u00e1zev p\u0159\u00edstupn\u00fd pro aplika\u010dn\u00ed artefakt, kter\u00fd poskytuje dan\u00e9 \u00falo\u017ei\u0161t\u011b, a datov\u00fd zdroj nebo perzisten\u010dn\u00ed jednotka mus\u00ed b\u00fdt spr\u00e1vn\u011b nakonfigurov\u00e1ny.
CWWKD1079.jndi.not.found.useraction=Ujist\u011bte se, \u017ee je zdroj spr\u00e1vn\u011b nakonfigurov\u00e1n, a ov\u011b\u0159te, zda rozsah n\u00e1zvu JNDI umo\u017e\u0148uje p\u0159\u00edstup k tomuto zdroji pro aplika\u010dn\u00ed artefakt, kter\u00fd poskytuje \u00falo\u017ei\u0161t\u011b.

CWWKD1080.datastore.general.err=CWWKD1080E: Jedno nebo v\u00edce rozhran\u00ed \u00falo\u017ei\u0161t\u011b ( {0} ) z artefaktu aplikace {1} nen\u00ed kv\u016fli chyb\u011b k dispozici. Chyba m\u016f\u017ee b\u00fdt zp\u016fsobena probl\u00e9mem s konfigurac\u00ed, p\u0159\u00edpadn\u011b m\u016f\u017ee b\u00fdt nedostupn\u00fd datov\u00fd \u00falo\u017ei\u0161t\u011b {2} pro dan\u00fd repozit\u00e1\u0159. Chyba zn\u00ed: {3}.
CWWKD1080.datastore.general.err.explanation=Kv\u016fli chyb\u011b nelze pou\u017e\u00edt uveden\u00e9 repozit\u00e1\u0159e.
CWWKD1080.datastore.general.err.useraction=Vyhledejte rozhran\u00ed \u00falo\u017ei\u0161t\u011b a konfiguraci datov\u00e9ho \u00falo\u017ei\u0161t\u011b a v p\u0159\u00edpad\u011b pot\u0159eby prove\u010fte opravy.

CWWKD1081.entity.general.err=CWWKD1081E: Z d\u016fvodu chyby nen\u00ed entita {0} k dispozici pro jedno nebo v\u00edce rozhran\u00ed \u00falo\u017ei\u0161t\u011b ( {1} ), kter\u00e1 vyu\u017e\u00edvaj\u00ed datov\u00e9 \u00falo\u017ei\u0161t\u011b {2}. Chyba: {3}
CWWKD1081.entity.general.err.explanation=Kv\u016fli chyb\u011b nelze zadanou entitu pou\u017e\u00edt.
CWWKD1081.entity.general.err.useraction=Najd\u011bte dan\u00fd subjekt a v p\u0159\u00edpad\u011b pot\u0159eby prove\u010fte opravy.

CWWKD1082.entity.classes.missing=CWWKD1082E: Persisten\u010dn\u00ed jednotka pro datov\u00fd \u00falo\u017ei\u0161t\u011b typu \u201e {0} \u201c nedefinuje jednu ani v\u00edce t\u0159\u00edd entit ( {1} ), kter\u00e9 vy\u017eaduje jedno nebo v\u00edce rozhran\u00ed \u00falo\u017ei\u0161t\u011b ( {2} ) vyu\u017e\u00edvaj\u00edc\u00edch toto datov\u00e9 \u00falo\u017ei\u0161t\u011b.
CWWKD1082.entity.classes.missing.explanation=Repozit\u00e1\u0159e vyu\u017e\u00edvaj\u00ed t\u0159\u00eddy entit, kter\u00e9 mus\u00ed b\u00fdt definov\u00e1ny v perzisten\u010dn\u00ed jednotce.
CWWKD1082.entity.classes.missing.useraction=Do jednotky perzistence zahr\u0148te v\u0161echny t\u0159\u00eddy entit.

CWWKD1083.dup.method.param=CWWKD1083E: N\u011bkolik parametr\u016f v metod\u011b ` {0} ` rozhran\u00ed repozit\u00e1\u0159e ` {1} ` odpov\u00edd\u00e1 pojmenovan\u00e9mu parametru: ` {2} `. Jeden parametr metody m\u016f\u017eete ozna\u010dit anotac\u00ed ` {3} `, \u010d\u00edm\u017e ur\u010d\u00edte parametr pojmenovan\u00fd podle dotazovac\u00edho jazyka. Alternativn\u011b m\u016f\u017eete zapnout kompila\u010dn\u00ed volbu -parameters a v formul\u00e1\u0159i definovat jeden parametr metody ve tvaru \u201e {4} \u201c, kter\u00fd nevy\u017eaduje anotaci Param.
CWWKD1083.dup.method.param.explanation=Ka\u017ed\u00fd parametr metody mus\u00ed odpov\u00eddat p\u0159esn\u011b jednomu parametru dotazu.
CWWKD1083.dup.method.param.useraction=Zkontrolujte, zda ka\u017ed\u00fd z parametr\u016f metody odkazuje na spr\u00e1vn\u00fd pojmenovan\u00fd parametr. Odstra\u0148te duplicitn\u00ed parametry metod. 
CWWKD1084.missing.named.params=CWWKD1084E: Parametry metody ` {0} ` rozhran\u00ed repozit\u00e1\u0159e ` {1} ` nedefinuj\u00ed pojmenovan\u00e9 parametry ( {2} ), kter\u00e9 vy\u017eaduje hodnota anotace `Query`: {3}. Pojmenovan\u00fd parametr dotazu m\u016f\u017eete definovat tak, \u017ee na p\u0159\u00edslu\u0161n\u00fd parametr metody um\u00edst\u00edte anotaci Param. Nap\u0159\u00edklad {4}. Alternativn\u011b, pokud zapnete kompila\u010dn\u00ed volbu -parameters, m\u016f\u017eete vynechat anotaci Param, pokud pojmenujete parametr metody stejn\u011b jako pojmenovan\u00fd parametr. Nap\u0159\u00edklad pokud je typem pojmenovan\u00e9ho parametru String, m\u016f\u017ee b\u00fdt parametr metody typu ` {5} `, co\u017e nevy\u017eaduje anotaci `Param`.
CWWKD1084.missing.named.params.explanation=Hodnota anotace Query vy\u017eaduje jeden nebo v\u00edce pojmenovan\u00fdch parametr\u016f, kter\u00e9 metoda repozit\u00e1\u0159e neposkytuje.
CWWKD1084.missing.named.params.useraction=P\u0159idejte parametry do metody repozit\u00e1\u0159e, abyste zadali chyb\u011bj\u00edc\u00ed pojmenovan\u00e9 parametry.

CWWKD1085.extra.method.params=CWWKD1085E: Parametry metody ` {0} ` rozhran\u00ed repozit\u00e1\u0159e ` {1} ` definuj\u00ed parametry dotazu ( {2} ), kter\u00e9 se neshoduj\u00ed s \u017e\u00e1dn\u00fdm z pojmenovan\u00fdch parametr\u016f ( {3} ) pou\u017eit\u00fdch v hodnot\u011b anotace `Query`: {4}.
CWWKD1085.extra.method.params.explanation=V\u0161echny parametry metody mus\u00ed b\u00fdt pou\u017eity v dotazu nebo mus\u00ed m\u00edt typy parametr\u016f definovan\u00e9 v Jakarta Data.
CWWKD1085.extra.method.params.useraction=Odstra\u0148te nadbyte\u010dn\u00e9 parametry metody.

CWWKD1086.named.params.unused=CWWKD1086E: Parametry metody ` {0} ` rozhran\u00ed repozit\u00e1\u0159e ` {1} ` definuj\u00ed pojmenovan\u00e9 parametry ( {2} ), kter\u00e9 se v\u0161ak nepou\u017e\u00edvaj\u00ed v hodnot\u011b anotace `Query`: {3}. V dotazu m\u016f\u017eete odkazovat na pojmenovan\u00e9 parametry pomoc\u00ed znaku : n\u00e1sledovan\u00e9ho n\u00e1zvem parametru. Nap\u0159\u00edklad {4}. Na pozi\u010dn\u00ed parametry v dotazu lze odkazovat pomoc\u00ed znaku? znak n\u00e1sledovan\u00fd po\u0159adov\u00fdm \u010d\u00edslem, po\u010d\u00ednaje?1. Nepou\u017e\u00edvejte anotaci Param u parametr\u016f metod, pokud dotaz vyu\u017e\u00edv\u00e1 pozi\u010dn\u00ed parametry nebo nem\u00e1 \u017e\u00e1dn\u00e9 parametry.
CWWKD1086.named.params.unused.explanation=Anotace Param lze pou\u017e\u00edt pouze v p\u0159\u00edpad\u011b, \u017ee dotaz obsahuje pojmenovan\u00e9 parametry.
CWWKD1086.named.params.unused.useraction=Odstra\u0148te anotaci Param nebo upravte dotaz tak, aby pou\u017e\u00edval pojmenovan\u00e9 parametry.

CWWKD1087.null.param=CWWKD1087E: Parametr ` {0} ` metody ` {1} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {2} ` m\u00e1 hodnotu null. Zadejte hodnotu, kter\u00e1 nen\u00ed pr\u00e1zdn\u00e1.
CWWKD1087.null.param.explanation=Hodnota parametru nesm\u00ed b\u00fdt nulov\u00e1.
CWWKD1087.null.param.useraction=Zadejte pro tento parametr hodnotu, kter\u00e1 nen\u00ed pr\u00e1zdn\u00e1.

CWWKD1088.empty.sorts=CWWKD1088E: Krit\u00e9ria \u0159azen\u00ed, kter\u00e1 jsou zad\u00e1na parametrem ` {0} ` metody ` {1} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {2} `, jsou pr\u00e1zdn\u00e1.
CWWKD1088.empty.sorts.explanation=Krit\u00e9ria \u0159azen\u00ed nesm\u00ed b\u00fdt pr\u00e1zdn\u00e1.
CWWKD1088.empty.sorts.useraction=Zadejte hodnotu pro krit\u00e9rium \u0159azen\u00ed.

CWWKD1089.unordered.pagination=CWWKD1089E: Metoda ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` mus\u00ed specifikovat krit\u00e9ria \u0159azen\u00ed, proto\u017ee tato metoda vrac\u00ed hodnotu typu ` {2} `. Neuspo\u0159\u00e1dan\u00e1 data nelze rozd\u011blit na str\u00e1nky.
CWWKD1089.unordered.pagination.explanation=Str\u00e1nkov\u00e1n\u00ed vy\u017eaduje uspo\u0159\u00e1dan\u00e1 data.
CWWKD1089.unordered.pagination.useraction=Pomoc\u00ed anotace ` OrderBy ` definujte krit\u00e9ria \u0159azen\u00ed pro metodu repozit\u00e1\u0159e.

CWWKD1090.orderby.conflict=CWWKD1090E: Metoda ` {0} ` rozhran\u00ed repozit\u00e1\u0159e ` {1} ` nem\u016f\u017ee kombinovat anotaci ` OrderBy ` a kl\u00ed\u010dov\u00e9 slovo ` OrderBy `.
CWWKD1090.orderby.conflict.explanation=Anotace ` OrderBy ` nen\u00ed kompatibiln\u00ed s kl\u00ed\u010dov\u00fdm slovem ` OrderBy `.
CWWKD1090.orderby.conflict.useraction=Pou\u017e\u00edvejte pouze anotaci ` OrderBy ` nebo kl\u00ed\u010dov\u00e9 slovo ` OrderBy `.

CWWKD1091.method.name.parse.err=CWWKD1091E: V t\u0159\u00edd\u011b entity \u201e {1} \u201c nebylo nalezeno atribut entity s n\u00e1zvem \u201e {0} \u201c pro metodu \u201e {2} \u201c rozhran\u00ed \u00falo\u017ei\u0161t\u011b \u201e {3} \u201c. Ov\u011b\u0159te, zda m\u00e1 metoda repozit\u00e1\u0159e bu\u010f n\u00e1zev, kter\u00fd odpov\u00edd\u00e1 vzoru \u201eQuery by Method Name\u201c, nebo zda je opat\u0159ena n\u011bkterou z n\u00e1sleduj\u00edc\u00edch anotac\u00ed: {4}. Platn\u00e9 n\u00e1zvy atribut\u016f pro tuto entitu jsou: {5}.
CWWKD1091.method.name.parse.err.explanation=N\u00e1zev metody repozit\u00e1\u0159e byl analyzov\u00e1n podle vzoru \u201eQuery by Method Name\u201c, proto\u017ee tato metoda repozit\u00e1\u0159e neobsahuje anotaci Jakarta Data, kter\u00e1 by ur\u010dovala typ operace.
CWWKD1091.method.name.parse.err.useraction=Opravte n\u00e1zev metody repozit\u00e1\u0159e nebo metodu repozit\u00e1\u0159e opat\u0159ete anotac\u00ed, kter\u00e1 ozna\u010duje operaci Jakarta Data, jako je Query, Find nebo Save.

CWWKD1092.lifecycle.arg.empty=CWWKD1092E: Metoda ` {0} ` v repozit\u00e1\u0159i ` {1} ` nep\u0159ij\u00edm\u00e1 pr\u00e1zdn\u00fd parametr ` {2} `. Hodnota parametru mus\u00ed obsahovat alespo\u0148 jednu entitu.
CWWKD1092.lifecycle.arg.empty.explanation=Metody Insert, Update, Save a Delete
 require alespo\u0148 jeden subjekt.
CWWKD1092.lifecycle.arg.empty.useraction=Ujist\u011bte se, \u017ee pole, seznam nebo proud p\u0159edan\u00fd t\u00e9to metod\u011b obsahuje alespo\u0148 jeden prvek.

CWWKD1093.fn.not.applicable=CWWKD1093E: Funkci ` {0} ` nelze vyhodnotit pro entitu ` {1} `, kterou vyu\u017e\u00edv\u00e1 metoda ` {2} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {3} `. Entita nem\u00e1 \u017e\u00e1dn\u00fd atribut, kter\u00fd by byl ozna\u010den anotac\u00ed \u201e {4} \u201c, ani z n\u011bho\u017e by bylo mo\u017en\u00e9 odvodit \u201e {0} \u201c.
CWWKD1093.fn.not.applicable.explanation=Tuto funkci nelze na dan\u00e9 entit\u011b pou\u017e\u00edt, proto\u017ee entita nem\u00e1 atribut ID nebo version.
CWWKD1093.fn.not.applicable.useraction=Tuto funkci nepou\u017e\u00edvejte v dotazovac\u00edm jazyce ani v parametrech metody \u00falo\u017ei\u0161t\u011b.

CWWKD1094.return.mismatch=CWWKD1094E: Metoda ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` m\u00e1 typ n\u00e1vratov\u00e9 hodnoty ` {2} `, kter\u00fd neumo\u017e\u0148uje vr\u00e1tit po\u010det entit ` {3} `, kter\u00e9 metoda \u00falo\u017ei\u0161t\u011b p\u0159ij\u00edm\u00e1 jako parametr. Mezi platn\u00e9 typy n\u00e1vratov\u00fdch hodnot pro metodu typu \u201e {4} \u201c, kter\u00e1 p\u0159ij\u00edm\u00e1 v\u00edce entit, pat\u0159\u00ed: {5}.
CWWKD1094.return.mismatch.explanation=Metoda \u017eivotn\u00edho cyklu \u00falo\u017ei\u0161t\u011b, kter\u00e1 vrac\u00ed entity, mus\u00ed b\u00fdt schopna vr\u00e1tit stejn\u00fd po\u010det entit, kolik jich metoda p\u0159ijala.
CWWKD1094.return.mismatch.useraction=Upravte metodu repozit\u00e1\u0159e tak, aby bu\u010f pou\u017e\u00edvala typ n\u00e1vratov\u00e9 hodnoty, kter\u00fd umo\u017e\u0148uje vr\u00e1tit v\u00edce entit, nebo aby p\u0159ij\u00edmala pouze jednu entitu.

CWWKD1095.repo.err=CWWKD1095E: Z d\u016fvodu chyby nelze poskytnout implementaci rozhran\u00ed \u00falo\u017ei\u0161t\u011b typu \u201e {0} \u201c. Anotace repozit\u00e1\u0159e je {1}. Hlavn\u00ed t\u0159\u00eddou entit je ` {2} `. Chyba zn\u00ed: {3}
CWWKD1095.repo.err.explanation=Vestav\u011bn\u00fd datov\u00fd poskytovatel Jakarta nen\u00ed schopen poskytnout instanci \u00falo\u017ei\u0161t\u011b z d\u016fvodu chyby.
CWWKD1095.repo.err.useraction=Zjist\u011bte p\u0159\u00ed\u010dinu chyby a opravte rozhran\u00ed repozit\u00e1\u0159e, entity, konfiguraci \u00falo\u017ei\u0161t\u011b dat nebo datab\u00e1zi.

CWWKD1096.orderby.incompat=CWWKD1096E: Metoda ` {0} ` v repozit\u00e1\u0159i ` {1} ` m\u00e1 anotaci ` OrderBy `, av\u0161ak metoda ` {0} ` nen\u00ed operac\u00ed vyhled\u00e1v\u00e1n\u00ed ani maz\u00e1n\u00ed, kter\u00e1 by vracela entity.
CWWKD1096.orderby.incompat.explanation=Anotace \u201e OrderBy \u201c nen\u00ed kompatibiln\u00ed s dan\u00fdm typem operace repozit\u00e1\u0159e.
CWWKD1096.orderby.incompat.useraction=Odstra\u0148te anotaci \u201e OrderBy \u201c.

CWWKD1097.param.incompat=CWWKD1097E: Metoda ` {0} ` v repozit\u00e1\u0159i ` {1} ` m\u00e1 parametr ` {2} `, av\u0161ak metoda ` {0} ` nen\u00ed operac\u00ed vyhled\u00e1v\u00e1n\u00ed ani maz\u00e1n\u00ed, kter\u00e1 by vracela entity.
CWWKD1097.param.incompat.explanation=Parametry \u201eOrder\u201c, \u201eSort\u201c a \u201eLimit\u201c nejsou kompatibiln\u00ed s t\u00edmto typem operace v \u00falo\u017ei\u0161ti.
CWWKD1097.param.incompat.useraction=Odstra\u0148te parametr \u201eOrder\u201c, \u201eSort\u201c nebo \u201eLimit\u201c.

CWWKD1098.spec.param.position.err=CWWKD1098E: Metoda ` {0} ` v repozit\u00e1\u0159i ` {1} ` obsahuje parametr ` {2} `, kter\u00fd je um\u00edst\u011bn p\u0159ed parametry dotazu. Typy parametr\u016f, kter\u00e9 maj\u00ed v Jakarta Data ( {3} ) zvl\u00e1\u0161tn\u00ed v\u00fdznam, mus\u00ed b\u00fdt v podpisu metody repozit\u00e1\u0159e uvedeny za ostatn\u00edmi parametry.
CWWKD1098.spec.param.position.err.explanation=Pokud jsou ve signatu\u0159e metody repozit\u00e1\u0159e zahrnuty speci\u00e1ln\u00ed typy parametr\u016f definovan\u00e9 v Jakarta Data, mus\u00ed b\u00fdt uvedeny a\u017e za v\u0161emi parametry dotazu.
CWWKD1098.spec.param.position.err.useraction=P\u0159esu\u0148te speci\u00e1ln\u00ed typy parametr\u016f definovan\u00e9 v Jakarta Data na konec podpisu metody v \u00falo\u017ei\u0161ti.

CWWKD1099.first.keyword.incompat=CWWKD1099E: Metoda ` {0} ` v repozit\u00e1\u0159i ` {1} ` m\u00e1 n\u00e1zev obsahuj\u00edc\u00ed kl\u00ed\u010dov\u00e9 slovo `First`, co\u017e je v rozporu s parametrem ` {2} ` t\u00e9to metody.
CWWKD1099.first.keyword.incompat.explanation=Metoda Query by Method Name, kter\u00e1 obsahuje parametr Limit nebo PageRequest, nem\u016f\u017ee pou\u017e\u00edvat kl\u00ed\u010dov\u00e9 slovo First.
CWWKD1099.first.keyword.incompat.useraction=Z n\u00e1zvu metody odstra\u0148te kl\u00ed\u010dov\u00e9 slovo \u201eFirst\u201c.

CWWKD1100.cursor.requires.sort=CWWKD1100E: Metoda ` {0} ` v repozit\u00e1\u0159i ` {1} ` vrac\u00ed ` {2} `, ale neobsahuje anotaci ` OrderBy ` ani \u017e\u00e1dn\u00fd z n\u00e1sleduj\u00edc\u00edch parametr\u016f pro ur\u010den\u00ed krit\u00e9ri\u00ed \u0159azen\u00ed: ` {3} `. Krit\u00e9ria \u0159azen\u00ed jsou pro str\u00e1nkov\u00e1n\u00ed pomoc\u00ed kurzoru povinn\u00e1 a nelze je zadat v klauzuli ORDER BY hodnoty anotace Query.
CWWKD1100.cursor.requires.sort.explanation=Str\u00e1nkov\u00e1n\u00ed pomoc\u00ed kurzoru vy\u017eaduje krit\u00e9ria pro \u0159azen\u00ed.
CWWKD1100.cursor.requires.sort.useraction=Pokud je v hodnot\u011b anotace Query nalezena klauzule ORDER BY, odstra\u0148te ji. Pro zad\u00e1n\u00ed krit\u00e9ri\u00ed \u0159azen\u00ed p\u0159idejte anotaci ` OrderBy ` nebo parametr metody repozit\u00e1\u0159e.

CWWKD1101.attr.subset.mismatch=CWWKD1101E: Typ n\u00e1vratov\u00e9 hodnoty ` {0} ` metody ` {1} ` repozit\u00e1\u0159e ` {2} ` vyu\u017e\u00edv\u00e1 typ z\u00e1znamu Java ` {3} ` k definov\u00e1n\u00ed v\u00fdsledk\u016f jako podmno\u017einy atribut\u016f entity: {4}. Nicm\u00e9n\u011b alespo\u0148 jeden z po\u017eadovan\u00fdch n\u00e1zv\u016f atribut\u016f v entit\u011b {5} chyb\u00ed. Chcete-li vr\u00e1tit podmno\u017einu atribut\u016f entity jako z\u00e1znam v jazyce Java, ujist\u011bte se, \u017ee n\u00e1zvy komponent z\u00e1znamu spadaj\u00ed do n\u00e1sleduj\u00edc\u00edho seznamu platn\u00fdch n\u00e1zv\u016f atribut\u016f pro entitu \u201e {5} \u201c: {6}. P\u0159\u00edpadn\u011b pou\u017eijte anotaci Select k p\u0159i\u0159azen\u00ed platn\u00fdch n\u00e1zv\u016f atribut\u016f entit. Chcete-li vr\u00e1tit jeden atribut entity, kter\u00fd m\u00e1 typ z\u00e1znamu Java, ozna\u010dte metodu ` {1} ` anotac\u00ed `Select` a p\u0159i\u0159a\u010fte hodnotu jej\u00edho \u010dlena k n\u00e1zvu\
    \ atributu entity.
CWWKD1101.attr.subset.mismatch.explanation=Pokud se k na\u010dten\u00ed podmno\u017einy atribut\u016f entity pou\u017e\u00edvaj\u00ed z\u00e1znamy Java, mus\u00ed v\u0161echny slo\u017eky z\u00e1znamu odpov\u00eddat platn\u00fdm atribut\u016fm entity.
CWWKD1101.attr.subset.mismatch.useraction=P\u0159ejmenujte komponenty z\u00e1znamu tak, aby odpov\u00eddaly platn\u00fdm n\u00e1zv\u016fm atribut\u016f entity, nebo pou\u017eijte anotaci Select k explicitn\u00edmu zad\u00e1n\u00ed atribut\u016f entity podle jejich n\u00e1zvu.

CWWKD1102.incompat.query.result=CWWKD1102E: Metoda ` {0} ` v repozit\u00e1\u0159i ` {1} ` m\u00e1 typ n\u00e1vratov\u00e9 hodnoty ` {2} `, av\u0161ak poskytovatel Jakarta Persistence provedl dotaz, jeho\u017e v\u00fdsledky maj\u00ed typ ` {3} `. Zkontrolujte, zda poskytovatel Jakarta Persistence umo\u017e\u0148uje dotazov\u00e1n\u00ed na typy atribut\u016f entit, kter\u00e9 vyb\u00edr\u00e1 metoda ` {0} `. Pokud poskytovatel Jakarta umo\u017e\u0148uje dotazov\u00e1n\u00ed na typy atribut\u016f entit, kter\u00e9 vyb\u00edr\u00e1 metoda ` {0} `, zkontrolujte, zda neexistuj\u00ed jin\u00e9 p\u0159\u00ed\u010diny nekompatibility.
CWWKD1102.incompat.query.result.explanation=Poskytovatel\u00e9 slu\u017eby Jakarta Persistence neumo\u017e\u0148uj\u00ed vracet v\u0161echny typy atribut\u016f entit. Pokud poskytovatel Jakarta vrac\u00ed jin\u00fd typ atribut\u016f entity, ne\u017e jak\u00fd zvolila dan\u00e1 metoda, jedn\u00e1 se o dal\u0161\u00ed p\u0159\u00ed\u010dinu nekompatibility. Nap\u0159\u00edklad poskytovatel Jakarta Persistence m\u016f\u017ee obsahovat chybu nebo m\u016f\u017ee b\u00fdt chybn\u00fd podpis metody repozit\u00e1\u0159e.
CWWKD1102.incompat.query.result.useraction=Pokud typ atribut\u016f entity, kter\u00e9 metoda vyb\u00edr\u00e1, nen\u00ed povolen, upravte dotaz tak, aby na\u010d\u00edtal celou entitu nebo jinou sadu atribut\u016f entity, kterou poskytovatel Jakarta Persistence povoluje. Pokud je typ atribut\u016f entity, kter\u00e9 metoda vyb\u00edr\u00e1, povolen, zkontrolujte, zda neexistuj\u00ed jin\u00e9 p\u0159\u00ed\u010diny nekompatibility.

CWWKD1103.incompat.query.result=CWWKD1103E: Metoda ` {0} ` v repozit\u00e1\u0159i ` {1} ` m\u00e1 n\u00e1vratov\u00fd typ ` {2} `, av\u0161ak poskytovatel Jakarta Persistence provedl dotaz typu ` {3} `, jeho\u017e v\u00fdsledky maj\u00ed typ ` {4} `. Zkontrolujte, zda poskytovatel Jakarta Persistence umo\u017e\u0148uje dotazov\u00e1n\u00ed na typy atribut\u016f entit, kter\u00e9 vyb\u00edr\u00e1 metoda ` {0} `. Pokud poskytovatel Jakarta umo\u017e\u0148uje dotazov\u00e1n\u00ed na typy atribut\u016f entit, kter\u00e9 vyb\u00edr\u00e1 metoda ` {0} `, zkontrolujte, zda neexistuj\u00ed jin\u00e9 p\u0159\u00ed\u010diny nekompatibility.
CWWKD1103.incompat.query.result.explanation=Poskytovatel\u00e9 slu\u017eby Jakarta Persistence neumo\u017e\u0148uj\u00ed vracet v\u0161echny typy atribut\u016f entit. Pokud poskytovatel Jakarta vrac\u00ed jin\u00fd typ atribut\u016f entity, ne\u017e jak\u00fd zvolila dan\u00e1 metoda, jedn\u00e1 se o dal\u0161\u00ed p\u0159\u00ed\u010dinu nekompatibility. Nap\u0159\u00edklad poskytovatel Jakarta Persistence m\u016f\u017ee obsahovat chybu nebo m\u016f\u017ee b\u00fdt chybn\u00fd podpis metody repozit\u00e1\u0159e.
CWWKD1103.incompat.query.result.useraction=Pokud typ atribut\u016f entity, kter\u00e9 metoda vyb\u00edr\u00e1, nen\u00ed povolen, upravte dotaz tak, aby na\u010d\u00edtal celou entitu nebo jinou sadu atribut\u016f entity, kterou poskytovatel Jakarta Persistence povoluje. Pokud je typ atribut\u016f entity, kter\u00e9 metoda vyb\u00edr\u00e1, povolen, zkontrolujte, zda neexistuj\u00ed jin\u00e9 p\u0159\u00ed\u010diny nekompatibility.

CWWKD1104.empty.anno.value=CWWKD1104E: Pr\u00e1zdn\u00e1 hodnota pro t\u0159\u00eddu String nen\u00ed platnou hodnotou pro anotaci ` {0} `, kter\u00e1 je pou\u017eita u metody ` {1} ` v \u00falo\u017ei\u0161ti ` {2} `.
CWWKD1104.empty.anno.value.explanation=Pr\u00e1zdn\u00e1 hodnota pro t\u0159\u00eddu String nen\u00ed podporov\u00e1na. Jak\u00e1 hodnota je podporov\u00e1na, z\u00e1vis\u00ed na typu anotace. Nap\u0159\u00edklad pokud se jedn\u00e1 o anotaci typu Param, jsou platn\u00fdmi hodnotami n\u00e1zvy parametr\u016f, kter\u00e9 jsou pou\u017eity v hodnot\u011b anotace Query.
CWWKD1104.empty.anno.value.useraction=Pokud anotace nen\u00ed pot\u0159eba, odstra\u0148te ji z metody repozit\u00e1\u0159e. V opa\u010dn\u00e9m p\u0159\u00edpad\u011b zadejte platnou hodnotu pro tuto pozn\u00e1mku.

CWWKD1105.keyword.in.orderby=CWWKD1105E: Klausuli \u201e OrderBy \u201c v metod\u011b \u201e {0} \u201c repozit\u00e1\u0159e \u201e {1} \u201c nelze analyzovat, proto\u017ee atribut entity \u201e {2} \u201c entity \u201e {3} \u201c obsahuje kl\u00ed\u010dov\u00e9 slovo \u201e {4} \u201c vzoru \u201eJakarta Data Query by Method Name\u201c. Odstra\u0148te z n\u00e1zvu metody \u201e {0} \u201c klauzuli \u201e OrderBy \u201c a m\u00edsto n\u00ed pou\u017eijte anotaci \u201e OrderBy \u201c.
CWWKD1105.keyword.in.orderby.explanation=N\u00e1zvy atribut\u016f entit, kter\u00e9 obsahuj\u00ed kl\u00ed\u010dov\u00e1 slova Jakarta Data, nelze pou\u017e\u00edt v n\u00e1zvech metod \u00falo\u017ei\u0161t\u011b, kter\u00e9 se \u0159\u00edd\u00ed vzorem Jakarta Data Query by Method Name.
CWWKD1105.keyword.in.orderby.useraction=P\u0159ejmenujte atribut entity nebo pou\u017eijte anotaci ` OrderBy `, abyste ur\u010dili po\u0159ad\u00ed.

CWWKD1106.init.timed.out=CWWKD1106E: \u00dalo\u017ei\u0161t\u011b {0}, kter\u00e9 vy\u017eaduje datov\u00fd \u00falo\u017ei\u0161t\u011b {1} a je poskytov\u00e1no nebo vyu\u017e\u00edv\u00e1no artefaktem aplikace {2}, nebylo k dispozici do {3} sekund. Ov\u011b\u0159te, zda se spust\u00ed aplika\u010dn\u00ed artefakt {2} a zda je datov\u00fd \u00falo\u017ei\u0161t\u011b {1}, kter\u00e9 je zad\u00e1no jako hodnota dataStore v anotaci Repository, spr\u00e1vn\u011b nakonfigurov\u00e1no a zda je pro aplika\u010dn\u00ed artefakt dostupn\u00e9 v okam\u017eiku prvn\u00edho p\u0159\u00edstupu k \u00falo\u017ei\u0161ti {0}.
CWWKD1106.init.timed.out.explanation=\u00dalo\u017ei\u0161t\u011b nebylo k dispozici v ur\u010den\u00e9m \u010dasov\u00e9m limitu.
CWWKD1106.init.timed.out.useraction=Zkontrolujte konfiguraci \u00falo\u017ei\u0161t\u011b dataStore a ov\u011b\u0159te, zda je p\u0159\u00edstupn\u00e9 pro artefakty aplikac\u00ed, kter\u00e9 toto \u00falo\u017ei\u0161t\u011b definuj\u00ed a vyu\u017e\u00edvaj\u00ed. Zkontrolujte tak\u00e9, zda se aplikace a v\u0161echny jej\u00ed moduly \u00fasp\u011b\u0161n\u011b spust\u00ed.

CWWKD1107.init.timed.out.checkpoint=CWWKD1107E: Aplikace \u201e {0} \u201c p\u0159istoupila k \u00falo\u017ei\u0161ti \u201e {1} \u201c je\u0161t\u011b p\u0159ed dokon\u010den\u00edm kontroln\u00edho bodu aplikace. Aktualizujte aplikaci {0}, aby se zabr\u00e1nilo pou\u017eit\u00ed \u00falo\u017ei\u0161t\u011b p\u0159ed vytvo\u0159en\u00edm kontroln\u00edho bodu.
CWWKD1107.init.timed.out.checkpoint.explanation=Aplikace nemohou vyu\u017e\u00edvat repozit\u00e1\u0159e p\u0159ed dokon\u010den\u00edm kontroln\u00edho bodu.
CWWKD1107.init.timed.out.checkpoint.useraction=Neu\u017e\u00edvejte repozit\u00e1\u0159, dokud nebude kontroln\u00ed bod dokon\u010den.

CWWKD1108.missing.entity.anno=CWWKD1108E: T\u0159\u00edda entity ` {0} ` vy\u017eaduje anotaci ` {1} `, proto\u017ee anotace ` {2} ` je p\u0159i\u0159azena \u010dlenu ` {3} ` t\u00e9to t\u0159\u00eddy entity.
CWWKD1108.missing.entity.anno.explanation=T\u0159\u00eddy entit, kter\u00e9 pou\u017e\u00edvaj\u00ed anotace
 from Bal\u00ed\u010dek \u201e jakarta.persistence \u201c mus\u00ed b\u00fdt rovn\u011b\u017e opat\u0159en anotac\u00ed Entity
 annotation ze specifikace Jakarta Persistence.
CWWKD1108.missing.entity.anno.useraction=Pou\u017eijte anotaci Entity na
 entity nebo odstranit anotace Jakarta Persistence z jej\u00edch \u010dlen\u016f.

CWWKD1109.jpa.anno.on.record=CWWKD1109E: Anotace ` {0} ` nen\u00ed povolena u metody ` {1} ` t\u0159\u00eddy entity ` {2} `, proto\u017ee t\u0159\u00edda entity ` {2} ` je z\u00e1znamem v Jav\u011b.
CWWKD1109.jpa.anno.on.record.explanation=V z\u00e1znamech jazyka Java nejsou povoleny anotace typu Jakarta Persistence.
CWWKD1109.jpa.anno.on.record.useraction=P\u0159ejd\u011bte na t\u0159\u00eddu entity Jakarta Persistence nebo odstra\u0148te anotaci Jakarta Persistence z Java z\u00e1znamu.

CWWKD1110.incompat.with.collection=CWWKD1110E: Metoda ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` m\u00e1 n\u00e1zev, kter\u00fd obsahuje kl\u00ed\u010dov\u00e9 slovo ` {2} `, co\u017e je v rozporu s atributem ` {3} ` entity ` {4} `, proto\u017ee tento atribut m\u00e1 typ kolekce. U atribut\u016f entit, kter\u00e9 maj\u00ed typ kolekce, lze pou\u017e\u00edt n\u00e1sleduj\u00edc\u00ed kl\u00ed\u010dov\u00e1 slova pro dotazov\u00e1n\u00ed podle n\u00e1zvu metody: {5}.
CWWKD1110.incompat.with.collection.explanation=N\u011bkter\u00e1 kl\u00ed\u010dov\u00e1 slova pro dotazy podle n\u00e1zvu metody nejsou kompatibiln\u00ed s atributy entit, kter\u00e9 maj\u00ed typ kolekce.
CWWKD1110.incompat.with.collection.useraction=Upravte metodu repozit\u00e1\u0159e tak, aby se nepou\u017e\u00edvalo kl\u00ed\u010dov\u00e9 slovo, kter\u00e9 nen\u00ed kompatibiln\u00ed s typem kolekce.

CWWKD1111.unsupported.convert=CWWKD1111E: Implementace v bal\u00ed\u010dku \u201e {0} \u201c ( AttributeConverter ) p\u0159ev\u00e1d\u00ed hodnoty typu \u201e {1} \u201c na typ \u201e {2} \u201c, kter\u00fd specifikace Jakarta Data nepodporuje. Specifikace Jakarta Data podporuje v\u00fd\u010dtov\u00e9 typy jazyka Java, \u010dasov\u00e9 typy knihovny \u201e {3} \u201c a n\u00e1sleduj\u00edc\u00ed z\u00e1kladn\u00ed typy: {4}. Integrovan\u00fd datov\u00fd poskytovatel Jakarta podporuje tak\u00e9 n\u011bkter\u00e9 typy Jakarta Persistence.
CWWKD1111.unsupported.convert.explanation=Implementaci typu ` AttributeConverter ` nelze pou\u017e\u00edt s vestav\u011bn\u00fdm poskytovatelem dat Jakarta, proto\u017ee p\u0159ev\u00e1d\u00ed hodnoty na nepodporovan\u00fd typ.
CWWKD1111.unsupported.convert.useraction=Upravte implementaci metody ` AttributeConverter ` tak, aby p\u0159ev\u00e1d\u011bla hodnoty na jeden z podporovan\u00fdch typ\u016f.

CWWKD1112.record.entity.verify.err=CWWKD1112W: Byla definov\u00e1na t\u0159\u00edda entity pro z\u00e1znam typu \u201e {0} \u201c, ale nemus\u00ed fungovat. Ov\u011b\u0159en\u00ed bajt\u016f t\u0159\u00eddy entity Jakarta Persistence, kter\u00e1 byla pro danou t\u0159\u00eddu entity vygenerov\u00e1na, selhalo. Definovan\u00e1 t\u0159\u00edda entity je vyu\u017e\u00edv\u00e1na jedn\u00edm nebo v\u00edce rozhran\u00edmi \u00falo\u017ei\u0161t\u011b ( {1} ) v aplika\u010dn\u00edm artefaktu {2}. Chyba zn\u00ed: {3}.
CWWKD1112.record.entity.verify.err.explanation=Pokud \u00falo\u017ei\u0161t\u011b pou\u017e\u00edv\u00e1 entitu typu z\u00e1znamu, vygeneruje se entita Jakarta Persistence, kter\u00e1 tuto entitu reprezentuje. Ov\u011b\u0159en\u00ed bajt\u016f vygenerovan\u00e9 t\u0159\u00eddy entity Jakarta Persistence selhalo.
CWWKD1112.record.entity.verify.err.useraction=Ov\u011b\u0159te, zda implementace entity z\u00e1znamu spl\u0148uje po\u017eadavky a konvence pro entitu z\u00e1znamu.

CWWKD1113.server.stopping=CWWKD1113I: Jeden nebo v\u00edce repozit\u00e1\u0159\u016f ( {0} ) se nepoda\u0159ilo inicializovat, proto\u017ee se server vyp\u00edn\u00e1.
CWWKD1113.server.stopping.explanation=Server se vyp\u00edn\u00e1 a nebude se pokou\u0161et inicializovat repozit\u00e1\u0159e.
CWWKD1113.server.stopping.useraction=Nen\u00ed pot\u0159eba \u017e\u00e1dn\u00e1 akce.

CWWKD1114.app.stopping=CWWKD1114I: Jedno nebo v\u00edce \u00falo\u017ei\u0161\u0165 ( {0} ) se nepoda\u0159ilo inicializovat, proto\u017ee aplikace {1} je ve stavu {2}.
CWWKD1114.app.stopping.explanation=Aplikace se zastavuje nebo ji\u017e byla zastavena a nepokus\u00ed se inicializovat repozit\u00e1\u0159e.
CWWKD1114.app.stopping.useraction=Spus\u0165te aplikaci, aby se repozit\u00e1\u0159e zp\u0159\u00edstupnily.

CWWKD1115.app.unavailable=CWWKD1115E: Jedno nebo v\u00edce \u00falo\u017ei\u0161\u0165 ( {0} ) se nepoda\u0159ilo inicializovat, proto\u017ee aplikace {1} nen\u00ed k dispozici.
CWWKD1115.app.unavailable.explanation=Aplikace, kter\u00e1 definuje repozit\u00e1\u0159e, nen\u00ed k dispozici. Repozit\u00e1\u0159e nelze inicializovat.
CWWKD1115.app.unavailable.useraction=Spus\u0165te aplikaci, aby se repozit\u00e1\u0159e zp\u0159\u00edstupnily.

CWWKD1116.resource.unavailable=CWWKD1116E: Jedno nebo v\u00edce \u00falo\u017ei\u0161\u0165 ( {0} ) se nepoda\u0159ilo inicializovat, proto\u017ee zdroj {1} nebyl k dispozici do {2} sekund.
CWWKD1116.resource.unavailable.explanation=Zdroje, kter\u00e9 \u00falo\u017ei\u0161t\u011b vy\u017eaduj\u00ed, nebyly zp\u0159\u00edstupn\u011bny.
CWWKD1116.resource.unavailable.useraction=Zkontrolujte konfiguraci prost\u0159edk\u016f, kter\u00e9 repozit\u00e1\u0159e vyu\u017e\u00edvaj\u00ed.

CWWKD1117.anno.constraint.conflict=CWWKD1117E: Parametr ` {0} ` metody ` {1} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {2} ` nelze opat\u0159it anotacemi: ` {3} `. Jedna nebo v\u00edce anotac\u00ed nen\u00ed kompatibiln\u00ed s typem ` {4} ` parametru metody repozit\u00e1\u0159e.
CWWKD1117.anno.constraint.conflict.explanation=Omezen\u00ed a jeho podtypy nelze kombinovat s jin\u00fdmi anotacemi parametr\u016f ne\u017e s anotac\u00ed By.
CWWKD1117.anno.constraint.conflict.useraction=Odstra\u0148te konfliktn\u00ed anotaci nebo m\u00edsto typu omezen\u00ed zadejte typ atributu entity.

CWWKD1118.param.anno.conflict=CWWKD1118E: Parametr ` {0} ` metody ` {1} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {2} ` nelze opat\u0159it anotacemi: ` {3} `. Dv\u011b nebo v\u00edce pozn\u00e1mek jsou ve vz\u00e1jemn\u00e9m rozporu.
CWWKD1118.param.anno.conflict.explanation=Kombinace anotac\u00ed parametr\u016f nen\u00ed platn\u00e1.
CWWKD1118.param.anno.conflict.useraction=Odstra\u0148te jednu nebo v\u00edce konfliktn\u00edch anotac\u00ed z parametru metody repozit\u00e1\u0159e.

CWWKD1119.keyword.prevents.count=CWWKD1119E: Metoda ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` na\u010dte str\u00e1nky, kter\u00e9 neobsahuj\u00ed celkov\u00fd po\u010det prvk\u016f a str\u00e1nek, proto\u017ee dotaz obsahuje kl\u00ed\u010dov\u00e9 slovo ` {2} `. Cel\u00fd dotaz zn\u00ed: {3}.
CWWKD1119.keyword.prevents.count.explanation=Toto kl\u00ed\u010dov\u00e9 slovo nen\u00ed kompatibiln\u00ed s funkc\u00ed pro z\u00edsk\u00e1n\u00ed celkov\u00e9ho po\u010dtu prvk\u016f a str\u00e1nek.
CWWKD1119.keyword.prevents.count.useraction=Nahra\u010fte dotaz takov\u00fdm, kter\u00fd kl\u00ed\u010dov\u00e9 slovo nepou\u017e\u00edv\u00e1, nebo se vyhn\u011bte po\u017eadavku na celkov\u00fd po\u010det prvk\u016f a str\u00e1nek.

CWWKD1120.cursor.keyword.mismatch=CWWKD1120E: Metoda ` {0} ` rozhran\u00ed \u00falo\u017ei\u0161t\u011b ` {1} ` definuje dotaz obsahuj\u00edc\u00ed kl\u00ed\u010dov\u00e9 slovo ` {2} `, kter\u00e9 nen\u00ed kompatibiln\u00ed s paginac\u00ed zalo\u017eenou na kurzoru. Dotazy vyu\u017e\u00edvaj\u00edc\u00ed str\u00e1nkov\u00e1n\u00ed pomoc\u00ed kurzoru mus\u00ed kon\u010dit klauzul\u00ed WHERE a nesm\u00ed obsahovat poddotazy. Dotaz zn\u00ed: {3}.
CWWKD1120.cursor.keyword.mismatch.explanation=Kl\u00ed\u010dov\u00e1 slova jako GROUP BY, HAVING, ORDER BY, EXCEPT, INTERSECT a UNION nejsou kompatibiln\u00ed s paginac\u00ed zalo\u017eenou na kurzorech.
CWWKD1120.cursor.keyword.mismatch.useraction=P\u0159epi\u0161te dotaz tak, aby obsahoval pouze klauzule SELECT, FROM a WHERE.

CWWKD1121.record.lacks.id=CWWKD1121E: Z\u00e1znam typu \u201e {0} \u201c nelze pou\u017e\u00edt jako entitu, proto\u017ee postr\u00e1d\u00e1 jedine\u010dn\u00fd identifik\u00e1tor. Jedna ze slo\u017eek z\u00e1znamu ( {1} ) mus\u00ed m\u00edt n\u00e1zev id, mus\u00ed m\u00edt n\u00e1zev kon\u010d\u00edc\u00ed na _id, Id nebo ID, nebo mus\u00ed b\u00fdt typu java.util.UUID.
CWWKD1121.record.lacks.id.explanation=Subjekty mus\u00ed m\u00edt atribut jedine\u010dn\u00e9ho identifik\u00e1toru.
CWWKD1121.record.lacks.id.useraction=P\u0159idejte nebo p\u0159ejmenujte komponentu z\u00e1znamu tak, aby odpov\u00eddala jedn\u00e9 z uveden\u00fdch konvenc\u00ed pro p\u0159i\u0159azov\u00e1n\u00ed jedine\u010dn\u00e9ho identifik\u00e1toru.

CWWKD1122.entity.lacks.id=CWWKD1122E: T\u0159\u00eddu \u201e {0} \u201c nelze pou\u017e\u00edt jako entitu, proto\u017ee postr\u00e1d\u00e1 jedine\u010dn\u00fd identifik\u00e1tor. Chcete-li p\u0159i\u0159adit jedine\u010dn\u00fd identifik\u00e1tor, ujist\u011bte se, \u017ee je povolena funkce \u201e {1} \u201c, p\u0159idejte do t\u0159\u00eddy entity anotaci @ jakarta.persistence.Entity a p\u0159idejte anotaci @ jakarta.persistence.Id maxim\u00e1ln\u011b k jednomu poli nebo getterov\u00e9 metod\u011b t\u00e9to t\u0159\u00eddy. Alternativn\u011b m\u016f\u017eete k definici entity a jej\u00edho jedine\u010dn\u00e9ho identifik\u00e1toru pou\u017e\u00edt soubor typu \u201e META-INF/orm.xml \u201c.
CWWKD1122.entity.lacks.id.explanation=Subjekty mus\u00ed m\u00edt atribut jedine\u010dn\u00e9ho identifik\u00e1toru.
CWWKD1122.entity.lacks.id.useraction=Aktivujte funkci Jakarta Persistence a p\u0159i p\u0159i\u0159azov\u00e1n\u00ed jedine\u010dn\u00e9ho identifik\u00e1toru postupujte podle entity modelu Jakarta Persistence.

CWWKD1123.sort.incompat.with.cursor=CWWKD1123E: Pro po\u017eadovanou str\u00e1nku v\u00fdsledk\u016f nelze odvodit kurzor, proto\u017ee jedno z krit\u00e9ri\u00ed \u0159azen\u00ed p\u0159edan\u00fdch metod\u011b ` {0} ` repozit\u00e1\u0159e ` {1} ` nen\u00ed atributem entity: {2}. Pomoc\u00ed metody ` {3} ` vytvo\u0159te kurzor, kter\u00fd odpov\u00edd\u00e1 krit\u00e9ri\u00edm \u0159azen\u00ed, a p\u0159ed\u00e1vejte jej metod\u00e1m ` afterCursor ` nebo ` beforeCursor ` t\u0159\u00eddy ` PageRequest `. P\u0159\u00edpadn\u011b zm\u011b\u0148te krit\u00e9ria \u0159azen\u00ed tak, aby zahrnovala pouze n\u00e1zvy atribut\u016f entit. Platn\u00e9 n\u00e1zvy atribut\u016f pro t\u0159\u00eddu entit \u201e {4} \u201c jsou {5}
CWWKD1123.sort.incompat.with.cursor.explanation=Aby bylo mo\u017en\u00e9 automaticky vytvo\u0159it kurzor na z\u00e1klad\u011b t\u0159\u00eddic\u00edch krit\u00e9ri\u00ed, mus\u00ed ka\u017ed\u00e9 z t\u011bchto krit\u00e9ri\u00ed t\u0159\u00eddit podle n\u00e1zvu jedin\u00e9ho atributu entity.
CWWKD1123.sort.incompat.with.cursor.useraction=Zadejte kurzor, kter\u00fd odpov\u00edd\u00e1 krit\u00e9ri\u00edm \u0159azen\u00ed. P\u0159\u00edpadn\u011b p\u0159ejd\u011bte na str\u00e1nkov\u00e1n\u00ed zalo\u017een\u00e9 na odsazen\u00ed nebo upravte krit\u00e9ria \u0159azen\u00ed tak, aby se \u0159adilo pouze podle atribut\u016f entit.
