<server>

    <featureManager>
        <feature>servlet-4.0</feature>
        <feature>componenttest-1.0</feature>
    </featureManager>

    <!-- Enable detailed classloading trace -->
    <logging traceSpecification="*=info:com.ibm.ws.classloading.*=all:com.ibm.ws.classloading.internal.*=all"
             traceFormat="BASIC"
             maxFileSize="100"
             maxFiles="10"/>

    <httpEndpoint id="defaultHttpEndpoint"
                  httpPort="8010"
                  httpsPort="8020" />

    <!-- Test application without libraries -->
    <application id="testApp" 
                 location="testApp.war" 
                 name="testApp">
        <classloader delegation="parentFirst"/>
    </application>

    <!-- Test application with private libraries -->
    <application id="testAppWithLibs" 
                 location="testAppWithLibs.war" 
                 name="testAppWithLibs">
        <classloader privateLibraryRef="testLib1,testLib2" 
                     delegation="parentFirst"/>
    </application>

    <!-- Private library definitions -->
    <library id="testLib1">
        <fileset dir="${server.config.dir}/lib" includes="testlib1.jar"/>
    </library>

    <library id="testLib2">
        <fileset dir="${server.config.dir}/lib" includes="testlib2.jar"/>
    </library>

</server>
