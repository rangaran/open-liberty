-include= ~../cnf/resources/bnd/bundle.props
bVersion=1.0
publish.wlp.jar.suffix: dev/api/stable

Bundle-SymbolicName: io.openliberty.io.opentelemetry.2.1; singleton:=true

openTelemetryVersion=1.48.0
openTelemetryInstrumentationVersion=2.14.0
semconvOpenTelemetryVersion=1.32.0

Private-Package: \
  io.opentelemetry.api; version=${openTelemetryVersion},\
  io.opentelemetry.api.baggage; version=${openTelemetryVersion},\
  io.opentelemetry.api.baggage.propagation; version=${openTelemetryVersion},\
  io.opentelemetry.api.common; version=${openTelemetryVersion},\
  io.opentelemetry.api.logs; version=${openTelemetryVersion},\
  io.opentelemetry.api.metrics; version=${openTelemetryVersion},\
  io.opentelemetry.api.trace; version=${openTelemetryVersion},\
  io.opentelemetry.api.trace.propagation; version=${openTelemetryVersion},\
  io.opentelemetry.context; version=${openTelemetryVersion},\
  io.opentelemetry.context.propagation; version=${openTelemetryVersion},\
  io.opentelemetry.exporter.logging; version=${openTelemetryVersion},\
  io.opentelemetry.exporter.otlp; version=${openTelemetryVersion},\
  io.opentelemetry.exporter.otlp.logs; version=${openTelemetryVersion},\
  io.opentelemetry.extension.incubator.metrics; version=${openTelemetryVersion},\
  io.opentelemetry.instrumentation.annotations; version=${openTelemetryInstrumentationVersion},\
  io.opentelemetry.sdk.autoconfigure.spi; version=${openTelemetryVersion},\
  io.opentelemetry.sdk.autoconfigure.spi.logs; version=${openTelemetryVersion},\
  io.opentelemetry.sdk.autoconfigure.spi.metrics; version=${openTelemetryVersion},\
  io.opentelemetry.sdk.autoconfigure.spi.traces; version=${openTelemetryVersion},\
  io.opentelemetry.sdk.common; version=${openTelemetryVersion},\
  io.opentelemetry.sdk.logs.data; version=${openTelemetryVersion},\
  io.opentelemetry.sdk.logs.export; version=${openTelemetryVersion},\
  io.opentelemetry.sdk.metrics; version=${openTelemetryVersion},\
  io.opentelemetry.sdk.metrics.data; version=${openTelemetryVersion},\
  io.opentelemetry.sdk.metrics.export; version=${openTelemetryVersion},\
  io.opentelemetry.sdk.resources; version=${openTelemetryVersion},\
  io.opentelemetry.sdk.trace; version=${openTelemetryVersion},\
  io.opentelemetry.sdk.trace.data; version=${openTelemetryVersion},\
  io.opentelemetry.sdk.trace.export; version=${openTelemetryVersion},\
  io.opentelemetry.sdk.trace.samplers; version=${openTelemetryVersion},\
  io.opentelemetry.semconv; version=${semconvOpenTelemetryVersion}

Import-Package:

Export-Package:

-buildpath: \
  io.openliberty.jakarta.interceptor.2.1;version=latest,\
  io.openliberty.io.opentelemetry.internal.2.1;version=latest
  
WS-TraceGroup: TELEMETRY
