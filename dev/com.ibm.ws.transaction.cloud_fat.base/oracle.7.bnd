-privatepackage: suite.oracle.suite7

# In a multiple suite FAT bucket, this is required to say which suite this bundle contains
suite.name=suite.oracle.suite7.FATSuite

# The FATSuite does EE 11 repeat which requires Java 17
fat.minimum.java.level=17

# Define additional tested features that are NOT present in any XML files in this bucket.
tested.features:\
  databaseRotation,\
  cdi-4.1,\
  expressionlanguage-6.0,\
  pages-4.0,\
  servlet-6.1
