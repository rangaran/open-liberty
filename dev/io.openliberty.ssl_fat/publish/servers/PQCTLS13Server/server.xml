<server>
    <featureManager>
        <feature>componenttest-1.0</feature>
        <feature>servlet-3.1</feature>
        <feature>transportSecurity-1.0</feature>
    </featureManager>

    <!-- Server SSL configuration for TLS 1.3 with PQC support -->
    <!-- <ssl id="defaultSSLConfig" 
         keyStoreRef="pqcKeyStore" 
         trustStoreRef="pqcTrustStore"
         sslProtocol="TLSv1.3"/> -->

    <ssl id="defaultSSLConfig"
         keyStoreRef="pqcKeyStore"
         trustStoreRef="pqcTrustStore"
         sslProtocol="TLSv1.3"
         enabledCiphers="TLS_AES_256_GCM_SHA384 TLS_AES_128_GCM_SHA256 TLS_CHACHA20_POLY1305_SHA256" />

    <keyStore id="pqcKeyStore" location="key.p12" type="PKCS12" password="passw0rd" />
    <keyStore id="pqcTrustStore" location="trust.p12" type="PKCS12" password="passw0rd" />

    <quickStartSecurity userName="test" userPassword="testpwd" />

    <include location="../fatTestPorts.xml"/>
    <javaPermission className="java.security.AllPermission"/>
</server>

