# Enable SSL handshake debugging to capture PQC negotiation details
-Djavax.net.debug=ssl,handshake

# Force TLS 1.3 protocol for both client and server
-Djdk.tls.client.protocols=TLSv1.3
-Djdk.tls.server.protocols=TLSv1.3

# Prioritize PQC hybrid named group X25519MLKEM768
# Falls back to x25519 and secp256r1 if PQC is not supported
-Djdk.tls.namedGroups=X25519MLKEM768,x25519,secp256r1