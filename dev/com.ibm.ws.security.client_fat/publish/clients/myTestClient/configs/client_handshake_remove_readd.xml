<client description="SSL handshake test client - remove and re-add with trace">
	<include location="client_base.xml" />

	<ssl id="supportedClientAuthenticationSSLConfig"
		clientAuthenticationSupported="true" keyStoreRef="defaultKeyStore"
		sslProtocol="TLSv1.2"
		enabledCiphers="-TLS_ECDHE* +TLS_ECDHE_RSA_WITH_AES_128_CBC_SHA" />

	<logging traceSpecification="*=info:SSLChannel=all:com.ibm.ws.ssl.*=all:com.ibm.websphere.ssl=all:com.ibm.wsspi.ssl.*=all" 
		traceFileName="ssl_trace.log" 
		maxFileSize="10000" 
		maxFiles="10" />

</client>
