<!--
    Client configuration for testHandshakeWithPlusCipherModifierPass (non-IBM JDK).
    Uses '+' modifier to add a specific ECDHE cipher that the server supports.
    The '+TLS_ECDHE_RSA_WITH_AES_128_CBC_SHA' modifier adds this cipher to the
    JDK's default cipher list, ensuring a common cipher with the server.
    Expected result: SSL handshake succeeds.
 -->
<client description="SSL handshake test client - plus modifier pass (non-IBM JDK)">
	<featureManager>
		<feature>javaeeClient-7.0</feature>
        <feature>appSecurityClient-1.0</feature>
        <feature>transportSecurity-1.0</feature>
	</featureManager>

	<application id="myCalc" name="BasicCalculatorClient" type="ear" location="BasicCalculatorClient.ear" />

	<orb id="defaultOrb" orbSSLInitTimeout="60">
		<clientPolicy.clientContainerCsiv2>
			<layers>
				<authenticationLayer user="user2" password="user2pwd" />
				<transportLayer sslRef="supportedClientAuthenticationSSLConfig" />
			</layers>
		</clientPolicy.clientContainerCsiv2>
	</orb>

	<keyStore id="defaultKeyStore" password="{xor}EzY9Oi0rJg==" />

	<sslDefault sslRef="supportedClientAuthenticationSSLConfig" />

	<!-- Use '+' modifier to add TLS_ECDHE_RSA_WITH_AES_128_CBC_SHA to the JDK defaults.
	     This cipher is supported by the server, so the handshake should succeed. -->
	<ssl id="supportedClientAuthenticationSSLConfig"
		clientAuthenticationSupported="true" keyStoreRef="defaultKeyStore"
		sslProtocol="TLSv1.2"
		enabledCiphers="-TLS_ECDHE* +TLS_ECDHE_RSA_WITH_AES_128_CBC_SHA" />
     <logging    traceSpecification="*=info:SSLChannel=all:com.ibm.ws.ssl.*=all:com.ibm.websphere.ssl=all:com.ibm.wsspi.ssl.*=all" 
        traceFileName="ssl_trace.log" 
        maxFileSize="10000" 
        maxFiles="10" />

</client>