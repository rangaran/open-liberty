<!--
    Client configuration for testHandshakeWithMixedModeCiphers.
    Uses mixed mode: both static cipher entries and filter modifiers (+/-).
    This configuration is NOT ALLOWED - cannot mix static entries with filter modifiers.
    Expected result: Error CWPKI0837E is logged, JDK defaults are used, handshake succeeds.
 -->
<client description="SSL handshake test client - mixed mode ciphers (error case)">
	<featureManager>
		<feature>javaeeClient-7.0</feature>
        <feature>appSecurityClient-1.0</feature>
        <feature>transportSecurity-1.0</feature>
	</featureManager>

	<application id="myCalc" name="BasicCalculatorClient" type="ear" location="BasicCalculatorClient.ear" />

	<orb id="defaultOrb" orbSSLInitTimeout="60">
		<clientPolicy.clientContainerCsiv2>
			<layers>
				<authenticationLayer user="user2" password="user2pwd" />
				<transportLayer sslRef="supportedClientAuthenticationSSLConfig" />
			</layers>
		</clientPolicy.clientContainerCsiv2>
	</orb>

	<keyStore id="defaultKeyStore" password="{xor}EzY9Oi0rJg==" />

	<sslDefault sslRef="supportedClientAuthenticationSSLConfig" />

	<!-- INVALID: Mixed mode - static cipher entry (TLS_AES_128_GCM_SHA256) combined with 
	     filter modifier (+TLS_AES_256_GCM_SHA384). This is not allowed.
	     Error CWPKI0837E will be logged and JDK defaults will be used instead. -->
	<ssl id="supportedClientAuthenticationSSLConfig"
		clientAuthenticationSupported="true" keyStoreRef="defaultKeyStore"
		sslProtocol="TLSv1.2"
		enabledCiphers="TLS_AES_128_GCM_SHA256 +TLS_AES_256_GCM_SHA384" />

</client>
