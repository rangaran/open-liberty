<!--
    Client configuration for testHandshakeWithWildcardInPlusEntry.
    Uses '+' modifier with a wildcard pattern (+TLS_ECDHE*).
    Wildcards are only allowed in '-' (remove) entries, not in '+' (add) entries.
    Expected result: The wildcard pattern in + entry is treated as a literal cipher name,
    which won't match any actual cipher. JDK defaults are used, handshake succeeds.
 -->
<client description="SSL handshake test client - wildcard in plus entry (error case)">
	<featureManager>
		<feature>javaeeClient-7.0</feature>
        <feature>appSecurityClient-1.0</feature>
        <feature>transportSecurity-1.0</feature>
	</featureManager>

	<application id="myCalc" name="BasicCalculatorClient" type="ear" location="BasicCalculatorClient.ear" />

	<orb id="defaultOrb" orbSSLInitTimeout="60">
		<clientPolicy.clientContainerCsiv2>
			<layers>
				<authenticationLayer user="user2" password="user2pwd" />
				<transportLayer sslRef="supportedClientAuthenticationSSLConfig" />
			</layers>
		</clientPolicy.clientContainerCsiv2>
	</orb>

	<keyStore id="defaultKeyStore" password="{xor}EzY9Oi0rJg==" />

	<sslDefault sslRef="supportedClientAuthenticationSSLConfig" />

	<!-- INVALID: Wildcard in '+' entry. Wildcards are only supported in '-' (remove) entries.
	     The '+TLS_ECDHE*' will be treated as a literal cipher name (which doesn't exist),
	     so it will be added to the list but won't match any actual cipher.
	     JDK defaults will effectively be used. -->
	<ssl id="supportedClientAuthenticationSSLConfig"
		clientAuthenticationSupported="true" keyStoreRef="defaultKeyStore"
		sslProtocol="TLSv1.2"
		enabledCiphers="+TLS_ECDHE*" />

</client>