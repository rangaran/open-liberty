-privatepackage: com.ibm.ws.jpa.tests.spec10.callback.jpa30,\ 
                 com.ibm.ws.jpa.tests.spec10.callback.tests

suite.name=com.ibm.ws.jpa.tests.spec10.callback.jpa30.FATSuite

tested.features: persistence-3.0, persistenceContainer-3.0, enterpriseBeansLite-4.0, servlet-5.0, jdbc-4.2, jndi-1.0, databaserotation
javac.source: 11
javac.target: 11
fat.minimum.java.level: 11

-buildpath: \
    io.openliberty.jakarta.annotation.2.0;version=latest,\
    io.openliberty.jakarta.enterpriseBeans.4.0;version=latest,\
    io.openliberty.jakarta.servlet.5.0;version=latest,\
    io.openliberty.jakarta.persistence.3.0;version=latest,\
    io.openliberty.jakarta.transaction.2.0;version=latest
