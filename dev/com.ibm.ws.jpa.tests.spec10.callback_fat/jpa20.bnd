# Package for this bucket's test suite
-privatepackage: com.ibm.ws.jpa.tests.spec10.callback.jpa20,\ 
                 com.ibm.ws.jpa.tests.spec10.callback.tests

# Suite class that will be run
suite.name=com.ibm.ws.jpa.tests.spec10.callback.jpa20.FATSuite

# Features tested by this bucket
tested.features: jpa-2.0, ejbLite-3.1, servlet-3.0, jdbc-4.0, jndi-1.0, databaserotation

javac.source: 1.8
javac.target: 1.8
fat.minimum.java.level: 8

# Bucket-specific API dependencies
-buildpath: \
    com.ibm.websphere.javaee.annotation.1.1;version=latest,\
    com.ibm.websphere.javaee.ejb.3.1;version=latest,\
    com.ibm.websphere.javaee.servlet.3.0;version=latest,\
    com.ibm.websphere.javaee.persistence.2.0;version=latest,\
    com.ibm.websphere.javaee.transaction.1.1;version=latest


    