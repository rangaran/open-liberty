-include= ~../cnf/resources/bnd/bundle.props

bVersion=1.0

Bundle-Name: JCA Feature
Bundle-SymbolicName: com.ibm.ws.jca.feature
Bundle-Description: JCA; version=${bVersion}

WS-TraceGroup: WAS.j2c

Import-Package: *

Include-Resource: \
    OSGI-INF=resources/OSGI-INF

instrument.disabled: true
