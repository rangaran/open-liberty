<?xml version="1.0" encoding="UTF-8"?>
<ejb-jar xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/ejb-jar_3_2.xsd"
         version="3.2">

    <enterprise-beans>
        <!-- EJB for Scenario 2 & 3: JAX-RS resource defined as EJB via XML -->
        <session>
            <ejb-name>EjbXmlFieldInjectionResource</ejb-name>
            <ejb-class>com.ibm.ws.jaxrs.fat.ejbinjection.EjbXmlFieldInjectionResource</ejb-class>
            <session-type>Stateless</session-type>
        </session>

        <session>
            <ejb-name>EjbXmlMethodParamInjectionResource</ejb-name>
            <ejb-class>com.ibm.ws.jaxrs.fat.ejbinjection.EjbXmlMethodParamInjectionResource</ejb-class>
            <session-type>Stateless</session-type>
        </session>

        <!-- EJB service for Scenario 6 & 7: Service EJB defined via XML, injected into standard JAX-RS resources -->
        <session>
            <ejb-name>MessageService</ejb-name>
            <ejb-class>com.ibm.ws.jaxrs.fat.ejbinjection.ejbs.MessageService</ejb-class>
            <session-type>Stateless</session-type>
        </session>
    </enterprise-beans>

</ejb-jar>
