<server>

  <featureManager>
    <feature>componenttest-2.0</feature>
    <feature>data-1.1</feature>
    <feature>persistence-3.2</feature>
    <feature>servlet-6.1</feature>
  </featureManager>

  <include location="../fatTestPorts.xml"/>

  <data>
    <logValues>*</logValues>
  </data>

  <application location="Data_1_1_App.war">
  </application>

  <dataSource id="MyDataStore" fat.modify="true">
    <jdbcDriver libraryRef="JDBCLibrary"/>
    <!-- TODO remove MODE=LEGACY once EclipseLink fixes bug #35022
         where it tries to compare a boolean attribute to an integer -->
    <properties.h2 URL="${env.DB_URL};MODE=LEGACY" user="dbuser1" password="dbpwd1"/>
  </dataSource>

  <library id="JDBCLibrary">
    <fileset dir="${shared.resource.dir}/h2" includes="*.jar"/>
  </library>

</server>