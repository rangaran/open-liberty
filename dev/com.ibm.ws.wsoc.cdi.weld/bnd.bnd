-include= ~../cnf/resources/bnd/bundle.props

-sub: *.bnd


bVersion=1.0

-dsannotations: \
 com.ibm.ws.wsoc.cdi.weld.ServiceManager,\
 com.ibm.ws.wsoc.cdi.weld.WebSocketInjectionClassListCollaborator

Export-Package: \
  com.ibm.ws.wsoc.cdi.weld

Import-Package: \
  javax.enterprise.context.spi; version="[1.1,3)", \
  javax.enterprise.inject.spi; version="[1.1,3)", \
  !com.ibm.ws.wsoc.cdi.weld, \
  ${defaultPackageImport}


-buildpath: \
	com.ibm.websphere.appserver.spi.logging,\
	com.ibm.ws.wsoc;version=latest,\
	com.ibm.websphere.javaee.cdi.1.2;version=latest,\
	com.ibm.ws.injection.core;version=latest,\
	com.ibm.websphere.appserver.spi.kernel.service,\
	com.ibm.websphere.org.osgi.core,\
	com.ibm.websphere.org.osgi.service.component,\
	com.ibm.ws.adaptable.module;version=latest,\
	com.ibm.ws.container.service;version=latest,\
	com.ibm.ws.anno;version=latest,\
	com.ibm.ws.webcontainer;version=latest,\
	com.ibm.ws.cdi.interfaces;version=latest,\
	com.ibm.ws.org.osgi.annotation.versioning;version=latest,\
	com.ibm.websphere.javaee.websocket.1.1;version=latest,\
	com.ibm.wsspi.org.osgi.service.component.annotations;version=latest
