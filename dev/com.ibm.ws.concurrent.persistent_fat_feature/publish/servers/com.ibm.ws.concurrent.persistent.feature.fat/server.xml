<server>
    <featureManager>
        <feature>jdbc-4.2</feature>
        <!--<feature>osgiconsole-1.0</feature>-->
        <feature>servlet-5.0</feature>
        <feature>usr:testFeature-1.0</feature>
    </featureManager>

    <include location="../fatTestPorts.xml"/>

    <!-- User feature configurable element -->
    <usr_persistentExecFeature jndiName="concurrent/executorService">
      <persistentExecutor taskStoreRef="dbTaskStore1" retryLimit="1" initialPollDelay="30m"/>
    </usr_persistentExecFeature>

    <databaseStore id="dbTaskStore1">
      <dataSource>
        <jdbcDriver libraryRef="jdbc1Lib1"/>
        <properties.h2 URL="jdbc:h2:mem:cpefeature;DB_CLOSE_DELAY=-1"/>
      </dataSource>
    </databaseStore>
    <library id="jdbc1Lib1">
      <fileset dir="${shared.resource.dir}/h2Java8" includes="h2.jar"/>
    </library>
  
    <javaPermission codebase="${shared.resource.dir}/h2Java8/h2.jar" className="java.security.AllPermission"/>
    <!-- Due to lack of doPriv in h2: -->
    <javaPermission className="java.lang.RuntimePermission" name="getClassLoader"/>
</server>