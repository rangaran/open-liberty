<server>

  <featureManager>
    <feature>componenttest-2.0</feature>
    <feature>data-1.0</feature>
    <feature>enterpriseBeans-4.0</feature>
    <feature>jndi-1.0</feature>
    <feature>persistence-3.2</feature>
    <feature>servlet-6.1</feature>
    <feature>localConnector-1.0</feature>
  </featureManager>

  <include location="../fatTestPorts.xml"/>

  <data>
    <logValues>test.jakarta.data.datastore.ejb</logValues>
    <logValues>test.jakarta.data.datastore.global.lib.GlobalLibRepo</logValues>
    <logValues>test.jakarta.data.datastore.lib</logValues>
    <logValues>test.jakarta.data.datastore.web</logValues>
    <logValues>test.jakarta.data.datastore.web2</logValues>
    <logValues>test.jakarta.data.datastore.webapp</logValues>
  </data>

  <!-- This app must start first to initialize H2 database users -->
  <application id="H2InitApp" location="H2InitApp.war">
    <classloader commonLibraryRef="H2Lib"/>
  </application>

  <application id="DataStoreTestApp" location="DataStoreTestApp.ear" startAfter="H2InitApp">
    <classloader commonLibraryRef="H2Lib"/>
    <ejb-jar-ext moduleName="DataStoreTestEJB">
      <session name="StartupSingletonEJB">
        <!-- force earliest bean metadata initialization -->
        <start-at-app-start value="true"/>
      </session>
    </ejb-jar-ext>
  </application>

  <application id="DataStoreWebApp" location="DataStoreWebApp.war" startAfter="H2InitApp">
    <!-- implicitly has access to libraries in lib/global -->
  </application>

  <ejbApplication id="DataStoreEJBApp" location="DataStoreEJBApp.jar" startAfter="H2InitApp">
    <classloader commonLibraryRef="H2Lib"/>
  </ejbApplication>

  <library id="H2Lib">
    <file name="${shared.resource.dir}/h2/h2.jar"/>
  </library>

  <authData id="ResRefAuth1" user="resrefuser1" password="resrefpwd1"/> <!-- for web module 1 -->
  <authData id="ResRefAuth2" user="resrefuser2" password="resrefpwd2"/> <!-- for web module 2 -->
  <authData id="ResRefAuth3" user="resrefuser3" password="resrefpwd3"/> <!-- for EJB -->
  <authData id="ResRefAuth4" user="resrefuser4" password="resrefpwd4"/> <!-- for global library -->

  <dataSource id="DefaultDataSource">
    <jdbcDriver libraryRef="H2Lib"/>
    <properties.h2 URL="jdbc:h2:mem:defaultdb;DB_CLOSE_DELAY=-1"
                   user="defaultuser1"
                   password="defaultpwd1"/>
  </dataSource>

  <dataSource id="ServerDataSource" jndiName="jdbc/ServerDataSource">
    <jdbcDriver libraryRef="H2Lib"/>
    <properties.h2 URL="jdbc:h2:mem:serverdb;DB_CLOSE_DELAY=-1"
                   user="serveruser1"
                   password="serverpwd1"/>
  </dataSource>

</server>