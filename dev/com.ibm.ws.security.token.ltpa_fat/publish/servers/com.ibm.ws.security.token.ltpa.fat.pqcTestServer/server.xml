<server description="LTPA PQC Test Server">

    <!-- Enable features -->
    <featureManager>
        <feature>servlet-6.0</feature>
        <feature>appSecurity-5.0</feature>
    </featureManager>

    <!-- Basic Registry for testing -->
    <basicRegistry id="basic" realm="BasicRealm">
        <user name="testuser" password="testpwd"/>
        <user name="user1" password="user1pwd"/>
        <user name="user2" password="user2pwd"/>
    </basicRegistry>

    <!-- LTPA Configuration with Hybrid Post-Quantum Cryptography (PQC) -->
    <!-- Combines RSA-2048 + ML-DSA-65 + ML-KEM-768 for defense-in-depth -->
    <ltpa
        keysFileName="${server.output.dir}/resources/security/ltpa.keys"
        keysPassword="{xor}Lz4sLCgwLTs="
        expiration="30m"
        tokenVersion="3"
        hybridPqcEnabled="true"
        hybridKeystoreFile="${server.output.dir}/resources/security/ltpa-hybrid.p12"
        hybridKeystorePassword="{xor}Lz4sLCgwLTs="
        mldsaAlgorithm="ML-DSA-65"
        mlkemAlgorithm="ML-KEM-768"/>

    <!-- HTTP Endpoint -->
    <httpEndpoint id="defaultHttpEndpoint"
                  httpPort="9080"
                  httpsPort="9443"/>

    <!-- Application Security -->
    <webAppSecurity 
        httpOnlyCookies="true"
        ssoRequiresSSL="false"
        ssoCookieName="LtpaToken2"/>

    <!-- Logging -->
    <logging 
        traceSpecification="*=info:com.ibm.ws.security.token.ltpa*=all:com.ibm.ws.security.token.ltpa.pqc*=all"
        maxFileSize="20"
        maxFiles="10"/>

</server>

